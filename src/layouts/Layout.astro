---
import "../styles/global.css";

interface Props {
	title: string;
	style?: string;
	lang?: string;
}

const { title, style, lang = "en" } = Astro.props;
---

<!doctype html>
<html lang={lang} data-style={style}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title} — Whisker Haven</title>
	</head>
	<body>
		<slot />
	</body>
</html>
