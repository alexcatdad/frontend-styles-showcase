---
import "../styles/global.css";
import type { Locale } from "../data/i18n";
import { localeLabels, locales } from "../data/i18n";
import { getStyle } from "../data/styles";

interface Props {
	title: string;
	style?: string;
	lang?: string;
}

const { title, style, lang = "en" } = Astro.props;
const meta = style ? getStyle(style) : null;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={lang} data-style={style}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title} — Whisker Haven</title>
	</head>
	<body>
		<slot />

		{meta && (
			<div id="style-badge" class="fixed bottom-4 right-4 z-[9999] flex items-center gap-1.5 rounded-full bg-black/80 backdrop-blur-md text-white text-xs font-medium pl-3 pr-1.5 py-1.5 shadow-lg border border-white/10 font-['DM_Sans',system-ui,sans-serif]">
				<a href="/" class="text-white/50 hover:text-white transition-colors" title="All styles">
					<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor">
						<path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z" />
					</svg>
				</a>
				<span class="text-white/30">·</span>
				<span class="text-white/90">{meta.name}</span>
				<span class="text-white/30">·</span>
				{locales.map((l) => (
					<a
						href={currentPath.replace(`/${lang}/`, `/${l}/`)}
						class:list={[
							"px-1.5 py-0.5 rounded-full text-[10px] uppercase tracking-wider transition-colors",
							l === lang
								? "bg-white/20 text-white"
								: "text-white/40 hover:text-white/70",
						]}
					>
						{l}
					</a>
				))}
			</div>
		)}
	</body>
</html>
