---
const { lang, style, nav, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-[#0a0a0f] text-gray-300 font-mono">
	<!-- Nav -->
	<nav class="relative z-20 border-b border-cyan-500/30 bg-[#0a0a0f]/90 backdrop-blur-sm">
		<div class="max-w-7xl mx-auto flex flex-wrap items-center justify-between px-6 py-4">
			<span class="text-cyan-400 text-xs tracking-widest uppercase">[SYS]</span>
			<div class="flex flex-wrap items-center gap-1">
				{nav.map((item: any) => (
					<a href={item.href} class="px-4 py-2 text-xs tracking-wider uppercase text-cyan-400/70 hover:text-cyan-300 hover:bg-cyan-500/10 transition-all duration-300">
						{item.label}
					</a>
				))}
			</div>
		</div>
	</nav>

	<main class="relative z-10 flex items-center justify-center px-6 py-16 md:py-24">
		<section class="w-full max-w-md">
			<!-- Terminal header -->
			<div class="text-center mb-10">
				<p class="text-[10px] tracking-[0.5em] uppercase text-cyan-400/40 mb-6">&gt; {t.auth.title}</p>

				<h1 class="relative text-3xl md:text-4xl lg:text-5xl font-bold leading-none tracking-tight uppercase">
					<span class="absolute inset-0 text-cyan-400/50 translate-x-[2px] -translate-y-[1px]" aria-hidden="true">{t.auth.title}</span>
					<span class="absolute inset-0 text-fuchsia-500/40 -translate-x-[2px] translate-y-[1px]" aria-hidden="true">{t.auth.title}</span>
					<span class="relative text-white">{t.auth.title}</span>
				</h1>

				<p class="mt-4 text-sm text-gray-500 tracking-wider">
					{t.auth.subtitle}
				</p>
			</div>

			<!-- HUD Terminal card -->
			<div class="border border-cyan-500/40 bg-gray-900/60 shadow-[0_0_20px_rgba(0,255,255,0.1)] relative">
				<!-- HUD corners -->
				<div class="absolute top-0 left-0 w-6 h-6 border-t-2 border-l-2 border-cyan-400"></div>
				<div class="absolute top-0 right-0 w-6 h-6 border-t-2 border-r-2 border-cyan-400"></div>
				<div class="absolute bottom-0 left-0 w-6 h-6 border-b-2 border-l-2 border-fuchsia-500"></div>
				<div class="absolute bottom-0 right-0 w-6 h-6 border-b-2 border-r-2 border-fuchsia-500"></div>

				<div class="p-8 md:p-10">
					<form class="space-y-6">
						<div>
							<label for="email" class="block text-[10px] tracking-widest uppercase text-fuchsia-400 mb-2">
								{t.auth.email}
							</label>
							<input
								type="email"
								id="email"
								name="email"
								placeholder="user@sanctuary.net"
								class="w-full px-4 py-3 bg-gray-900 border border-cyan-500/50 text-cyan-100 placeholder-gray-600 font-mono text-sm focus:border-cyan-400 focus:shadow-[0_0_10px_rgba(0,255,255,0.3)] focus:outline-none transition-all duration-300"
							/>
						</div>

						<div>
							<label for="password" class="block text-[10px] tracking-widest uppercase text-fuchsia-400 mb-2">
								{t.auth.password}
							</label>
							<input
								type="password"
								id="password"
								name="password"
								placeholder="••••••••••"
								class="w-full px-4 py-3 bg-gray-900 border border-cyan-500/50 text-cyan-100 placeholder-gray-600 font-mono text-sm focus:border-cyan-400 focus:shadow-[0_0_10px_rgba(0,255,255,0.3)] focus:outline-none transition-all duration-300"
							/>
						</div>

						<!-- Remember / Forgot -->
						<div class="flex items-center justify-between">
							<label class="flex items-center gap-2 cursor-pointer">
								<input type="checkbox" name="remember" class="w-4 h-4 accent-cyan-500 bg-gray-900 border border-cyan-500/50" />
								<span class="text-xs text-gray-500 tracking-wider">{t.auth.rememberMe}</span>
							</label>
							<a href="#" class="text-xs text-cyan-400/60 hover:text-cyan-300 tracking-wider transition-colors duration-300">
								{t.auth.forgotPassword}
							</a>
						</div>

						<!-- Submit -->
						<button type="submit" class="w-full py-4 bg-cyan-500 text-black font-bold text-sm tracking-wider uppercase hover:bg-cyan-400 hover:shadow-[0_0_20px_rgba(0,255,255,0.4)] transition-all duration-300">
							{t.auth.signIn}
						</button>
					</form>

					<!-- Divider -->
					<div class="my-8">
						<div class="flex items-center gap-4">
							<div class="flex-1 h-px bg-gray-800"></div>
							<span class="text-[10px] tracking-widest uppercase text-gray-600">{t.auth.continueWith}</span>
							<div class="flex-1 h-px bg-gray-800"></div>
						</div>

						<div class="mt-6 grid grid-cols-2 gap-4">
							<button type="button" class="py-3 border border-cyan-500/30 text-cyan-400/70 text-xs tracking-wider uppercase hover:border-cyan-500/60 hover:bg-cyan-500/5 hover:shadow-[0_0_10px_rgba(0,255,255,0.1)] transition-all duration-300">
								Google
							</button>
							<button type="button" class="py-3 border border-fuchsia-500/30 text-fuchsia-400/70 text-xs tracking-wider uppercase hover:border-fuchsia-500/60 hover:bg-fuchsia-500/5 hover:shadow-[0_0_10px_rgba(217,70,239,0.1)] transition-all duration-300">
								Apple
							</button>
						</div>
					</div>

					<p class="text-center text-xs text-gray-500 tracking-wider">
						{t.auth.noAccount}{" "}
						<a href="#" class="text-fuchsia-400 hover:text-fuchsia-300 transition-colors duration-300">
							{t.auth.signUp}
						</a>
					</p>
				</div>
			</div>

			<!-- Bottom terminal prompt -->
			<p class="mt-8 text-center text-[10px] text-gray-700 tracking-widest">&gt;_</p>
		</section>
	</main>
</div>
