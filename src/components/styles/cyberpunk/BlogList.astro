---
const { lang, style, nav, posts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-[#0a0a0f] text-gray-300 font-mono">
	<!-- Nav -->
	<nav class="relative z-20 border-b border-cyan-500/30 bg-[#0a0a0f]/90 backdrop-blur-sm">
		<div class="max-w-7xl mx-auto flex flex-wrap items-center justify-between px-6 py-4">
			<span class="text-cyan-400 text-xs tracking-widest uppercase">[SYS]</span>
			<div class="flex flex-wrap items-center gap-1">
				{nav.map((item: any) => (
					<a href={item.href} class="px-4 py-2 text-xs tracking-wider uppercase text-cyan-400/70 hover:text-cyan-300 hover:bg-cyan-500/10 transition-all duration-300">
						{item.label}
					</a>
				))}
			</div>
		</div>
	</nav>

	<main class="relative z-10 max-w-4xl mx-auto px-6 py-16">
		<!-- Header -->
		<div class="mb-16">
			<h1 class="relative text-4xl md:text-6xl lg:text-7xl font-bold leading-none tracking-tight uppercase">
				<span class="absolute inset-0 text-cyan-400/50 translate-x-[3px] -translate-y-[2px]" aria-hidden="true">{t.blog.title}</span>
				<span class="absolute inset-0 text-fuchsia-500/40 -translate-x-[3px] translate-y-[2px]" aria-hidden="true">{t.blog.title}</span>
				<span class="relative text-white">{t.blog.title}</span>
			</h1>
			<p class="mt-4 text-fuchsia-400/70 text-sm tracking-wider">
				{t.blog.subtitle}
			</p>
			<div class="mt-6 h-px w-32 bg-gradient-to-r from-cyan-500 to-transparent"></div>
		</div>

		<!-- Blog posts -->
		<div class="flex flex-col gap-8">
			{posts.map((post: any) => (
				<a href={`${_base}/${lang}/${style}/blog/${post.slug}`} class="group block border border-gray-800 bg-gray-900/40 hover:border-cyan-500/50 hover:shadow-[0_0_20px_rgba(0,255,255,0.1)] transition-all duration-300">
					<!-- Image with neon glow -->
					<div class="relative overflow-hidden">
						<img src={post.image} alt={post.title} class="w-full h-52 object-cover opacity-75 group-hover:opacity-90 transition-opacity duration-300" />
						<div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-cyan-500 via-fuchsia-500 to-cyan-500 opacity-60"></div>
					</div>

					<div class="p-6 md:p-8">
						<!-- Date + Author -->
						<div class="flex items-center gap-4 mb-4">
							<time datetime={post.date} class="text-xs tracking-wider text-cyan-400/70">
								{post.date}
							</time>
							<span class="text-gray-700">|</span>
							<span class="text-xs text-fuchsia-400/60 tracking-wider">{t.blog.by} {post.author}</span>
						</div>

						<!-- Title -->
						<h2 class="text-xl md:text-2xl font-bold text-white group-hover:text-cyan-300 tracking-wide uppercase transition-colors duration-300">
							{post.title}
						</h2>

						<!-- Excerpt -->
						<p class="mt-3 text-sm text-gray-400 leading-relaxed">
							{post.excerpt}
						</p>

						<!-- Tags -->
						<div class="mt-5 flex flex-wrap gap-2">
							{post.tags.map((tag: string) => (
								<span class="text-[10px] tracking-wider uppercase px-2 py-1 border border-cyan-500/30 text-cyan-400/60 bg-cyan-500/5">
									{tag}
								</span>
							))}
						</div>
					</div>
				</a>
			))}
		</div>
	</main>

	<footer class="relative z-10 border-t border-cyan-500/20 py-8 mt-16">
		<div class="h-px w-full bg-gradient-to-r from-transparent via-cyan-500/20 to-transparent"></div>
	</footer>
</div>
