---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-[#0a0a0f] text-gray-300 font-mono">
	<!-- Nav -->
	<nav class="relative z-20 border-b border-cyan-500/30 bg-[#0a0a0f]/90 backdrop-blur-sm">
		<div class="max-w-7xl mx-auto flex flex-wrap items-center justify-between px-6 py-4">
			<span class="text-cyan-400 text-xs tracking-widest uppercase">[SYS]</span>
			<div class="flex flex-wrap items-center gap-1">
				{nav.map((item: any) => (
					<a href={item.href} class="px-4 py-2 text-xs tracking-wider uppercase text-cyan-400/70 hover:text-cyan-300 hover:bg-cyan-500/10 transition-all duration-300">
						{item.label}
					</a>
				))}
			</div>
		</div>
	</nav>

	<main class="relative z-10 max-w-4xl mx-auto px-6 py-12">
		<!-- Back link -->
		<a href={`${_base}/${lang}/${style}/cats`} class="inline-flex items-center gap-2 text-xs tracking-wider uppercase text-cyan-400/60 hover:text-cyan-300 transition-colors duration-300 mb-10">
			<span class="text-lg leading-none">&larr;</span> {t.cats.backToAll}
		</a>

		<!-- Profile card -->
		<article class="border border-cyan-500/30 bg-gray-900/40 relative">
			<!-- HUD corners -->
			<div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-cyan-400"></div>
			<div class="absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-cyan-400"></div>
			<div class="absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-fuchsia-500"></div>
			<div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-fuchsia-500"></div>

			<div class="p-8 md:p-12">
				<!-- Name with glitch -->
				<h1 class="relative text-4xl md:text-6xl lg:text-7xl font-bold leading-none tracking-tight uppercase mb-10 text-center">
					<span class="absolute inset-0 text-cyan-400/50 translate-x-[4px] -translate-y-[2px]" aria-hidden="true">{cat.name}</span>
					<span class="absolute inset-0 text-fuchsia-500/40 -translate-x-[4px] translate-y-[2px]" aria-hidden="true">{cat.name}</span>
					<span class="relative text-white">{cat.name}</span>
				</h1>

				<!-- Cat image with neon frame -->
				<div class="flex justify-center mb-12">
					<div class="relative">
						<img src={cat.image} alt={cat.name} class="w-64 h-64 md:w-80 md:h-80 object-cover border-2 border-cyan-500/50 shadow-[0_0_25px_rgba(0,255,255,0.25)]" />
						<div class="absolute top-0 left-0 w-6 h-6 border-t-2 border-l-2 border-fuchsia-500 -translate-x-2 -translate-y-2"></div>
						<div class="absolute top-0 right-0 w-6 h-6 border-t-2 border-r-2 border-fuchsia-500 translate-x-2 -translate-y-2"></div>
						<div class="absolute bottom-0 left-0 w-6 h-6 border-b-2 border-l-2 border-fuchsia-500 -translate-x-2 translate-y-2"></div>
						<div class="absolute bottom-0 right-0 w-6 h-6 border-b-2 border-r-2 border-fuchsia-500 translate-x-2 translate-y-2"></div>
					</div>
				</div>

				<!-- HUD Readout metadata -->
				<div class="max-w-lg mx-auto mb-12 space-y-0">
					<div class="flex items-center justify-between py-3 border-b border-gray-800">
						<span class="text-xs tracking-wider uppercase text-fuchsia-400">{t.cats.breed}</span>
						<span class="text-sm text-white">{cat.breed}</span>
					</div>
					<div class="flex items-center justify-between py-3 border-b border-gray-800">
						<span class="text-xs tracking-wider uppercase text-fuchsia-400">{t.cats.age}</span>
						<span class="text-sm text-white">{cat.age}</span>
					</div>
					<div class="flex items-center justify-between py-3 border-b border-gray-800">
						<span class="text-xs tracking-wider uppercase text-fuchsia-400">{t.cats.gender}</span>
						<span class="text-sm text-white">{cat.gender}</span>
					</div>
					<div class="flex items-center justify-between py-3 border-b border-gray-800">
						<span class="text-xs tracking-wider uppercase text-fuchsia-400">{t.cats.color}</span>
						<span class="text-sm text-white">{cat.color}</span>
					</div>
					<div class="flex items-center justify-between py-3 border-b border-gray-800">
						<span class="text-xs tracking-wider uppercase text-fuchsia-400">{t.cats.arrived}</span>
						<span class="text-sm text-white">{cat.arrivalDate}</span>
					</div>
					<div class="flex items-center justify-between py-3 border-b border-gray-800">
						<span class="text-xs tracking-wider uppercase text-fuchsia-400">{t.cats.status}</span>
						<span class="text-sm text-white">{cat.status}</span>
					</div>
				</div>

				<!-- Personality traits as neon chips -->
				<div class="flex flex-wrap justify-center gap-3 mb-12">
					{cat.personality.map((trait: string) => (
						<span class="text-[10px] tracking-wider uppercase px-4 py-2 border border-cyan-500/40 text-cyan-400 bg-cyan-500/5 hover:bg-cyan-500/10 hover:shadow-[0_0_10px_rgba(0,255,255,0.15)] transition-all duration-300">
							{trait}
						</span>
					))}
				</div>

				<!-- Description -->
				<div class="border-t border-gray-800 pt-8 mb-10">
					<p class="text-gray-400 leading-relaxed text-sm md:text-base text-center max-w-2xl mx-auto">
						{cat.description}
					</p>
				</div>

				<!-- Adopt button -->
				<div class="text-center">
					<a href={`${_base}/${lang}/${style}/auth`} class="inline-block px-10 py-4 bg-fuchsia-600 hover:bg-fuchsia-500 text-white font-bold text-sm tracking-wider uppercase hover:shadow-[0_0_25px_rgba(217,70,239,0.4)] transition-all duration-300">
						{t.cats.adopt} {cat.name}
					</a>
				</div>
			</div>
		</article>

		<!-- Other Cats -->
		<section class="mt-20">
			<h2 class="text-xs tracking-[0.4em] uppercase text-cyan-400 mb-8">// {t.cats.otherCats}</h2>
			<div class="h-px w-full bg-gradient-to-r from-cyan-500/30 to-transparent mb-8"></div>

			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
				{otherCats.map((c: any) => (
					<a href={`${_base}/${lang}/${style}/cats/${c.id}`} class="group block p-6 border border-gray-800 bg-gray-900/30 hover:border-cyan-500/50 hover:shadow-[0_0_15px_rgba(0,255,255,0.1)] transition-all duration-300">
						<h3 class="text-sm font-bold text-cyan-400 group-hover:text-cyan-300 uppercase tracking-wide transition-colors duration-300">
							{c.name}
						</h3>
						<p class="mt-2 text-xs text-fuchsia-400/60 tracking-wider">
							{c.breed} // {c.age}
						</p>
					</a>
				))}
			</div>
		</section>
	</main>

	<footer class="relative z-10 border-t border-cyan-500/20 py-8 mt-16">
		<div class="h-px w-full bg-gradient-to-r from-transparent via-cyan-500/20 to-transparent"></div>
	</footer>
</div>
