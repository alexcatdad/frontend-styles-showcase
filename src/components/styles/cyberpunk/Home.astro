---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-[#0a0a0f] text-gray-300 font-mono">
	<!-- Nav -->
	<nav class="relative z-20 border-b border-cyan-500/30 bg-[#0a0a0f]/90 backdrop-blur-sm">
		<div class="max-w-7xl mx-auto flex flex-wrap items-center justify-between px-6 py-4">
			<span class="text-cyan-400 text-xs tracking-widest uppercase">[{sanctuary.name}]</span>
			<div class="flex flex-wrap items-center gap-1">
				{nav.map((item: any) => (
					<a href={item.href} class="px-4 py-2 text-xs tracking-wider uppercase text-cyan-400/70 hover:text-cyan-300 hover:bg-cyan-500/10 transition-all duration-300">
						{item.label}
					</a>
				))}
			</div>
		</div>
	</nav>

	<main class="relative z-10">
		<!-- Hero Section -->
		<section class="relative px-6 py-20 md:py-32">
			<div class="max-w-6xl mx-auto">
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
					<div>
						<!-- Glitched title -->
						<h1 class="relative text-5xl md:text-7xl lg:text-8xl font-bold leading-none tracking-tight uppercase">
							<span class="absolute inset-0 text-cyan-400/60 translate-x-[3px] -translate-y-[2px]" aria-hidden="true">{sanctuary.name}</span>
							<span class="absolute inset-0 text-fuchsia-500/50 -translate-x-[3px] translate-y-[2px]" aria-hidden="true">{sanctuary.name}</span>
							<span class="relative text-white">{sanctuary.name}</span>
						</h1>

						<p class="mt-6 text-lg md:text-xl text-fuchsia-400 font-bold tracking-wide">
							{sanctuary.tagline}
						</p>

						<div class="mt-10 flex flex-col sm:flex-row gap-4">
							<a href={`${_base}/${lang}/${style}/cats`} class="inline-block px-8 py-4 bg-cyan-500 text-black font-bold text-sm tracking-wider uppercase hover:bg-cyan-400 hover:shadow-[0_0_20px_rgba(0,255,255,0.4)] transition-all duration-300 text-center">
								{t.home.meetCats}
							</a>
							<a href={`${_base}/${lang}/${style}/donate`} class="inline-block px-8 py-4 border-2 border-fuchsia-500 text-fuchsia-400 font-bold text-sm tracking-wider uppercase hover:bg-fuchsia-500/10 hover:shadow-[0_0_20px_rgba(217,70,239,0.3)] transition-all duration-300 text-center">
								{t.home.donate}
							</a>
						</div>
					</div>

					<div class="relative">
						<img
							src={sanctuary.heroImage}
							alt={sanctuary.name}
							class="w-full object-cover border-2 border-cyan-500/40 shadow-[0_0_20px_rgba(0,255,255,0.3)]"
						/>
						<!-- HUD overlay corners -->
						<div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-cyan-400"></div>
						<div class="absolute top-0 right-0 w-8 h-8 border-t-2 border-r-2 border-cyan-400"></div>
						<div class="absolute bottom-0 left-0 w-8 h-8 border-b-2 border-l-2 border-cyan-400"></div>
						<div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-cyan-400"></div>
					</div>
				</div>
			</div>
		</section>

		<!-- Mission -->
		<section class="px-6 py-16">
			<div class="max-w-4xl mx-auto border border-cyan-500/50 bg-gray-900/50 p-8 md:p-12 relative">
				<!-- HUD corner accents -->
				<div class="absolute top-0 left-0 w-6 h-6 border-t-2 border-l-2 border-fuchsia-500"></div>
				<div class="absolute top-0 right-0 w-6 h-6 border-t-2 border-r-2 border-fuchsia-500"></div>
				<div class="absolute bottom-0 left-0 w-6 h-6 border-b-2 border-l-2 border-fuchsia-500"></div>
				<div class="absolute bottom-0 right-0 w-6 h-6 border-b-2 border-r-2 border-fuchsia-500"></div>

				<h2 class="text-xs tracking-[0.4em] uppercase text-fuchsia-400 mb-6">// {t.home.mission}</h2>
				<p class="text-gray-400 leading-relaxed text-sm md:text-base">
					{sanctuary.mission}
				</p>
			</div>
		</section>

		<!-- Stats -->
		<section class="px-6 py-16">
			<div class="max-w-5xl mx-auto">
				<div class="grid grid-cols-2 md:grid-cols-4 gap-6">
					{sanctuary.stats.map((stat: any) => (
						<div class="border border-gray-800 bg-gray-900/40 p-6 text-center hover:border-cyan-500/50 hover:shadow-[0_0_15px_rgba(0,255,255,0.1)] transition-all duration-300">
							<span class="block text-4xl md:text-5xl font-bold font-mono text-cyan-400">
								{stat.value}
							</span>
							<span class="block mt-3 text-xs tracking-wider uppercase text-gray-500">
								{stat.label}
							</span>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- About -->
		<section class="px-6 py-16">
			<div class="max-w-4xl mx-auto border border-cyan-500/30 bg-gray-900/40 p-8 md:p-12 relative">
				<div class="absolute top-0 left-0 w-5 h-5 border-t-2 border-l-2 border-cyan-400"></div>
				<div class="absolute bottom-0 right-0 w-5 h-5 border-b-2 border-r-2 border-cyan-400"></div>

				<h2 class="text-xs tracking-[0.4em] uppercase text-cyan-400 mb-8">// {t.home.aboutUs}</h2>
				{sanctuary.about.map((paragraph: string) => (
					<p class="text-gray-400 leading-relaxed mb-6 last:mb-0 text-sm md:text-base">
						{paragraph}
					</p>
				))}
			</div>
		</section>

		<!-- Contact -->
		<section class="max-w-xl mx-auto px-6 pt-8 pb-20 text-center">
			<p class="text-xs text-gray-500 tracking-wider">{sanctuary.contact}</p>
		</section>
	</main>

	<!-- Footer -->
	<footer class="relative z-10 border-t border-cyan-500/20 py-8">
		<div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
			<p class="text-xs text-gray-600 tracking-wider">
				&copy; 2026 {sanctuary.name}
			</p>
			<p class="text-xs text-cyan-500/40 tracking-wider uppercase">
				{t.footer.style}: {meta.name}
			</p>
		</div>
		<div class="mt-4 h-px w-full bg-gradient-to-r from-transparent via-cyan-500/30 to-transparent"></div>
	</footer>
</div>
