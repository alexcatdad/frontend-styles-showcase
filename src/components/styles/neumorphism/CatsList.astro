---
const { lang, style, nav, cats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-[#e0e5ec] font-sans text-[#4a5568] antialiased">
	<!-- Floating pill navigation -->
	<nav class="sticky top-4 z-50 mx-auto max-w-4xl px-6 py-4">
		<div class="flex flex-wrap items-center justify-between gap-4 rounded-full bg-[#e0e5ec] px-6 py-3 shadow-[8px_8px_16px_#b8bec7,-8px_-8px_16px_#ffffff]">
			<span class="rounded-full bg-[#e0e5ec] px-5 py-2 text-xs font-bold uppercase tracking-[0.2em] text-[#6b8aab] shadow-[4px_4px_8px_#b8bec7,-4px_-4px_8px_#ffffff]">Neumorphism</span>
			<div class="flex flex-wrap items-center gap-2">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-full bg-[#e0e5ec] px-5 py-2 text-sm font-medium text-[#5a6a7c] shadow-[3px_3px_6px_#b8bec7,-3px_-3px_6px_#ffffff] transition-all duration-300 hover:shadow-[inset_3px_3px_6px_#b8bec7,inset_-3px_-3px_6px_#ffffff] hover:text-[#6b8aab]">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="mx-auto max-w-6xl space-y-12 px-6 pb-16 pt-8">
		<!-- Header: raised slab -->
		<header class="rounded-[2rem] bg-[#e0e5ec] px-8 py-10 text-center shadow-[10px_10px_20px_#b8bec7,-10px_-10px_20px_#ffffff] sm:py-14">
			<h1 class="mb-3 text-4xl font-extrabold tracking-tight text-[#3a4a5c] sm:text-5xl">{t.cats.title}</h1>
			<div class="mx-auto mt-5 max-w-md rounded-full bg-[#e0e5ec] px-6 py-3 shadow-[inset_3px_3px_6px_#b8bec7,inset_-3px_-3px_6px_#ffffff]">
				<p class="text-sm font-medium text-[#6b8aab]">{t.cats.subtitle}</p>
			</div>
		</header>

		<!-- Cat cards grid -->
		<div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
			{cats.map((cat: any) => (
				<a href={`${_base}/${lang}/${style}/cats/${cat.id}`} class="group block rounded-[1.5rem] bg-[#e0e5ec] p-7 shadow-[8px_8px_16px_#b8bec7,-8px_-8px_16px_#ffffff] transition-all duration-400 hover:shadow-[12px_12px_24px_#b8bec7,-12px_-12px_24px_#ffffff]">
					<!-- Cat thumbnail -->
					<img src={cat.thumbnail} alt={cat.name} class="w-full h-40 object-cover rounded-xl mb-5 shadow-[inset_3px_3px_6px_#b8bec7,inset_-3px_-3px_6px_#ffffff]" />

					<h2 class="mb-1 text-center text-xl font-extrabold text-[#3a4a5c] transition-colors duration-300 group-hover:text-[#6b8aab]">{cat.name}</h2>

					<!-- Breed, age, gender as inset pill -->
					<div class="mx-auto mb-4 mt-3 rounded-full bg-[#e0e5ec] px-4 py-2 text-center shadow-[inset_2px_2px_5px_#b8bec7,inset_-2px_-2px_5px_#ffffff]">
						<span class="text-xs font-semibold text-[#6b8aab]">{cat.breed} &middot; {cat.age} &middot; {cat.gender}</span>
					</div>

					<!-- Description in recessed well -->
					<div class="mb-5 rounded-xl bg-[#e0e5ec] p-4 shadow-[inset_3px_3px_6px_#b8bec7,inset_-3px_-3px_6px_#ffffff]">
						<p class="text-xs leading-relaxed text-[#5a6a7c]">{cat.description.slice(0, 110)}...</p>
					</div>

					<!-- Personality pills: extruded -->
					<div class="mb-4 flex flex-wrap justify-center gap-2">
						{cat.personality.map((trait: string) => (
							<span class="rounded-full bg-[#e0e5ec] px-3 py-1 text-[11px] font-semibold text-[#6b8aab] shadow-[3px_3px_6px_#b8bec7,-3px_-3px_6px_#ffffff]">{trait}</span>
						))}
					</div>

					<!-- Status badge: raised pill -->
					<div class="text-center">
						<span class="inline-block rounded-full bg-[#e0e5ec] px-5 py-1.5 text-xs font-bold uppercase tracking-wider text-[#6b8aab] shadow-[4px_4px_8px_#b8bec7,-4px_-4px_8px_#ffffff]">{cat.status}</span>
					</div>
				</a>
			))}
		</div>
	</main>
</div>
