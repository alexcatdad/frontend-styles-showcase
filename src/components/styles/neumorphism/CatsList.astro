---
const { lang, style, nav, cats, t } = Astro.props;
---

<div class="min-h-screen bg-[#e0e5ec] font-sans text-[#4a5568] antialiased">
	<nav class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-4 py-6 sm:px-6">
		<div class="flex items-center gap-2">
			<span class="rounded-xl bg-[#e0e5ec] px-4 py-2 text-sm font-semibold uppercase tracking-widest text-[#6b8aab] shadow-[3px_3px_6px_#b8bec7,-3px_-3px_6px_#ffffff]">Neumorphism</span>
		</div>
		<div class="flex flex-wrap items-center gap-2">
			{nav.map((item: any) => (
				<a href={item.href} class="rounded-xl bg-[#e0e5ec] px-4 py-2 text-sm font-medium text-[#4a5568] shadow-[4px_4px_8px_#b8bec7,-4px_-4px_8px_#ffffff] transition-all duration-200 hover:shadow-[inset_3px_3px_6px_#b8bec7,inset_-3px_-3px_6px_#ffffff] hover:text-[#6b8aab]">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="mx-auto max-w-5xl space-y-10 px-4 py-8 sm:px-6">
		<div class="text-center">
			<h1 class="mb-3 text-4xl font-bold tracking-tight text-[#3a4a5c]">{t.cats.title}</h1>
			<p class="text-lg font-medium text-[#6b7b8d]">{t.cats.subtitle}</p>
		</div>

		<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
			{cats.map((cat: any) => (
				<a href={`/${lang}/${style}/cats/${cat.id}`} class="group block rounded-2xl bg-[#e0e5ec] p-6 shadow-[6px_6px_12px_#b8bec7,-6px_-6px_12px_#ffffff] transition-all duration-300 hover:shadow-[8px_8px_16px_#b8bec7,-8px_-8px_16px_#ffffff]">
					<div class="space-y-3">
						<h2 class="text-xl font-bold text-[#3a4a5c] group-hover:text-[#6b8aab] transition-colors duration-200">{cat.name}</h2>
						<p class="text-sm font-medium text-[#6b7b8d]">{cat.breed} · {cat.age} · {cat.gender}</p>
						<p class="text-sm text-[#5a6a7c] leading-relaxed">{cat.description.slice(0, 100)}...</p>
						<div class="flex flex-wrap gap-2">
							{cat.personality.map((trait: string) => (
								<span class="rounded-lg bg-[#e0e5ec] px-3 py-1 text-xs font-medium text-[#6b8aab] shadow-[inset_2px_2px_4px_#b8bec7,inset_-2px_-2px_4px_#ffffff]">{trait}</span>
							))}
						</div>
						<span class="inline-block rounded-lg bg-[#e0e5ec] px-3 py-1 text-xs font-semibold uppercase tracking-wide text-[#6b8aab] shadow-[3px_3px_6px_#b8bec7,-3px_-3px_6px_#ffffff]">{cat.status}</span>
					</div>
				</a>
			))}
		</div>
	</main>
</div>
