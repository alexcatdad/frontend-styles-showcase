---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-[#e0e5ec] font-sans text-[#4a5568] antialiased">
	<nav class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-4 py-6 sm:px-6">
		<div class="flex items-center gap-2">
			<span class="rounded-xl bg-[#e0e5ec] px-4 py-2 text-sm font-semibold uppercase tracking-widest text-[#6b8aab] shadow-[3px_3px_6px_#b8bec7,-3px_-3px_6px_#ffffff]">Neumorphism</span>
		</div>
		<div class="flex flex-wrap items-center gap-2">
			{nav.map((item: any) => (
				<a href={item.href} class="rounded-xl bg-[#e0e5ec] px-4 py-2 text-sm font-medium text-[#4a5568] shadow-[4px_4px_8px_#b8bec7,-4px_-4px_8px_#ffffff] transition-all duration-200 hover:shadow-[inset_3px_3px_6px_#b8bec7,inset_-3px_-3px_6px_#ffffff] hover:text-[#6b8aab]">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="mx-auto flex max-w-2xl items-center justify-center px-4 py-20 sm:px-6">
		<section class="w-full rounded-2xl bg-[#e0e5ec] p-10 text-center shadow-[8px_8px_16px_#b8bec7,-8px_-8px_16px_#ffffff] sm:p-14">
			<h1 class="mb-4 text-7xl font-bold text-[#6b8aab] sm:text-8xl">{t.notFound.title}</h1>
			<h2 class="mb-4 text-2xl font-bold text-[#3a4a5c] sm:text-3xl">{t.notFound.heading}</h2>
			<p class="mb-10 text-[#5a6a7c] leading-relaxed">{t.notFound.description}</p>
			<div class="flex flex-wrap justify-center gap-4">
				<a href={`/${lang}/${style}/`} class="rounded-xl bg-[#e0e5ec] px-8 py-3 font-semibold text-[#6b8aab] shadow-[6px_6px_12px_#b8bec7,-6px_-6px_12px_#ffffff] transition-all duration-200 hover:shadow-[inset_4px_4px_8px_#b8bec7,inset_-4px_-4px_8px_#ffffff]">{t.notFound.backHome}</a>
				<a href={`/${lang}/${style}/cats`} class="rounded-xl bg-[#e0e5ec] px-8 py-3 font-semibold text-[#6b8aab] shadow-[6px_6px_12px_#b8bec7,-6px_-6px_12px_#ffffff] transition-all duration-200 hover:shadow-[inset_4px_4px_8px_#b8bec7,inset_-4px_-4px_8px_#ffffff]">{t.notFound.meetCats}</a>
			</div>
		</section>
	</main>
</div>
