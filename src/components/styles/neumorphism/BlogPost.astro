---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
---

<div class="min-h-screen bg-[#e0e5ec] font-sans text-[#4a5568] antialiased">
	<nav class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-4 px-4 py-6 sm:px-6">
		<div class="flex items-center gap-2">
			<span class="rounded-xl bg-[#e0e5ec] px-4 py-2 text-sm font-semibold uppercase tracking-widest text-[#6b8aab] shadow-[3px_3px_6px_#b8bec7,-3px_-3px_6px_#ffffff]">Neumorphism</span>
		</div>
		<div class="flex flex-wrap items-center gap-2">
			{nav.map((item: any) => (
				<a href={item.href} class="rounded-xl bg-[#e0e5ec] px-4 py-2 text-sm font-medium text-[#4a5568] shadow-[4px_4px_8px_#b8bec7,-4px_-4px_8px_#ffffff] transition-all duration-200 hover:shadow-[inset_3px_3px_6px_#b8bec7,inset_-3px_-3px_6px_#ffffff] hover:text-[#6b8aab]">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="mx-auto max-w-3xl space-y-10 px-4 py-8 sm:px-6">
		<a href={`/${lang}/${style}/blog`} class="inline-flex items-center gap-2 rounded-xl bg-[#e0e5ec] px-5 py-2.5 text-sm font-medium text-[#6b8aab] shadow-[4px_4px_8px_#b8bec7,-4px_-4px_8px_#ffffff] transition-all duration-200 hover:shadow-[inset_3px_3px_6px_#b8bec7,inset_-3px_-3px_6px_#ffffff]">&larr; {t.blog.backToBlog}</a>

		<article class="rounded-2xl bg-[#e0e5ec] p-8 shadow-[8px_8px_16px_#b8bec7,-8px_-8px_16px_#ffffff] sm:p-10">
			<header class="mb-8 space-y-4">
				<time datetime={post.date} class="inline-block rounded-lg bg-[#e0e5ec] px-3 py-1 text-xs font-semibold text-[#6b8aab] shadow-[inset_2px_2px_4px_#b8bec7,inset_-2px_-2px_4px_#ffffff]">{post.date}</time>
				<h1 class="text-3xl font-bold tracking-tight text-[#3a4a5c] sm:text-4xl">{post.title}</h1>
				<span class="block text-sm font-medium text-[#6b7b8d]">{t.blog.by} {post.author}</span>
				<div class="flex flex-wrap gap-2">
					{post.tags.map((tag: string) => (
						<span class="rounded-lg bg-[#e0e5ec] px-3 py-1 text-xs font-medium text-[#6b8aab] shadow-[3px_3px_6px_#b8bec7,-3px_-3px_6px_#ffffff]">{tag}</span>
					))}
				</div>
			</header>

			<div class="space-y-5">
				{post.content.map((paragraph: string) => (
					<p class="text-[#5a6a7c] leading-relaxed">{paragraph}</p>
				))}
			</div>
		</article>

		<section class="mx-auto max-w-5xl">
			<h2 class="mb-6 text-2xl font-bold text-[#3a4a5c]">{t.blog.moreStories}</h2>
			<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{otherPosts.map((p: any) => (
					<a href={`/${lang}/${style}/blog/${p.slug}`} class="group block rounded-2xl bg-[#e0e5ec] p-6 shadow-[6px_6px_12px_#b8bec7,-6px_-6px_12px_#ffffff] transition-all duration-300 hover:shadow-[8px_8px_16px_#b8bec7,-8px_-8px_16px_#ffffff]">
						<h3 class="text-lg font-bold text-[#3a4a5c] group-hover:text-[#6b8aab] transition-colors duration-200">{p.title}</h3>
						<p class="mt-2 text-sm text-[#5a6a7c] leading-relaxed">{p.excerpt}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
