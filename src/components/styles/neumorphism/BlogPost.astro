---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-[#e0e5ec] font-sans text-[#4a5568] antialiased">
	<!-- Floating pill navigation -->
	<nav class="sticky top-4 z-50 mx-auto max-w-4xl px-6 py-4">
		<div class="flex flex-wrap items-center justify-between gap-4 rounded-full bg-[#e0e5ec] px-6 py-3 shadow-[8px_8px_16px_#b8bec7,-8px_-8px_16px_#ffffff]">
			<span class="rounded-full bg-[#e0e5ec] px-5 py-2 text-xs font-bold uppercase tracking-[0.2em] text-[#6b8aab] shadow-[4px_4px_8px_#b8bec7,-4px_-4px_8px_#ffffff]">Neumorphism</span>
			<div class="flex flex-wrap items-center gap-2">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-full bg-[#e0e5ec] px-5 py-2 text-sm font-medium text-[#5a6a7c] shadow-[3px_3px_6px_#b8bec7,-3px_-3px_6px_#ffffff] transition-all duration-300 hover:shadow-[inset_3px_3px_6px_#b8bec7,inset_-3px_-3px_6px_#ffffff] hover:text-[#6b8aab]">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="mx-auto max-w-5xl space-y-12 px-6 pb-16 pt-8">
		<!-- Back button pill -->
		<a href={`${_base}/${lang}/${style}/blog`} class="inline-flex items-center gap-2 rounded-full bg-[#e0e5ec] px-6 py-2.5 text-sm font-semibold text-[#6b8aab] shadow-[5px_5px_10px_#b8bec7,-5px_-5px_10px_#ffffff] transition-all duration-300 hover:shadow-[inset_3px_3px_6px_#b8bec7,inset_-3px_-3px_6px_#ffffff]">
			<span class="text-lg leading-none">&larr;</span> {t.blog.backToBlog}
		</a>

		<!-- Two-column: article sidebar + content -->
		<div class="grid gap-10 lg:grid-cols-[280px_1fr]">
			<!-- Sidebar: metadata -->
			<aside class="space-y-6">
				<!-- Date: inset counter -->
				<div class="rounded-2xl bg-[#e0e5ec] px-5 py-5 text-center shadow-[inset_4px_4px_8px_#b8bec7,inset_-4px_-4px_8px_#ffffff]">
					<time datetime={post.date} class="text-2xl font-extrabold text-[#6b8aab]">{post.date.split('-')[2]}</time>
					<span class="mt-1 block text-xs font-bold uppercase tracking-widest text-[#7a8a9c]">{post.date.split('-')[1]}/{post.date.split('-')[0]}</span>
				</div>

				<!-- Author: raised pill -->
				<div class="rounded-2xl bg-[#e0e5ec] px-5 py-4 shadow-[6px_6px_12px_#b8bec7,-6px_-6px_12px_#ffffff]">
					<span class="block text-[10px] font-bold uppercase tracking-widest text-[#6b8aab]">{t.blog.by}</span>
					<span class="mt-1 block text-sm font-semibold text-[#3a4a5c]">{post.author}</span>
				</div>

				<!-- Tags: extruded pills stack -->
				<div class="space-y-2">
					{post.tags.map((tag: string) => (
						<div class="rounded-full bg-[#e0e5ec] px-5 py-2 text-center shadow-[4px_4px_8px_#b8bec7,-4px_-4px_8px_#ffffff]">
							<span class="text-xs font-bold uppercase tracking-wider text-[#6b8aab]">{tag}</span>
						</div>
					))}
				</div>
			</aside>

			<!-- Main content -->
			<article class="rounded-[1.5rem] bg-[#e0e5ec] p-8 shadow-[10px_10px_20px_#b8bec7,-10px_-10px_20px_#ffffff] sm:p-10">
				<img src={post.image} alt={post.title} class="w-full h-52 md:h-64 object-cover rounded-xl mb-8 shadow-[inset_4px_4px_8px_#b8bec7,inset_-4px_-4px_8px_#ffffff]" />
				<h1 class="mb-8 text-3xl font-extrabold tracking-tight text-[#3a4a5c] sm:text-4xl">{post.title}</h1>

				<div class="space-y-5">
					{post.content.map((paragraph: string, i: number) => (
						<div class:list={[
							"rounded-xl bg-[#e0e5ec] p-5",
							i % 2 === 0
								? "shadow-[inset_3px_3px_6px_#b8bec7,inset_-3px_-3px_6px_#ffffff]"
								: "shadow-[4px_4px_8px_#b8bec7,-4px_-4px_8px_#ffffff]"
						]}>
							<p class="text-sm leading-relaxed text-[#5a6a7c] sm:text-base">{paragraph}</p>
						</div>
					))}
				</div>
			</article>
		</div>

		<!-- More stories -->
		<section class="space-y-8">
			<h2 class="text-center text-2xl font-extrabold text-[#3a4a5c] lg:text-left">{t.blog.moreStories}</h2>
			<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
				{otherPosts.map((p: any) => (
					<a href={`${_base}/${lang}/${style}/blog/${p.slug}`} class="group block rounded-2xl bg-[#e0e5ec] p-6 shadow-[6px_6px_12px_#b8bec7,-6px_-6px_12px_#ffffff] transition-all duration-300 hover:shadow-[10px_10px_20px_#b8bec7,-10px_-10px_20px_#ffffff]">
						<time datetime={p.date} class="mb-3 inline-block rounded-full bg-[#e0e5ec] px-3 py-1 text-[11px] font-bold text-[#6b8aab] shadow-[inset_2px_2px_4px_#b8bec7,inset_-2px_-2px_4px_#ffffff]">{p.date}</time>
						<h3 class="text-lg font-bold text-[#3a4a5c] transition-colors duration-300 group-hover:text-[#6b8aab]">{p.title}</h3>
						<p class="mt-2 text-xs leading-relaxed text-[#7a8a9c]">{p.excerpt.slice(0, 80)}...</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
