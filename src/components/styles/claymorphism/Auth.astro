---
const { lang, style, nav, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-[#f0e6ff] font-sans text-purple-900 antialiased">
	<!-- Puffy clay navigation bar -->
	<nav class="sticky top-4 z-50 mx-4 sm:mx-8 lg:mx-auto lg:max-w-5xl mt-4">
		<div class="bg-white/70 rounded-3xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] p-3 flex items-center justify-between">
			<span class="rounded-full bg-purple-200 px-5 py-2 text-sm font-bold text-purple-700 shadow-[0_4px_12px_rgba(147,51,234,0.15),inset_0_-3px_6px_rgba(0,0,0,0.06)]">Claymorphism</span>
			<div class="flex flex-wrap items-center gap-2">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-full bg-purple-100 px-4 py-2 text-sm font-medium text-purple-600 shadow-[0_4px_12px_rgba(0,0,0,0.06),inset_0_-2px_4px_rgba(0,0,0,0.05)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-purple-200 hover:text-purple-700">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="flex min-h-[calc(100vh-120px)] items-center justify-center px-4 sm:px-8 py-12">
		<div class="w-full max-w-md">
			<!-- Auth clay card -->
			<section class="bg-white/60 rounded-3xl shadow-[0_12px_40px_rgba(0,0,0,0.1),inset_0_-8px_16px_rgba(0,0,0,0.05)] p-8 sm:p-10">
				<!-- Header with icon -->
				<div class="mb-8 text-center">
					<div class="mx-auto mb-5 flex h-20 w-20 items-center justify-center rounded-3xl bg-purple-100 shadow-[0_6px_20px_rgba(147,51,234,0.15),inset_0_-4px_8px_rgba(0,0,0,0.06)]">
						<span class="text-3xl">&#128062;</span>
					</div>
					<h1 class="mb-2 text-3xl font-black text-purple-800">{t.auth.title}</h1>
					<p class="text-sm font-medium text-purple-500">{t.auth.subtitle}</p>
				</div>

				<form class="space-y-6">
					<!-- Email field -->
					<div>
						<label for="email" class="mb-2.5 block text-xs font-bold uppercase tracking-widest text-purple-500">{t.auth.email}</label>
						<input
							type="email"
							id="email"
							name="email"
							placeholder="you@example.com"
							class="w-full rounded-2xl bg-purple-50 px-5 py-3.5 text-sm font-medium text-purple-800 border-0 shadow-[inset_0_-4px_8px_rgba(0,0,0,0.06)] outline-none transition-all duration-300 placeholder:text-purple-300 focus:ring-2 focus:ring-purple-400 focus:shadow-[inset_0_-4px_8px_rgba(0,0,0,0.06),0_0_0_3px_rgba(192,132,252,0.3)]"
						/>
					</div>

					<!-- Password field -->
					<div>
						<label for="password" class="mb-2.5 block text-xs font-bold uppercase tracking-widest text-purple-500">{t.auth.password}</label>
						<input
							type="password"
							id="password"
							name="password"
							placeholder="••••••••"
							class="w-full rounded-2xl bg-purple-50 px-5 py-3.5 text-sm font-medium text-purple-800 border-0 shadow-[inset_0_-4px_8px_rgba(0,0,0,0.06)] outline-none transition-all duration-300 placeholder:text-purple-300 focus:ring-2 focus:ring-purple-400 focus:shadow-[inset_0_-4px_8px_rgba(0,0,0,0.06),0_0_0_3px_rgba(192,132,252,0.3)]"
						/>
					</div>

					<!-- Remember + Forgot row -->
					<div class="flex items-center justify-between">
						<label class="flex items-center gap-3 text-sm font-medium text-purple-600">
							<div class="relative">
								<input type="checkbox" name="remember" class="peer sr-only" />
								<div class="h-6 w-6 rounded-lg bg-purple-100 shadow-[inset_0_-2px_4px_rgba(0,0,0,0.06)] transition-all duration-300 peer-checked:bg-purple-400 peer-checked:shadow-[0_3px_8px_rgba(147,51,234,0.2),inset_0_-2px_4px_rgba(0,0,0,0.1)]"></div>
								<div class="absolute inset-0 flex items-center justify-center text-xs font-bold text-white opacity-0 transition-opacity peer-checked:opacity-100">&#10003;</div>
							</div>
							{t.auth.rememberMe}
						</label>
						<a href="#" class="text-xs font-semibold text-purple-500 hover:text-purple-700 transition-colors duration-200">{t.auth.forgotPassword}</a>
					</div>

					<!-- Sign in button: puffy purple -->
					<button type="submit" class="w-full rounded-2xl bg-purple-500 px-8 py-4 text-base font-bold text-white shadow-[0_6px_20px_rgba(147,51,234,0.3),inset_0_-4px_8px_rgba(0,0,0,0.1)] hover:-translate-y-0.5 hover:shadow-[0_10px_28px_rgba(147,51,234,0.4),inset_0_-4px_8px_rgba(0,0,0,0.1)] transition-all duration-300">{t.auth.signIn}</button>
				</form>

				<!-- Divider -->
				<div class="my-8 flex items-center gap-4">
					<div class="h-0.5 flex-1 rounded-full bg-purple-200/60"></div>
					<span class="text-[10px] font-bold uppercase tracking-widest text-purple-400">{t.auth.continueWith}</span>
					<div class="h-0.5 flex-1 rounded-full bg-purple-200/60"></div>
				</div>

				<!-- Social buttons: puffy outlined -->
				<div class="grid grid-cols-2 gap-5">
					<button type="button" class="rounded-2xl bg-pink-50 px-4 py-3.5 text-sm font-bold text-purple-700 shadow-[0_4px_12px_rgba(0,0,0,0.06),inset_0_-3px_6px_rgba(0,0,0,0.05)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-pink-100 hover:shadow-[0_6px_16px_rgba(0,0,0,0.08),inset_0_-3px_6px_rgba(0,0,0,0.05)]">Google</button>
					<button type="button" class="rounded-2xl bg-blue-50 px-4 py-3.5 text-sm font-bold text-purple-700 shadow-[0_4px_12px_rgba(0,0,0,0.06),inset_0_-3px_6px_rgba(0,0,0,0.05)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-blue-100 hover:shadow-[0_6px_16px_rgba(0,0,0,0.08),inset_0_-3px_6px_rgba(0,0,0,0.05)]">Apple</button>
				</div>

				<!-- Sign up link -->
				<p class="mt-8 text-center text-sm font-medium text-purple-400">
					{t.auth.noAccount}{' '}
					<a href="#" class="font-bold text-purple-600 hover:text-purple-800 transition-colors duration-200">{t.auth.signUp}</a>
				</p>
			</section>
		</div>
	</main>
</div>
