---
const { lang, style, nav, cats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-[#f0e6ff] font-sans text-purple-900 antialiased">
	<!-- Puffy clay navigation bar -->
	<nav class="sticky top-4 z-50 mx-4 sm:mx-8 lg:mx-auto lg:max-w-5xl mt-4">
		<div class="bg-white/70 rounded-3xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] p-3 flex items-center justify-between">
			<span class="rounded-full bg-purple-200 px-5 py-2 text-sm font-bold text-purple-700 shadow-[0_4px_12px_rgba(147,51,234,0.15),inset_0_-3px_6px_rgba(0,0,0,0.06)]">Claymorphism</span>
			<div class="flex flex-wrap items-center gap-2">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-full bg-purple-100 px-4 py-2 text-sm font-medium text-purple-600 shadow-[0_4px_12px_rgba(0,0,0,0.06),inset_0_-2px_4px_rgba(0,0,0,0.05)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-purple-200 hover:text-purple-700">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="mx-auto max-w-6xl px-4 sm:px-8 lg:px-0 pb-16 pt-8 space-y-12">
		<!-- Header clay card -->
		<header class="bg-white/60 rounded-3xl shadow-[0_8px_32px_rgba(0,0,0,0.08),inset_0_-8px_16px_rgba(0,0,0,0.05)] px-8 py-10 text-center sm:py-14">
			<h1 class="text-4xl sm:text-5xl font-black text-purple-800 mb-3">{t.cats.title}</h1>
			<p class="text-purple-500 font-medium max-w-md mx-auto">{t.cats.subtitle}</p>
		</header>

		<!-- Cat cards grid -->
		<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
			{cats.map((cat: any, i: number) => (
				<a href={`${_base}/${lang}/${style}/cats/${cat.id}`} class="group block bg-white/60 rounded-3xl p-6 shadow-[0_8px_24px_rgba(0,0,0,0.08),inset_0_-6px_12px_rgba(0,0,0,0.05)] hover:-translate-y-1 hover:shadow-[0_12px_32px_rgba(0,0,0,0.12),inset_0_-6px_12px_rgba(0,0,0,0.05)] transition-all duration-300">
					<!-- Cat thumbnail -->
					<img src={cat.thumbnail} alt={cat.name} class="w-full h-44 object-cover rounded-2xl mb-5 shadow-[0_4px_16px_rgba(0,0,0,0.1),inset_0_-4px_8px_rgba(0,0,0,0.08)]" />

					<h2 class="text-xl font-bold text-purple-700 text-center mb-1 group-hover:text-purple-900 transition-colors duration-300">{cat.name}</h2>

					<!-- Breed, age, gender pill -->
					<div class="mx-auto mt-2 mb-4 rounded-full bg-pink-100 px-4 py-1.5 text-center shadow-[0_3px_8px_rgba(0,0,0,0.05),inset_0_-2px_4px_rgba(0,0,0,0.04)]">
						<span class="text-xs font-semibold text-pink-600">{cat.breed} &middot; {cat.age} &middot; {cat.gender}</span>
					</div>

					<!-- Description -->
					<div class="mb-4 rounded-2xl bg-purple-50 p-4 shadow-[inset_0_-4px_8px_rgba(0,0,0,0.04)]">
						<p class="text-xs leading-relaxed text-purple-600/80">{cat.description.slice(0, 110)}...</p>
					</div>

					<!-- Personality pills -->
					<div class="mb-4 flex flex-wrap justify-center gap-2">
						{cat.personality.map((trait: string, j: number) => (
							<span class={`rounded-full px-3 py-1 text-[11px] font-semibold shadow-[0_3px_8px_rgba(0,0,0,0.06),inset_0_-2px_4px_rgba(0,0,0,0.04)] ${j % 3 === 0 ? 'bg-pink-100 text-pink-600' : j % 3 === 1 ? 'bg-blue-100 text-blue-600' : 'bg-yellow-100 text-yellow-700'}`}>{trait}</span>
						))}
					</div>

					<!-- Status badge -->
					<div class="text-center">
						<span class="inline-block rounded-full bg-purple-200 px-5 py-1.5 text-xs font-bold uppercase tracking-wider text-purple-700 shadow-[0_4px_12px_rgba(147,51,234,0.15),inset_0_-2px_4px_rgba(0,0,0,0.06)]">{cat.status}</span>
					</div>
				</a>
			))}
		</div>
	</main>
</div>
