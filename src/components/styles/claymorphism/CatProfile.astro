---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-[#f0e6ff] font-sans text-purple-900 antialiased">
	<!-- Puffy clay navigation bar -->
	<nav class="sticky top-4 z-50 mx-4 sm:mx-8 lg:mx-auto lg:max-w-5xl mt-4">
		<div class="bg-white/70 rounded-3xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] p-3 flex items-center justify-between">
			<span class="rounded-full bg-purple-200 px-5 py-2 text-sm font-bold text-purple-700 shadow-[0_4px_12px_rgba(147,51,234,0.15),inset_0_-3px_6px_rgba(0,0,0,0.06)]">Claymorphism</span>
			<div class="flex flex-wrap items-center gap-2">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-full bg-purple-100 px-4 py-2 text-sm font-medium text-purple-600 shadow-[0_4px_12px_rgba(0,0,0,0.06),inset_0_-2px_4px_rgba(0,0,0,0.05)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-purple-200 hover:text-purple-700">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="mx-auto max-w-5xl px-4 sm:px-8 lg:px-0 pb-16 pt-8 space-y-12">
		<!-- Back link -->
		<a href={`${_base}/${lang}/${style}/cats`} class="inline-flex items-center gap-2 rounded-full bg-purple-100 px-6 py-2.5 text-sm font-semibold text-purple-500 shadow-[0_4px_12px_rgba(0,0,0,0.06),inset_0_-3px_6px_rgba(0,0,0,0.05)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-purple-200 hover:text-purple-700">
			<span class="text-lg leading-none">&larr;</span> {t.cats.backToAll}
		</a>

		<!-- Two-column layout -->
		<div class="grid gap-10 lg:grid-cols-[320px_1fr]">
			<!-- Sidebar -->
			<aside class="space-y-8">
				<!-- Cat image -->
				<img src={cat.image} alt={cat.name} class="w-full h-64 lg:h-72 object-cover rounded-3xl shadow-[0_8px_24px_rgba(0,0,0,0.12),inset_0_-8px_16px_rgba(0,0,0,0.1)]" />

				<h1 class="text-center text-3xl sm:text-4xl font-black text-purple-800">{cat.name}</h1>

				<!-- Status badge -->
				<div class="text-center">
					<span class="inline-block rounded-full bg-purple-200 px-6 py-2 text-xs font-bold uppercase tracking-widest text-purple-700 shadow-[0_4px_12px_rgba(147,51,234,0.15),inset_0_-2px_4px_rgba(0,0,0,0.06)]">{cat.status}</span>
				</div>

				<!-- Metadata clay card with alternating rows -->
				<div class="bg-white/60 rounded-3xl shadow-[0_8px_24px_rgba(0,0,0,0.08),inset_0_-6px_12px_rgba(0,0,0,0.05)] overflow-hidden">
					<div class="bg-pink-50 px-5 py-4">
						<span class="block text-[10px] font-bold uppercase tracking-widest text-purple-500">{t.cats.breed}</span>
						<span class="mt-1 block text-sm font-semibold text-purple-800">{cat.breed}</span>
					</div>
					<div class="bg-blue-50 px-5 py-4">
						<span class="block text-[10px] font-bold uppercase tracking-widest text-purple-500">{t.cats.age}</span>
						<span class="mt-1 block text-sm font-semibold text-purple-800">{cat.age}</span>
					</div>
					<div class="bg-yellow-50 px-5 py-4">
						<span class="block text-[10px] font-bold uppercase tracking-widest text-purple-500">{t.cats.gender}</span>
						<span class="mt-1 block text-sm font-semibold text-purple-800">{cat.gender}</span>
					</div>
					<div class="bg-pink-50 px-5 py-4">
						<span class="block text-[10px] font-bold uppercase tracking-widest text-purple-500">{t.cats.color}</span>
						<span class="mt-1 block text-sm font-semibold text-purple-800">{cat.color}</span>
					</div>
					<div class="bg-blue-50 px-5 py-4">
						<span class="block text-[10px] font-bold uppercase tracking-widest text-purple-500">{t.cats.arrived}</span>
						<span class="mt-1 block text-sm font-semibold text-purple-800">{cat.arrivalDate}</span>
					</div>
				</div>
			</aside>

			<!-- Main content -->
			<article class="space-y-8">
				<!-- Personality puffy pills -->
				<div class="bg-white/60 rounded-3xl shadow-[0_8px_24px_rgba(0,0,0,0.08),inset_0_-6px_12px_rgba(0,0,0,0.05)] p-6">
					<div class="flex flex-wrap gap-3">
						{cat.personality.map((trait: string, i: number) => (
							<span class={`rounded-full px-5 py-2 text-sm font-semibold shadow-[0_4px_12px_rgba(0,0,0,0.06),inset_0_-3px_6px_rgba(0,0,0,0.05)] ${i % 3 === 0 ? 'bg-pink-100 text-pink-600' : i % 3 === 1 ? 'bg-blue-100 text-blue-600' : 'bg-yellow-100 text-yellow-700'}`}>{trait}</span>
						))}
					</div>
				</div>

				<!-- Description clay card -->
				<div class="bg-white/60 rounded-3xl shadow-[0_8px_24px_rgba(0,0,0,0.08),inset_0_-6px_12px_rgba(0,0,0,0.05)] p-8 sm:p-10">
					<p class="text-base leading-relaxed text-purple-700/80">{cat.description}</p>
				</div>

				<!-- Adopt button: puffy purple -->
				<div class="text-center lg:text-left">
					<a href={`${_base}/${lang}/${style}/auth`} class="inline-block rounded-2xl bg-purple-500 px-12 py-4 text-lg font-bold text-white shadow-[0_6px_20px_rgba(147,51,234,0.3),inset_0_-4px_8px_rgba(0,0,0,0.1)] hover:-translate-y-1 hover:shadow-[0_10px_28px_rgba(147,51,234,0.4),inset_0_-4px_8px_rgba(0,0,0,0.1)] transition-all duration-300">{t.cats.adopt} {cat.name}</a>
				</div>
			</article>
		</div>

		<!-- Other cats -->
		<section class="space-y-8">
			<h2 class="text-center text-2xl font-bold text-purple-800 lg:text-left">{t.cats.otherCats}</h2>
			<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{otherCats.map((c: any, i: number) => (
					<a href={`${_base}/${lang}/${style}/cats/${c.id}`} class={`group flex items-center gap-4 rounded-3xl p-5 shadow-[0_6px_20px_rgba(0,0,0,0.07),inset_0_-4px_8px_rgba(0,0,0,0.04)] hover:-translate-y-1 hover:shadow-[0_10px_28px_rgba(0,0,0,0.1),inset_0_-4px_8px_rgba(0,0,0,0.04)] transition-all duration-300 ${i % 3 === 0 ? 'bg-pink-100' : i % 3 === 1 ? 'bg-blue-100' : 'bg-yellow-100'}`}>
						<div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-white/60 shadow-[0_4px_12px_rgba(0,0,0,0.06),inset_0_-3px_6px_rgba(0,0,0,0.05)]">
							<span class="text-lg font-black text-purple-700">{c.name.charAt(0)}</span>
						</div>
						<div>
							<h3 class="text-lg font-bold text-purple-800 group-hover:text-purple-600 transition-colors duration-300">{c.name}</h3>
							<p class="mt-0.5 text-xs font-medium text-purple-500/70">{c.breed} &middot; {c.age}</p>
						</div>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
