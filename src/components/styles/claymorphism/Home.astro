---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-[#f0e6ff] font-sans text-purple-900 antialiased">
	<!-- Puffy clay navigation bar -->
	<nav class="sticky top-4 z-50 mx-4 sm:mx-8 lg:mx-auto lg:max-w-5xl mt-4">
		<div class="bg-white/70 rounded-3xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] shadow-purple-200/40 p-3 flex items-center justify-between">
			<a href={`${_base}/${lang}/${style}/`} class="rounded-full bg-purple-200 px-5 py-2 text-sm font-bold text-purple-700 shadow-[0_4px_12px_rgba(147,51,234,0.15),inset_0_-3px_6px_rgba(0,0,0,0.06)] transition-all duration-300 hover:-translate-y-0.5">{meta.name}</a>
			<div class="flex flex-wrap items-center gap-2">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-full bg-purple-100 px-4 py-2 text-sm font-medium text-purple-600 shadow-[0_4px_12px_rgba(0,0,0,0.06),inset_0_-2px_4px_rgba(0,0,0,0.05)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-purple-200 hover:text-purple-700">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="mx-auto max-w-6xl px-4 sm:px-8 lg:px-0 pb-16">
		<!-- Hero section -->
		<section class="relative pt-16 sm:pt-24 pb-20 text-center max-w-4xl mx-auto">
			<img src={sanctuary.heroImage} alt={sanctuary.name} class="w-full h-56 md:h-72 object-cover rounded-3xl mb-10 shadow-[0_8px_24px_rgba(0,0,0,0.12),inset_0_-8px_16px_rgba(0,0,0,0.1)]" />
			<h1 class="text-5xl sm:text-6xl lg:text-7xl font-black text-purple-800 mb-6 leading-tight">{sanctuary.name}</h1>
			<p class="text-lg sm:text-xl text-purple-500 max-w-2xl mx-auto mb-12 leading-relaxed">{sanctuary.tagline}</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a href={`${_base}/${lang}/${style}/cats`} class="px-10 py-4 rounded-2xl bg-purple-500 text-white font-bold shadow-[0_6px_20px_rgba(147,51,234,0.3),inset_0_-4px_8px_rgba(0,0,0,0.1)] hover:-translate-y-1 hover:shadow-[0_10px_28px_rgba(147,51,234,0.4),inset_0_-4px_8px_rgba(0,0,0,0.1)] transition-all duration-300">{t.home.meetCats}</a>
				<a href={`${_base}/${lang}/${style}/donate`} class="px-10 py-4 rounded-2xl bg-pink-100 text-pink-700 font-bold shadow-[0_6px_20px_rgba(0,0,0,0.08),inset_0_-4px_8px_rgba(0,0,0,0.06)] hover:-translate-y-1 hover:shadow-[0_10px_28px_rgba(0,0,0,0.12),inset_0_-4px_8px_rgba(0,0,0,0.06)] transition-all duration-300">{t.home.donate}</a>
			</div>
		</section>

		<!-- Mission clay card -->
		<section class="mb-16 max-w-4xl mx-auto">
			<div class="bg-white/60 rounded-3xl shadow-[0_8px_32px_rgba(0,0,0,0.08),inset_0_-8px_16px_rgba(0,0,0,0.05)] p-8 sm:p-12">
				<h2 class="text-2xl sm:text-3xl font-bold text-purple-800 mb-5">{t.home.mission}</h2>
				<p class="text-purple-700/80 text-lg leading-relaxed">{sanctuary.mission}</p>
			</div>
		</section>

		<!-- Stats in puffy pastel cards -->
		<section class="mb-16">
			<div class="grid grid-cols-2 lg:grid-cols-4 gap-5">
				{sanctuary.stats.map((stat: any, i: number) => (
					<div class={`rounded-3xl p-6 sm:p-8 text-center shadow-[0_8px_24px_rgba(0,0,0,0.08),inset_0_-6px_12px_rgba(0,0,0,0.06)] hover:-translate-y-1 transition-all duration-300 cursor-default ${i % 4 === 0 ? 'bg-pink-100' : i % 4 === 1 ? 'bg-blue-100' : i % 4 === 2 ? 'bg-yellow-100' : 'bg-green-100'}`}>
						<span class="block text-3xl sm:text-4xl font-black text-purple-800 leading-none">{stat.value}</span>
						<span class="block text-sm text-purple-600/70 mt-2 font-medium">{stat.label}</span>
					</div>
				))}
			</div>
		</section>

		<!-- About section -->
		<section class="mb-16 max-w-4xl mx-auto">
			<div class="bg-white/60 rounded-3xl shadow-[0_8px_32px_rgba(0,0,0,0.08),inset_0_-8px_16px_rgba(0,0,0,0.05)] p-8 sm:p-12">
				<h2 class="text-2xl sm:text-3xl font-bold text-purple-800 mb-6">{t.home.aboutUs}</h2>
				<div class="space-y-4">
					{sanctuary.about.map((paragraph: string) => (
						<p class="text-purple-700/70 leading-relaxed">{paragraph}</p>
					))}
				</div>
			</div>
		</section>

		<!-- Contact pills -->
		<section class="mb-16 flex flex-wrap items-center justify-center gap-4">
			<div class="rounded-full bg-pink-100 px-6 py-3 shadow-[0_4px_16px_rgba(0,0,0,0.06),inset_0_-3px_6px_rgba(0,0,0,0.05)]">
				<span class="text-sm font-semibold text-purple-700">{sanctuary.contact.email}</span>
			</div>
			<div class="rounded-full bg-blue-100 px-6 py-3 shadow-[0_4px_16px_rgba(0,0,0,0.06),inset_0_-3px_6px_rgba(0,0,0,0.05)]">
				<span class="text-sm font-semibold text-purple-700">{sanctuary.contact.phone}</span>
			</div>
			<div class="rounded-full bg-yellow-100 px-6 py-3 shadow-[0_4px_16px_rgba(0,0,0,0.06),inset_0_-3px_6px_rgba(0,0,0,0.05)]">
				<span class="text-sm font-semibold text-purple-700">{sanctuary.contact.address}</span>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="mx-4 sm:mx-8 lg:mx-auto lg:max-w-5xl mb-6">
		<div class="bg-white/50 rounded-3xl shadow-[0_4px_16px_rgba(0,0,0,0.06),inset_0_-4px_8px_rgba(0,0,0,0.04)] px-6 py-5 text-center">
			<p class="text-sm text-purple-500">&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.</p>
		</div>
	</footer>
</div>
