---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-[#f0e6ff] font-sans text-purple-900 antialiased">
	<!-- Puffy clay navigation bar -->
	<nav class="sticky top-4 z-50 mx-4 sm:mx-8 lg:mx-auto lg:max-w-5xl mt-4">
		<div class="bg-white/70 rounded-3xl shadow-[0_8px_32px_rgba(0,0,0,0.08)] p-3 flex items-center justify-between">
			<span class="rounded-full bg-purple-200 px-5 py-2 text-sm font-bold text-purple-700 shadow-[0_4px_12px_rgba(147,51,234,0.15),inset_0_-3px_6px_rgba(0,0,0,0.06)]">Claymorphism</span>
			<div class="flex flex-wrap items-center gap-2">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-full bg-purple-100 px-4 py-2 text-sm font-medium text-purple-600 shadow-[0_4px_12px_rgba(0,0,0,0.06),inset_0_-2px_4px_rgba(0,0,0,0.05)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-purple-200 hover:text-purple-700">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="mx-auto max-w-5xl px-4 sm:px-8 lg:px-0 pb-16 pt-8 space-y-12">
		<!-- Back link -->
		<a href={`${_base}/${lang}/${style}/blog`} class="inline-flex items-center gap-2 rounded-full bg-purple-100 px-6 py-2.5 text-sm font-semibold text-purple-500 shadow-[0_4px_12px_rgba(0,0,0,0.06),inset_0_-3px_6px_rgba(0,0,0,0.05)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-purple-200 hover:text-purple-700">
			<span class="text-lg leading-none">&larr;</span> {t.blog.backToBlog}
		</a>

		<!-- Two-column: sidebar + article content -->
		<div class="grid gap-10 lg:grid-cols-[280px_1fr]">
			<!-- Sidebar metadata -->
			<aside class="space-y-6">
				<!-- Date clay card -->
				<div class="rounded-3xl bg-blue-100 px-5 py-5 text-center shadow-[0_6px_20px_rgba(0,0,0,0.07),inset_0_-4px_8px_rgba(0,0,0,0.05)]">
					<time datetime={post.date} class="text-2xl font-black text-purple-800">{post.date.split('-')[2]}</time>
					<span class="mt-1 block text-xs font-bold uppercase tracking-widest text-purple-500">{post.date.split('-')[1]}/{post.date.split('-')[0]}</span>
				</div>

				<!-- Author clay card -->
				<div class="rounded-3xl bg-pink-100 px-5 py-4 shadow-[0_6px_20px_rgba(0,0,0,0.07),inset_0_-4px_8px_rgba(0,0,0,0.05)]">
					<span class="block text-[10px] font-bold uppercase tracking-widest text-purple-500">{t.blog.by}</span>
					<span class="mt-1 block text-sm font-semibold text-purple-800">{post.author}</span>
				</div>

				<!-- Tags as stacked pastel pills -->
				<div class="space-y-2">
					{post.tags.map((tag: string, i: number) => (
						<div class={`rounded-full px-5 py-2 text-center shadow-[0_4px_12px_rgba(0,0,0,0.06),inset_0_-2px_4px_rgba(0,0,0,0.04)] ${i % 3 === 0 ? 'bg-yellow-100' : i % 3 === 1 ? 'bg-pink-100' : 'bg-blue-100'}`}>
							<span class="text-xs font-bold uppercase tracking-wider text-purple-700">{tag}</span>
						</div>
					))}
				</div>
			</aside>

			<!-- Main article -->
			<article class="bg-white/60 rounded-3xl shadow-[0_8px_32px_rgba(0,0,0,0.08),inset_0_-8px_16px_rgba(0,0,0,0.05)] p-8 sm:p-10">
				<img src={post.image} alt={post.title} class="w-full h-52 md:h-64 object-cover rounded-3xl mb-8 shadow-[0_6px_20px_rgba(0,0,0,0.1),inset_0_-6px_12px_rgba(0,0,0,0.08)]" />
				<h1 class="mb-8 text-3xl sm:text-4xl font-black text-purple-800 leading-tight">{post.title}</h1>

				<div class="space-y-5">
					{post.content.map((paragraph: string) => (
						<p class="text-base leading-relaxed text-purple-700/80">{paragraph}</p>
					))}
				</div>
			</article>
		</div>

		<!-- More stories -->
		<section class="space-y-8">
			<h2 class="text-center text-2xl font-bold text-purple-800 lg:text-left">{t.blog.moreStories}</h2>
			<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{otherPosts.map((p: any, i: number) => (
					<a href={`${_base}/${lang}/${style}/blog/${p.slug}`} class={`group block rounded-3xl p-6 shadow-[0_6px_20px_rgba(0,0,0,0.07),inset_0_-4px_8px_rgba(0,0,0,0.04)] hover:-translate-y-1 hover:shadow-[0_10px_28px_rgba(0,0,0,0.1),inset_0_-4px_8px_rgba(0,0,0,0.04)] transition-all duration-300 ${i % 3 === 0 ? 'bg-pink-50' : i % 3 === 1 ? 'bg-blue-50' : 'bg-yellow-50'}`}>
						<time datetime={p.date} class="mb-3 inline-block rounded-full bg-white/60 px-3 py-1 text-[11px] font-bold text-purple-500 shadow-[0_2px_6px_rgba(0,0,0,0.05),inset_0_-1px_3px_rgba(0,0,0,0.04)]">{p.date}</time>
						<h3 class="text-lg font-bold text-purple-800 group-hover:text-purple-600 transition-colors duration-300">{p.title}</h3>
						<p class="mt-2 text-xs leading-relaxed text-purple-500/70">{p.excerpt.slice(0, 80)}...</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
