---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-stone-900 text-stone-300 font-mono">
	<nav class="border-b-4 border-stone-700 bg-stone-950 px-4 py-3 md:px-8">
		<div class="mx-auto flex max-w-5xl flex-wrap items-center gap-1">
			{nav.map((item: any, i: number) => (
				<>
					{i > 0 && <span class="text-stone-600 select-none">|</span>}
					<a href={item.href} class="px-2 py-1 text-sm uppercase tracking-widest text-stone-400 hover:text-amber-200 hover:line-through transition-colors">{item.label}</a>
				</>
			))}
		</div>
	</nav>

	<main class="mx-auto max-w-5xl px-4 py-12 md:px-8 md:py-16">
		<a href={`/${lang}/${style}/cats`} class="mb-8 inline-block text-xs uppercase tracking-widest text-stone-500 hover:text-amber-400 transition-colors">&larr; {t.cats.backToAll}</a>

		<article class="border-2 border-stone-700 bg-stone-800/30 p-6 md:p-10">
			<div class="mb-6 border-b-2 border-stone-700 pb-6">
				<p class="mb-1 text-xs uppercase tracking-[0.3em] text-stone-600">● ● ●</p>
				<h1 class="text-4xl font-black uppercase tracking-tight text-stone-100 md:text-6xl">{cat.name}</h1>
			</div>

			<dl class="mb-8 grid grid-cols-2 gap-x-6 gap-y-3 md:grid-cols-3">
				<div>
					<dt class="text-[10px] uppercase tracking-widest text-stone-600">{t.cats.breed}</dt>
					<dd class="text-sm text-stone-300">{cat.breed}</dd>
				</div>
				<div>
					<dt class="text-[10px] uppercase tracking-widest text-stone-600">{t.cats.age}</dt>
					<dd class="text-sm text-stone-300">{cat.age}</dd>
				</div>
				<div>
					<dt class="text-[10px] uppercase tracking-widest text-stone-600">{t.cats.gender}</dt>
					<dd class="text-sm text-stone-300">{cat.gender}</dd>
				</div>
				<div>
					<dt class="text-[10px] uppercase tracking-widest text-stone-600">{t.cats.color}</dt>
					<dd class="text-sm text-stone-300">{cat.color}</dd>
				</div>
				<div>
					<dt class="text-[10px] uppercase tracking-widest text-stone-600">{t.cats.arrived}</dt>
					<dd class="text-sm text-stone-300">{cat.arrivalDate}</dd>
				</div>
				<div>
					<dt class="text-[10px] uppercase tracking-widest text-stone-600">{t.cats.status}</dt>
					<dd class="text-sm text-stone-300">{cat.status}</dd>
				</div>
			</dl>

			<div class="mb-8 flex flex-wrap gap-2">
				{cat.personality.map((trait: string) => (
					<span class="border border-stone-600 bg-stone-800 px-3 py-1 text-xs uppercase tracking-widest text-stone-400">✗ {trait}</span>
				))}
			</div>

			<div class="mb-8 border-l-4 border-amber-800 pl-6">
				<p class="leading-relaxed text-stone-400">{cat.description}</p>
			</div>

			<a href={`/${lang}/${style}/auth`} class="inline-block border-2 border-stone-300 bg-stone-300 px-8 py-3 text-sm font-bold uppercase tracking-widest text-stone-900 hover:bg-transparent hover:text-stone-300 transition-colors">{t.cats.adopt} {cat.name}</a>
		</article>

		<section class="mt-12 border-t-2 border-stone-700 pt-10">
			<h2 class="mb-6 text-xs uppercase tracking-[0.3em] text-stone-500">// {t.cats.otherCats}</h2>
			<div class="grid gap-3 md:grid-cols-3">
				{otherCats.map((c: any) => (
					<a href={`/${lang}/${style}/cats/${c.id}`} class="group block border-2 border-stone-700 p-4 transition-colors hover:border-amber-800 hover:bg-stone-800/50">
						<h3 class="text-lg font-black uppercase tracking-tight text-stone-200 group-hover:text-amber-400 transition-colors">{c.name}</h3>
						<p class="text-xs uppercase tracking-wider text-stone-500">{c.breed} · {c.age}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
