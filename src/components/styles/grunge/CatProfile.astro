---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-[#1a1714] text-[#c8c0b0] font-mono selection:bg-amber-900/60 selection:text-amber-200">
	<nav class="border-b-[3px] border-[#3a3530] bg-[#0f0d0b] px-4 py-3 md:px-8">
		<div class="mx-auto flex max-w-6xl flex-wrap items-center gap-0.5">
			<span class="mr-3 text-[10px] uppercase tracking-widest text-[#5a4f40] select-none">///</span>
			{nav.map((item: any, i: number) => (
				<>
					{i > 0 && <span class="text-[#3a3530] select-none px-1">|</span>}
					<a href={item.href} class="px-2 py-1 text-xs uppercase tracking-[0.2em] text-[#7a7060] hover:text-[#f5f0e8] hover:line-through decoration-[#8b4513] decoration-2 transition-colors">{item.label}</a>
				</>
			))}
		</div>
	</nav>

	<main class="mx-auto max-w-5xl px-4 py-12 md:px-8 md:py-20">
		<a href={`/${lang}/${style}/cats`} class="mb-10 inline-block text-[10px] uppercase tracking-[0.3em] text-[#5a4f40] hover:text-[#c87941] transition-colors">&larr; {t.cats.backToAll}</a>

		<!-- Main profile: like a wanted poster / underground flyer -->
		<article class="relative border-[3px] border-[#3a3530] bg-[#1f1c18] p-6 md:p-10 lg:p-12">
			<!-- Corner marks -->
			<div class="absolute top-3 right-4 text-[10px] text-[#2a2520] select-none">●●●</div>
			<div class="absolute bottom-3 left-4 text-[10px] text-[#2a2520] select-none">---</div>

			<!-- Cat photo: like a polaroid pinned to a board -->
			<div class="mb-8 border-[3px] border-[#3a3530] bg-[#241f1a] p-3 inline-block -rotate-1">
				<img src={cat.image} alt={cat.name} class="w-56 h-56 md:w-72 md:h-72 object-cover grayscale-[25%] opacity-90" />
			</div>

			<!-- Name header -->
			<div class="mb-8 border-b-[3px] border-[#2a2520] pb-8">
				<p class="mb-2 text-[10px] uppercase tracking-[0.5em] text-[#5a4f40]">● {t.cats.catProfile || 'cat profile'}</p>
				<h1 class="text-5xl font-black uppercase leading-[0.85] tracking-tighter text-[#f5f0e8] md:text-7xl lg:text-8xl" style="text-shadow: 3px 3px 0 #2a2520;">{cat.name}</h1>
				<div class="mt-3 h-1 w-24 bg-[#8b4513]"></div>
				<span class={`mt-4 inline-block border-[3px] px-3 py-1 text-[10px] font-black uppercase tracking-[0.3em] ${cat.status === 'adopted' ? 'border-[#3a5530] text-[#5a8050] line-through decoration-2' : 'border-[#8b4513] text-[#c87941]'}`}>{cat.status}</span>
			</div>

			<!-- Data grid: scratched-in details -->
			<dl class="mb-10 grid grid-cols-2 gap-4 md:grid-cols-3 md:gap-6">
				<div class="border-l-[3px] border-[#3a3530] pl-4">
					<dt class="text-[9px] uppercase tracking-[0.3em] text-[#4a4030]">{t.cats.breed}</dt>
					<dd class="mt-1 text-sm text-[#b8b0a0]">{cat.breed}</dd>
				</div>
				<div class="border-l-[3px] border-[#4a3520] pl-4">
					<dt class="text-[9px] uppercase tracking-[0.3em] text-[#4a4030]">{t.cats.age}</dt>
					<dd class="mt-1 text-sm text-[#b8b0a0]">{cat.age}</dd>
				</div>
				<div class="border-l-[3px] border-[#3a3530] pl-4">
					<dt class="text-[9px] uppercase tracking-[0.3em] text-[#4a4030]">{t.cats.gender}</dt>
					<dd class="mt-1 text-sm text-[#b8b0a0]">{cat.gender}</dd>
				</div>
				<div class="border-l-[3px] border-[#4a3520] pl-4">
					<dt class="text-[9px] uppercase tracking-[0.3em] text-[#4a4030]">{t.cats.color}</dt>
					<dd class="mt-1 text-sm text-[#b8b0a0]">{cat.color}</dd>
				</div>
				<div class="border-l-[3px] border-[#3a3530] pl-4">
					<dt class="text-[9px] uppercase tracking-[0.3em] text-[#4a4030]">{t.cats.arrived}</dt>
					<dd class="mt-1 text-sm text-[#b8b0a0]">{cat.arrivalDate}</dd>
				</div>
				<div class="border-l-[3px] border-[#4a3520] pl-4">
					<dt class="text-[9px] uppercase tracking-[0.3em] text-[#4a4030]">{t.cats.status}</dt>
					<dd class="mt-1 text-sm text-[#b8b0a0]">{cat.status}</dd>
				</div>
			</dl>

			<!-- Personality: ink stamps -->
			<div class="mb-10">
				<p class="mb-3 text-[9px] uppercase tracking-[0.3em] text-[#4a4030]">// {t.cats.personality || 'traits'}</p>
				<div class="flex flex-wrap gap-2">
					{cat.personality.map((trait: string, i: number) => (
						<span class={`border-[2px] px-3 py-1 text-[10px] font-bold uppercase tracking-[0.2em] ${i % 2 === 0 ? 'border-[#4a3520] text-[#9a8060] bg-[#241f1a]' : 'border-[#3a3530] text-[#8a7060] bg-[#1f1c18]'}`}>✗ {trait}</span>
					))}
				</div>
			</div>

			<!-- Description: written on the wall -->
			<div class="mb-10 border-l-[5px] border-[#8b4513] bg-[#241f1a]/50 p-6 md:p-8">
				<p class="text-sm leading-loose text-[#9a9080] md:text-base">{cat.description}</p>
			</div>

			<!-- CTA -->
			<div class="flex flex-wrap items-center gap-4">
				<a href={`/${lang}/${style}/auth`} class="border-[3px] border-[#f5f0e8] bg-[#f5f0e8] px-8 py-3 text-xs font-black uppercase tracking-[0.2em] text-[#1a1714] hover:bg-transparent hover:text-[#f5f0e8] transition-all duration-200">{t.cats.adopt} {cat.name}</a>
				<span class="text-[10px] uppercase tracking-widest text-[#3a3530]">&larr; ✘</span>
			</div>
		</article>

		<!-- Other cats: small flyer stubs -->
		<section class="mt-16 border-t-[3px] border-[#2a2520] pt-10">
			<h2 class="mb-8 text-[10px] uppercase tracking-[0.4em] text-[#5a4f40]">// {t.cats.otherCats} <span class="ml-2 text-[#3a3530]">---</span></h2>
			<div class="grid gap-3 md:grid-cols-3">
				{otherCats.map((c: any, i: number) => (
					<a href={`/${lang}/${style}/cats/${c.id}`}
						class={`group block border-[3px] ${i % 2 === 0 ? 'border-[#3a3530]' : 'border-[#4a3520]'} p-4 transition-all duration-200 hover:border-[#8b4513] hover:bg-[#241f1a]`}>
						<h3 class="text-xl font-black uppercase tracking-tighter text-[#c8c0b0] group-hover:text-[#c87941] transition-colors">{c.name}</h3>
						<p class="mt-1 text-[10px] uppercase tracking-[0.15em] text-[#5a4f40]">{c.breed} // {c.age}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
