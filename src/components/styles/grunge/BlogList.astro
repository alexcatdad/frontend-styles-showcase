---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-stone-900 text-stone-300 font-mono">
	<nav class="border-b-4 border-stone-700 bg-stone-950 px-4 py-3 md:px-8">
		<div class="mx-auto flex max-w-5xl flex-wrap items-center gap-1">
			{nav.map((item: any, i: number) => (
				<>
					{i > 0 && <span class="text-stone-600 select-none">|</span>}
					<a href={item.href} class="px-2 py-1 text-sm uppercase tracking-widest text-stone-400 hover:text-amber-200 hover:line-through transition-colors">{item.label}</a>
				</>
			))}
		</div>
	</nav>

	<main class="mx-auto max-w-5xl px-4 py-12 md:px-8 md:py-16">
		<div class="mb-10 border-b-2 border-stone-700 pb-8">
			<p class="mb-1 text-xs uppercase tracking-[0.3em] text-stone-600">▪ ▪ ▪</p>
			<h1 class="text-4xl font-black uppercase tracking-tight text-stone-100 md:text-6xl">{t.blog.title}</h1>
			<p class="mt-3 text-stone-500">{t.blog.subtitle}</p>
		</div>

		<div class="space-y-4">
			{posts.map((post: any) => (
				<a href={`/${lang}/${style}/blog/${post.slug}`} class="group block border-2 border-stone-700 bg-stone-800/30 p-5 md:p-6 transition-colors hover:border-amber-800 hover:bg-stone-800/60">
					<article>
						<div class="mb-2 flex flex-wrap items-center gap-3">
							<time datetime={post.date} class="text-[10px] uppercase tracking-widest text-stone-600">{post.date}</time>
							<span class="text-stone-700">|</span>
							<span class="text-[10px] uppercase tracking-widest text-stone-600">{t.blog.by} {post.author}</span>
						</div>
						<h2 class="mb-2 text-xl font-black uppercase tracking-tight text-stone-100 group-hover:text-amber-400 transition-colors md:text-2xl">{post.title}</h2>
						<p class="mb-4 text-sm leading-relaxed text-stone-400">{post.excerpt}</p>
						<div class="flex flex-wrap gap-1.5">
							{post.tags.map((tag: string) => (
								<span class="bg-stone-700/50 px-2 py-0.5 text-[10px] uppercase tracking-widest text-stone-500">#{tag}</span>
							))}
						</div>
					</article>
				</a>
			))}
		</div>
	</main>
</div>
