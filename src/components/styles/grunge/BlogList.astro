---
const { lang, style, nav, posts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-[#1a1714] text-[#c8c0b0] font-mono selection:bg-amber-900/60 selection:text-amber-200">
	<nav class="border-b-[3px] border-[#3a3530] bg-[#0f0d0b] px-4 py-3 md:px-8">
		<div class="mx-auto flex max-w-6xl flex-wrap items-center gap-0.5">
			<span class="mr-3 text-[10px] uppercase tracking-widest text-[#5a4f40] select-none">///</span>
			{nav.map((item: any, i: number) => (
				<>
					{i > 0 && <span class="text-[#3a3530] select-none px-1">|</span>}
					<a href={item.href} class="px-2 py-1 text-xs uppercase tracking-[0.2em] text-[#7a7060] hover:text-[#f5f0e8] hover:line-through decoration-[#8b4513] decoration-2 transition-colors">{item.label}</a>
				</>
			))}
		</div>
	</nav>

	<main class="mx-auto max-w-5xl px-4 py-12 md:px-8 md:py-20">
		<!-- Header -->
		<div class="relative mb-14 pb-8">
			<p class="mb-2 text-[10px] uppercase tracking-[0.5em] text-[#5a4f40]">▪ ▪ ▪</p>
			<h1 class="text-5xl font-black uppercase leading-[0.85] tracking-tighter text-[#f5f0e8] md:text-7xl" style="text-shadow: 3px 3px 0 #2a2520;">{t.blog.title}</h1>
			<div class="mt-3 h-1 w-20 bg-[#8b4513]"></div>
			<p class="mt-4 max-w-lg text-sm text-[#7a7060]">{t.blog.subtitle}</p>
			<div class="mt-6 w-full border-t-[3px] border-dashed border-[#2a2520]"></div>
		</div>

		<!-- Posts: like torn-out journal pages pinned to a board -->
		<div class="space-y-5">
			{posts.map((post: any, i: number) => (
				<a href={`${_base}/${lang}/${style}/blog/${post.slug}`}
					class={`group relative block border-[3px] ${i % 3 === 0 ? 'border-[#3a3530]' : i % 3 === 1 ? 'border-[#4a3520]' : 'border-[#3a4530]'} bg-[#1f1c18] p-5 md:p-7 transition-all duration-200 hover:border-[#8b4513] hover:bg-[#241f1a]`}>

					<!-- Post number -->
					<div class="absolute top-3 right-4 text-[8px] uppercase tracking-widest text-[#2a2520] select-none">entry #{String(i + 1).padStart(2, '0')}</div>

					<article>
						<!-- Post image -->
						<img src={post.image} alt={post.title} class="w-full h-36 md:h-48 object-cover border-[2px] border-[#2a2520] mb-4 grayscale-[20%] opacity-90" />

						<!-- Meta line -->
						<div class="mb-3 flex flex-wrap items-center gap-2 text-[10px] uppercase tracking-[0.2em] text-[#5a4f40]">
							<time datetime={post.date} class="border-[2px] border-[#2a2520] px-2 py-0.5">{post.date}</time>
							<span class="text-[#3a3530]">|</span>
							<span>{t.blog.by} <span class="text-[#7a7060]">{post.author}</span></span>
						</div>

						<!-- Title -->
						<h2 class="mb-3 text-xl font-black uppercase leading-tight tracking-tighter text-[#f5f0e8] group-hover:text-[#c87941] transition-colors md:text-2xl">{post.title}</h2>

						<!-- Excerpt -->
						<p class="mb-5 max-w-2xl text-sm leading-relaxed text-[#7a7060]">{post.excerpt}</p>

						<!-- Tags: ink stamps -->
						<div class="flex flex-wrap gap-1.5">
							{post.tags.map((tag: string) => (
								<span class="bg-[#2a2520] px-2 py-0.5 text-[9px] uppercase tracking-[0.2em] text-[#5a4f40]">#{tag}</span>
							))}
						</div>

						<!-- Bottom divider accent -->
						<div class="mt-4 flex items-center gap-3">
							<div class="h-px flex-1 bg-[#2a2520]"></div>
							<span class="text-[9px] text-[#2a2520] select-none">✗</span>
						</div>
					</article>
				</a>
			))}
		</div>
	</main>
</div>
