---
const { lang, style, nav, cats, t } = Astro.props;
const rotations = [
	"-rotate-1",
	"rotate-0.5",
	"-rotate-0.5",
	"rotate-1",
	"rotate-0",
	"-rotate-1",
	"rotate-0.5",
	"-rotate-0.5",
];
const borderColors = [
	"border-[#4a3520]",
	"border-[#3a3530]",
	"border-[#5a4030]",
	"border-[#3a3530]",
	"border-[#4a3520]",
	"border-[#3a4530]",
	"border-[#5a3520]",
	"border-[#3a3530]",
];
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-[#1a1714] text-[#c8c0b0] font-mono selection:bg-amber-900/60 selection:text-amber-200">
	<nav class="border-b-[3px] border-[#3a3530] bg-[#0f0d0b] px-4 py-3 md:px-8">
		<div class="mx-auto flex max-w-6xl flex-wrap items-center gap-0.5">
			<span class="mr-3 text-[10px] uppercase tracking-widest text-[#5a4f40] select-none">///</span>
			{nav.map((item: any, i: number) => (
				<>
					{i > 0 && <span class="text-[#3a3530] select-none px-1">|</span>}
					<a href={item.href} class="px-2 py-1 text-xs uppercase tracking-[0.2em] text-[#7a7060] hover:text-[#f5f0e8] hover:line-through decoration-[#8b4513] decoration-2 transition-colors">{item.label}</a>
				</>
			))}
		</div>
	</nav>

	<main class="mx-auto max-w-6xl px-4 py-12 md:px-8 md:py-20">
		<!-- Header: like a hand-stamped zine cover -->
		<div class="relative mb-14 pb-8">
			<div class="absolute top-0 right-0 text-[10px] uppercase tracking-widest text-[#3a3530] select-none">[{cats.length} {t.cats.total || 'total'}]</div>
			<p class="mb-2 text-[10px] uppercase tracking-[0.5em] text-[#5a4f40]">✘ ✘ ✘</p>
			<h1 class="text-5xl font-black uppercase leading-[0.85] tracking-tighter text-[#f5f0e8] md:text-7xl" style="text-shadow: 3px 3px 0 #2a2520;">{t.cats.title}</h1>
			<div class="mt-3 h-1 w-20 bg-[#8b4513]"></div>
			<p class="mt-4 max-w-lg text-sm text-[#7a7060]">{t.cats.subtitle}</p>
			<div class="mt-6 w-full border-t-[3px] border-dashed border-[#2a2520]"></div>
		</div>

		<!-- Cat cards: like wanted posters / underground show flyers -->
		<div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
			{cats.map((cat: any, i: number) => (
				<a href={`${_base}/${lang}/${style}/cats/${cat.id}`}
					class={`group relative block border-[3px] ${borderColors[i % borderColors.length]} bg-[#1f1c18] p-5 md:p-6 transition-all duration-200 hover:bg-[#241f1a] hover:border-[#8b4513] hover:-translate-y-0.5 ${rotations[i % rotations.length]}`}>
					<!-- Poster number stamp -->
					<div class="absolute top-3 right-3 text-[8px] uppercase tracking-widest text-[#2a2520] select-none">no.{String(i + 1).padStart(2, '0')}</div>

					<!-- Cat thumbnail -->
					<img src={cat.thumbnail} alt={cat.name} class="w-full h-36 md:h-44 object-cover border-[2px] border-[#3a3530] mb-4 grayscale-[20%] opacity-90" />

					<!-- Name + Status -->
					<div class="mb-4">
						<h2 class="text-2xl font-black uppercase leading-tight tracking-tighter text-[#f5f0e8] group-hover:text-[#c87941] transition-colors md:text-3xl">{cat.name}</h2>
						<span class={`mt-1 inline-block border-[2px] px-2 py-0.5 text-[9px] font-bold uppercase tracking-[0.2em] ${cat.status === 'adopted' ? 'border-[#3a5530] text-[#5a8050] line-through decoration-2' : 'border-[#8b4513] text-[#c87941]'}`}>{cat.status}</span>
					</div>

					<!-- Details line -->
					<p class="mb-3 text-[10px] uppercase tracking-[0.15em] text-[#5a4f40]">{cat.breed} // {cat.age} // {cat.gender}</p>

					<!-- Divider -->
					<div class="mb-3 border-t border-dashed border-[#2a2520]"></div>

					<!-- Description snippet -->
					<p class="mb-4 text-xs leading-relaxed text-[#7a7060]">{cat.description.slice(0, 120)}...</p>

					<!-- Personality tags: like ink stamps -->
					<div class="flex flex-wrap gap-1.5">
						{cat.personality.slice(0, 4).map((trait: string) => (
							<span class="bg-[#2a2520] px-2 py-0.5 text-[9px] uppercase tracking-[0.2em] text-[#6a6050]">✗ {trait}</span>
						))}
					</div>

					<!-- Bottom mark -->
					<div class="mt-4 text-right text-[10px] text-[#2a2520] select-none">---</div>
				</a>
			))}
		</div>
	</main>
</div>
