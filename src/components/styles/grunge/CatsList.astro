---
const { lang, style, nav, cats, t } = Astro.props;
---

<div class="min-h-screen bg-stone-900 text-stone-300 font-mono">
	<nav class="border-b-4 border-stone-700 bg-stone-950 px-4 py-3 md:px-8">
		<div class="mx-auto flex max-w-5xl flex-wrap items-center gap-1">
			{nav.map((item: any, i: number) => (
				<>
					{i > 0 && <span class="text-stone-600 select-none">|</span>}
					<a href={item.href} class="px-2 py-1 text-sm uppercase tracking-widest text-stone-400 hover:text-amber-200 hover:line-through transition-colors">{item.label}</a>
				</>
			))}
		</div>
	</nav>

	<main class="mx-auto max-w-5xl px-4 py-12 md:px-8 md:py-16">
		<div class="mb-10 border-b-2 border-stone-700 pb-8">
			<p class="mb-1 text-xs uppercase tracking-[0.3em] text-stone-600">✘ ✘ ✘</p>
			<h1 class="text-4xl font-black uppercase tracking-tight text-stone-100 md:text-6xl">{t.cats.title}</h1>
			<p class="mt-3 text-stone-500">{t.cats.subtitle}</p>
		</div>

		<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
			{cats.map((cat: any) => (
				<a href={`/${lang}/${style}/cats/${cat.id}`} class="group block border-2 border-stone-700 bg-stone-800/40 p-5 transition-colors hover:border-amber-800 hover:bg-stone-800">
					<div class="mb-3 flex items-start justify-between">
						<h2 class="text-xl font-black uppercase tracking-tight text-stone-100 group-hover:text-amber-400 transition-colors">{cat.name}</h2>
						<span class="mt-1 border border-stone-600 px-2 py-0.5 text-[10px] uppercase tracking-widest text-stone-500">{cat.status}</span>
					</div>
					<p class="mb-3 text-xs uppercase tracking-wider text-stone-500">{cat.breed} · {cat.age} · {cat.gender}</p>
					<p class="mb-4 text-sm leading-relaxed text-stone-400">{cat.description.slice(0, 100)}...</p>
					<div class="flex flex-wrap gap-1.5">
						{cat.personality.map((trait: string) => (
							<span class="bg-stone-700/60 px-2 py-0.5 text-[10px] uppercase tracking-widest text-stone-400">▪ {trait}</span>
						))}
					</div>
				</a>
			))}
		</div>
	</main>
</div>
