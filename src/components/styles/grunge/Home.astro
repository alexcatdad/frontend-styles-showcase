---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-[#1a1714] text-[#c8c0b0] font-mono selection:bg-amber-900/60 selection:text-amber-200">
	<nav class="border-b-[3px] border-[#3a3530] bg-[#0f0d0b] px-4 py-3 md:px-8">
		<div class="mx-auto flex max-w-6xl flex-wrap items-center gap-0.5">
			<span class="mr-3 text-[10px] uppercase tracking-widest text-[#5a4f40] select-none">///</span>
			{nav.map((item: any, i: number) => (
				<>
					{i > 0 && <span class="text-[#3a3530] select-none px-1">|</span>}
					<a href={item.href} class="px-2 py-1 text-xs uppercase tracking-[0.2em] text-[#7a7060] hover:text-[#f5f0e8] hover:line-through decoration-[#8b4513] decoration-2 transition-colors">{item.label}</a>
				</>
			))}
		</div>
	</nav>

	<main class="mx-auto max-w-6xl px-4 md:px-8">
		<!-- HERO: like a wheat-pasted poster peeling off a wall -->
		<section class="relative py-16 md:py-28">
			<div class="absolute top-8 right-4 text-[10px] text-[#3a3530] uppercase tracking-widest select-none rotate-3 md:right-12">est. 2026</div>
			<div class="absolute bottom-12 left-0 w-24 border-t-[3px] border-dashed border-[#4a3f30] md:w-40"></div>

			<img src={sanctuary.heroImage} alt={sanctuary.name} class="mb-6 w-full max-h-[350px] md:max-h-[500px] object-cover border-[3px] border-[#3a3530] opacity-90 grayscale-[30%]" />
			<p class="mb-4 text-[10px] uppercase tracking-[0.5em] text-[#5a4f40]">▪ ▪ ▪ {t.home.welcomeTo || ''}</p>
			<h1 class="mb-2 text-5xl font-black uppercase leading-[0.85] tracking-tighter text-[#f5f0e8] md:text-8xl lg:text-9xl" style="text-shadow: 3px 3px 0 #2a2520, -1px -1px 0 #0a0908;">{sanctuary.name}</h1>
			<div class="mb-6 h-1 w-32 bg-[#8b4513] md:w-48"></div>
			<p class="mb-10 max-w-xl text-base leading-relaxed text-[#9a9080] md:text-lg"><span class="text-[#8b4513] mr-2 font-bold">//</span>{sanctuary.tagline}</p>

			<div class="flex flex-wrap gap-3">
				<a href={`${_base}/${lang}/${style}/cats`} class="border-[3px] border-[#f5f0e8] bg-[#f5f0e8] px-7 py-3 text-xs font-black uppercase tracking-[0.2em] text-[#1a1714] hover:bg-transparent hover:text-[#f5f0e8] transition-all duration-200">{t.home.meetCats}</a>
				<a href={`${_base}/${lang}/${style}/donate`} class="border-[3px] border-[#8b4513] px-7 py-3 text-xs font-black uppercase tracking-[0.2em] text-[#c87941] hover:bg-[#8b4513] hover:text-[#f5f0e8] transition-all duration-200">✗ {t.home.donate}</a>
			</div>
		</section>

		<!-- MISSION: scrawled on the wall -->
		<section class="relative border-t-[3px] border-[#2a2520] py-12 md:py-20">
			<div class="absolute -top-4 left-6 bg-[#1a1714] px-3 text-[10px] uppercase tracking-[0.4em] text-[#5a4f40]">// {t.home.mission}</div>

			<div class="mt-4 border-l-[5px] border-[#8b4513] pl-6 md:pl-10">
				<p class="text-xl leading-relaxed text-[#b8b0a0] md:text-2xl" style="font-style: italic;">{sanctuary.mission}</p>
			</div>
			<div class="mt-6 text-right text-[10px] uppercase tracking-widest text-[#3a3530] select-none">--- ✘ ---</div>
		</section>

		<!-- STATS: scratched into the surface like tally marks -->
		<section class="border-t-[3px] border-[#2a2520] py-12 md:py-16">
			<div class="grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-4">
				{sanctuary.stats.map((stat: any, i: number) => (
					<div class={`relative p-5 md:p-6 ${i % 2 === 0 ? 'border-[3px] border-[#3a3530] bg-[#1f1c18]' : 'border-[3px] border-[#4a3520] bg-[#241f1a]'} ${i === 0 ? '-rotate-1' : i === 1 ? 'rotate-0.5' : i === 2 ? 'rotate-1' : '-rotate-0.5'}`}>
						<span class="block text-4xl font-black text-[#c87941] md:text-5xl" style="text-shadow: 2px 2px 0 #1a1714;">{stat.value}</span>
						<span class="mt-2 block text-[10px] uppercase tracking-[0.3em] text-[#5a4f40]">▪ {stat.label}</span>
						<div class="absolute top-2 right-3 text-[8px] text-[#2a2520] select-none">#{String(i + 1).padStart(2, '0')}</div>
					</div>
				))}
			</div>
		</section>

		<!-- ABOUT: torn journal pages -->
		<section class="border-t-[3px] border-[#2a2520] py-12 md:py-20">
			<h2 class="mb-8 text-[10px] uppercase tracking-[0.4em] text-[#5a4f40]">// {t.home.aboutUs} <span class="ml-2 line-through decoration-[#8b4513]">read more</span></h2>
			<div class="space-y-6">
				{sanctuary.about.map((paragraph: string, i: number) => (
					<div class={`relative max-w-3xl ${i % 2 === 0 ? 'ml-0 border-l-[3px] border-[#3a3530] pl-5' : 'ml-4 md:ml-12 border-l-[3px] border-[#4a3520] pl-5'}`}>
						<p class="text-sm leading-loose text-[#8a8070] md:text-base">{paragraph}</p>
					</div>
				))}
			</div>
		</section>

		<!-- CONTACT STRIP -->
		<section class="border-t-[3px] border-[#2a2520] py-10">
			<div class="flex flex-wrap items-center gap-4 text-xs uppercase tracking-widest text-[#5a4f40]">
				<span class="text-[#8b4513]">✘</span>
				<span>{sanctuary.contact?.email || ''}</span>
				<span class="text-[#3a3530]">|</span>
				<span>{sanctuary.contact?.phone || ''}</span>
				<span class="text-[#3a3530]">|</span>
				<span>{sanctuary.contact?.address || ''}</span>
			</div>
		</section>
	</main>

	<footer class="border-t-[5px] border-[#2a2520] bg-[#0f0d0b] px-4 py-6 md:px-8">
		<div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4">
			<p class="text-[10px] uppercase tracking-[0.3em] text-[#3a3530]">&copy; 2026 {sanctuary.name}</p>
			<p class="text-[10px] uppercase tracking-[0.3em] text-[#3a3530]">{t.footer.style}: <span class="text-[#5a4f40]">{meta.name}</span> ✗</p>
		</div>
	</footer>
</div>
