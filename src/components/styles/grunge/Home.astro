---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-stone-900 text-stone-300 font-mono">
	<nav class="border-b-4 border-stone-700 bg-stone-950 px-4 py-3 md:px-8">
		<div class="mx-auto flex max-w-5xl flex-wrap items-center gap-1">
			{nav.map((item: any, i: number) => (
				<>
					{i > 0 && <span class="text-stone-600 select-none">|</span>}
					<a href={item.href} class="px-2 py-1 text-sm uppercase tracking-widest text-stone-400 hover:text-amber-200 hover:line-through transition-colors">{item.label}</a>
				</>
			))}
		</div>
	</nav>

	<main class="mx-auto max-w-5xl px-4 md:px-8">
		<section class="border-b-2 border-stone-700 py-16 md:py-24">
			<p class="mb-2 text-xs uppercase tracking-[0.3em] text-stone-500">▪ ▪ ▪</p>
			<h1 class="mb-4 text-5xl font-black uppercase tracking-tight text-stone-100 md:text-7xl lg:text-8xl">{sanctuary.name}</h1>
			<p class="mb-8 max-w-2xl text-lg text-stone-400 md:text-xl">{sanctuary.tagline}</p>
			<div class="flex flex-wrap gap-4">
				<a href={`/${lang}/${style}/cats`} class="border-2 border-stone-300 bg-stone-300 px-6 py-3 text-sm font-bold uppercase tracking-widest text-stone-900 hover:bg-transparent hover:text-stone-300 transition-colors">{t.home.meetCats}</a>
				<a href={`/${lang}/${style}/donate`} class="border-2 border-amber-700 px-6 py-3 text-sm font-bold uppercase tracking-widest text-amber-600 hover:bg-amber-700 hover:text-stone-100 transition-colors">{t.home.donate}</a>
			</div>
		</section>

		<section class="border-b-2 border-stone-700 py-12 md:py-16">
			<h2 class="mb-1 text-xs uppercase tracking-[0.3em] text-stone-500">// {t.home.mission}</h2>
			<div class="mt-4 border-l-4 border-amber-800 pl-6">
				<p class="text-lg leading-relaxed text-stone-300 md:text-xl">{sanctuary.mission}</p>
			</div>
		</section>

		<section class="border-b-2 border-stone-700 py-12 md:py-16">
			<div class="grid grid-cols-2 gap-4 md:grid-cols-4 md:gap-6">
				{sanctuary.stats.map((stat: any) => (
					<div class="border-2 border-stone-700 bg-stone-800/50 p-4 md:p-6 text-center">
						<span class="block text-3xl font-black text-amber-500 md:text-4xl">{stat.value}</span>
						<span class="mt-1 block text-xs uppercase tracking-widest text-stone-500">{stat.label}</span>
					</div>
				))}
			</div>
		</section>

		<section class="py-12 md:py-16">
			<h2 class="mb-6 text-xs uppercase tracking-[0.3em] text-stone-500">// {t.home.aboutUs}</h2>
			<div class="space-y-4">
				{sanctuary.about.map((paragraph: string) => (
					<p class="max-w-3xl leading-relaxed text-stone-400">{paragraph}</p>
				))}
			</div>
		</section>
	</main>

	<footer class="border-t-4 border-stone-700 bg-stone-950 px-4 py-6 md:px-8">
		<div class="mx-auto max-w-5xl">
			<p class="text-xs uppercase tracking-widest text-stone-600">&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}. ✗</p>
		</div>
	</footer>
</div>
