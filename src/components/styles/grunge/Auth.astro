---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-[#1a1714] text-[#c8c0b0] font-mono selection:bg-amber-900/60 selection:text-amber-200">
	<nav class="border-b-[3px] border-[#3a3530] bg-[#0f0d0b] px-4 py-3 md:px-8">
		<div class="mx-auto flex max-w-6xl flex-wrap items-center gap-0.5">
			<span class="mr-3 text-[10px] uppercase tracking-widest text-[#5a4f40] select-none">///</span>
			{nav.map((item: any, i: number) => (
				<>
					{i > 0 && <span class="text-[#3a3530] select-none px-1">|</span>}
					<a href={item.href} class="px-2 py-1 text-xs uppercase tracking-[0.2em] text-[#7a7060] hover:text-[#f5f0e8] hover:line-through decoration-[#8b4513] decoration-2 transition-colors">{item.label}</a>
				</>
			))}
		</div>
	</nav>

	<main class="flex min-h-[80vh] items-center justify-center px-4 py-12 md:px-8">
		<!-- Auth card: like a backstage pass / underground club entry form -->
		<section class="relative w-full max-w-md border-[3px] border-[#3a3530] bg-[#1f1c18] p-6 md:p-10">
			<!-- Corner marks -->
			<div class="absolute top-3 right-4 text-[10px] text-[#2a2520] select-none">●●●</div>
			<div class="absolute bottom-3 left-4 text-[10px] text-[#2a2520] select-none">---</div>

			<!-- Header -->
			<div class="mb-8 border-b-[3px] border-dashed border-[#2a2520] pb-6">
				<p class="mb-2 text-[10px] uppercase tracking-[0.5em] text-[#5a4f40]">● {t.auth.access || 'access'}</p>
				<h1 class="text-3xl font-black uppercase tracking-tighter text-[#f5f0e8] md:text-4xl" style="text-shadow: 2px 2px 0 #2a2520;">{t.auth.title}</h1>
				<div class="mt-2 h-1 w-12 bg-[#8b4513]"></div>
				<p class="mt-3 text-xs text-[#5a4f40]">{t.auth.subtitle}</p>
			</div>

			<!-- Form -->
			<form class="space-y-5">
				<div>
					<label for="email" class="mb-2 block text-[9px] uppercase tracking-[0.3em] text-[#5a4f40]">// {t.auth.email}</label>
					<input type="email" id="email" name="email" placeholder="you@example.com"
						class="w-full border-[3px] border-[#3a3530] bg-[#1a1714] px-4 py-3 text-sm text-[#c8c0b0] placeholder-[#3a3530] focus:border-[#8b4513] focus:outline-none transition-colors" />
				</div>
				<div>
					<label for="password" class="mb-2 block text-[9px] uppercase tracking-[0.3em] text-[#5a4f40]">// {t.auth.password}</label>
					<input type="password" id="password" name="password" placeholder="••••••••"
						class="w-full border-[3px] border-[#3a3530] bg-[#1a1714] px-4 py-3 text-sm text-[#c8c0b0] placeholder-[#3a3530] focus:border-[#8b4513] focus:outline-none transition-colors" />
				</div>

				<div class="flex items-center justify-between">
					<label class="flex items-center gap-2 text-[10px] uppercase tracking-[0.15em] text-[#5a4f40] cursor-pointer">
						<input type="checkbox" name="remember" class="size-4 accent-[#8b4513] border-[#3a3530]" />
						{t.auth.rememberMe}
					</label>
					<a href="#" class="text-[10px] uppercase tracking-[0.15em] text-[#5a4f40] hover:text-[#c87941] transition-colors">{t.auth.forgotPassword}</a>
				</div>

				<button type="submit" class="w-full border-[3px] border-[#f5f0e8] bg-[#f5f0e8] py-3 text-xs font-black uppercase tracking-[0.2em] text-[#1a1714] hover:bg-transparent hover:text-[#f5f0e8] transition-all duration-200">✗ {t.auth.signIn}</button>
			</form>

			<!-- Social divider -->
			<div class="mt-8 border-t-[3px] border-dashed border-[#2a2520] pt-6">
				<p class="mb-4 text-center text-[9px] uppercase tracking-[0.3em] text-[#3a3530]">--- {t.auth.continueWith} ---</p>
				<div class="grid grid-cols-2 gap-3">
					<button type="button" class="border-[3px] border-[#3a3530] py-3 text-[10px] font-black uppercase tracking-[0.2em] text-[#7a7060] hover:border-[#8b4513] hover:text-[#c87941] transition-all duration-200">Google</button>
					<button type="button" class="border-[3px] border-[#3a3530] py-3 text-[10px] font-black uppercase tracking-[0.2em] text-[#7a7060] hover:border-[#8b4513] hover:text-[#c87941] transition-all duration-200">Apple</button>
				</div>
			</div>

			<!-- Sign up link -->
			<p class="mt-6 text-center text-[10px] uppercase tracking-[0.15em] text-[#5a4f40]">
				{t.auth.noAccount} <a href="#" class="text-[#b8b0a0] hover:text-[#c87941] hover:line-through decoration-[#8b4513] transition-colors">{t.auth.signUp}</a>
			</p>
		</section>
	</main>
</div>
