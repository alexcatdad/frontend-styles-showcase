---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
---

<div class="min-h-screen bg-[#1a1714] text-[#c8c0b0] font-mono selection:bg-amber-900/60 selection:text-amber-200">
	<nav class="border-b-[3px] border-[#3a3530] bg-[#0f0d0b] px-4 py-3 md:px-8">
		<div class="mx-auto flex max-w-6xl flex-wrap items-center gap-0.5">
			<span class="mr-3 text-[10px] uppercase tracking-widest text-[#5a4f40] select-none">///</span>
			{nav.map((item: any, i: number) => (
				<>
					{i > 0 && <span class="text-[#3a3530] select-none px-1">|</span>}
					<a href={item.href} class="px-2 py-1 text-xs uppercase tracking-[0.2em] text-[#7a7060] hover:text-[#f5f0e8] hover:line-through decoration-[#8b4513] decoration-2 transition-colors">{item.label}</a>
				</>
			))}
		</div>
	</nav>

	<main class="mx-auto max-w-3xl px-4 py-12 md:px-8 md:py-20">
		<a href={`/${lang}/${style}/blog`} class="mb-10 inline-block text-[10px] uppercase tracking-[0.3em] text-[#5a4f40] hover:text-[#c87941] transition-colors">&larr; {t.blog.backToBlog}</a>

		<!-- Article: torn journal page, pinned to the wall -->
		<article class="relative border-[3px] border-[#3a3530] bg-[#1f1c18] p-6 md:p-10 lg:p-12">
			<!-- Corner marks -->
			<div class="absolute top-3 right-4 text-[10px] text-[#2a2520] select-none">●●●</div>

			<!-- Header -->
			<header class="mb-10 border-b-[3px] border-dashed border-[#2a2520] pb-10">
				<!-- Meta -->
				<div class="mb-4 flex flex-wrap items-center gap-2 text-[10px] uppercase tracking-[0.2em] text-[#5a4f40]">
					<time datetime={post.date} class="border-[2px] border-[#2a2520] px-2 py-0.5">{post.date}</time>
					<span class="text-[#3a3530]">|</span>
					<span>{t.blog.by} <span class="text-[#7a7060]">{post.author}</span></span>
				</div>

				<!-- Title -->
				<h1 class="mb-4 text-3xl font-black uppercase leading-[0.9] tracking-tighter text-[#f5f0e8] md:text-5xl" style="text-shadow: 2px 2px 0 #2a2520;">{post.title}</h1>
				<div class="mb-5 h-1 w-16 bg-[#8b4513]"></div>

				<!-- Tags -->
				<div class="flex flex-wrap gap-1.5">
					{post.tags.map((tag: string) => (
						<span class="bg-[#2a2520] px-2 py-0.5 text-[9px] uppercase tracking-[0.2em] text-[#5a4f40]">#{tag}</span>
					))}
				</div>
			</header>

			<!-- Content: handwritten journal entries -->
			<div class="space-y-6">
				{post.content.map((paragraph: string, i: number) => (
					<div class={`${i === 0 ? 'border-l-[5px] border-[#8b4513] pl-5 md:pl-6' : i % 3 === 0 ? 'border-l-[3px] border-[#3a3530] pl-5 md:pl-6' : 'pl-0'}`}>
						<p class={`leading-loose ${i === 0 ? 'text-base text-[#b8b0a0] md:text-lg' : 'text-sm text-[#8a8070] md:text-base'}`}>{paragraph}</p>
					</div>
				))}
			</div>

			<!-- End mark -->
			<div class="mt-10 flex items-center gap-4">
				<div class="h-px flex-1 bg-[#2a2520]"></div>
				<span class="text-[10px] uppercase tracking-widest text-[#3a3530]">✘ end ✘</span>
				<div class="h-px flex-1 bg-[#2a2520]"></div>
			</div>
		</article>

		<!-- More stories -->
		<section class="mt-16 border-t-[3px] border-[#2a2520] pt-10">
			<h2 class="mb-8 text-[10px] uppercase tracking-[0.4em] text-[#5a4f40]">// {t.blog.moreStories} <span class="ml-2 text-[#3a3530]">---</span></h2>
			<div class="grid gap-3 md:grid-cols-2">
				{otherPosts.map((p: any, i: number) => (
					<a href={`/${lang}/${style}/blog/${p.slug}`}
						class={`group block border-[3px] ${i % 2 === 0 ? 'border-[#3a3530]' : 'border-[#4a3520]'} p-4 md:p-5 transition-all duration-200 hover:border-[#8b4513] hover:bg-[#241f1a]`}>
						<h3 class="mb-2 text-lg font-black uppercase tracking-tighter text-[#c8c0b0] group-hover:text-[#c87941] transition-colors">{p.title}</h3>
						<p class="text-xs leading-relaxed text-[#5a4f40]">{p.excerpt}</p>
						<div class="mt-3 text-[9px] text-[#2a2520] select-none">✗ ---</div>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
