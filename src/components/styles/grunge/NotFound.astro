---
const { lang, style, nav, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-[#1a1714] text-[#c8c0b0] font-mono selection:bg-amber-900/60 selection:text-amber-200">
	<nav class="border-b-[3px] border-[#3a3530] bg-[#0f0d0b] px-4 py-3 md:px-8">
		<div class="mx-auto flex max-w-6xl flex-wrap items-center gap-0.5">
			<span class="mr-3 text-[10px] uppercase tracking-widest text-[#5a4f40] select-none">///</span>
			{nav.map((item: any, i: number) => (
				<>
					{i > 0 && <span class="text-[#3a3530] select-none px-1">|</span>}
					<a href={item.href} class="px-2 py-1 text-xs uppercase tracking-[0.2em] text-[#7a7060] hover:text-[#f5f0e8] hover:line-through decoration-[#8b4513] decoration-2 transition-colors">{item.label}</a>
				</>
			))}
		</div>
	</nav>

	<main class="flex min-h-[80vh] items-center justify-center px-4 py-12 md:px-8">
		<section class="relative text-center">
			<!-- Background scratched number -->
			<div class="relative">
				<p class="mb-4 text-[10px] uppercase tracking-[0.5em] text-[#3a3530]">✗ ✗ ✗</p>
				<h1 class="text-[8rem] font-black uppercase leading-none tracking-tighter text-[#2a2520] md:text-[14rem]" style="text-shadow: 3px 3px 0 #1f1c18;">{t.notFound.title}</h1>
				<!-- Overlay text -->
				<div class="absolute inset-0 flex items-center justify-center">
					<div class="border-[3px] border-[#8b4513] bg-[#1a1714]/90 px-6 py-3 md:px-10 md:py-4">
						<h2 class="text-xl font-black uppercase tracking-tighter text-[#f5f0e8] md:text-3xl">{t.notFound.heading}</h2>
					</div>
				</div>
			</div>

			<p class="mx-auto mt-8 max-w-md text-sm leading-relaxed text-[#5a4f40]">{t.notFound.description}</p>

			<!-- Action buttons -->
			<div class="mt-10 flex flex-wrap items-center justify-center gap-4">
				<a href={`${_base}/${lang}/${style}/`} class="border-[3px] border-[#f5f0e8] bg-[#f5f0e8] px-7 py-3 text-xs font-black uppercase tracking-[0.2em] text-[#1a1714] hover:bg-transparent hover:text-[#f5f0e8] transition-all duration-200">{t.notFound.backHome}</a>
				<a href={`${_base}/${lang}/${style}/cats`} class="border-[3px] border-[#8b4513] px-7 py-3 text-xs font-black uppercase tracking-[0.2em] text-[#c87941] hover:bg-[#8b4513] hover:text-[#f5f0e8] transition-all duration-200">✗ {t.notFound.meetCats}</a>
			</div>

			<!-- Bottom mark -->
			<div class="mt-12 text-[10px] uppercase tracking-widest text-[#2a2520]">--- ✘ {t.notFound.lostInTheVoid || 'lost in the void'} ✘ ---</div>
		</section>
	</main>
</div>
