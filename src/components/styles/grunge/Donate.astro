---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-stone-900 text-stone-300 font-mono">
	<nav class="border-b-4 border-stone-700 bg-stone-950 px-4 py-3 md:px-8">
		<div class="mx-auto flex max-w-5xl flex-wrap items-center gap-1">
			{nav.map((item: any, i: number) => (
				<>
					{i > 0 && <span class="text-stone-600 select-none">|</span>}
					<a href={item.href} class="px-2 py-1 text-sm uppercase tracking-widest text-stone-400 hover:text-amber-200 hover:line-through transition-colors">{item.label}</a>
				</>
			))}
		</div>
	</nav>

	<main class="mx-auto max-w-5xl px-4 py-12 md:px-8 md:py-16">
		<div class="mb-10 border-b-2 border-stone-700 pb-8">
			<p class="mb-1 text-xs uppercase tracking-[0.3em] text-stone-600">✘ ✘ ✘</p>
			<h1 class="text-4xl font-black uppercase tracking-tight text-stone-100 md:text-6xl">{t.donate.title}</h1>
			<p class="mt-3 text-stone-500">{t.donate.subtitle}</p>
		</div>

		<section class="mb-14">
			<h2 class="mb-6 text-xs uppercase tracking-[0.3em] text-stone-500">// {t.donate.monthly}</h2>
			<div class="grid gap-4 md:grid-cols-3">
				{monthlyTiers.map((tier: any) => (
					<div class={`relative border-2 p-5 md:p-6 ${tier.highlighted ? "border-amber-700 bg-stone-800/60" : "border-stone-700 bg-stone-800/30"}`}>
						{tier.highlighted && (
							<span class="absolute -top-3 left-4 bg-amber-700 px-3 py-0.5 text-[10px] font-bold uppercase tracking-widest text-stone-100">{t.donate.mostPopular}</span>
						)}
						<h3 class="mb-1 text-lg font-black uppercase tracking-tight text-stone-100">{tier.name}</h3>
						<p class="mb-3">
							<span class="text-3xl font-black text-amber-500">${tier.amount}</span>
							<span class="text-xs uppercase tracking-widest text-stone-600">{t.donate.perMonth}</span>
						</p>
						<p class="mb-4 text-sm text-stone-400">{tier.description}</p>
						<ul class="mb-6 space-y-1.5">
							{tier.perks.map((perk: string) => (
								<li class="text-sm text-stone-400"><span class="mr-2 text-amber-700">▪</span>{perk}</li>
							))}
						</ul>
						<button type="button" class={`w-full border-2 px-4 py-2.5 text-xs font-bold uppercase tracking-widest transition-colors ${tier.highlighted ? "border-amber-600 bg-amber-700 text-stone-100 hover:bg-amber-800" : "border-stone-500 text-stone-400 hover:border-stone-300 hover:text-stone-200"}`}>{t.donate.choose} {tier.name}</button>
					</div>
				))}
			</div>
		</section>

		<section>
			<h2 class="mb-6 text-xs uppercase tracking-[0.3em] text-stone-500">// {t.donate.oneTime}</h2>
			<div class="grid gap-4 md:grid-cols-3">
				{oneTimeTiers.map((tier: any) => (
					<div class={`relative border-2 p-5 md:p-6 ${tier.highlighted ? "border-amber-700 bg-stone-800/60" : "border-stone-700 bg-stone-800/30"}`}>
						{tier.highlighted && (
							<span class="absolute -top-3 left-4 bg-amber-700 px-3 py-0.5 text-[10px] font-bold uppercase tracking-widest text-stone-100">{t.donate.greatestImpact}</span>
						)}
						<h3 class="mb-1 text-lg font-black uppercase tracking-tight text-stone-100">{tier.name}</h3>
						<p class="mb-3">
							<span class="text-3xl font-black text-amber-500">${tier.amount}</span>
						</p>
						<p class="mb-4 text-sm text-stone-400">{tier.description}</p>
						<ul class="mb-6 space-y-1.5">
							{tier.perks.map((perk: string) => (
								<li class="text-sm text-stone-400"><span class="mr-2 text-amber-700">▪</span>{perk}</li>
							))}
						</ul>
						<button type="button" class={`w-full border-2 px-4 py-2.5 text-xs font-bold uppercase tracking-widest transition-colors ${tier.highlighted ? "border-amber-600 bg-amber-700 text-stone-100 hover:bg-amber-800" : "border-stone-500 text-stone-400 hover:border-stone-300 hover:text-stone-200"}`}>{t.donate.give} ${tier.amount}</button>
					</div>
				))}
			</div>
		</section>
	</main>
</div>
