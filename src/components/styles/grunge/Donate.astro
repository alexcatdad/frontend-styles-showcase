---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-[#1a1714] text-[#c8c0b0] font-mono selection:bg-amber-900/60 selection:text-amber-200">
	<nav class="border-b-[3px] border-[#3a3530] bg-[#0f0d0b] px-4 py-3 md:px-8">
		<div class="mx-auto flex max-w-6xl flex-wrap items-center gap-0.5">
			<span class="mr-3 text-[10px] uppercase tracking-widest text-[#5a4f40] select-none">///</span>
			{nav.map((item: any, i: number) => (
				<>
					{i > 0 && <span class="text-[#3a3530] select-none px-1">|</span>}
					<a href={item.href} class="px-2 py-1 text-xs uppercase tracking-[0.2em] text-[#7a7060] hover:text-[#f5f0e8] hover:line-through decoration-[#8b4513] decoration-2 transition-colors">{item.label}</a>
				</>
			))}
		</div>
	</nav>

	<main class="mx-auto max-w-5xl px-4 py-12 md:px-8 md:py-20">
		<!-- Header -->
		<div class="relative mb-14 pb-8">
			<p class="mb-2 text-[10px] uppercase tracking-[0.5em] text-[#5a4f40]">✘ ✘ ✘</p>
			<h1 class="text-5xl font-black uppercase leading-[0.85] tracking-tighter text-[#f5f0e8] md:text-7xl" style="text-shadow: 3px 3px 0 #2a2520;">{t.donate.title}</h1>
			<div class="mt-3 h-1 w-20 bg-[#8b4513]"></div>
			<p class="mt-4 max-w-lg text-sm text-[#7a7060]">{t.donate.subtitle}</p>
			<div class="mt-6 w-full border-t-[3px] border-dashed border-[#2a2520]"></div>
		</div>

		<!-- Monthly tiers: like underground show ticket stubs -->
		<section class="mb-16">
			<h2 class="mb-8 text-[10px] uppercase tracking-[0.4em] text-[#5a4f40]">// {t.donate.monthly} <span class="ml-2 text-[#3a3530]">---</span></h2>
			<div class="grid gap-4 md:grid-cols-3">
				{monthlyTiers.map((tier: any, i: number) => (
					<div class={`relative border-[3px] p-5 md:p-6 transition-all duration-200 ${tier.highlighted ? 'border-[#8b4513] bg-[#241f1a] -translate-y-1' : i % 2 === 0 ? 'border-[#3a3530] bg-[#1f1c18]' : 'border-[#4a3520] bg-[#1f1c18]'}`}>
						{tier.highlighted && (
							<div class="absolute -top-4 left-4 border-[2px] border-[#8b4513] bg-[#1a1714] px-3 py-0.5 text-[9px] font-black uppercase tracking-[0.2em] text-[#c87941]">✗ {t.donate.mostPopular}</div>
						)}

						<!-- Tier number -->
						<div class="absolute top-3 right-3 text-[8px] text-[#2a2520] select-none">no.{String(i + 1).padStart(2, '0')}</div>

						<h3 class="mb-2 text-lg font-black uppercase tracking-tighter text-[#f5f0e8]">{tier.name}</h3>
						<div class="mb-4">
							<span class="text-4xl font-black text-[#c87941]" style="text-shadow: 2px 2px 0 #1a1714;">${tier.amount}</span>
							<span class="ml-1 text-[10px] uppercase tracking-[0.2em] text-[#4a4030]">{t.donate.perMonth}</span>
						</div>
						<p class="mb-5 text-xs leading-relaxed text-[#7a7060]">{tier.description}</p>

						<!-- Perks list -->
						<ul class="mb-6 space-y-2">
							{tier.perks.map((perk: string) => (
								<li class="flex items-start gap-2 text-xs text-[#8a8070]">
									<span class="mt-0.5 text-[#8b4513] font-bold">▪</span>
									<span>{perk}</span>
								</li>
							))}
						</ul>

						<button type="button" class={`w-full border-[3px] px-4 py-3 text-[10px] font-black uppercase tracking-[0.2em] transition-all duration-200 ${tier.highlighted ? 'border-[#8b4513] bg-[#8b4513] text-[#f5f0e8] hover:bg-transparent hover:text-[#c87941]' : 'border-[#3a3530] text-[#7a7060] hover:border-[#8b4513] hover:text-[#c87941]'}`}>{t.donate.choose} {tier.name}</button>
					</div>
				))}
			</div>
		</section>

		<!-- One-time tiers -->
		<section>
			<h2 class="mb-8 text-[10px] uppercase tracking-[0.4em] text-[#5a4f40]">// {t.donate.oneTime} <span class="ml-2 text-[#3a3530]">---</span></h2>
			<div class="grid gap-4 md:grid-cols-3">
				{oneTimeTiers.map((tier: any, i: number) => (
					<div class={`relative border-[3px] p-5 md:p-6 transition-all duration-200 ${tier.highlighted ? 'border-[#8b4513] bg-[#241f1a] -translate-y-1' : i % 2 === 0 ? 'border-[#3a3530] bg-[#1f1c18]' : 'border-[#4a3520] bg-[#1f1c18]'}`}>
						{tier.highlighted && (
							<div class="absolute -top-4 left-4 border-[2px] border-[#8b4513] bg-[#1a1714] px-3 py-0.5 text-[9px] font-black uppercase tracking-[0.2em] text-[#c87941]">✗ {t.donate.greatestImpact}</div>
						)}

						<div class="absolute top-3 right-3 text-[8px] text-[#2a2520] select-none">no.{String(i + 1).padStart(2, '0')}</div>

						<h3 class="mb-2 text-lg font-black uppercase tracking-tighter text-[#f5f0e8]">{tier.name}</h3>
						<div class="mb-4">
							<span class="text-4xl font-black text-[#c87941]" style="text-shadow: 2px 2px 0 #1a1714;">${tier.amount}</span>
						</div>
						<p class="mb-5 text-xs leading-relaxed text-[#7a7060]">{tier.description}</p>

						<ul class="mb-6 space-y-2">
							{tier.perks.map((perk: string) => (
								<li class="flex items-start gap-2 text-xs text-[#8a8070]">
									<span class="mt-0.5 text-[#8b4513] font-bold">▪</span>
									<span>{perk}</span>
								</li>
							))}
						</ul>

						<button type="button" class={`w-full border-[3px] px-4 py-3 text-[10px] font-black uppercase tracking-[0.2em] transition-all duration-200 ${tier.highlighted ? 'border-[#8b4513] bg-[#8b4513] text-[#f5f0e8] hover:bg-transparent hover:text-[#c87941]' : 'border-[#3a3530] text-[#7a7060] hover:border-[#8b4513] hover:text-[#c87941]'}`}>{t.donate.give} ${tier.amount}</button>
					</div>
				))}
			</div>
		</section>

		<!-- Bottom mark -->
		<div class="mt-16 flex items-center gap-4">
			<div class="h-px flex-1 bg-[#2a2520]"></div>
			<span class="text-[10px] uppercase tracking-widest text-[#3a3530]">✘ ✘ ✘</span>
			<div class="h-px flex-1 bg-[#2a2520]"></div>
		</div>
	</main>
</div>
