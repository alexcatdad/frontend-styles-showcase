---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<main class="bg-white font-sans text-black overflow-x-hidden relative">
	<!-- GEOMETRIC DECORATIONS -->
	<div class="absolute top-12 left-6 w-8 h-8 rounded-full bg-pink-500 opacity-60 pointer-events-none hidden md:block"></div>
	<div class="absolute top-32 right-12 w-12 h-12 bg-yellow-400 rotate-45 opacity-50 pointer-events-none hidden md:block"></div>
	<div class="absolute top-64 left-1/4 w-6 h-6 bg-blue-500 opacity-40 pointer-events-none hidden md:block"></div>
	<div class="absolute top-48 right-1/3 w-0 h-0 border-l-[12px] border-l-transparent border-r-[12px] border-r-transparent border-b-[20px] border-b-green-400 opacity-50 pointer-events-none hidden md:block"></div>
	<div class="absolute top-96 right-8 w-10 h-10 rounded-full bg-red-500 opacity-40 pointer-events-none hidden lg:block"></div>
	<div class="absolute top-[40rem] left-8 w-14 h-14 bg-yellow-400 rotate-12 opacity-30 pointer-events-none hidden lg:block"></div>

	<!-- NAV -->
	<nav class="relative z-20 border-b-4 border-black bg-white px-4 py-4 md:px-8">
		<div class="flex flex-wrap items-center gap-x-6 gap-y-2">
			{nav.map((item: any) => (
				<a href={item.href} class="text-sm md:text-base font-extrabold uppercase tracking-wide text-black hover:text-pink-500 cursor-pointer">{item.label}</a>
			))}
		</div>
	</nav>

	<!-- HERO -->
	<section class="relative px-4 py-12 md:px-8 md:py-20 lg:py-28">
		<div class="flex flex-col lg:flex-row lg:items-center gap-8 lg:gap-16 relative z-10">
			<div class="flex-1">
				<h1 class="text-5xl md:text-7xl lg:text-8xl font-black uppercase leading-none tracking-tight text-black">{sanctuary.name}</h1>
				<p class="text-xl md:text-2xl font-bold text-pink-500 mt-4">{sanctuary.tagline}</p>
				<div class="flex flex-wrap gap-4 mt-8">
					<a href={`${_base}/${lang}/${style}/cats`} class="inline-block bg-yellow-400 border-2 border-black px-6 py-3 font-extrabold uppercase text-sm md:text-base tracking-wide shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-[2px] hover:translate-y-[2px] cursor-pointer">{t.home.meetCats}</a>
					<a href={`${_base}/${lang}/${style}/donate`} class="inline-block bg-pink-500 text-white border-2 border-black px-6 py-3 font-extrabold uppercase text-sm md:text-base tracking-wide shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-[2px] hover:translate-y-[2px] cursor-pointer">{t.home.donate}</a>
				</div>
			</div>
			<div class="flex-shrink-0 w-full lg:w-1/2">
				<img src={sanctuary.heroImage} alt={sanctuary.name} class="w-full h-64 md:h-80 lg:h-96 object-cover border-4 border-black shadow-[8px_8px_0_#ec4899]" />
			</div>
		</div>
		<!-- Hero decorations -->
		<div class="absolute bottom-4 left-1/2 w-10 h-10 bg-blue-500 rotate-45 opacity-30 pointer-events-none hidden md:block"></div>
	</section>

	<!-- MISSION -->
	<section class="px-4 md:px-8 py-12 md:py-20 relative">
		<div class="max-w-3xl mx-auto bg-white border-2 border-black p-6 md:p-10 shadow-[8px_8px_0_#ec4899] relative">
			<div class="absolute -top-3 -left-3 w-6 h-6 bg-yellow-400 border-2 border-black rounded-full"></div>
			<div class="absolute -bottom-3 -right-3 w-8 h-8 bg-blue-500 border-2 border-black rotate-45"></div>
			<h2 class="text-3xl md:text-5xl font-black uppercase tracking-tight">{t.home.mission}</h2>
			<p class="text-base md:text-lg font-bold mt-6 leading-relaxed">{sanctuary.mission}</p>
		</div>
	</section>

	<!-- STATS -->
	<section class="px-4 md:px-8 py-12 md:py-16">
		<div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
			{sanctuary.stats.map((stat: any, i: number) => (
				<div class={`border-2 border-black p-4 md:p-6 text-center
					${i % 4 === 0 ? 'bg-pink-500 text-white shadow-[4px_4px_0_#000]' : ''}
					${i % 4 === 1 ? 'bg-yellow-400 text-black shadow-[4px_4px_0_#3b82f6]' : ''}
					${i % 4 === 2 ? 'bg-blue-500 text-white shadow-[4px_4px_0_#000]' : ''}
					${i % 4 === 3 ? 'bg-green-400 text-black shadow-[4px_4px_0_#ec4899]' : ''}
				`}>
					<span class="block text-4xl md:text-5xl lg:text-6xl font-black leading-none">{stat.value}</span>
					<span class="block text-xs md:text-sm font-extrabold uppercase tracking-wide mt-2">{stat.label}</span>
				</div>
			))}
		</div>
	</section>

	<!-- ABOUT -->
	<section class="px-4 md:px-8 py-12 md:py-20 relative">
		<div class="absolute top-8 right-8 w-0 h-0 border-l-[16px] border-l-transparent border-r-[16px] border-r-transparent border-b-[28px] border-b-pink-500 opacity-40 pointer-events-none hidden md:block"></div>
		<div class="absolute bottom-12 left-12 w-10 h-10 bg-green-400 rounded-full opacity-30 pointer-events-none hidden md:block"></div>
		<h2 class="text-3xl md:text-5xl font-black uppercase tracking-tight mb-8 md:mb-12 inline-block border-b-4 border-yellow-400 pb-2">{t.home.aboutUs}</h2>
		<div class="space-y-4 max-w-3xl">
			{sanctuary.about.map((paragraph: string, i: number) => (
				<p class={`text-base md:text-lg font-bold leading-relaxed border-l-4 pl-4 md:pl-6
					${i % 3 === 0 ? 'border-pink-500' : ''}
					${i % 3 === 1 ? 'border-blue-500' : ''}
					${i % 3 === 2 ? 'border-yellow-400' : ''}
				`}>{paragraph}</p>
			))}
		</div>
	</section>

	<!-- CONTACT -->
	{sanctuary.contact && (
		<section class="px-4 md:px-8 py-8 md:py-12 border-t-2 border-black">
			<div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-8">
				<p class="text-sm font-extrabold uppercase tracking-wide text-pink-500">{sanctuary.contact.email}</p>
				<p class="text-sm font-extrabold uppercase tracking-wide text-blue-500">{sanctuary.contact.phone}</p>
				<p class="text-sm font-extrabold uppercase tracking-wide text-black">{sanctuary.contact.address}</p>
			</div>
		</section>
	)}

	<!-- FOOTER -->
	<footer class="border-t-4 border-black bg-white px-4 md:px-8 py-6 relative overflow-hidden">
		<!-- Geometric strip -->
		<div class="flex gap-0 mb-4">
			<div class="h-3 flex-1 bg-pink-500"></div>
			<div class="h-3 flex-1 bg-yellow-400"></div>
			<div class="h-3 flex-1 bg-blue-500"></div>
			<div class="h-3 flex-1 bg-green-400"></div>
			<div class="h-3 flex-1 bg-red-500"></div>
		</div>
		<div class="flex flex-wrap gap-x-6 gap-y-2">
			{nav.map((item: any) => (
				<a href={item.href} class="text-sm font-extrabold uppercase tracking-wide text-black hover:text-pink-500 cursor-pointer">{item.label}</a>
			))}
		</div>
		<p class="text-xs font-bold uppercase tracking-wide mt-4 text-black">&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.</p>
	</footer>
</main>
