---
const { lang, style, nav, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<main class="bg-white font-sans text-black min-h-screen overflow-x-hidden relative">
	<!-- SCATTERED GEOMETRIC DECORATIONS -->
	<div class="absolute top-16 left-8 w-14 h-14 bg-yellow-400 rotate-45 opacity-40 pointer-events-none hidden md:block"></div>
	<div class="absolute top-32 right-16 w-10 h-10 rounded-full bg-pink-500 opacity-50 pointer-events-none hidden md:block"></div>
	<div class="absolute top-1/3 left-1/4 w-8 h-8 bg-blue-500 opacity-30 pointer-events-none hidden lg:block"></div>
	<div class="absolute top-1/2 right-12 w-0 h-0 border-l-[16px] border-l-transparent border-r-[16px] border-r-transparent border-b-[28px] border-b-green-400 opacity-40 pointer-events-none hidden lg:block"></div>
	<div class="absolute bottom-40 left-12 w-12 h-12 rounded-full bg-red-500 opacity-30 pointer-events-none hidden md:block"></div>
	<div class="absolute bottom-24 right-1/4 w-10 h-10 bg-yellow-400 rotate-12 opacity-30 pointer-events-none hidden lg:block"></div>
	<div class="absolute top-2/3 left-8 w-0 h-0 border-l-[10px] border-l-transparent border-r-[10px] border-r-transparent border-b-[18px] border-b-pink-500 opacity-40 pointer-events-none hidden md:block"></div>

	<!-- NAV -->
	<nav class="relative z-20 border-b-4 border-black bg-white px-4 py-4 md:px-8">
		<div class="flex flex-wrap items-center gap-x-6 gap-y-2">
			{nav.map((item: any) => (
				<a href={item.href} class="text-sm md:text-base font-extrabold uppercase tracking-wide text-black hover:text-pink-500 cursor-pointer">{item.label}</a>
			))}
		</div>
	</nav>

	<!-- 404 CONTENT -->
	<div class="relative z-10 flex flex-col items-center justify-center min-h-[calc(100vh-4rem)] px-4 py-12 text-center">
		<!-- Big 404 with offset shadow -->
		<div class="relative mb-8">
			<span class="absolute top-2 left-2 text-[8rem] md:text-[14rem] lg:text-[18rem] font-black leading-none tracking-tighter text-pink-500 select-none pointer-events-none">404</span>
			<h1 class="relative text-[8rem] md:text-[14rem] lg:text-[18rem] font-black leading-none tracking-tighter text-black">404</h1>
		</div>

		<h2 class="text-3xl md:text-5xl lg:text-6xl font-black uppercase tracking-tight">{t.notFound.heading}</h2>
		<p class="text-base md:text-lg font-bold mt-6 max-w-lg leading-relaxed">{t.notFound.description}</p>

		<div class="flex flex-col sm:flex-row gap-4 mt-10">
			<a href={`${_base}/${lang}/${style}/`} class="inline-block bg-yellow-400 border-2 border-black px-8 py-4 font-extrabold uppercase text-base tracking-wide shadow-[6px_6px_0_#000] hover:shadow-[3px_3px_0_#000] hover:translate-x-[3px] hover:translate-y-[3px] cursor-pointer transition-all">{t.notFound.backHome}</a>
			<a href={`${_base}/${lang}/${style}/cats`} class="inline-block bg-pink-500 text-white border-2 border-black px-8 py-4 font-extrabold uppercase text-base tracking-wide shadow-[6px_6px_0_#000] hover:shadow-[3px_3px_0_#000] hover:translate-x-[3px] hover:translate-y-[3px] cursor-pointer transition-all">{t.notFound.meetCats}</a>
		</div>
	</div>
</main>
