---
const { lang, style, nav, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<main class="bg-white font-sans text-black min-h-screen overflow-x-hidden relative">
	<!-- GEOMETRIC DECORATIONS -->
	<div class="absolute top-20 left-8 w-12 h-12 bg-yellow-400 rotate-45 opacity-30 pointer-events-none hidden md:block"></div>
	<div class="absolute top-40 right-12 w-10 h-10 rounded-full bg-pink-500 opacity-40 pointer-events-none hidden md:block"></div>
	<div class="absolute bottom-32 left-16 w-8 h-8 bg-blue-500 opacity-30 pointer-events-none hidden lg:block"></div>
	<div class="absolute bottom-48 right-20 w-0 h-0 border-l-[14px] border-l-transparent border-r-[14px] border-r-transparent border-b-[24px] border-b-green-400 opacity-40 pointer-events-none hidden lg:block"></div>
	<div class="absolute top-1/2 left-6 w-6 h-6 rounded-full bg-red-500 opacity-30 pointer-events-none hidden md:block"></div>
	<div class="absolute top-72 right-1/3 w-10 h-10 bg-yellow-400 rotate-12 opacity-20 pointer-events-none hidden lg:block"></div>

	<!-- NAV -->
	<nav class="relative z-20 border-b-4 border-black bg-white px-4 py-4 md:px-8">
		<div class="flex flex-wrap items-center gap-x-6 gap-y-2">
			{nav.map((item: any) => (
				<a href={item.href} class="text-sm md:text-base font-extrabold uppercase tracking-wide text-black hover:text-pink-500 cursor-pointer">{item.label}</a>
			))}
		</div>
	</nav>

	<!-- AUTH FORM -->
	<div class="relative z-10 flex items-center justify-center min-h-[calc(100vh-4rem)] px-4 py-12 md:py-16">
		<div class="w-full max-w-md bg-white border-4 border-black p-6 md:p-10 shadow-[8px_8px_0_#ec4899] relative">
			<!-- Decorative corner shapes -->
			<div class="absolute -top-3 -right-3 w-6 h-6 bg-yellow-400 border-2 border-black rotate-45"></div>
			<div class="absolute -bottom-3 -left-3 w-6 h-6 bg-blue-500 border-2 border-black rounded-full"></div>

			<div class="mb-8">
				<h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight">{t.auth.title}</h2>
				<p class="text-sm font-bold text-pink-500 mt-2">{t.auth.subtitle}</p>
			</div>

			<form class="space-y-6">
				<div>
					<label for="email" class="block text-xs font-extrabold uppercase tracking-wide mb-2">{t.auth.email}</label>
					<input type="email" id="email" name="email" placeholder="you@example.com" class="w-full border-2 border-black bg-white px-4 py-3 font-bold text-base focus:outline-none focus:bg-yellow-50 focus:border-pink-500 placeholder:text-gray-400" />
				</div>
				<div>
					<label for="password" class="block text-xs font-extrabold uppercase tracking-wide mb-2">{t.auth.password}</label>
					<input type="password" id="password" name="password" placeholder="********" class="w-full border-2 border-black bg-white px-4 py-3 font-bold text-base focus:outline-none focus:bg-yellow-50 focus:border-pink-500 placeholder:text-gray-400" />
				</div>
				<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
					<label class="flex items-center gap-2 cursor-pointer">
						<input type="checkbox" name="remember" class="w-5 h-5 border-2 border-black accent-pink-500 cursor-pointer" />
						<span class="text-xs font-bold uppercase tracking-wide">{t.auth.rememberMe}</span>
					</label>
					<a href="#" class="text-xs font-bold uppercase tracking-wide text-blue-500 hover:text-pink-500 cursor-pointer">{t.auth.forgotPassword}</a>
				</div>
				<button type="submit" class="w-full bg-pink-500 text-white border-2 border-black px-4 py-3 font-extrabold uppercase text-base tracking-wide shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-[2px] hover:translate-y-[2px] cursor-pointer transition-all">{t.auth.signIn}</button>
			</form>

			<div class="mt-8 border-t-2 border-black pt-6">
				<p class="text-xs font-extrabold uppercase tracking-wide text-center mb-4">{t.auth.continueWith}</p>
				<div class="grid grid-cols-2 gap-3">
					<button type="button" class="border-2 border-black bg-white px-4 py-3 font-extrabold uppercase text-sm tracking-wide hover:bg-yellow-400 cursor-pointer shadow-[3px_3px_0_#000] hover:shadow-[1px_1px_0_#000] hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Google</button>
					<button type="button" class="border-2 border-black bg-white px-4 py-3 font-extrabold uppercase text-sm tracking-wide hover:bg-blue-500 hover:text-white cursor-pointer shadow-[3px_3px_0_#000] hover:shadow-[1px_1px_0_#000] hover:translate-x-[2px] hover:translate-y-[2px] transition-all">Apple</button>
				</div>
			</div>

			<div class="mt-6 bg-yellow-400 border-2 border-black px-4 py-3 text-center">
				<p class="text-sm font-bold uppercase tracking-wide">
					{t.auth.noAccount} <a href="#" class="border-b-2 border-black hover:border-pink-500 hover:text-pink-500 cursor-pointer">{t.auth.signUp}</a>
				</p>
			</div>
		</div>
	</div>
</main>
