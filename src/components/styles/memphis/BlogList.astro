---
const { lang, style, nav, posts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<main class="bg-white font-sans text-black overflow-x-hidden relative">
	<!-- GEOMETRIC DECORATIONS -->
	<div class="absolute top-28 right-10 w-12 h-12 bg-pink-500 rotate-12 opacity-30 pointer-events-none hidden md:block"></div>
	<div class="absolute top-48 left-6 w-8 h-8 rounded-full bg-blue-500 opacity-40 pointer-events-none hidden lg:block"></div>

	<!-- NAV -->
	<nav class="relative z-20 border-b-4 border-black bg-white px-4 py-4 md:px-8">
		<div class="flex flex-wrap items-center gap-x-6 gap-y-2">
			{nav.map((item: any) => (
				<a href={item.href} class="text-sm md:text-base font-extrabold uppercase tracking-wide text-black hover:text-pink-500 cursor-pointer">{item.label}</a>
			))}
		</div>
	</nav>

	<!-- TITLE -->
	<section class="px-4 md:px-8 pt-12 pb-8 md:pt-20 md:pb-12 relative">
		<div class="flex items-center gap-4">
			<div class="w-8 h-8 bg-yellow-400 rotate-45 border-2 border-black hidden md:block"></div>
			<h1 class="text-5xl md:text-7xl lg:text-8xl font-black uppercase leading-none tracking-tight">{t.blog.title}</h1>
		</div>
		<p class="text-lg md:text-xl font-bold text-pink-500 mt-4">{t.blog.subtitle}</p>
	</section>

	<!-- POSTS GRID -->
	<section class="px-4 md:px-8 pb-12 md:pb-20">
		<div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
			{posts.map((post: any, i: number) => (
				<a href={`${_base}/${lang}/${style}/blog/${post.slug}`} class={`block border-2 border-black bg-white p-4 cursor-pointer group hover:-translate-y-1 transition-transform
					${i % 4 === 0 ? 'shadow-[6px_6px_0_#ec4899]' : ''}
					${i % 4 === 1 ? 'shadow-[6px_6px_0_#facc15]' : ''}
					${i % 4 === 2 ? 'shadow-[6px_6px_0_#3b82f6]' : ''}
					${i % 4 === 3 ? 'shadow-[6px_6px_0_#4ade80]' : ''}
				`}>
					<img src={post.image} alt={post.title} class="w-full h-44 md:h-52 object-cover border-2 border-black" />
					<h2 class="text-2xl md:text-3xl font-black uppercase tracking-tight mt-4 leading-tight group-hover:text-pink-500">{post.title}</h2>
					<p class="text-sm font-bold mt-3 leading-snug">{post.excerpt}</p>
					<div class="flex flex-wrap items-center gap-2 mt-4">
						<time datetime={post.date} class={`text-xs font-extrabold uppercase tracking-wide px-2 py-1 border-2 border-black
							${i % 4 === 0 ? 'bg-pink-500 text-white' : ''}
							${i % 4 === 1 ? 'bg-yellow-400 text-black' : ''}
							${i % 4 === 2 ? 'bg-blue-500 text-white' : ''}
							${i % 4 === 3 ? 'bg-green-400 text-black' : ''}
						`}>{post.date}</time>
						<span class="text-xs font-bold uppercase tracking-wide">{t.blog.by} {post.author}</span>
					</div>
					<div class="flex flex-wrap gap-1 mt-3">
						{post.tags.map((tag: string) => (
							<span class="border-2 border-black text-xs font-bold uppercase px-2 py-0.5 tracking-wide bg-white group-hover:bg-yellow-400">{tag}</span>
						))}
					</div>
				</a>
			))}
		</div>
	</section>

	<!-- FOOTER -->
	<footer class="border-t-4 border-black bg-white px-4 md:px-8 py-6">
		<div class="flex gap-0 mb-4">
			<div class="h-3 flex-1 bg-pink-500"></div>
			<div class="h-3 flex-1 bg-yellow-400"></div>
			<div class="h-3 flex-1 bg-blue-500"></div>
			<div class="h-3 flex-1 bg-green-400"></div>
			<div class="h-3 flex-1 bg-red-500"></div>
		</div>
		<div class="flex flex-wrap gap-x-6 gap-y-2">
			{nav.map((item: any) => (
				<a href={item.href} class="text-sm font-extrabold uppercase tracking-wide text-black hover:text-pink-500 cursor-pointer">{item.label}</a>
			))}
		</div>
	</footer>
</main>
