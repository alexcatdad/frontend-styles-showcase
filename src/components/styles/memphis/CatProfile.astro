---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<main class="bg-white font-sans text-black overflow-x-hidden relative">
	<!-- GEOMETRIC DECORATIONS -->
	<div class="absolute top-24 right-12 w-10 h-10 bg-yellow-400 rotate-45 opacity-40 pointer-events-none hidden md:block"></div>
	<div class="absolute top-64 left-6 w-8 h-8 rounded-full bg-green-400 opacity-50 pointer-events-none hidden lg:block"></div>
	<div class="absolute top-[30rem] right-8 w-0 h-0 border-l-[12px] border-l-transparent border-r-[12px] border-r-transparent border-b-[20px] border-b-pink-500 opacity-40 pointer-events-none hidden lg:block"></div>

	<!-- NAV -->
	<nav class="relative z-20 border-b-4 border-black bg-white px-4 py-4 md:px-8">
		<div class="flex flex-wrap items-center gap-x-6 gap-y-2">
			{nav.map((item: any) => (
				<a href={item.href} class="text-sm md:text-base font-extrabold uppercase tracking-wide text-black hover:text-pink-500 cursor-pointer">{item.label}</a>
			))}
		</div>
	</nav>

	<!-- BACK LINK -->
	<div class="px-4 md:px-8 pt-6">
		<a href={`${_base}/${lang}/${style}/cats`} class="inline-flex items-center gap-2 text-sm font-extrabold uppercase tracking-wide text-pink-500 hover:text-blue-500 cursor-pointer">
			<span class="w-4 h-4 bg-pink-500 rounded-full border-2 border-black inline-block"></span>
			&larr; {t.cats.backToAll}
		</a>
	</div>

	<!-- CAT HERO -->
	<section class="px-4 md:px-8 py-8 md:py-12 relative">
		<div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
			<div class="w-full lg:w-1/2">
				<img src={cat.image} alt={cat.name} class="w-full h-72 md:h-96 object-cover border-4 border-black shadow-[8px_8px_0_#3b82f6]" />
			</div>
			<div class="flex-1">
				<h1 class="text-5xl md:text-7xl lg:text-8xl font-black uppercase leading-none tracking-tight">{cat.name}</h1>
				<span class="inline-block mt-4 bg-yellow-400 border-2 border-black text-sm font-extrabold uppercase px-4 py-2 tracking-wide shadow-[3px_3px_0_#000]">{cat.status}</span>

				<!-- METADATA -->
				<div class="mt-8 space-y-0">
					<div class="flex items-center border-b-2 border-black py-3">
						<span class="text-sm font-extrabold uppercase tracking-wide text-pink-500 w-24 md:w-32">{t.cats.breed}</span>
						<span class="text-base md:text-lg font-bold">{cat.breed}</span>
					</div>
					<div class="flex items-center border-b-2 border-black py-3">
						<span class="text-sm font-extrabold uppercase tracking-wide text-blue-500 w-24 md:w-32">{t.cats.age}</span>
						<span class="text-base md:text-lg font-bold">{cat.age}</span>
					</div>
					<div class="flex items-center border-b-2 border-black py-3">
						<span class="text-sm font-extrabold uppercase tracking-wide text-green-500 w-24 md:w-32">{t.cats.gender}</span>
						<span class="text-base md:text-lg font-bold">{cat.gender}</span>
					</div>
					<div class="flex items-center border-b-2 border-black py-3">
						<span class="text-sm font-extrabold uppercase tracking-wide text-red-500 w-24 md:w-32">{t.cats.color}</span>
						<span class="text-base md:text-lg font-bold">{cat.color}</span>
					</div>
					<div class="flex items-center py-3">
						<span class="text-sm font-extrabold uppercase tracking-wide text-yellow-500 w-24 md:w-32">{t.cats.arrived}</span>
						<span class="text-base md:text-lg font-bold">{cat.arrivalDate}</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- PERSONALITY CHIPS -->
	<section class="px-4 md:px-8 py-8 md:py-12">
		<div class="flex flex-wrap gap-3">
			{cat.personality.map((trait: string, i: number) => (
				<span class={`border-2 border-black px-4 py-2 font-extrabold uppercase text-sm tracking-wide
					${i % 5 === 0 ? 'bg-pink-500 text-white shadow-[3px_3px_0_#000]' : ''}
					${i % 5 === 1 ? 'bg-yellow-400 text-black shadow-[3px_3px_0_#3b82f6]' : ''}
					${i % 5 === 2 ? 'bg-blue-500 text-white shadow-[3px_3px_0_#000]' : ''}
					${i % 5 === 3 ? 'bg-green-400 text-black shadow-[3px_3px_0_#ec4899]' : ''}
					${i % 5 === 4 ? 'bg-red-500 text-white shadow-[3px_3px_0_#facc15]' : ''}
				`}>{trait}</span>
			))}
		</div>
	</section>

	<!-- DESCRIPTION -->
	<section class="px-4 md:px-8 py-8 md:py-12">
		<div class="max-w-3xl border-l-4 border-pink-500 pl-4 md:pl-6">
			<p class="text-base md:text-lg font-bold leading-relaxed">{cat.description}</p>
		</div>
	</section>

	<!-- ADOPT CTA -->
	<section class="px-4 md:px-8 py-10 md:py-16 text-center relative">
		<div class="absolute top-4 left-1/4 w-6 h-6 bg-yellow-400 rotate-45 opacity-40 pointer-events-none hidden md:block"></div>
		<div class="absolute bottom-4 right-1/3 w-8 h-8 rounded-full bg-green-400 opacity-30 pointer-events-none hidden md:block"></div>
		<a href={`${_base}/${lang}/${style}/auth`} class="inline-block bg-pink-500 text-white border-4 border-black px-10 md:px-16 py-4 md:py-5 text-xl md:text-3xl font-black uppercase tracking-wide shadow-[6px_6px_0_#000] hover:shadow-[3px_3px_0_#000] hover:translate-x-[3px] hover:translate-y-[3px] cursor-pointer transition-all">{t.cats.adopt} {cat.name}</a>
	</section>

	<!-- OTHER CATS -->
	<section class="px-4 md:px-8 py-10 md:py-16 border-t-2 border-black">
		<h2 class="text-3xl md:text-5xl font-black uppercase tracking-tight mb-6 md:mb-10">{t.cats.otherCats}</h2>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
			{otherCats.map((c: any, i: number) => (
				<a href={`${_base}/${lang}/${style}/cats/${c.id}`} class={`block border-2 border-black p-4 cursor-pointer hover:-translate-y-1 transition-transform
					${i % 3 === 0 ? 'bg-white shadow-[4px_4px_0_#ec4899]' : ''}
					${i % 3 === 1 ? 'bg-white shadow-[4px_4px_0_#3b82f6]' : ''}
					${i % 3 === 2 ? 'bg-white shadow-[4px_4px_0_#facc15]' : ''}
				`}>
					<h3 class="text-xl md:text-2xl font-black uppercase tracking-tight">{c.name}</h3>
					<p class="text-sm font-bold mt-1 text-blue-500">{c.breed} ● {c.age}</p>
				</a>
			))}
		</div>
	</section>

	<!-- FOOTER -->
	<footer class="border-t-4 border-black bg-white px-4 md:px-8 py-6">
		<div class="flex gap-0 mb-4">
			<div class="h-3 flex-1 bg-pink-500"></div>
			<div class="h-3 flex-1 bg-yellow-400"></div>
			<div class="h-3 flex-1 bg-blue-500"></div>
			<div class="h-3 flex-1 bg-green-400"></div>
			<div class="h-3 flex-1 bg-red-500"></div>
		</div>
		<div class="flex flex-wrap gap-x-6 gap-y-2">
			{nav.map((item: any) => (
				<a href={item.href} class="text-sm font-extrabold uppercase tracking-wide text-black hover:text-pink-500 cursor-pointer">{item.label}</a>
			))}
		</div>
	</footer>
</main>
