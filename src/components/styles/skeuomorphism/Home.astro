---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-amber-50 via-orange-50 to-amber-100">
	<!-- Navigation - Toolbar style -->
	<nav class="bg-gradient-to-b from-amber-700 via-amber-800 to-amber-900 border-b-4 border-amber-950 shadow-lg px-4 py-3">
		<div class="max-w-6xl mx-auto flex flex-wrap items-center justify-center gap-1 sm:gap-2">
			{nav.map((item: any) => (
				<a
					href={item.href}
					class="px-4 py-2 bg-gradient-to-b from-amber-500 to-amber-700 text-amber-50 font-semibold text-sm rounded-lg border border-amber-900 shadow-md hover:from-amber-400 hover:to-amber-600 active:from-amber-700 active:to-amber-800 active:shadow-inner transition-all"
				>
					{item.label}
				</a>
			))}
		</div>
	</nav>

	<main class="max-w-6xl mx-auto px-4 py-8 space-y-10">
		<!-- Hero Section - Leather-bound card -->
		<section class="relative bg-gradient-to-b from-amber-100 to-amber-200 rounded-2xl border-4 border-amber-800/40 shadow-2xl overflow-hidden">
			<div class="absolute inset-0 bg-gradient-to-br from-white/30 via-transparent to-amber-900/10 pointer-events-none"></div>
			<div class="relative px-6 py-12 sm:px-12 sm:py-16 text-center space-y-6">
				<h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-amber-900 drop-shadow-sm">
					{sanctuary.name}
				</h1>
				<p class="text-xl sm:text-2xl text-amber-800/80 font-medium italic max-w-2xl mx-auto">
					{sanctuary.tagline}
				</p>
				<div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
					<a
						href={`/${lang}/${style}/cats`}
						class="px-8 py-3 bg-gradient-to-b from-green-500 via-green-600 to-green-800 text-white font-bold text-lg rounded-xl border-2 border-green-900/50 shadow-lg hover:from-green-400 hover:to-green-700 active:shadow-inner active:from-green-700 active:to-green-900 transition-all"
					>
						{t.home.meetCats}
					</a>
					<a
						href={`/${lang}/${style}/donate`}
						class="px-8 py-3 bg-gradient-to-b from-yellow-400 via-yellow-500 to-yellow-700 text-amber-900 font-bold text-lg rounded-xl border-2 border-yellow-800/40 shadow-lg hover:from-yellow-300 hover:to-yellow-600 active:shadow-inner active:from-yellow-600 active:to-yellow-800 transition-all"
					>
						{t.home.donate}
					</a>
				</div>
			</div>
		</section>

		<!-- Mission Section - Paper card -->
		<section class="bg-gradient-to-b from-amber-50 to-amber-100 rounded-xl border-2 border-amber-700/30 shadow-xl p-6 sm:p-10">
			<div class="bg-gradient-to-b from-white to-amber-50/80 rounded-lg border border-amber-300 shadow-inner p-6 sm:p-8">
				<h2 class="text-2xl sm:text-3xl font-bold text-amber-900 mb-4 pb-3 border-b-2 border-amber-300">
					{t.home.mission}
				</h2>
				<p class="text-amber-800 text-lg leading-relaxed">
					{sanctuary.mission}
				</p>
			</div>
		</section>

		<!-- Stats Section - Metal plaques -->
		<section class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
			{sanctuary.stats.map((stat: any) => (
				<div class="bg-gradient-to-b from-amber-200 via-amber-100 to-amber-300 rounded-xl border-2 border-amber-600/30 shadow-lg p-5 text-center">
					<div class="bg-gradient-to-b from-amber-700 to-amber-900 rounded-lg shadow-inner p-4 mb-3">
						<span class="text-3xl sm:text-4xl font-extrabold text-amber-100 drop-shadow-md">
							{stat.value}
						</span>
					</div>
					<span class="text-amber-800 font-semibold text-sm uppercase tracking-wide">
						{stat.label}
					</span>
				</div>
			))}
		</section>

		<!-- About Section - Book pages -->
		<section class="bg-gradient-to-b from-amber-50 to-amber-100 rounded-xl border-2 border-amber-700/30 shadow-xl p-6 sm:p-10">
			<div class="bg-gradient-to-b from-white to-amber-50/80 rounded-lg border border-amber-300 shadow-inner p-6 sm:p-8 space-y-4">
				<h2 class="text-2xl sm:text-3xl font-bold text-amber-900 mb-4 pb-3 border-b-2 border-amber-300">
					{t.home.aboutUs}
				</h2>
				{sanctuary.about.map((paragraph: string) => (
					<p class="text-amber-800 leading-relaxed text-base sm:text-lg">
						{paragraph}
					</p>
				))}
			</div>
		</section>
	</main>

	<!-- Footer - Dark wood bar -->
	<footer class="bg-gradient-to-b from-amber-800 via-amber-900 to-amber-950 border-t-4 border-amber-700 mt-10 px-4 py-6">
		<p class="text-center text-amber-200/80 text-sm">
			&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.
		</p>
	</footer>
</div>
