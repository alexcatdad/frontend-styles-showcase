---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-gradient-to-b from-amber-800 via-amber-900 to-stone-900">
	<!-- Navigation - macOS-style brushed metal toolbar -->
	<nav class="relative bg-gradient-to-b from-stone-300 via-stone-200 to-stone-400 border-b-2 border-stone-500 shadow-[0_2px_8px_rgba(0,0,0,0.4)] px-4 py-2.5">
		<div class="absolute inset-0 bg-gradient-to-b from-white/20 to-transparent pointer-events-none"></div>
		<div class="relative max-w-6xl mx-auto flex flex-wrap items-center justify-center gap-1.5 sm:gap-2">
			{nav.map((item: any) => (
				<a
					href={item.href}
					class="px-5 py-1.5 bg-gradient-to-b from-stone-100 via-stone-50 to-stone-200 text-stone-700 font-semibold text-sm rounded-md border border-stone-400 shadow-[0_1px_2px_rgba(0,0,0,0.2),inset_0_1px_0_rgba(255,255,255,0.8)] hover:from-white hover:to-stone-100 active:from-stone-300 active:to-stone-200 active:shadow-[inset_0_2px_4px_rgba(0,0,0,0.2)] transition-all"
				>
					{item.label}
				</a>
			))}
		</div>
	</nav>

	<main class="max-w-6xl mx-auto px-4 py-8 space-y-10">
		<!-- Hero Section - Leather-bound book with gold embossing -->
		<section class="relative rounded-2xl overflow-hidden shadow-[0_8px_32px_rgba(0,0,0,0.5)]">
			<!-- Leather texture background -->
			<div class="absolute inset-0 bg-gradient-to-br from-amber-900 via-amber-800 to-yellow-900"></div>
			<!-- Stitching border effect -->
			<div class="absolute inset-2 rounded-xl border-2 border-dashed border-amber-600/40 pointer-events-none"></div>
			<!-- Sheen highlight -->
			<div class="absolute inset-0 bg-gradient-to-br from-white/10 via-transparent to-black/20 pointer-events-none"></div>

			<div class="relative px-8 py-14 sm:px-14 sm:py-20 text-center space-y-6">
				<!-- Gold embossed title -->
				<h1 class="text-4xl sm:text-5xl lg:text-6xl font-serif font-bold text-transparent bg-clip-text bg-gradient-to-b from-yellow-300 via-yellow-200 to-yellow-400 drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]" style="text-shadow: 0 1px 2px rgba(0,0,0,0.3);">
					{sanctuary.name}
				</h1>
				<p class="text-xl sm:text-2xl text-amber-200/80 font-serif italic max-w-2xl mx-auto">
					{sanctuary.tagline}
				</p>
				<img src={sanctuary.heroImage} alt={sanctuary.name} class="w-full max-w-3xl mx-auto mt-6 rounded-lg object-cover border-4 border-amber-700/50 shadow-[0_6px_20px_rgba(0,0,0,0.5)]" />
				<div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
					<a
						href={`${_base}/${lang}/${style}/cats`}
						class="px-8 py-3.5 bg-gradient-to-b from-emerald-500 via-emerald-600 to-emerald-800 text-white font-bold text-lg rounded-lg border border-emerald-900 shadow-[0_4px_12px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.3)] hover:from-emerald-400 hover:to-emerald-700 active:shadow-[inset_0_3px_8px_rgba(0,0,0,0.4)] active:from-emerald-700 active:to-emerald-900 transition-all"
					>
						{t.home.meetCats}
					</a>
					<a
						href={`${_base}/${lang}/${style}/donate`}
						class="px-8 py-3.5 bg-gradient-to-b from-yellow-500 via-yellow-600 to-amber-700 text-amber-950 font-bold text-lg rounded-lg border border-amber-800 shadow-[0_4px_12px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.4)] hover:from-yellow-400 hover:to-amber-600 active:shadow-[inset_0_3px_8px_rgba(0,0,0,0.4)] active:from-amber-700 active:to-amber-800 transition-all"
					>
						{t.home.donate}
					</a>
				</div>
			</div>
		</section>

		<!-- Mission Section - Torn notebook paper -->
		<section class="relative">
			<!-- Paper shadow -->
			<div class="absolute inset-0 translate-y-1 translate-x-0.5 bg-stone-600/30 rounded-lg blur-sm"></div>
			<div class="relative bg-gradient-to-b from-amber-50 via-yellow-50 to-amber-100 rounded-lg overflow-hidden shadow-[0_2px_10px_rgba(0,0,0,0.3)]">
				<!-- Notebook red margin line -->
				<div class="absolute left-10 sm:left-16 top-0 bottom-0 w-px bg-red-300/60 pointer-events-none"></div>
				<!-- Notebook hole punches -->
				<div class="absolute left-3 sm:left-5 top-8 w-4 h-4 rounded-full bg-gradient-to-b from-amber-800 to-amber-900 shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)] border border-amber-700"></div>
				<div class="absolute left-3 sm:left-5 top-24 w-4 h-4 rounded-full bg-gradient-to-b from-amber-800 to-amber-900 shadow-[inset_0_2px_4px_rgba(0,0,0,0.5)] border border-amber-700"></div>

				<div class="px-14 sm:px-20 py-8 space-y-1">
					<!-- Horizontal ruled lines via repeating background -->
					<h2 class="text-2xl sm:text-3xl font-serif font-bold text-stone-800 mb-4 pb-3 border-b border-blue-200/60">
						{t.home.mission}
					</h2>
					<p class="text-stone-700 text-lg leading-loose font-serif" style="background-image: repeating-linear-gradient(transparent, transparent 1.75rem, #cbd5e1 1.75rem, #cbd5e1 1.8rem); background-size: 100% 1.85rem; padding-top: 0.2rem;">
						{sanctuary.mission}
					</p>
				</div>
			</div>
		</section>

		<!-- Stats Section - Brass plaques on a wooden shelf -->
		<section class="relative">
			<!-- Wooden shelf -->
			<div class="bg-gradient-to-b from-amber-700 via-amber-800 to-amber-900 rounded-xl border-2 border-amber-950 shadow-[0_8px_24px_rgba(0,0,0,0.5),inset_0_1px_0_rgba(255,255,255,0.1)] p-5 sm:p-8">
				<!-- Wood grain highlight -->
				<div class="absolute inset-0 rounded-xl bg-gradient-to-r from-transparent via-white/5 to-transparent pointer-events-none"></div>

				<div class="relative grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
					{sanctuary.stats.map((stat: any) => (
						<div class="bg-gradient-to-b from-yellow-600 via-yellow-500 to-yellow-700 rounded-lg border border-yellow-800/60 shadow-[0_4px_12px_rgba(0,0,0,0.4),inset_0_1px_0_rgba(255,255,255,0.4)] p-4 text-center">
							<!-- Engraved number -->
							<div class="text-3xl sm:text-4xl font-serif font-extrabold text-yellow-900 drop-shadow-[0_1px_0_rgba(255,255,255,0.3)]" style="text-shadow: 0 -1px 0 rgba(0,0,0,0.2), 0 1px 0 rgba(255,255,255,0.3);">
								{stat.value}
							</div>
							<!-- Engraved label -->
							<div class="mt-1 text-yellow-900/80 font-semibold text-xs uppercase tracking-widest">
								{stat.label}
							</div>
						</div>
					))}
				</div>
			</div>
			<!-- Shelf bracket shadow -->
			<div class="mx-8 h-3 bg-gradient-to-b from-black/30 to-transparent rounded-b-full"></div>
		</section>

		<!-- About Section - Cork board with pinned cards -->
		<section class="bg-gradient-to-br from-amber-600 via-amber-500 to-yellow-700 rounded-xl border-4 border-amber-900 shadow-[0_6px_20px_rgba(0,0,0,0.5),inset_0_2px_8px_rgba(0,0,0,0.2)] p-5 sm:p-8">
			<h2 class="text-2xl sm:text-3xl font-serif font-bold text-amber-950 mb-6 text-center drop-shadow-[0_1px_0_rgba(255,255,255,0.2)]">
				{t.home.aboutUs}
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
				{sanctuary.about.map((paragraph: string) => (
					<div class="relative">
						<!-- Pin -->
						<div class="absolute -top-2 left-1/2 -translate-x-1/2 z-10 w-5 h-5 rounded-full bg-gradient-to-b from-red-400 to-red-700 border border-red-800 shadow-[0_2px_4px_rgba(0,0,0,0.4)]">
							<div class="absolute inset-1 rounded-full bg-gradient-to-b from-white/40 to-transparent"></div>
						</div>
						<!-- Index card -->
						<div class="bg-gradient-to-b from-white via-amber-50 to-amber-100 rounded-sm p-5 pt-6 shadow-[2px_3px_8px_rgba(0,0,0,0.3)] border border-amber-200/60 rotate-[0.3deg]" style="background-image: repeating-linear-gradient(transparent, transparent 1.5rem, #e2d5c0 1.5rem, #e2d5c0 1.52rem);">
							<p class="text-stone-700 leading-relaxed text-sm sm:text-base font-serif">
								{paragraph}
							</p>
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- Contact - Embossed brass plate -->
		<section class="text-center">
			<div class="inline-block bg-gradient-to-b from-yellow-600 via-yellow-500 to-yellow-700 rounded-lg border-2 border-yellow-800/50 shadow-[0_4px_16px_rgba(0,0,0,0.4),inset_0_1px_0_rgba(255,255,255,0.4)] px-10 py-5">
				<p class="text-yellow-950 font-serif font-bold text-lg tracking-wide" style="text-shadow: 0 1px 0 rgba(255,255,255,0.3);">
					{sanctuary.contact.phone}
				</p>
				<p class="text-yellow-900/80 text-sm mt-1 font-serif">
					{sanctuary.contact.address}
				</p>
			</div>
		</section>
	</main>

	<!-- Footer - Dark walnut wood bar -->
	<footer class="bg-gradient-to-b from-stone-800 via-stone-900 to-stone-950 border-t-4 border-amber-700/50 mt-10 px-4 py-6 shadow-[inset_0_4px_8px_rgba(0,0,0,0.4)]">
		<p class="text-center text-amber-200/60 text-sm font-serif">
			&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.
		</p>
	</footer>
</div>
