---
const { lang, style, nav, posts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-gradient-to-b from-amber-800 via-amber-900 to-stone-900">
	<!-- Navigation - Brushed metal toolbar -->
	<nav class="relative bg-gradient-to-b from-stone-300 via-stone-200 to-stone-400 border-b-2 border-stone-500 shadow-[0_2px_8px_rgba(0,0,0,0.4)] px-4 py-2.5">
		<div class="absolute inset-0 bg-gradient-to-b from-white/20 to-transparent pointer-events-none"></div>
		<div class="relative max-w-6xl mx-auto flex flex-wrap items-center justify-center gap-1.5 sm:gap-2">
			{nav.map((item: any) => (
				<a
					href={item.href}
					class="px-5 py-1.5 bg-gradient-to-b from-stone-100 via-stone-50 to-stone-200 text-stone-700 font-semibold text-sm rounded-md border border-stone-400 shadow-[0_1px_2px_rgba(0,0,0,0.2),inset_0_1px_0_rgba(255,255,255,0.8)] hover:from-white hover:to-stone-100 active:from-stone-300 active:to-stone-200 active:shadow-[inset_0_2px_4px_rgba(0,0,0,0.2)] transition-all"
				>
					{item.label}
				</a>
			))}
		</div>
	</nav>

	<main class="max-w-4xl mx-auto px-4 py-8 space-y-8">
		<!-- Header - Wooden carved sign -->
		<div class="relative bg-gradient-to-b from-amber-700 via-amber-800 to-amber-900 rounded-xl border-4 border-amber-950 shadow-[0_6px_20px_rgba(0,0,0,0.5),inset_0_1px_0_rgba(255,255,255,0.1)] p-6 sm:p-8 text-center">
			<div class="absolute inset-0 rounded-xl opacity-10 bg-gradient-to-r from-transparent via-amber-400 to-transparent pointer-events-none"></div>
			<h1 class="relative text-3xl sm:text-4xl font-serif font-bold text-amber-100" style="text-shadow: 0 -1px 0 rgba(0,0,0,0.4), 0 1px 0 rgba(255,255,255,0.1);">
				{t.blog.title}
			</h1>
			<p class="relative text-amber-300/80 text-lg mt-2 font-serif italic">{t.blog.subtitle}</p>
		</div>

		<!-- Blog posts - Stacked papers on a desk surface -->
		<div class="space-y-6">
			{posts.map((post: any, i: number) => (
				<a
					href={`${_base}/${lang}/${style}/blog/${post.slug}`}
					class="group relative block"
				>
					<!-- Stacked paper layers underneath -->
					<div class="absolute -bottom-1 left-1 right-1 h-full bg-amber-100 rounded-sm shadow-[1px_2px_4px_rgba(0,0,0,0.15)] rotate-[0.3deg]"></div>
					<div class="absolute -bottom-0.5 left-0.5 right-0.5 h-full bg-amber-50 rounded-sm shadow-[1px_1px_3px_rgba(0,0,0,0.1)] rotate-[-0.2deg]"></div>

					<!-- Main paper -->
					<article class="relative bg-gradient-to-b from-white via-amber-50 to-amber-100 rounded-sm shadow-[2px_3px_10px_rgba(0,0,0,0.3)] border border-amber-200/80 overflow-hidden group-hover:-translate-y-1 group-hover:shadow-[2px_5px_14px_rgba(0,0,0,0.35)] transition-all duration-200">
						<!-- Red margin line -->
						<div class="absolute left-12 sm:left-16 top-0 bottom-0 w-px bg-red-300/40 pointer-events-none"></div>

						<img src={post.image} alt={post.title} class="w-full h-40 object-cover border-b border-amber-200/60" />

						<div class="p-6 sm:p-8 pl-16 sm:pl-20 space-y-3">
							<!-- Date - Rubber stamp style -->
							<div class="inline-block">
								<time
									datetime={post.date}
									class="inline-block px-3 py-1 text-stone-600 text-xs font-bold uppercase tracking-widest border-2 border-stone-400/60 rounded-sm rotate-[-1deg]"
									style="font-family: monospace;"
								>
									{post.date}
								</time>
							</div>

							<h2 class="text-xl sm:text-2xl font-serif font-bold text-stone-800 group-hover:text-stone-600 transition-colors">
								{post.title}
							</h2>

							<!-- Excerpt area - slightly recessed -->
							<div class="bg-white/60 rounded border border-amber-200/40 shadow-[inset_0_1px_3px_rgba(0,0,0,0.06)] p-4" style="background-image: repeating-linear-gradient(transparent, transparent 1.5rem, #e2d5c0 1.5rem, #e2d5c0 1.52rem);">
								<p class="text-stone-600 leading-relaxed text-sm sm:text-base font-serif">{post.excerpt}</p>
							</div>

							<!-- Tags - Sticky label tabs -->
							<div class="flex flex-wrap items-center gap-2 pt-1">
								{post.tags.map((tag: string) => (
									<span class="px-3 py-0.5 bg-gradient-to-b from-yellow-200 to-yellow-300 text-yellow-900 text-xs font-bold uppercase tracking-wider rounded-sm border border-yellow-400/60 shadow-[0_1px_2px_rgba(0,0,0,0.1)]">
										{tag}
									</span>
								))}
							</div>

							<span class="block text-stone-500 text-sm font-serif italic">
								{t.blog.by} {post.author}
							</span>
						</div>
					</article>
				</a>
			))}
		</div>
	</main>
</div>
