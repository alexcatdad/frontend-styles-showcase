---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-amber-50 via-orange-50 to-amber-100">
	<!-- Navigation - Toolbar -->
	<nav class="bg-gradient-to-b from-amber-700 via-amber-800 to-amber-900 border-b-4 border-amber-950 shadow-lg px-4 py-3">
		<div class="max-w-6xl mx-auto flex flex-wrap items-center justify-center gap-1 sm:gap-2">
			{nav.map((item: any) => (
				<a
					href={item.href}
					class="px-4 py-2 bg-gradient-to-b from-amber-500 to-amber-700 text-amber-50 font-semibold text-sm rounded-lg border border-amber-900 shadow-md hover:from-amber-400 hover:to-amber-600 active:from-amber-700 active:to-amber-800 active:shadow-inner transition-all"
				>
					{item.label}
				</a>
			))}
		</div>
	</nav>

	<main class="max-w-4xl mx-auto px-4 py-8 space-y-8">
		<!-- Header plaque -->
		<div class="bg-gradient-to-b from-amber-200 via-amber-100 to-amber-200 rounded-xl border-2 border-amber-600/30 shadow-lg p-6 sm:p-8 text-center">
			<h1 class="text-3xl sm:text-4xl font-bold text-amber-900 drop-shadow-sm mb-2">
				{t.blog.title}
			</h1>
			<p class="text-amber-700 text-lg">{t.blog.subtitle}</p>
		</div>

		<!-- Blog posts - Stacked paper cards -->
		<div class="space-y-6">
			{posts.map((post: any) => (
				<a
					href={`/${lang}/${style}/blog/${post.slug}`}
					class="group block bg-gradient-to-b from-amber-50 to-amber-100 rounded-xl border-2 border-amber-700/30 shadow-xl hover:shadow-2xl hover:-translate-y-0.5 transition-all duration-200 overflow-hidden"
				>
					<article class="p-6 sm:p-8 space-y-3">
						<!-- Date stamp - Wax seal feel -->
						<time
							datetime={post.date}
							class="inline-block px-3 py-1 bg-gradient-to-b from-amber-600 to-amber-800 text-amber-100 text-xs font-bold uppercase tracking-wider rounded-md border border-amber-900/50 shadow-sm"
						>
							{post.date}
						</time>

						<h2 class="text-xl sm:text-2xl font-bold text-amber-900 group-hover:text-amber-700 transition-colors">
							{post.title}
						</h2>

						<!-- Excerpt on paper inset -->
						<div class="bg-gradient-to-b from-white to-amber-50 rounded-lg border border-amber-200 shadow-inner p-4">
							<p class="text-amber-800 leading-relaxed">{post.excerpt}</p>
						</div>

						<div class="flex flex-wrap items-center gap-2 pt-1">
							{post.tags.map((tag: string) => (
								<span class="px-3 py-1 bg-gradient-to-b from-green-400 to-green-600 text-white text-xs font-semibold rounded-full border border-green-700/50 shadow-sm">
									{tag}
								</span>
							))}
						</div>

						<span class="block text-amber-600 text-sm font-medium italic">
							{t.blog.by} {post.author}
						</span>
					</article>
				</a>
			))}
		</div>
	</main>
</div>
