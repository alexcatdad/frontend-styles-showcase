---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-amber-800 via-amber-900 to-stone-900">
	<!-- Navigation - Brushed metal toolbar -->
	<nav class="relative bg-gradient-to-b from-stone-300 via-stone-200 to-stone-400 border-b-2 border-stone-500 shadow-[0_2px_8px_rgba(0,0,0,0.4)] px-4 py-2.5">
		<div class="absolute inset-0 bg-gradient-to-b from-white/20 to-transparent pointer-events-none"></div>
		<div class="relative max-w-6xl mx-auto flex flex-wrap items-center justify-center gap-1.5 sm:gap-2">
			{nav.map((item: any) => (
				<a
					href={item.href}
					class="px-5 py-1.5 bg-gradient-to-b from-stone-100 via-stone-50 to-stone-200 text-stone-700 font-semibold text-sm rounded-md border border-stone-400 shadow-[0_1px_2px_rgba(0,0,0,0.2),inset_0_1px_0_rgba(255,255,255,0.8)] hover:from-white hover:to-stone-100 active:from-stone-300 active:to-stone-200 active:shadow-[inset_0_2px_4px_rgba(0,0,0,0.2)] transition-all"
				>
					{item.label}
				</a>
			))}
		</div>
	</nav>

	<main class="max-w-4xl mx-auto px-4 py-8 space-y-8">
		<!-- Back button -->
		<a
			href={`/${lang}/${style}/blog`}
			class="inline-flex items-center gap-1.5 px-5 py-2 bg-gradient-to-b from-stone-200 via-stone-100 to-stone-300 text-stone-700 font-semibold text-sm rounded-md border border-stone-400 shadow-[0_2px_4px_rgba(0,0,0,0.2),inset_0_1px_0_rgba(255,255,255,0.8)] hover:from-white hover:to-stone-200 active:shadow-[inset_0_2px_4px_rgba(0,0,0,0.2)] transition-all"
		>
			&larr; {t.blog.backToBlog}
		</a>

		<!-- Article - Leather-bound journal -->
		<article class="relative">
			<!-- Leather journal cover -->
			<div class="relative rounded-2xl overflow-hidden shadow-[0_8px_32px_rgba(0,0,0,0.5)]">
				<div class="absolute inset-0 bg-gradient-to-br from-amber-900 via-amber-800 to-yellow-900"></div>
				<!-- Stitching -->
				<div class="absolute inset-2.5 rounded-xl border-2 border-dashed border-amber-600/30 pointer-events-none"></div>
				<!-- Sheen -->
				<div class="absolute inset-0 bg-gradient-to-br from-white/8 via-transparent to-black/15 pointer-events-none"></div>

				<!-- Header on leather -->
				<header class="relative px-6 py-8 sm:px-10 sm:py-10 space-y-4">
					<!-- Date wax seal -->
					<div class="inline-block">
						<time
							datetime={post.date}
							class="inline-block px-4 py-1.5 bg-gradient-to-b from-red-600 via-red-700 to-red-900 text-red-100 text-xs font-bold uppercase tracking-widest rounded-full border border-red-950 shadow-[0_3px_8px_rgba(0,0,0,0.4),inset_0_1px_0_rgba(255,255,255,0.2)]"
						>
							{post.date}
						</time>
					</div>

					<!-- Gold embossed title -->
					<h1 class="text-2xl sm:text-3xl lg:text-4xl font-serif font-bold text-transparent bg-clip-text bg-gradient-to-b from-yellow-300 via-yellow-200 to-yellow-400" style="text-shadow: 0 1px 2px rgba(0,0,0,0.3);">
						{post.title}
					</h1>

					<span class="block text-amber-300/80 text-sm font-serif italic">
						{t.blog.by} {post.author}
					</span>

					<!-- Tags as leather tab bookmarks -->
					<div class="flex flex-wrap gap-2 pt-1">
						{post.tags.map((tag: string) => (
							<span class="px-3 py-1 bg-gradient-to-b from-amber-600 to-amber-800 text-amber-100 text-xs font-semibold rounded-sm border border-amber-900/60 shadow-[0_2px_4px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.15)]">
								{tag}
							</span>
						))}
					</div>
				</header>

				<!-- Content - Paper pages inside the journal -->
				<div class="relative mx-4 mb-6 sm:mx-8 sm:mb-8">
					<!-- Paper edge layer -->
					<div class="absolute inset-0 translate-x-0.5 translate-y-0.5 bg-amber-200 rounded-lg"></div>
					<div class="relative bg-gradient-to-b from-white via-amber-50 to-amber-100 rounded-lg shadow-[inset_0_2px_8px_rgba(0,0,0,0.1)] p-6 sm:p-10 space-y-0" style="background-image: repeating-linear-gradient(transparent, transparent 1.85rem, #d4c5a9 1.85rem, #d4c5a9 1.87rem); background-size: 100% 1.95rem;">
						<!-- Red margin -->
						<div class="absolute left-10 sm:left-14 top-0 bottom-0 w-px bg-red-300/40 pointer-events-none"></div>

						{post.content.map((paragraph: string) => (
							<p class="text-stone-700 leading-loose text-base sm:text-lg font-serif pl-4 sm:pl-6 py-1">
								{paragraph}
							</p>
						))}
					</div>
				</div>
			</div>
		</article>

		<!-- More Stories - Wooden bookshelf -->
		<section class="space-y-4">
			<h2 class="text-2xl font-serif font-bold text-amber-200 drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]">{t.blog.moreStories}</h2>

			<div class="bg-gradient-to-b from-amber-700 via-amber-800 to-amber-900 rounded-xl border-2 border-amber-950 shadow-[0_6px_20px_rgba(0,0,0,0.5),inset_0_1px_0_rgba(255,255,255,0.1)] p-4 sm:p-6">
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
					{otherPosts.map((p: any) => (
						<a
							href={`/${lang}/${style}/blog/${p.slug}`}
							class="group block bg-gradient-to-b from-white via-amber-50 to-amber-100 rounded-sm shadow-[2px_3px_8px_rgba(0,0,0,0.35)] border border-amber-200/80 p-5 space-y-2 hover:-translate-y-1 hover:shadow-[2px_5px_12px_rgba(0,0,0,0.4)] transition-all duration-200"
						>
							<h3 class="text-lg font-serif font-bold text-stone-800 group-hover:text-stone-600 transition-colors">
								{p.title}
							</h3>
							<div class="bg-white/60 rounded border border-amber-200/40 shadow-[inset_0_1px_3px_rgba(0,0,0,0.06)] p-3" style="background-image: repeating-linear-gradient(transparent, transparent 1.3rem, #e2d5c0 1.3rem, #e2d5c0 1.32rem);">
								<p class="text-stone-600 text-sm leading-relaxed font-serif">{p.excerpt}</p>
							</div>
						</a>
					))}
				</div>
			</div>
			<!-- Shelf shadow -->
			<div class="mx-8 h-3 bg-gradient-to-b from-black/25 to-transparent rounded-b-full -mt-3"></div>
		</section>
	</main>
</div>
