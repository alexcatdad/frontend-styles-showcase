---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-amber-50 via-orange-50 to-amber-100">
	<!-- Navigation - Toolbar -->
	<nav class="bg-gradient-to-b from-amber-700 via-amber-800 to-amber-900 border-b-4 border-amber-950 shadow-lg px-4 py-3">
		<div class="max-w-6xl mx-auto flex flex-wrap items-center justify-center gap-1 sm:gap-2">
			{nav.map((item: any) => (
				<a
					href={item.href}
					class="px-4 py-2 bg-gradient-to-b from-amber-500 to-amber-700 text-amber-50 font-semibold text-sm rounded-lg border border-amber-900 shadow-md hover:from-amber-400 hover:to-amber-600 active:from-amber-700 active:to-amber-800 active:shadow-inner transition-all"
				>
					{item.label}
				</a>
			))}
		</div>
	</nav>

	<main class="max-w-4xl mx-auto px-4 py-8 space-y-8">
		<!-- Back link -->
		<a
			href={`/${lang}/${style}/blog`}
			class="inline-block px-5 py-2 bg-gradient-to-b from-amber-300 to-amber-500 text-amber-900 font-semibold text-sm rounded-lg border border-amber-600/40 shadow-md hover:from-amber-200 hover:to-amber-400 active:shadow-inner transition-all"
		>
			&larr; {t.blog.backToBlog}
		</a>

		<!-- Article - Leather-bound journal page -->
		<article class="bg-gradient-to-b from-amber-100 to-amber-200 rounded-2xl border-4 border-amber-800/40 shadow-2xl overflow-hidden">
			<!-- Header band -->
			<header class="bg-gradient-to-b from-amber-700 via-amber-800 to-amber-900 px-6 py-6 sm:px-10 shadow-inner space-y-3">
				<time
					datetime={post.date}
					class="inline-block px-3 py-1 bg-gradient-to-b from-amber-500 to-amber-700 text-amber-100 text-xs font-bold uppercase tracking-wider rounded-md border border-amber-900/50 shadow-sm"
				>
					{post.date}
				</time>
				<h1 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-amber-100 drop-shadow-md">
					{post.title}
				</h1>
				<span class="block text-amber-300 text-sm font-medium italic">
					{t.blog.by} {post.author}
				</span>
				<div class="flex flex-wrap gap-2 pt-1">
					{post.tags.map((tag: string) => (
						<span class="px-3 py-1 bg-gradient-to-b from-green-400 to-green-600 text-white text-xs font-semibold rounded-full border border-green-700/50 shadow-sm">
							{tag}
						</span>
					))}
				</div>
			</header>

			<!-- Content - Paper inset -->
			<div class="p-6 sm:p-10">
				<div class="bg-gradient-to-b from-white to-amber-50 rounded-xl border border-amber-300 shadow-inner p-6 sm:p-8 space-y-5">
					{post.content.map((paragraph: string) => (
						<p class="text-amber-800 leading-relaxed text-base sm:text-lg">
							{paragraph}
						</p>
					))}
				</div>
			</div>
		</article>

		<!-- More Stories -->
		<section class="space-y-4">
			<h2 class="text-2xl font-bold text-amber-900 drop-shadow-sm">{t.blog.moreStories}</h2>
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
				{otherPosts.map((p: any) => (
					<a
						href={`/${lang}/${style}/blog/${p.slug}`}
						class="group block bg-gradient-to-b from-amber-50 to-amber-100 rounded-xl border-2 border-amber-700/30 shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-200 p-5 space-y-2"
					>
						<h3 class="text-lg font-bold text-amber-900 group-hover:text-amber-700 transition-colors">
							{p.title}
						</h3>
						<div class="bg-gradient-to-b from-white to-amber-50 rounded-lg border border-amber-200 shadow-inner p-3">
							<p class="text-amber-700 text-sm leading-relaxed">{p.excerpt}</p>
						</div>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
