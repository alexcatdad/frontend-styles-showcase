---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-amber-800 via-amber-900 to-stone-900">
	<!-- Navigation - Brushed metal toolbar -->
	<nav class="relative bg-gradient-to-b from-stone-300 via-stone-200 to-stone-400 border-b-2 border-stone-500 shadow-[0_2px_8px_rgba(0,0,0,0.4)] px-4 py-2.5">
		<div class="absolute inset-0 bg-gradient-to-b from-white/20 to-transparent pointer-events-none"></div>
		<div class="relative max-w-6xl mx-auto flex flex-wrap items-center justify-center gap-1.5 sm:gap-2">
			{nav.map((item: any) => (
				<a
					href={item.href}
					class="px-5 py-1.5 bg-gradient-to-b from-stone-100 via-stone-50 to-stone-200 text-stone-700 font-semibold text-sm rounded-md border border-stone-400 shadow-[0_1px_2px_rgba(0,0,0,0.2),inset_0_1px_0_rgba(255,255,255,0.8)] hover:from-white hover:to-stone-100 active:from-stone-300 active:to-stone-200 active:shadow-[inset_0_2px_4px_rgba(0,0,0,0.2)] transition-all"
				>
					{item.label}
				</a>
			))}
		</div>
	</nav>

	<main class="max-w-4xl mx-auto px-4 py-8 space-y-8">
		<!-- Back button - Embossed metal -->
		<a
			href={`/${lang}/${style}/cats`}
			class="inline-flex items-center gap-1.5 px-5 py-2 bg-gradient-to-b from-stone-200 via-stone-100 to-stone-300 text-stone-700 font-semibold text-sm rounded-md border border-stone-400 shadow-[0_2px_4px_rgba(0,0,0,0.2),inset_0_1px_0_rgba(255,255,255,0.8)] hover:from-white hover:to-stone-200 active:shadow-[inset_0_2px_4px_rgba(0,0,0,0.2)] transition-all"
		>
			&larr; {t.cats.backToAll}
		</a>

		<!-- Cat Dossier - Manila folder with tab -->
		<article class="relative">
			<!-- Folder tab -->
			<div class="relative z-10 inline-block ml-6 px-8 py-2 bg-gradient-to-b from-amber-300 via-amber-200 to-amber-300 rounded-t-lg border-2 border-b-0 border-amber-400 shadow-[0_-2px_6px_rgba(0,0,0,0.1)]">
				<span class="text-amber-900 font-serif font-bold text-lg">{cat.name}</span>
			</div>

			<!-- Folder body -->
			<div class="relative bg-gradient-to-b from-amber-200 via-amber-100 to-amber-200 rounded-xl rounded-tl-none border-2 border-amber-400 shadow-[0_6px_24px_rgba(0,0,0,0.4)] overflow-hidden">
				<!-- Folder crease line -->
				<div class="absolute top-0 left-0 right-0 h-px bg-amber-400/60"></div>

				<div class="p-6 sm:p-10 space-y-6">
					<!-- CLASSIFIED header stamp -->
					<div class="text-center">
						<span class="inline-block px-6 py-1.5 text-red-700 text-sm font-bold uppercase tracking-[0.3em] border-3 border-red-700/50 rounded-sm rotate-[-1deg]" style="font-family: monospace; border-width: 3px;">
							{t.cats.status}: {cat.status}
						</span>
					</div>

					<!-- Details grid - Typewriter-style form fields -->
					<dl class="bg-white/60 rounded-lg border border-amber-300/60 shadow-[inset_0_2px_6px_rgba(0,0,0,0.08)] p-5 grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4">
						<div class="border-b border-dotted border-stone-400 pb-2">
							<dt class="text-stone-500 text-xs uppercase tracking-widest font-bold">{t.cats.breed}</dt>
							<dd class="text-stone-800 font-serif text-lg mt-0.5" style="font-family: 'Courier New', monospace;">{cat.breed}</dd>
						</div>
						<div class="border-b border-dotted border-stone-400 pb-2">
							<dt class="text-stone-500 text-xs uppercase tracking-widest font-bold">{t.cats.age}</dt>
							<dd class="text-stone-800 font-serif text-lg mt-0.5" style="font-family: 'Courier New', monospace;">{cat.age}</dd>
						</div>
						<div class="border-b border-dotted border-stone-400 pb-2">
							<dt class="text-stone-500 text-xs uppercase tracking-widest font-bold">{t.cats.gender}</dt>
							<dd class="text-stone-800 font-serif text-lg mt-0.5" style="font-family: 'Courier New', monospace;">{cat.gender}</dd>
						</div>
						<div class="border-b border-dotted border-stone-400 pb-2">
							<dt class="text-stone-500 text-xs uppercase tracking-widest font-bold">{t.cats.color}</dt>
							<dd class="text-stone-800 font-serif text-lg mt-0.5" style="font-family: 'Courier New', monospace;">{cat.color}</dd>
						</div>
						<div class="border-b border-dotted border-stone-400 pb-2">
							<dt class="text-stone-500 text-xs uppercase tracking-widest font-bold">{t.cats.arrived}</dt>
							<dd class="text-stone-800 font-serif text-lg mt-0.5" style="font-family: 'Courier New', monospace;">{cat.arrivalDate}</dd>
						</div>
						<div class="border-b border-dotted border-stone-400 pb-2">
							<dt class="text-stone-500 text-xs uppercase tracking-widest font-bold">{t.cats.status}</dt>
							<dd class="text-stone-800 font-serif text-lg mt-0.5" style="font-family: 'Courier New', monospace;">{cat.status}</dd>
						</div>
					</dl>

					<!-- Personality - Paper clip attached note -->
					<div class="relative">
						<!-- Paper clip -->
						<div class="absolute -top-1 right-8 w-6 h-12 border-2 border-stone-400 rounded-full bg-gradient-to-b from-stone-200 to-stone-400 z-10" style="clip-path: inset(0 0 50% 0);"></div>
						<div class="bg-gradient-to-b from-yellow-100 to-yellow-200 rounded-sm shadow-[2px_3px_8px_rgba(0,0,0,0.2)] p-4 rotate-[0.5deg] border border-yellow-300/60">
							<p class="text-xs text-stone-500 uppercase tracking-wider font-bold mb-2">Personality Notes:</p>
							<div class="flex flex-wrap gap-2">
								{cat.personality.map((trait: string) => (
									<span class="px-3 py-1 bg-gradient-to-b from-emerald-500 to-emerald-700 text-white text-sm font-semibold rounded-md border border-emerald-800/50 shadow-[0_2px_4px_rgba(0,0,0,0.2),inset_0_1px_0_rgba(255,255,255,0.3)]">
										{trait}
									</span>
								))}
							</div>
						</div>
					</div>

					<!-- Description - Lined notebook paper inset -->
					<div class="bg-white/80 rounded-lg border border-amber-300/60 shadow-[inset_0_2px_8px_rgba(0,0,0,0.1)] p-6" style="background-image: repeating-linear-gradient(transparent, transparent 1.75rem, #cbd5e1 1.75rem, #cbd5e1 1.78rem); background-size: 100% 1.85rem;">
						<p class="text-stone-700 leading-loose text-base sm:text-lg font-serif">
							{cat.description}
						</p>
					</div>

					<!-- Adopt CTA - Big glossy 3D button -->
					<div class="text-center pt-4">
						<a
							href={`/${lang}/${style}/auth`}
							class="inline-block px-12 py-4 bg-gradient-to-b from-emerald-400 via-emerald-500 to-emerald-700 text-white font-bold text-lg rounded-xl border-2 border-emerald-900/60 shadow-[0_6px_0_0_#166534,0_8px_16px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.3)] hover:shadow-[0_4px_0_0_#166534,0_6px_12px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.3)] hover:translate-y-0.5 active:shadow-[0_1px_0_0_#166534,inset_0_2px_6px_rgba(0,0,0,0.3)] active:translate-y-1 transition-all"
						>
							{t.cats.adopt} {cat.name}
						</a>
					</div>
				</div>
			</div>
		</article>

		<!-- Other Cats - Wooden shelf with mini cards -->
		<section class="space-y-4">
			<h2 class="text-2xl font-serif font-bold text-amber-200 drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]">{t.cats.otherCats}</h2>

			<!-- Wooden shelf -->
			<div class="bg-gradient-to-b from-amber-700 via-amber-800 to-amber-900 rounded-xl border-2 border-amber-950 shadow-[0_6px_20px_rgba(0,0,0,0.5),inset_0_1px_0_rgba(255,255,255,0.1)] p-4 sm:p-6">
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
					{otherCats.map((c: any) => (
						<a
							href={`/${lang}/${style}/cats/${c.id}`}
							class="group block bg-gradient-to-b from-white via-amber-50 to-amber-100 rounded-sm shadow-[2px_3px_8px_rgba(0,0,0,0.35)] border border-amber-200/80 p-4 hover:-translate-y-1 hover:shadow-[2px_5px_12px_rgba(0,0,0,0.4)] transition-all duration-200"
						>
							<div class="bg-gradient-to-b from-emerald-600 to-emerald-800 rounded-md px-3 py-2 shadow-[inset_0_1px_0_rgba(255,255,255,0.2)] mb-2">
								<h3 class="text-base font-serif font-bold text-white group-hover:text-emerald-100 transition-colors">
									{c.name}
								</h3>
							</div>
							<p class="text-stone-600 text-sm font-serif">{c.breed} &middot; {c.age}</p>
						</a>
					))}
				</div>
			</div>
			<!-- Shelf shadow -->
			<div class="mx-8 h-3 bg-gradient-to-b from-black/25 to-transparent rounded-b-full -mt-3"></div>
		</section>
	</main>
</div>
