---
const { lang, style, nav, cats, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-amber-50 via-orange-50 to-amber-100">
	<!-- Navigation - Toolbar -->
	<nav class="bg-gradient-to-b from-amber-700 via-amber-800 to-amber-900 border-b-4 border-amber-950 shadow-lg px-4 py-3">
		<div class="max-w-6xl mx-auto flex flex-wrap items-center justify-center gap-1 sm:gap-2">
			{nav.map((item: any) => (
				<a
					href={item.href}
					class="px-4 py-2 bg-gradient-to-b from-amber-500 to-amber-700 text-amber-50 font-semibold text-sm rounded-lg border border-amber-900 shadow-md hover:from-amber-400 hover:to-amber-600 active:from-amber-700 active:to-amber-800 active:shadow-inner transition-all"
				>
					{item.label}
				</a>
			))}
		</div>
	</nav>

	<main class="max-w-6xl mx-auto px-4 py-8 space-y-8">
		<!-- Header - Engraved plaque -->
		<div class="bg-gradient-to-b from-amber-200 via-amber-100 to-amber-200 rounded-xl border-2 border-amber-600/30 shadow-lg p-6 sm:p-8 text-center">
			<h1 class="text-3xl sm:text-4xl font-bold text-amber-900 drop-shadow-sm mb-2">
				{t.cats.title}
			</h1>
			<p class="text-amber-700 text-lg">{t.cats.subtitle}</p>
		</div>

		<!-- Cat Cards Grid -->
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
			{cats.map((cat: any) => (
				<a
					href={`/${lang}/${style}/cats/${cat.id}`}
					class="group block bg-gradient-to-b from-amber-50 to-amber-100 rounded-xl border-2 border-amber-700/30 shadow-xl hover:shadow-2xl hover:-translate-y-1 transition-all duration-200 overflow-hidden"
				>
					<div class="p-5 space-y-3">
						<!-- Cat name banner -->
						<div class="bg-gradient-to-b from-amber-700 to-amber-900 rounded-lg px-4 py-3 shadow-inner">
							<h2 class="text-xl font-bold text-amber-100 group-hover:text-white transition-colors">
								{cat.name}
							</h2>
							<p class="text-amber-300 text-sm">
								{cat.breed} &middot; {cat.age} &middot; {cat.gender}
							</p>
						</div>

						<!-- Description on paper background -->
						<div class="bg-gradient-to-b from-white to-amber-50 rounded-lg border border-amber-200 shadow-inner p-3">
							<p class="text-amber-800 text-sm leading-relaxed">
								{cat.description.slice(0, 100)}...
							</p>
						</div>

						<!-- Personality tags - small beveled badges -->
						<div class="flex flex-wrap gap-2">
							{cat.personality.map((trait: string) => (
								<span class="px-3 py-1 bg-gradient-to-b from-green-400 to-green-600 text-white text-xs font-semibold rounded-full border border-green-700/50 shadow-sm">
									{trait}
								</span>
							))}
						</div>

						<!-- Status badge -->
						<div class="pt-2">
							<span class="inline-block px-4 py-1.5 bg-gradient-to-b from-yellow-400 to-yellow-600 text-amber-900 text-xs font-bold uppercase tracking-wide rounded-full border border-yellow-700/40 shadow-sm">
								{cat.status}
							</span>
						</div>
					</div>
				</a>
			))}
		</div>
	</main>
</div>
