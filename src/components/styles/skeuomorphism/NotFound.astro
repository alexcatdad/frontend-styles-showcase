---
const { lang, style, nav, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-gradient-to-b from-amber-800 via-amber-900 to-stone-900">
	<!-- Navigation - Brushed metal toolbar -->
	<nav class="relative bg-gradient-to-b from-stone-300 via-stone-200 to-stone-400 border-b-2 border-stone-500 shadow-[0_2px_8px_rgba(0,0,0,0.4)] px-4 py-2.5">
		<div class="absolute inset-0 bg-gradient-to-b from-white/20 to-transparent pointer-events-none"></div>
		<div class="relative max-w-6xl mx-auto flex flex-wrap items-center justify-center gap-1.5 sm:gap-2">
			{nav.map((item: any) => (
				<a
					href={item.href}
					class="px-5 py-1.5 bg-gradient-to-b from-stone-100 via-stone-50 to-stone-200 text-stone-700 font-semibold text-sm rounded-md border border-stone-400 shadow-[0_1px_2px_rgba(0,0,0,0.2),inset_0_1px_0_rgba(255,255,255,0.8)] hover:from-white hover:to-stone-100 active:from-stone-300 active:to-stone-200 active:shadow-[inset_0_2px_4px_rgba(0,0,0,0.2)] transition-all"
				>
					{item.label}
				</a>
			))}
		</div>
	</nav>

	<main class="max-w-lg mx-auto px-4 py-16 sm:py-24">
		<!-- 404 - Old wooden "CLOSED" sign hanging by chains -->
		<section class="relative">
			<!-- Chain links left -->
			<div class="absolute -top-8 left-1/4 flex flex-col items-center">
				<div class="w-3 h-5 border-2 border-stone-500 rounded-full bg-gradient-to-b from-stone-300 to-stone-500"></div>
				<div class="w-3 h-5 border-2 border-stone-500 rounded-full bg-gradient-to-b from-stone-400 to-stone-600 -mt-1.5"></div>
				<div class="w-3 h-5 border-2 border-stone-500 rounded-full bg-gradient-to-b from-stone-300 to-stone-500 -mt-1.5"></div>
			</div>
			<!-- Chain links right -->
			<div class="absolute -top-8 right-1/4 flex flex-col items-center">
				<div class="w-3 h-5 border-2 border-stone-500 rounded-full bg-gradient-to-b from-stone-300 to-stone-500"></div>
				<div class="w-3 h-5 border-2 border-stone-500 rounded-full bg-gradient-to-b from-stone-400 to-stone-600 -mt-1.5"></div>
				<div class="w-3 h-5 border-2 border-stone-500 rounded-full bg-gradient-to-b from-stone-300 to-stone-500 -mt-1.5"></div>
			</div>

			<!-- Wooden sign board -->
			<div class="relative bg-gradient-to-b from-amber-700 via-amber-800 to-amber-900 rounded-xl border-4 border-amber-950 shadow-[0_8px_28px_rgba(0,0,0,0.6),inset_0_1px_0_rgba(255,255,255,0.1)] overflow-hidden rotate-[-1deg]">
				<!-- Wood grain effect -->
				<div class="absolute inset-0 opacity-10">
					<div class="absolute inset-0 bg-gradient-to-r from-transparent via-amber-400 to-transparent"></div>
				</div>

				<!-- Nail holes in corners -->
				<div class="absolute top-3 left-3 w-4 h-4 rounded-full bg-gradient-to-b from-stone-400 to-stone-600 border border-stone-700 shadow-[inset_0_1px_2px_rgba(0,0,0,0.5)]"></div>
				<div class="absolute top-3 right-3 w-4 h-4 rounded-full bg-gradient-to-b from-stone-400 to-stone-600 border border-stone-700 shadow-[inset_0_1px_2px_rgba(0,0,0,0.5)]"></div>

				<!-- 404 carved into wood -->
				<div class="relative px-8 py-10 sm:py-14 text-center space-y-6">
					<h1 class="text-7xl sm:text-8xl font-serif font-extrabold text-amber-950/80" style="text-shadow: 0 2px 0 rgba(255,255,255,0.1), 0 -1px 0 rgba(0,0,0,0.3);">
						{t.notFound.title}
					</h1>

					<h2 class="text-2xl sm:text-3xl font-serif font-bold text-amber-200" style="text-shadow: 0 -1px 0 rgba(0,0,0,0.4), 0 1px 0 rgba(255,255,255,0.1);">
						{t.notFound.heading}
					</h2>

					<!-- Description on a tacked-on paper note -->
					<div class="relative inline-block mx-auto rotate-[1deg]">
						<!-- Tape strip -->
						<div class="absolute -top-2 left-1/2 -translate-x-1/2 w-16 h-4 bg-gradient-to-b from-amber-200/80 to-amber-300/60 rounded-sm shadow-[0_1px_2px_rgba(0,0,0,0.2)] z-10"></div>
						<div class="bg-gradient-to-b from-white via-amber-50 to-amber-100 rounded-sm p-5 pt-6 shadow-[2px_3px_10px_rgba(0,0,0,0.4)] border border-amber-200/60 max-w-sm mx-auto" style="background-image: repeating-linear-gradient(transparent, transparent 1.5rem, #d4c5a9 1.5rem, #d4c5a9 1.52rem);">
							<p class="text-stone-600 leading-relaxed text-sm font-serif">
								{t.notFound.description}
							</p>
						</div>
					</div>

					<!-- Action buttons - 3D pressable -->
					<div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
						<a
							href={`${_base}/${lang}/${style}/`}
							class="px-8 py-3 bg-gradient-to-b from-emerald-400 via-emerald-500 to-emerald-700 text-white font-bold rounded-lg border-2 border-emerald-900/60 shadow-[0_5px_0_0_#166534,0_7px_14px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.3)] hover:shadow-[0_3px_0_0_#166534,0_5px_10px_rgba(0,0,0,0.3)] hover:translate-y-0.5 active:shadow-[0_1px_0_0_#166534,inset_0_2px_4px_rgba(0,0,0,0.3)] active:translate-y-1 transition-all"
						>
							{t.notFound.backHome}
						</a>
						<a
							href={`${_base}/${lang}/${style}/cats`}
							class="px-8 py-3 bg-gradient-to-b from-yellow-500 via-yellow-600 to-amber-700 text-amber-950 font-bold rounded-lg border-2 border-amber-800 shadow-[0_5px_0_0_#92400e,0_7px_14px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.4)] hover:shadow-[0_3px_0_0_#92400e,0_5px_10px_rgba(0,0,0,0.3)] hover:translate-y-0.5 active:shadow-[0_1px_0_0_#92400e,inset_0_2px_4px_rgba(0,0,0,0.3)] active:translate-y-1 transition-all"
						>
							{t.notFound.meetCats}
						</a>
					</div>
				</div>

				<!-- Bottom nail holes -->
				<div class="absolute bottom-3 left-3 w-4 h-4 rounded-full bg-gradient-to-b from-stone-400 to-stone-600 border border-stone-700 shadow-[inset_0_1px_2px_rgba(0,0,0,0.5)]"></div>
				<div class="absolute bottom-3 right-3 w-4 h-4 rounded-full bg-gradient-to-b from-stone-400 to-stone-600 border border-stone-700 shadow-[inset_0_1px_2px_rgba(0,0,0,0.5)]"></div>
			</div>
		</section>
	</main>
</div>
