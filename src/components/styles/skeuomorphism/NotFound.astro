---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-amber-50 via-orange-50 to-amber-100">
	<!-- Navigation - Toolbar -->
	<nav class="bg-gradient-to-b from-amber-700 via-amber-800 to-amber-900 border-b-4 border-amber-950 shadow-lg px-4 py-3">
		<div class="max-w-6xl mx-auto flex flex-wrap items-center justify-center gap-1 sm:gap-2">
			{nav.map((item: any) => (
				<a
					href={item.href}
					class="px-4 py-2 bg-gradient-to-b from-amber-500 to-amber-700 text-amber-50 font-semibold text-sm rounded-lg border border-amber-900 shadow-md hover:from-amber-400 hover:to-amber-600 active:from-amber-700 active:to-amber-800 active:shadow-inner transition-all"
				>
					{item.label}
				</a>
			))}
		</div>
	</nav>

	<main class="max-w-lg mx-auto px-4 py-16 sm:py-24">
		<!-- 404 Card - Worn leather notice -->
		<section class="bg-gradient-to-b from-amber-100 to-amber-200 rounded-2xl border-4 border-amber-800/40 shadow-2xl overflow-hidden text-center">
			<!-- Top band -->
			<div class="bg-gradient-to-b from-amber-700 via-amber-800 to-amber-900 px-6 py-5 shadow-inner">
				<h1 class="text-6xl sm:text-7xl font-extrabold text-amber-100 drop-shadow-lg">
					{t.notFound.title}
				</h1>
			</div>

			<div class="p-8 sm:p-10 space-y-6">
				<h2 class="text-2xl sm:text-3xl font-bold text-amber-900">
					{t.notFound.heading}
				</h2>

				<!-- Description on paper inset -->
				<div class="bg-gradient-to-b from-white to-amber-50 rounded-lg border border-amber-300 shadow-inner p-5">
					<p class="text-amber-700 leading-relaxed">
						{t.notFound.description}
					</p>
				</div>

				<!-- Action buttons -->
				<div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-2">
					<a
						href={`/${lang}/${style}/`}
						class="px-8 py-3 bg-gradient-to-b from-green-400 via-green-500 to-green-700 text-white font-bold rounded-xl border-2 border-green-800/50 shadow-lg hover:from-green-300 hover:to-green-600 active:shadow-inner active:from-green-600 active:to-green-800 transition-all"
					>
						{t.notFound.backHome}
					</a>
					<a
						href={`/${lang}/${style}/cats`}
						class="px-8 py-3 bg-gradient-to-b from-amber-400 via-amber-500 to-amber-700 text-white font-bold rounded-xl border-2 border-amber-800/50 shadow-lg hover:from-amber-300 hover:to-amber-600 active:shadow-inner active:from-amber-600 active:to-amber-800 transition-all"
					>
						{t.notFound.meetCats}
					</a>
				</div>
			</div>
		</section>
	</main>
</div>
