---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-amber-800 via-amber-900 to-stone-900">
	<!-- Navigation - Brushed metal toolbar -->
	<nav class="relative bg-gradient-to-b from-stone-300 via-stone-200 to-stone-400 border-b-2 border-stone-500 shadow-[0_2px_8px_rgba(0,0,0,0.4)] px-4 py-2.5">
		<div class="absolute inset-0 bg-gradient-to-b from-white/20 to-transparent pointer-events-none"></div>
		<div class="relative max-w-6xl mx-auto flex flex-wrap items-center justify-center gap-1.5 sm:gap-2">
			{nav.map((item: any) => (
				<a
					href={item.href}
					class="px-5 py-1.5 bg-gradient-to-b from-stone-100 via-stone-50 to-stone-200 text-stone-700 font-semibold text-sm rounded-md border border-stone-400 shadow-[0_1px_2px_rgba(0,0,0,0.2),inset_0_1px_0_rgba(255,255,255,0.8)] hover:from-white hover:to-stone-100 active:from-stone-300 active:to-stone-200 active:shadow-[inset_0_2px_4px_rgba(0,0,0,0.2)] transition-all"
				>
					{item.label}
				</a>
			))}
		</div>
	</nav>

	<main class="max-w-md mx-auto px-4 py-10">
		<!-- Auth - Safe / vault door interface -->
		<section class="relative">
			<!-- Vault door outer ring -->
			<div class="relative bg-gradient-to-b from-stone-400 via-stone-300 to-stone-500 rounded-2xl border-4 border-stone-600 shadow-[0_8px_32px_rgba(0,0,0,0.6),inset_0_2px_0_rgba(255,255,255,0.3)] overflow-hidden">
				<!-- Metallic sheen -->
				<div class="absolute inset-0 bg-gradient-to-br from-white/15 via-transparent to-black/10 pointer-events-none"></div>

				<!-- Header - Vault dial area -->
				<div class="relative bg-gradient-to-b from-stone-600 via-stone-700 to-stone-800 px-6 py-6 text-center border-b-2 border-stone-900 shadow-[inset_0_-2px_6px_rgba(0,0,0,0.3)]">
					<!-- Lock icon circle -->
					<div class="mx-auto mb-3 w-14 h-14 rounded-full bg-gradient-to-b from-stone-400 via-stone-300 to-stone-500 border-4 border-stone-500 shadow-[0_4px_10px_rgba(0,0,0,0.4),inset_0_2px_4px_rgba(255,255,255,0.3)] flex items-center justify-center">
						<div class="w-6 h-7 rounded-t-full border-3 border-stone-700 border-b-0" style="border-width: 3px; border-bottom: none;"></div>
					</div>
					<h1 class="text-2xl sm:text-3xl font-serif font-bold text-stone-100" style="text-shadow: 0 -1px 0 rgba(0,0,0,0.4), 0 1px 0 rgba(255,255,255,0.1);">
						{t.auth.title}
					</h1>
					<p class="text-stone-400 text-sm mt-1 font-serif">{t.auth.subtitle}</p>
				</div>

				<!-- Form area - inner panel -->
				<div class="relative p-6 sm:p-8 space-y-6">
					<form class="space-y-5">
						<!-- Email field - Deep recessed slot -->
						<div class="space-y-2">
							<label for="email" class="block text-stone-600 font-bold text-xs uppercase tracking-widest">
								{t.auth.email}
							</label>
							<div class="relative">
								<input
									type="email"
									id="email"
									name="email"
									placeholder="you@example.com"
									class="w-full px-4 py-3 bg-gradient-to-b from-stone-200 to-white rounded-md border-2 border-stone-400 shadow-[inset_0_3px_8px_rgba(0,0,0,0.15),inset_0_1px_2px_rgba(0,0,0,0.1)] text-stone-800 placeholder-stone-400 focus:outline-none focus:border-amber-600 focus:shadow-[inset_0_3px_8px_rgba(0,0,0,0.15),0_0_0_2px_rgba(217,119,6,0.3)] transition-all"
								/>
							</div>
						</div>

						<!-- Password field - Deep recessed slot -->
						<div class="space-y-2">
							<label for="password" class="block text-stone-600 font-bold text-xs uppercase tracking-widest">
								{t.auth.password}
							</label>
							<div class="relative">
								<input
									type="password"
									id="password"
									name="password"
									placeholder="••••••••"
									class="w-full px-4 py-3 bg-gradient-to-b from-stone-200 to-white rounded-md border-2 border-stone-400 shadow-[inset_0_3px_8px_rgba(0,0,0,0.15),inset_0_1px_2px_rgba(0,0,0,0.1)] text-stone-800 placeholder-stone-400 focus:outline-none focus:border-amber-600 focus:shadow-[inset_0_3px_8px_rgba(0,0,0,0.15),0_0_0_2px_rgba(217,119,6,0.3)] transition-all"
								/>
							</div>
						</div>

						<!-- Remember / Forgot row -->
						<div class="flex items-center justify-between">
							<label class="flex items-center gap-2 cursor-pointer group">
								<!-- Custom toggle switch -->
								<div class="relative w-10 h-5 bg-gradient-to-b from-stone-400 to-stone-500 rounded-full border border-stone-600 shadow-[inset_0_2px_4px_rgba(0,0,0,0.3)]">
									<div class="absolute left-0.5 top-0.5 w-4 h-4 bg-gradient-to-b from-white to-stone-200 rounded-full border border-stone-400 shadow-[0_1px_3px_rgba(0,0,0,0.3)]"></div>
								</div>
								<input type="checkbox" name="remember" class="sr-only" />
								<span class="text-stone-600 text-sm font-medium">{t.auth.rememberMe}</span>
							</label>
							<a href="#" class="text-amber-700 text-sm font-medium hover:text-amber-900 transition-colors underline decoration-dotted">
								{t.auth.forgotPassword}
							</a>
						</div>

						<!-- Submit button - Large heavy vault handle button -->
						<button
							type="submit"
							class="w-full py-4 bg-gradient-to-b from-emerald-400 via-emerald-500 to-emerald-700 text-white font-bold text-lg rounded-lg border-2 border-emerald-900/60 shadow-[0_6px_0_0_#166534,0_8px_16px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.3)] hover:shadow-[0_4px_0_0_#166534,0_6px_12px_rgba(0,0,0,0.3)] hover:translate-y-0.5 active:shadow-[0_1px_0_0_#166534,inset_0_2px_6px_rgba(0,0,0,0.3)] active:translate-y-1.5 transition-all"
						>
							{t.auth.signIn}
						</button>
					</form>

					<!-- Divider - Engraved line -->
					<div class="flex items-center gap-4">
						<div class="flex-1 h-0.5 bg-gradient-to-r from-transparent via-stone-400 to-transparent shadow-[0_1px_0_rgba(255,255,255,0.3)]"></div>
						<p class="text-stone-500 text-xs font-bold uppercase tracking-widest shrink-0">{t.auth.continueWith}</p>
						<div class="flex-1 h-0.5 bg-gradient-to-r from-transparent via-stone-400 to-transparent shadow-[0_1px_0_rgba(255,255,255,0.3)]"></div>
					</div>

					<!-- Social buttons - Physical keypad buttons -->
					<div class="grid grid-cols-2 gap-3">
						<button
							type="button"
							class="py-3 bg-gradient-to-b from-white via-stone-50 to-stone-200 text-stone-700 font-bold text-sm rounded-lg border-2 border-stone-400 shadow-[0_4px_0_0_#a8a29e,0_6px_10px_rgba(0,0,0,0.2),inset_0_1px_0_rgba(255,255,255,0.8)] hover:shadow-[0_3px_0_0_#a8a29e,0_4px_8px_rgba(0,0,0,0.2)] hover:translate-y-0.5 active:shadow-[0_1px_0_0_#a8a29e,inset_0_2px_4px_rgba(0,0,0,0.15)] active:translate-y-1 transition-all"
						>
							Google
						</button>
						<button
							type="button"
							class="py-3 bg-gradient-to-b from-stone-700 via-stone-800 to-stone-900 text-stone-100 font-bold text-sm rounded-lg border-2 border-stone-950 shadow-[0_4px_0_0_#1c1917,0_6px_10px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.1)] hover:shadow-[0_3px_0_0_#1c1917,0_4px_8px_rgba(0,0,0,0.3)] hover:translate-y-0.5 active:shadow-[0_1px_0_0_#1c1917,inset_0_2px_4px_rgba(0,0,0,0.4)] active:translate-y-1 transition-all"
						>
							Apple
						</button>
					</div>

					<!-- Sign up link -->
					<p class="text-center text-stone-500 text-sm font-serif">
						{t.auth.noAccount}{" "}
						<a href="#" class="font-bold text-amber-700 hover:text-amber-900 underline decoration-dotted transition-colors">
							{t.auth.signUp}
						</a>
					</p>
				</div>

				<!-- Bottom rivets -->
				<div class="flex justify-between px-4 pb-3">
					<div class="w-3 h-3 rounded-full bg-gradient-to-b from-stone-400 to-stone-600 border border-stone-700 shadow-[inset_0_1px_0_rgba(255,255,255,0.4)]"></div>
					<div class="w-3 h-3 rounded-full bg-gradient-to-b from-stone-400 to-stone-600 border border-stone-700 shadow-[inset_0_1px_0_rgba(255,255,255,0.4)]"></div>
				</div>
			</div>
		</section>
	</main>
</div>
