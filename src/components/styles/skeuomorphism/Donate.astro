---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-amber-800 via-amber-900 to-stone-900">
	<!-- Navigation - Brushed metal toolbar -->
	<nav class="relative bg-gradient-to-b from-stone-300 via-stone-200 to-stone-400 border-b-2 border-stone-500 shadow-[0_2px_8px_rgba(0,0,0,0.4)] px-4 py-2.5">
		<div class="absolute inset-0 bg-gradient-to-b from-white/20 to-transparent pointer-events-none"></div>
		<div class="relative max-w-6xl mx-auto flex flex-wrap items-center justify-center gap-1.5 sm:gap-2">
			{nav.map((item: any) => (
				<a
					href={item.href}
					class="px-5 py-1.5 bg-gradient-to-b from-stone-100 via-stone-50 to-stone-200 text-stone-700 font-semibold text-sm rounded-md border border-stone-400 shadow-[0_1px_2px_rgba(0,0,0,0.2),inset_0_1px_0_rgba(255,255,255,0.8)] hover:from-white hover:to-stone-100 active:from-stone-300 active:to-stone-200 active:shadow-[inset_0_2px_4px_rgba(0,0,0,0.2)] transition-all"
				>
					{item.label}
				</a>
			))}
		</div>
	</nav>

	<main class="max-w-6xl mx-auto px-4 py-8 space-y-10">
		<!-- Header - Glass charity box / tip jar metaphor -->
		<div class="relative bg-gradient-to-b from-amber-700 via-amber-800 to-amber-900 rounded-2xl border-4 border-amber-950 shadow-[0_8px_28px_rgba(0,0,0,0.5),inset_0_1px_0_rgba(255,255,255,0.1)] p-8 sm:p-10 text-center overflow-hidden">
			<!-- Coin slot visualization -->
			<div class="mx-auto mb-4 w-24 h-3 bg-gradient-to-b from-stone-800 to-stone-950 rounded-full border border-stone-600 shadow-[inset_0_2px_4px_rgba(0,0,0,0.6)]"></div>
			<h1 class="text-3xl sm:text-4xl font-serif font-bold text-transparent bg-clip-text bg-gradient-to-b from-yellow-300 via-yellow-200 to-yellow-400" style="text-shadow: 0 1px 2px rgba(0,0,0,0.3);">
				{t.donate.title}
			</h1>
			<p class="text-amber-300/80 text-lg mt-2 font-serif italic">{t.donate.subtitle}</p>
		</div>

		<!-- Monthly Tiers - Physical donation envelopes -->
		<section class="space-y-6">
			<h2 class="text-2xl sm:text-3xl font-serif font-bold text-amber-200 text-center drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]">
				{t.donate.monthly}
			</h2>

			<!-- Display shelf -->
			<div class="bg-gradient-to-b from-amber-700 via-amber-800 to-amber-900 rounded-xl border-2 border-amber-950 shadow-[0_6px_20px_rgba(0,0,0,0.5),inset_0_1px_0_rgba(255,255,255,0.1)] p-5 sm:p-8">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{monthlyTiers.map((tier: any) => (
						<div
							class={`relative flex flex-col rounded-xl overflow-hidden transition-all hover:-translate-y-1 hover:shadow-[3px_6px_16px_rgba(0,0,0,0.5)] ${
								tier.highlighted
									? "shadow-[0_0_20px_rgba(234,179,8,0.3),3px_4px_12px_rgba(0,0,0,0.4)]"
									: "shadow-[3px_4px_12px_rgba(0,0,0,0.4)]"
							}`}
							data-highlighted={tier.highlighted}
						>
							{/* Gold ribbon for highlighted */}
							{tier.highlighted && (
								<div class="bg-gradient-to-b from-yellow-400 via-yellow-500 to-yellow-600 text-yellow-950 text-center py-2 font-bold text-xs uppercase tracking-widest border-b border-yellow-700 shadow-[inset_0_1px_0_rgba(255,255,255,0.4)]">
									{t.donate.mostPopular}
								</div>
							)}

							<div class={`flex flex-col flex-1 bg-gradient-to-b from-white via-amber-50 to-amber-100 p-6 space-y-4 ${tier.highlighted ? "border-2 border-yellow-500/60 border-t-0" : "border border-amber-200/80"}`}>
								<!-- Tier name - Engraved brass nameplate -->
								<div class="bg-gradient-to-b from-yellow-600 via-yellow-500 to-yellow-700 rounded-md px-4 py-2.5 shadow-[0_2px_6px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.4)] text-center border border-yellow-800/40">
									<h3 class="text-lg font-serif font-bold text-yellow-950" style="text-shadow: 0 1px 0 rgba(255,255,255,0.3);">{tier.name}</h3>
								</div>

								<!-- Price - Large embossed number -->
								<p class="text-center py-2">
									<span class="text-4xl font-serif font-extrabold text-stone-800" style="text-shadow: 0 -1px 0 rgba(0,0,0,0.1), 0 1px 0 rgba(255,255,255,0.8);">${tier.amount}</span>
									<span class="text-stone-500 font-medium text-sm block mt-0.5">{t.donate.perMonth}</span>
								</p>

								<!-- Description - handwritten feel -->
								<div class="bg-white/60 rounded border border-amber-200/40 shadow-[inset_0_1px_3px_rgba(0,0,0,0.06)] p-3">
									<p class="text-stone-600 text-sm text-center font-serif italic">{tier.description}</p>
								</div>

								<!-- Perks - Checklist on paper -->
								<ul class="space-y-2.5 flex-1">
									{tier.perks.map((perk: string) => (
										<li class="flex items-start gap-2.5 text-stone-700 text-sm">
											<span class="mt-0.5 w-5 h-5 flex-shrink-0 bg-gradient-to-b from-emerald-400 to-emerald-600 rounded-full flex items-center justify-center text-white text-xs font-bold border border-emerald-700/50 shadow-[0_2px_4px_rgba(0,0,0,0.2),inset_0_1px_0_rgba(255,255,255,0.3)]">
												&#10003;
											</span>
											<span class="font-serif">{perk}</span>
										</li>
									))}
								</ul>

								<!-- CTA - 3D pressable button -->
								<button
									type="button"
									class={`w-full py-3 font-bold text-base rounded-lg border-2 transition-all ${
										tier.highlighted
											? "bg-gradient-to-b from-emerald-400 via-emerald-500 to-emerald-700 text-white border-emerald-900/60 shadow-[0_4px_0_0_#166534,0_6px_12px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.3)] hover:shadow-[0_3px_0_0_#166534,0_4px_8px_rgba(0,0,0,0.3)] hover:translate-y-0.5 active:shadow-[0_1px_0_0_#166534,inset_0_2px_4px_rgba(0,0,0,0.3)] active:translate-y-1"
											: "bg-gradient-to-b from-stone-200 via-stone-100 to-stone-300 text-stone-700 border-stone-400 shadow-[0_4px_0_0_#78716c,0_6px_12px_rgba(0,0,0,0.2),inset_0_1px_0_rgba(255,255,255,0.8)] hover:shadow-[0_3px_0_0_#78716c,0_4px_8px_rgba(0,0,0,0.2)] hover:translate-y-0.5 active:shadow-[0_1px_0_0_#78716c,inset_0_2px_4px_rgba(0,0,0,0.2)] active:translate-y-1"
									}`}
								>
									{t.donate.choose} {tier.name}
								</button>
							</div>
						</div>
					))}
				</div>
			</div>
			<!-- Shelf shadow -->
			<div class="mx-8 h-3 bg-gradient-to-b from-black/25 to-transparent rounded-b-full -mt-5"></div>
		</section>

		<!-- One-Time Tiers - Coins/tokens on velvet -->
		<section class="space-y-6">
			<h2 class="text-2xl sm:text-3xl font-serif font-bold text-amber-200 text-center drop-shadow-[0_2px_4px_rgba(0,0,0,0.5)]">
				{t.donate.oneTime}
			</h2>

			<!-- Velvet display surface -->
			<div class="bg-gradient-to-b from-emerald-900 via-emerald-950 to-stone-950 rounded-xl border-2 border-emerald-800/50 shadow-[0_6px_20px_rgba(0,0,0,0.5),inset_0_2px_10px_rgba(0,0,0,0.4)] p-5 sm:p-8">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{oneTimeTiers.map((tier: any) => (
						<div
							class={`relative flex flex-col rounded-xl overflow-hidden transition-all hover:-translate-y-1 ${
								tier.highlighted
									? "shadow-[0_0_24px_rgba(234,179,8,0.25),3px_4px_12px_rgba(0,0,0,0.4)] hover:shadow-[0_0_28px_rgba(234,179,8,0.35),3px_6px_16px_rgba(0,0,0,0.5)]"
									: "shadow-[3px_4px_12px_rgba(0,0,0,0.4)] hover:shadow-[3px_6px_16px_rgba(0,0,0,0.5)]"
							}`}
							data-highlighted={tier.highlighted}
						>
							{tier.highlighted && (
								<div class="bg-gradient-to-b from-yellow-400 via-yellow-500 to-yellow-600 text-yellow-950 text-center py-2 font-bold text-xs uppercase tracking-widest border-b border-yellow-700 shadow-[inset_0_1px_0_rgba(255,255,255,0.4)]">
									{t.donate.greatestImpact}
								</div>
							)}

							<div class={`flex flex-col flex-1 bg-gradient-to-b from-white via-amber-50 to-amber-100 p-6 space-y-4 ${tier.highlighted ? "border-2 border-yellow-500/60 border-t-0" : "border border-amber-200/80"}`}>
								<!-- Tier name plate -->
								<div class="bg-gradient-to-b from-yellow-600 via-yellow-500 to-yellow-700 rounded-md px-4 py-2.5 shadow-[0_2px_6px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.4)] text-center border border-yellow-800/40">
									<h3 class="text-lg font-serif font-bold text-yellow-950" style="text-shadow: 0 1px 0 rgba(255,255,255,0.3);">{tier.name}</h3>
								</div>

								<!-- Price - Coin-like circle -->
								<div class="mx-auto w-24 h-24 rounded-full bg-gradient-to-b from-yellow-400 via-yellow-300 to-yellow-500 border-4 border-yellow-600/60 shadow-[0_4px_12px_rgba(0,0,0,0.3),inset_0_2px_4px_rgba(255,255,255,0.5)] flex items-center justify-center">
									<span class="text-2xl font-serif font-extrabold text-yellow-900" style="text-shadow: 0 1px 0 rgba(255,255,255,0.4);">${tier.amount}</span>
								</div>

								<!-- Description -->
								<div class="bg-white/60 rounded border border-amber-200/40 shadow-[inset_0_1px_3px_rgba(0,0,0,0.06)] p-3">
									<p class="text-stone-600 text-sm text-center font-serif italic">{tier.description}</p>
								</div>

								<!-- Perks -->
								<ul class="space-y-2.5 flex-1">
									{tier.perks.map((perk: string) => (
										<li class="flex items-start gap-2.5 text-stone-700 text-sm">
											<span class="mt-0.5 w-5 h-5 flex-shrink-0 bg-gradient-to-b from-emerald-400 to-emerald-600 rounded-full flex items-center justify-center text-white text-xs font-bold border border-emerald-700/50 shadow-[0_2px_4px_rgba(0,0,0,0.2),inset_0_1px_0_rgba(255,255,255,0.3)]">
												&#10003;
											</span>
											<span class="font-serif">{perk}</span>
										</li>
									))}
								</ul>

								<!-- CTA -->
								<button
									type="button"
									class={`w-full py-3 font-bold text-base rounded-lg border-2 transition-all ${
										tier.highlighted
											? "bg-gradient-to-b from-emerald-400 via-emerald-500 to-emerald-700 text-white border-emerald-900/60 shadow-[0_4px_0_0_#166534,0_6px_12px_rgba(0,0,0,0.3),inset_0_1px_0_rgba(255,255,255,0.3)] hover:shadow-[0_3px_0_0_#166534,0_4px_8px_rgba(0,0,0,0.3)] hover:translate-y-0.5 active:shadow-[0_1px_0_0_#166534,inset_0_2px_4px_rgba(0,0,0,0.3)] active:translate-y-1"
											: "bg-gradient-to-b from-stone-200 via-stone-100 to-stone-300 text-stone-700 border-stone-400 shadow-[0_4px_0_0_#78716c,0_6px_12px_rgba(0,0,0,0.2),inset_0_1px_0_rgba(255,255,255,0.8)] hover:shadow-[0_3px_0_0_#78716c,0_4px_8px_rgba(0,0,0,0.2)] hover:translate-y-0.5 active:shadow-[0_1px_0_0_#78716c,inset_0_2px_4px_rgba(0,0,0,0.2)] active:translate-y-1"
									}`}
								>
									{t.donate.give} ${tier.amount}
								</button>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>
</div>
