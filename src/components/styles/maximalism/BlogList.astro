---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-rose-950 via-purple-950 to-indigo-950">
	<!-- Navigation -->
	<nav class="bg-gradient-to-r from-amber-900 via-yellow-800 to-amber-900 border-b-4 border-amber-400 shadow-2xl shadow-amber-900/50">
		<div class="max-w-7xl mx-auto px-4 py-4 flex flex-wrap items-center justify-center gap-2 md:gap-6">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 font-bold text-amber-100 uppercase tracking-widest text-sm hover:text-white hover:bg-amber-700/50 rounded-sm transition-all duration-300 border border-transparent hover:border-amber-400">
					{item.label}
				</a>
			))}
		</div>
		<div class="text-center text-amber-400 text-xs tracking-[0.5em] py-1">✦ ◆ ✦ ◆ ✦ ◆ ✦ ◆ ✦ ◆ ✦</div>
	</nav>

	<main class="max-w-6xl mx-auto px-4 py-12 md:py-20">
		<!-- Header -->
		<div class="text-center mb-16">
			<p class="text-rose-400 tracking-[0.4em] text-sm mb-4">❋ ★ ❋ ★ ❋</p>
			<h1 class="font-serif text-5xl md:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-rose-300 via-pink-200 to-rose-400 mb-6">
				{t.blog.title}
			</h1>
			<p class="text-purple-200 text-xl md:text-2xl font-serif italic max-w-2xl mx-auto">
				{t.blog.subtitle}
			</p>
			<p class="text-rose-400 tracking-[0.4em] text-sm mt-6">❋ ★ ❋ ★ ❋</p>
		</div>

		<!-- Posts Grid -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
			{posts.map((post: any) => (
				<a href={`/${lang}/${style}/blog/${post.slug}`} class="group block">
					<article class="h-full bg-gradient-to-b from-rose-900/60 to-purple-950/80 border-2 border-rose-600/40 rounded-sm shadow-xl shadow-rose-900/40 hover:shadow-2xl hover:shadow-amber-500/20 hover:border-amber-400 transition-all duration-500 overflow-hidden">
						<!-- Card Top Ornament -->
						<div class="bg-gradient-to-r from-rose-700/60 via-pink-600/60 to-rose-700/60 text-center py-2">
							<span class="text-rose-200/60 text-xs tracking-[0.3em] font-bold">❋ ◆ ❋</span>
						</div>

						<div class="p-6 md:p-8">
							<time datetime={post.date} class="text-amber-400 text-sm font-bold uppercase tracking-widest">
								◆ {post.date}
							</time>
							<h2 class="font-serif text-2xl md:text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-yellow-200 mt-3 mb-4 group-hover:from-yellow-200 group-hover:to-amber-300 leading-tight">
								{post.title}
							</h2>
							<p class="text-purple-200/80 leading-relaxed mb-5">
								{post.excerpt}
							</p>

							<!-- Tags -->
							<div class="flex flex-wrap gap-2 mb-5">
								{post.tags.map((tag: string) => (
									<span class="px-3 py-1 bg-gradient-to-r from-indigo-800/60 to-violet-800/60 border border-indigo-500/40 text-indigo-200 text-xs font-bold uppercase tracking-wider rounded-sm">
										✦ {tag}
									</span>
								))}
							</div>

							<!-- Author -->
							<div class="flex justify-between items-center pt-4 border-t border-rose-600/30">
								<span class="text-rose-300 text-sm font-semibold italic">
									{t.blog.by} {post.author}
								</span>
								<span class="text-amber-400 text-sm font-bold group-hover:translate-x-1 transition-transform duration-300">
									❧ &rarr;
								</span>
							</div>
						</div>
					</article>
				</a>
			))}
		</div>
	</main>
</div>
