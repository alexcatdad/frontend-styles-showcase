---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-rose-950 via-purple-950 to-indigo-950">
	<!-- Navigation — Gilded Ribbon -->
	<nav class="relative bg-gradient-to-r from-amber-950 via-yellow-900 to-amber-950 border-b-4 border-double border-amber-400 shadow-[0_8px_32px_rgba(180,120,0,0.4)]">
		<div class="absolute inset-0 opacity-10 bg-[repeating-linear-gradient(90deg,transparent,transparent_12px,rgba(255,215,0,0.15)_12px,rgba(255,215,0,0.15)_14px)]"></div>
		<div class="relative max-w-7xl mx-auto px-4 pt-4 pb-2 flex flex-wrap items-center justify-center gap-1 md:gap-4">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 font-bold text-amber-200 uppercase tracking-[0.25em] text-xs hover:text-white hover:bg-amber-700/60 rounded-sm transition-all duration-300 border border-transparent hover:border-amber-300 hover:shadow-lg hover:shadow-amber-500/20">
					{item.label}
				</a>
			))}
		</div>
		<div class="relative text-center text-amber-500 text-xs tracking-[0.6em] py-1.5 border-t border-amber-700/50">❧ ✦ ◆ ★ ◆ ✦ ❧ ✦ ◆ ★ ◆ ✦ ❧</div>
	</nav>

	<main>
		<!-- ═══════════════════ HEADER — Rose/Garnet ═══════════════════ -->
		<section class="relative bg-gradient-to-b from-rose-950 via-red-950 to-purple-950 py-16 md:py-24 px-4 text-center overflow-hidden">
			<div class="absolute inset-0 opacity-[0.04] bg-[repeating-linear-gradient(135deg,transparent,transparent_8px,rgba(251,113,133,0.2)_8px,rgba(251,113,133,0.2)_10px,transparent_10px,transparent_18px,rgba(251,113,133,0.2)_18px,rgba(251,113,133,0.2)_20px)]"></div>
			<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(225,29,72,0.08)_0%,transparent_60%)]"></div>

			<div class="relative max-w-4xl mx-auto">
				<p class="text-rose-400 tracking-[0.5em] text-xs mb-5">❋ ★ ◆ ★ ❋</p>
				<div class="border-2 border-rose-600/25 p-3 md:p-4 inline-block">
					<div class="border border-rose-400/15 px-8 md:px-16 py-4 md:py-6">
						<h1 class="font-serif text-5xl md:text-7xl lg:text-8xl font-black text-transparent bg-clip-text bg-gradient-to-r from-rose-300 via-pink-200 to-rose-400 leading-none">
							{t.blog.title}
						</h1>
					</div>
				</div>
				<p class="text-rose-200 text-xl md:text-2xl font-serif italic max-w-2xl mx-auto mt-6">
					{t.blog.subtitle}
				</p>
				<p class="text-rose-400 tracking-[0.5em] text-xs mt-6">❋ ★ ◆ ★ ❋</p>
			</div>
		</section>

		<!-- Divider -->
		<div class="relative py-4 bg-gradient-to-r from-purple-950 via-amber-900/15 to-purple-950">
			<div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-rose-400/40 to-transparent"></div>
			<div class="text-center"><span class="text-amber-400 text-xl tracking-[0.4em]">★ ✦ ❧ ◆ ❧ ✦ ★</span></div>
			<div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-rose-400/40 to-transparent"></div>
		</div>

		<!-- ═══════════════════ POSTS GRID — Deep Purple ═══════════════════ -->
		<section class="relative bg-gradient-to-br from-purple-950 via-violet-950 to-indigo-950 py-14 md:py-20 px-4 overflow-hidden">
			<div class="absolute inset-0 opacity-[0.04] bg-[repeating-linear-gradient(0deg,transparent,transparent_24px,rgba(168,85,247,0.15)_24px,rgba(168,85,247,0.15)_26px),repeating-linear-gradient(90deg,transparent,transparent_24px,rgba(168,85,247,0.15)_24px,rgba(168,85,247,0.15)_26px)]"></div>

			<div class="relative max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10">
				{posts.map((post: any, i: number) => (
					<a href={`/${lang}/${style}/blog/${post.slug}`} class="group block">
						<article class="relative h-full">
							<!-- Hover outer glow frame -->
							<div class="absolute -inset-1 border border-amber-500/0 group-hover:border-amber-500/15 transition-all duration-700"></div>

							<div class="relative h-full bg-gradient-to-b from-rose-900/50 via-purple-900/40 to-indigo-950/80 border-2 border-rose-600/35 shadow-[0_8px_40px_rgba(136,19,55,0.4)] group-hover:shadow-[0_16px_60px_rgba(180,120,0,0.15),0_8px_40px_rgba(136,19,55,0.4)] group-hover:border-amber-400/60 transition-all duration-700 overflow-hidden flex flex-col">
								<!-- Top ornamental band -->
								<div class="bg-gradient-to-r from-rose-800/70 via-pink-700/70 to-rose-800/70 text-center py-2.5 relative">
									<div class="absolute inset-0 opacity-15 bg-[repeating-linear-gradient(90deg,transparent,transparent_6px,rgba(0,0,0,0.15)_6px,rgba(0,0,0,0.15)_7px)]"></div>
									<span class="relative text-rose-200/60 text-xs tracking-[0.4em] font-bold">❋ ◆ ★ ◆ ❋</span>
								</div>

								<div class="p-6 md:p-8 flex flex-col flex-1">
									<!-- Post image -->
									<img src={post.image} alt={post.title} class="w-full h-44 md:h-52 object-cover border-2 border-rose-500/30 shadow-[0_4px_20px_rgba(0,0,0,0.3)] mb-5" />

									<!-- Date -->
									<time datetime={post.date} class="text-amber-400 text-xs font-bold uppercase tracking-[0.2em] mb-3 block">
										◆ {post.date} ◆
									</time>

									<!-- Title -->
									<h2 class="font-serif text-2xl md:text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-yellow-200 to-amber-400 mb-4 group-hover:from-yellow-100 group-hover:to-amber-300 leading-tight">
										{post.title}
									</h2>
									<div class="w-20 h-0.5 bg-gradient-to-r from-amber-500 to-transparent mb-4"></div>

									<!-- Excerpt -->
									<p class="text-purple-200/70 leading-relaxed mb-6 flex-1">
										{post.excerpt}
									</p>

									<!-- Tags -->
									<div class="flex flex-wrap gap-2 mb-6">
										{post.tags.map((tag: string) => (
											<span class="px-3 py-1 bg-gradient-to-r from-indigo-900/70 to-violet-900/70 border border-indigo-500/30 text-indigo-200 text-xs font-bold uppercase tracking-wider shadow-md">
												✦ {tag}
											</span>
										))}
									</div>

									<!-- Author & arrow -->
									<div class="flex justify-between items-center pt-5 border-t-2 border-rose-600/20 mt-auto">
										<span class="text-rose-300 text-sm font-serif italic">
											{t.blog.by} {post.author}
										</span>
										<span class="text-amber-400 font-bold group-hover:translate-x-2 transition-transform duration-500 text-lg">
											❧ &rarr;
										</span>
									</div>
								</div>
							</div>
						</article>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
