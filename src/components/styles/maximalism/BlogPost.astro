---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-indigo-950 via-purple-950 to-rose-950">
	<!-- Navigation -->
	<nav class="relative bg-gradient-to-r from-amber-950 via-yellow-900 to-amber-950 border-b-4 border-double border-amber-400 shadow-[0_8px_32px_rgba(180,120,0,0.4)]">
		<div class="absolute inset-0 opacity-10 bg-[repeating-linear-gradient(90deg,transparent,transparent_12px,rgba(255,215,0,0.15)_12px,rgba(255,215,0,0.15)_14px)]"></div>
		<div class="relative max-w-7xl mx-auto px-4 pt-4 pb-2 flex flex-wrap items-center justify-center gap-1 md:gap-4">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 font-bold text-amber-200 uppercase tracking-[0.25em] text-xs hover:text-white hover:bg-amber-700/60 rounded-sm transition-all duration-300 border border-transparent hover:border-amber-300 hover:shadow-lg hover:shadow-amber-500/20">
					{item.label}
				</a>
			))}
		</div>
		<div class="relative text-center text-amber-500 text-xs tracking-[0.6em] py-1.5 border-t border-amber-700/50">❧ ✦ ◆ ★ ◆ ✦ ❧ ✦ ◆ ★ ◆ ✦ ❧</div>
	</nav>

	<main class="max-w-4xl mx-auto px-4 py-10 md:py-16">
		<!-- Back Link -->
		<a href={`/${lang}/${style}/blog`} class="inline-flex items-center gap-2 text-amber-400 hover:text-amber-200 font-bold uppercase tracking-[0.2em] text-xs mb-10 transition-colors group">
			<span class="text-lg group-hover:-translate-x-1 transition-transform duration-300">&larr;</span>
			<span>❧ {t.blog.backToBlog}</span>
		</a>

		<!-- ═══════ Article — Grand Ornamental Frame ═══════ -->
		<article class="relative">
			<!-- Outer decorative borders -->
			<div class="absolute -inset-2 border border-amber-500/15 hidden md:block"></div>
			<div class="absolute -inset-1 border border-amber-500/10 hidden md:block"></div>

			<div class="relative bg-gradient-to-b from-indigo-900/50 via-purple-950/70 to-violet-950/80 border-2 border-amber-500/50 shadow-[0_12px_60px_rgba(49,46,129,0.5),0_0_100px_rgba(180,120,0,0.06)] overflow-hidden">
				<!-- Top Grand Ornament -->
				<div class="relative bg-gradient-to-r from-amber-800 via-yellow-600 to-amber-800 text-center py-4 overflow-hidden">
					<div class="absolute inset-0 opacity-20 bg-[repeating-linear-gradient(90deg,transparent,transparent_8px,rgba(0,0,0,0.15)_8px,rgba(0,0,0,0.15)_9px)]"></div>
					<span class="relative text-amber-950 text-sm tracking-[0.5em] font-black">❋ ✦ ★ ◆ ★ ✦ ❋</span>
				</div>

				<!-- Header -->
				<header class="p-6 md:p-10 lg:p-16 pb-0 md:pb-0 lg:pb-0 text-center">
					<time datetime={post.date} class="text-amber-400 text-xs font-bold uppercase tracking-[0.2em]">
						◆ {post.date} ◆
					</time>

					<!-- Title with decorative frame -->
					<div class="mt-6 mb-6">
						<div class="border-2 border-amber-600/20 p-2 md:p-3 inline-block">
							<div class="border border-amber-500/10 px-6 md:px-10 py-3 md:py-5">
								<h1 class="font-serif text-4xl md:text-6xl lg:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-yellow-100 to-amber-400 leading-tight">
									{post.title}
								</h1>
							</div>
						</div>
					</div>

					<span class="text-purple-300 font-serif italic text-lg block mb-4">
						{t.blog.by} {post.author}
					</span>

					<!-- Tags -->
					<div class="flex flex-wrap gap-2 justify-center mt-4">
						{post.tags.map((tag: string) => (
							<span class="relative px-4 py-1.5 bg-gradient-to-r from-purple-800/60 to-indigo-800/60 border border-purple-500/30 text-purple-200 text-xs font-bold uppercase tracking-[0.15em] shadow-md">
								<span class="absolute -inset-px border border-purple-400/10"></span>
								✦ {tag}
							</span>
						))}
					</div>

					<!-- Ornamental divider -->
					<div class="mt-10">
						<div class="flex items-center gap-3 max-w-sm mx-auto">
							<div class="flex-1 h-px bg-gradient-to-r from-transparent via-amber-500/40 to-amber-500/40"></div>
							<span class="text-amber-500/50 text-sm tracking-[0.3em]">◆ ✦ ◆</span>
							<div class="flex-1 h-px bg-gradient-to-l from-transparent via-amber-500/40 to-amber-500/40"></div>
						</div>
					</div>
				</header>

				<!-- Header image — Ornamental frame -->
				<div class="px-6 md:px-10 lg:px-16 pt-8 md:pt-10 lg:pt-10">
					<div class="relative border-2 border-amber-600/20 p-2 mb-8">
						<div class="border border-amber-500/10 p-1">
							<img src={post.image} alt={post.title} class="w-full h-56 md:h-80 object-cover shadow-[0_8px_40px_rgba(0,0,0,0.3)]" />
						</div>
					</div>
				</div>

				<!-- Content -->
				<div class="p-6 md:p-10 lg:p-16 pt-8 md:pt-10 lg:pt-10 space-y-7">
					{post.content.map((paragraph: string, i: number) => (
						<p class={`text-indigo-100 text-lg leading-[1.85] ${i === 0 ? 'first-letter:text-6xl first-letter:font-serif first-letter:font-black first-letter:text-transparent first-letter:bg-clip-text first-letter:bg-gradient-to-b first-letter:from-amber-300 first-letter:to-amber-600 first-letter:float-left first-letter:mr-3 first-letter:mt-1 first-letter:leading-none' : ''}`}>
							{paragraph}
						</p>
					))}
				</div>

				<!-- End ornament -->
				<div class="text-center pb-10">
					<span class="text-amber-500/40 text-lg tracking-[0.4em]">║ ★ ◆ ❋ ◆ ★ ║</span>
				</div>

				<!-- Bottom Grand Ornament -->
				<div class="relative bg-gradient-to-r from-amber-800 via-yellow-600 to-amber-800 text-center py-4 overflow-hidden">
					<div class="absolute inset-0 opacity-20 bg-[repeating-linear-gradient(90deg,transparent,transparent_8px,rgba(0,0,0,0.15)_8px,rgba(0,0,0,0.15)_9px)]"></div>
					<span class="relative text-amber-950 text-sm tracking-[0.5em] font-black">❋ ✦ ★ ◆ ★ ✦ ❋</span>
				</div>
			</div>
		</article>

		<!-- ═══════ More Stories — Rose Section ═══════ -->
		<section class="mt-20">
			<div class="text-center mb-12">
				<p class="text-rose-400 tracking-[0.4em] text-xs mb-4">❋ ★ ✿ ★ ❋</p>
				<h2 class="font-serif text-3xl md:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-rose-300 via-pink-200 to-rose-400">
					{t.blog.moreStories}
				</h2>
				<p class="text-rose-400 tracking-[0.4em] text-xs mt-4">❋ ★ ✿ ★ ❋</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
				{otherPosts.map((p: any) => (
					<a href={`/${lang}/${style}/blog/${p.slug}`} class="group block">
						<div class="relative bg-gradient-to-b from-rose-900/50 to-purple-950/70 border-2 border-rose-600/30 shadow-[0_6px_24px_rgba(136,19,55,0.4)] hover:shadow-[0_12px_40px_rgba(180,120,0,0.15),0_6px_24px_rgba(136,19,55,0.4)] hover:border-amber-400/60 transition-all duration-700 overflow-hidden">
							<div class="bg-gradient-to-r from-rose-800/50 via-pink-700/50 to-rose-800/50 text-center py-2">
								<span class="text-rose-300/50 text-xs tracking-[0.3em]">❋ ◆ ❋</span>
							</div>
							<div class="p-5 md:p-7">
								<h3 class="font-serif text-xl md:text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-yellow-200 mb-3 group-hover:from-yellow-100 group-hover:to-amber-300 leading-tight">
									{p.title}
								</h3>
								<div class="w-12 h-0.5 bg-gradient-to-r from-amber-500 to-transparent mb-3"></div>
								<p class="text-purple-200/60 text-sm leading-relaxed">
									{p.excerpt}
								</p>
							</div>
						</div>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
