---
const { lang, style, nav, cat, otherCats, t } = Astro.props;

const detailColors = [
	{ bg: 'from-emerald-800/50 to-emerald-900/60', border: 'border-emerald-500/40', dt: 'text-emerald-400', dd: 'text-emerald-100' },
	{ bg: 'from-purple-800/50 to-purple-900/60', border: 'border-purple-500/40', dt: 'text-purple-400', dd: 'text-purple-100' },
	{ bg: 'from-rose-800/50 to-rose-900/60', border: 'border-rose-500/40', dt: 'text-rose-400', dd: 'text-rose-100' },
	{ bg: 'from-indigo-800/50 to-indigo-900/60', border: 'border-indigo-500/40', dt: 'text-indigo-400', dd: 'text-indigo-100' },
	{ bg: 'from-teal-800/50 to-teal-900/60', border: 'border-teal-500/40', dt: 'text-teal-400', dd: 'text-teal-100' },
	{ bg: 'from-amber-800/50 to-amber-900/60', border: 'border-amber-500/40', dt: 'text-amber-400', dd: 'text-amber-100' },
];
const details = [
	{ key: t.cats.breed, value: cat.breed },
	{ key: t.cats.age, value: cat.age },
	{ key: t.cats.gender, value: cat.gender },
	{ key: t.cats.color, value: cat.color },
	{ key: t.cats.arrived, value: cat.arrivalDate },
	{ key: t.cats.status, value: cat.status },
];
---

<div class="min-h-screen bg-gradient-to-b from-emerald-950 via-teal-950 to-indigo-950">
	<!-- Navigation -->
	<nav class="relative bg-gradient-to-r from-amber-950 via-yellow-900 to-amber-950 border-b-4 border-double border-amber-400 shadow-[0_8px_32px_rgba(180,120,0,0.4)]">
		<div class="absolute inset-0 opacity-10 bg-[repeating-linear-gradient(90deg,transparent,transparent_12px,rgba(255,215,0,0.15)_12px,rgba(255,215,0,0.15)_14px)]"></div>
		<div class="relative max-w-7xl mx-auto px-4 pt-4 pb-2 flex flex-wrap items-center justify-center gap-1 md:gap-4">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 font-bold text-amber-200 uppercase tracking-[0.25em] text-xs hover:text-white hover:bg-amber-700/60 rounded-sm transition-all duration-300 border border-transparent hover:border-amber-300 hover:shadow-lg hover:shadow-amber-500/20">
					{item.label}
				</a>
			))}
		</div>
		<div class="relative text-center text-amber-500 text-xs tracking-[0.6em] py-1.5 border-t border-amber-700/50">❧ ✦ ◆ ★ ◆ ✦ ❧ ✦ ◆ ★ ◆ ✦ ❧</div>
	</nav>

	<main class="max-w-5xl mx-auto px-4 py-10 md:py-16">
		<!-- Back Link -->
		<a href={`/${lang}/${style}/cats`} class="inline-flex items-center gap-2 text-amber-400 hover:text-amber-200 font-bold uppercase tracking-[0.2em] text-xs mb-10 transition-colors group">
			<span class="text-lg group-hover:-translate-x-1 transition-transform duration-300">&larr;</span>
			<span>❧ {t.cats.backToAll}</span>
		</a>

		<!-- ═══════ Profile Card — Grand Ornamental Frame ═══════ -->
		<article class="relative">
			<!-- Outermost decorative border -->
			<div class="absolute -inset-2 border border-amber-500/15 hidden md:block"></div>
			<div class="absolute -inset-1 border border-amber-500/10 hidden md:block"></div>

			<div class="relative bg-gradient-to-b from-emerald-900/50 via-teal-950/70 to-indigo-950/80 border-2 border-amber-500/50 shadow-[0_12px_60px_rgba(6,78,59,0.5),0_0_100px_rgba(180,120,0,0.06)] overflow-hidden">
				<!-- Top Grand Ornament Bar -->
				<div class="relative bg-gradient-to-r from-amber-800 via-yellow-600 to-amber-800 text-center py-4 overflow-hidden">
					<div class="absolute inset-0 opacity-20 bg-[repeating-linear-gradient(90deg,transparent,transparent_8px,rgba(0,0,0,0.15)_8px,rgba(0,0,0,0.15)_9px)]"></div>
					<span class="relative text-amber-950 text-sm tracking-[0.5em] font-black">★ ❋ ✦ ◆ ✦ ❋ ★</span>
				</div>

				<div class="p-6 md:p-10 lg:p-16">
					<!-- Name — Triple frame -->
					<div class="text-center mb-12">
						<p class="text-amber-500 tracking-[0.4em] text-xs mb-4">❧ ✿ ★ ✿ ❧</p>
						<div class="inline-block border-2 border-amber-600/25 p-2 md:p-3">
							<div class="border border-amber-500/15 px-6 md:px-12 py-3 md:py-5">
								<h1 class="font-serif text-5xl md:text-7xl lg:text-8xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-yellow-100 to-amber-400 leading-none">
									{cat.name}
								</h1>
							</div>
						</div>
						<p class="text-amber-500 tracking-[0.4em] text-xs mt-4">❧ ✿ ★ ✿ ❧</p>
					</div>

					<!-- Details Grid — Each tile a different jewel color -->
					<dl class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6 mb-12">
						{details.map((detail, i) => (
							<div class={`group relative bg-gradient-to-b ${detailColors[i].bg} border-2 ${detailColors[i].border} p-4 md:p-5 text-center shadow-[0_4px_20px_rgba(0,0,0,0.3)] hover:shadow-[0_8px_30px_rgba(0,0,0,0.4)] transition-all duration-300`}>
								<span class="absolute top-1.5 left-1.5 text-amber-500/30 text-[10px]">◆</span>
								<span class="absolute top-1.5 right-1.5 text-amber-500/30 text-[10px]">◆</span>
								<dt class={`${detailColors[i].dt} text-xs uppercase tracking-[0.2em] font-bold mb-2`}>✦ {detail.key}</dt>
								<dd class={`${detailColors[i].dd} font-serif text-lg md:text-xl font-bold`}>{detail.value}</dd>
							</div>
						))}
					</dl>

					<!-- Ornamental Divider -->
					<div class="text-center py-5">
						<span class="text-amber-500/40 text-lg tracking-[0.4em]">║ ◆ ✦ ★ ✿ ★ ✦ ◆ ║</span>
					</div>

					<!-- Personality Traits — Jeweled badges -->
					<div class="flex flex-wrap gap-3 justify-center mb-12">
						{cat.personality.map((trait: string) => (
							<span class="relative px-6 py-2.5 bg-gradient-to-r from-purple-800/60 via-violet-800/50 to-indigo-800/60 border-2 border-purple-400/35 text-purple-200 font-bold uppercase tracking-[0.15em] text-sm shadow-[0_4px_16px_rgba(88,28,135,0.4)]">
								<span class="absolute -inset-0.5 border border-purple-400/10"></span>
								✿ {trait}
							</span>
						))}
					</div>

					<!-- Description — Ornate quote box -->
					<div class="relative border-2 border-amber-600/25 p-2 mb-12">
						<div class="border border-amber-500/15 p-1">
							<div class="bg-gradient-to-r from-emerald-900/50 via-teal-900/40 to-emerald-900/50 border border-amber-600/20 px-8 md:px-12 py-8 shadow-[inset_0_2px_20px_rgba(0,0,0,0.3)]">
								<span class="block text-amber-500 text-2xl mb-3 font-serif">&#8220;</span>
								<p class="text-emerald-100 text-lg md:text-xl leading-relaxed font-serif italic">
									{cat.description}
								</p>
								<span class="block text-amber-500 text-2xl mt-3 font-serif text-right">&#8221;</span>
							</div>
						</div>
					</div>

					<!-- Adopt CTA — Grand button -->
					<div class="text-center">
						<a href={`/${lang}/${style}/auth`} class="group relative inline-block">
							<span class="absolute -inset-2 border border-rose-400/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
							<span class="absolute -inset-1 border border-rose-400/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
							<span class="relative inline-block px-14 py-5 bg-gradient-to-r from-rose-700 via-pink-600 to-rose-700 text-white font-black uppercase tracking-[0.2em] text-lg shadow-[0_0_40px_rgba(225,29,72,0.25)] hover:shadow-[0_0_60px_rgba(225,29,72,0.4)] transition-all duration-500 border-2 border-rose-400">
								★ {t.cats.adopt} {cat.name} ★
							</span>
						</a>
					</div>
				</div>

				<!-- Bottom Grand Ornament Bar -->
				<div class="relative bg-gradient-to-r from-amber-800 via-yellow-600 to-amber-800 text-center py-4 overflow-hidden">
					<div class="absolute inset-0 opacity-20 bg-[repeating-linear-gradient(90deg,transparent,transparent_8px,rgba(0,0,0,0.15)_8px,rgba(0,0,0,0.15)_9px)]"></div>
					<span class="relative text-amber-950 text-sm tracking-[0.5em] font-black">★ ❋ ✦ ◆ ✦ ❋ ★</span>
				</div>
			</div>
		</article>

		<!-- ═══════ Other Cats — Sapphire Section ═══════ -->
		<section class="mt-20">
			<div class="text-center mb-12">
				<p class="text-indigo-400 tracking-[0.4em] text-xs mb-4">❋ ★ ✦ ★ ❋</p>
				<h2 class="font-serif text-3xl md:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-indigo-300 via-blue-200 to-indigo-400">
					{t.cats.otherCats}
				</h2>
				<p class="text-indigo-400 tracking-[0.4em] text-xs mt-4">❋ ★ ✦ ★ ❋</p>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
				{otherCats.map((c: any) => (
					<a href={`/${lang}/${style}/cats/${c.id}`} class="group block">
						<div class="relative bg-gradient-to-b from-indigo-900/60 to-blue-950/70 border-2 border-indigo-500/30 shadow-[0_6px_24px_rgba(49,46,129,0.5)] hover:shadow-[0_12px_40px_rgba(180,120,0,0.15),0_6px_24px_rgba(49,46,129,0.5)] hover:border-amber-400/60 transition-all duration-700 overflow-hidden">
							<div class="bg-gradient-to-r from-indigo-700/50 via-blue-600/50 to-indigo-700/50 text-center py-2">
								<span class="text-indigo-200/50 text-xs tracking-[0.3em]">✦ ◆ ✦</span>
							</div>
							<div class="p-5 md:p-6">
								<h3 class="font-serif text-xl md:text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-yellow-200 mb-2 group-hover:from-yellow-100 group-hover:to-amber-300 leading-tight">
									{c.name}
								</h3>
								<p class="text-indigo-300 text-xs uppercase tracking-wider font-semibold flex items-center gap-2">
									<span>{c.breed}</span>
									<span class="text-amber-500/40">◆</span>
									<span>{c.age}</span>
								</p>
							</div>
						</div>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
