---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-emerald-950 via-teal-950 to-indigo-950">
	<!-- Navigation -->
	<nav class="bg-gradient-to-r from-amber-900 via-yellow-800 to-amber-900 border-b-4 border-amber-400 shadow-2xl shadow-amber-900/50">
		<div class="max-w-7xl mx-auto px-4 py-4 flex flex-wrap items-center justify-center gap-2 md:gap-6">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 font-bold text-amber-100 uppercase tracking-widest text-sm hover:text-white hover:bg-amber-700/50 rounded-sm transition-all duration-300 border border-transparent hover:border-amber-400">
					{item.label}
				</a>
			))}
		</div>
		<div class="text-center text-amber-400 text-xs tracking-[0.5em] py-1">✦ ◆ ✦ ◆ ✦ ◆ ✦ ◆ ✦ ◆ ✦</div>
	</nav>

	<main class="max-w-5xl mx-auto px-4 py-10 md:py-16">
		<!-- Back Link -->
		<a href={`/${lang}/${style}/cats`} class="inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 font-bold uppercase tracking-widest text-sm mb-10 transition-colors">
			<span class="text-lg">&larr;</span> <span>❧ {t.cats.backToAll}</span>
		</a>

		<!-- Cat Profile Card -->
		<article class="bg-gradient-to-b from-emerald-900/60 to-teal-950/80 border-2 border-amber-500/50 rounded-sm shadow-2xl shadow-emerald-900/60 overflow-hidden">
			<!-- Card Top Ornament -->
			<div class="bg-gradient-to-r from-amber-700 via-yellow-600 to-amber-700 text-center py-3">
				<span class="text-amber-950 text-sm tracking-[0.4em] font-black">★ ✦ ◆ ✦ ★</span>
			</div>

			<div class="p-6 md:p-10 lg:p-14">
				<!-- Name -->
				<div class="text-center mb-10">
					<p class="text-amber-400 tracking-[0.3em] text-sm mb-3">❧ ✿ ❧</p>
					<h1 class="font-serif text-5xl md:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-yellow-200 to-amber-400 mb-4">
						{cat.name}
					</h1>
					<p class="text-amber-400 tracking-[0.3em] text-sm">❧ ✿ ❧</p>
				</div>

				<!-- Details Grid -->
				<dl class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6 mb-10">
					<div class="bg-gradient-to-b from-emerald-800/50 to-emerald-900/50 border border-emerald-600/40 rounded-sm p-4 text-center shadow-lg">
						<dt class="text-emerald-400 text-xs uppercase tracking-widest font-bold mb-2">✦ {t.cats.breed}</dt>
						<dd class="text-emerald-100 font-serif text-lg font-bold">{cat.breed}</dd>
					</div>
					<div class="bg-gradient-to-b from-purple-800/50 to-purple-900/50 border border-purple-600/40 rounded-sm p-4 text-center shadow-lg">
						<dt class="text-purple-400 text-xs uppercase tracking-widest font-bold mb-2">✦ {t.cats.age}</dt>
						<dd class="text-purple-100 font-serif text-lg font-bold">{cat.age}</dd>
					</div>
					<div class="bg-gradient-to-b from-rose-800/50 to-rose-900/50 border border-rose-600/40 rounded-sm p-4 text-center shadow-lg">
						<dt class="text-rose-400 text-xs uppercase tracking-widest font-bold mb-2">✦ {t.cats.gender}</dt>
						<dd class="text-rose-100 font-serif text-lg font-bold">{cat.gender}</dd>
					</div>
					<div class="bg-gradient-to-b from-indigo-800/50 to-indigo-900/50 border border-indigo-600/40 rounded-sm p-4 text-center shadow-lg">
						<dt class="text-indigo-400 text-xs uppercase tracking-widest font-bold mb-2">✦ {t.cats.color}</dt>
						<dd class="text-indigo-100 font-serif text-lg font-bold">{cat.color}</dd>
					</div>
					<div class="bg-gradient-to-b from-teal-800/50 to-teal-900/50 border border-teal-600/40 rounded-sm p-4 text-center shadow-lg">
						<dt class="text-teal-400 text-xs uppercase tracking-widest font-bold mb-2">✦ {t.cats.arrived}</dt>
						<dd class="text-teal-100 font-serif text-lg font-bold">{cat.arrivalDate}</dd>
					</div>
					<div class="bg-gradient-to-b from-amber-800/50 to-amber-900/50 border border-amber-600/40 rounded-sm p-4 text-center shadow-lg">
						<dt class="text-amber-400 text-xs uppercase tracking-widest font-bold mb-2">✦ {t.cats.status}</dt>
						<dd class="text-amber-100 font-serif text-lg font-bold">{cat.status}</dd>
					</div>
				</dl>

				<!-- Divider -->
				<div class="text-center py-4">
					<span class="text-amber-500/60 text-lg tracking-[0.3em]">◆ ✦ ◆ ✦ ◆ ✦ ◆</span>
				</div>

				<!-- Personality -->
				<div class="flex flex-wrap gap-3 justify-center mb-10">
					{cat.personality.map((trait: string) => (
						<span class="px-5 py-2 bg-gradient-to-r from-purple-800/60 to-indigo-800/60 border-2 border-purple-400/40 text-purple-200 font-bold uppercase tracking-widest text-sm rounded-sm shadow-lg">
							✿ {trait}
						</span>
					))}
				</div>

				<!-- Description -->
				<div class="bg-gradient-to-r from-emerald-900/40 via-teal-900/30 to-emerald-900/40 border-l-4 border-r-4 border-amber-500 px-6 md:px-10 py-6 rounded-sm shadow-inner mb-10">
					<p class="text-emerald-100 text-lg leading-relaxed font-serif italic">
						{cat.description}
					</p>
				</div>

				<!-- Adopt Button -->
				<div class="text-center">
					<a href={`/${lang}/${style}/auth`} class="inline-block px-12 py-5 bg-gradient-to-r from-rose-700 via-pink-600 to-rose-700 text-white font-black uppercase tracking-widest text-lg rounded-sm shadow-2xl shadow-rose-700/40 hover:from-rose-600 hover:via-pink-500 hover:to-rose-600 transition-all duration-300 border-2 border-rose-400">
						★ {t.cats.adopt} {cat.name} ★
					</a>
				</div>
			</div>

			<!-- Card Bottom Ornament -->
			<div class="bg-gradient-to-r from-amber-700 via-yellow-600 to-amber-700 text-center py-3">
				<span class="text-amber-950 text-sm tracking-[0.4em] font-black">★ ✦ ◆ ✦ ★</span>
			</div>
		</article>

		<!-- Other Cats Section -->
		<section class="mt-16">
			<div class="text-center mb-10">
				<p class="text-amber-400 tracking-[0.3em] text-sm mb-4">❋ ✦ ❋</p>
				<h2 class="font-serif text-3xl md:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-yellow-200 to-amber-400">
					{t.cats.otherCats}
				</h2>
				<p class="text-amber-400 tracking-[0.3em] text-sm mt-4">❋ ✦ ❋</p>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
				{otherCats.map((c: any) => (
					<a href={`/${lang}/${style}/cats/${c.id}`} class="group block bg-gradient-to-b from-purple-900/60 to-indigo-950/60 border-2 border-purple-600/40 rounded-sm shadow-xl hover:shadow-2xl hover:border-amber-400 transition-all duration-500 overflow-hidden">
						<div class="bg-gradient-to-r from-purple-700/50 via-indigo-700/50 to-purple-700/50 text-center py-1.5">
							<span class="text-purple-300/60 text-xs tracking-[0.3em]">✦ ◆ ✦</span>
						</div>
						<div class="p-5">
							<h3 class="font-serif text-xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-yellow-200 mb-2 group-hover:from-yellow-200 group-hover:to-amber-300">
								{c.name}
							</h3>
							<p class="text-purple-300 text-sm uppercase tracking-wide font-semibold">
								{c.breed} ║ {c.age}
							</p>
						</div>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
