---
const { lang, style, nav, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-gradient-to-b from-rose-950 via-purple-950 to-indigo-950">
	<!-- Navigation -->
	<nav class="relative bg-gradient-to-r from-amber-950 via-yellow-900 to-amber-950 border-b-4 border-double border-amber-400 shadow-[0_8px_32px_rgba(180,120,0,0.4)]">
		<div class="absolute inset-0 opacity-10 bg-[repeating-linear-gradient(90deg,transparent,transparent_12px,rgba(255,215,0,0.15)_12px,rgba(255,215,0,0.15)_14px)]"></div>
		<div class="relative max-w-7xl mx-auto px-4 pt-4 pb-2 flex flex-wrap items-center justify-center gap-1 md:gap-4">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 font-bold text-amber-200 uppercase tracking-[0.25em] text-xs hover:text-white hover:bg-amber-700/60 rounded-sm transition-all duration-300 border border-transparent hover:border-amber-300 hover:shadow-lg hover:shadow-amber-500/20">
					{item.label}
				</a>
			))}
		</div>
		<div class="relative text-center text-amber-500 text-xs tracking-[0.6em] py-1.5 border-t border-amber-700/50">❧ ✦ ◆ ★ ◆ ✦ ❧ ✦ ◆ ★ ◆ ✦ ❧</div>
	</nav>

	<!-- ═══════ Full-bleed layered background ═══════ -->
	<main class="relative flex items-center justify-center px-4 py-20 md:py-32 overflow-hidden min-h-[calc(100vh-5rem)]">
		<!-- Rose/garnet herringbone texture -->
		<div class="absolute inset-0 opacity-[0.04] bg-[repeating-linear-gradient(135deg,transparent,transparent_8px,rgba(251,113,133,0.2)_8px,rgba(251,113,133,0.2)_10px,transparent_10px,transparent_18px,rgba(251,113,133,0.2)_18px,rgba(251,113,133,0.2)_20px)]"></div>
		<!-- Radial vignette -->
		<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(136,19,55,0.12)_0%,transparent_60%)]"></div>

		<section class="relative text-center max-w-2xl">
			<!-- Top ornament -->
			<p class="text-amber-500 tracking-[0.5em] text-xs mb-8">❋ ✦ ★ ◆ ✿ ◆ ★ ✦ ❋</p>

			<!-- 404 — Grand framed number -->
			<div class="border-2 border-amber-600/25 p-3 md:p-4 inline-block mb-8">
				<div class="border border-amber-500/15 px-8 md:px-16 py-4 md:py-6">
					<h1 class="font-serif text-8xl md:text-[10rem] font-black text-transparent bg-clip-text bg-gradient-to-b from-amber-300 via-yellow-100 to-amber-500 leading-none">
						{t.notFound.title}
					</h1>
				</div>
			</div>

			<!-- Heading -->
			<h2 class="font-serif text-3xl md:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-rose-300 via-pink-200 to-rose-400 mb-8 drop-shadow-lg">
				{t.notFound.heading}
			</h2>

			<!-- Description in ornate quote frame -->
			<div class="relative border-2 border-rose-600/25 p-2 mx-auto max-w-xl mb-10">
				<div class="border border-rose-400/15 p-1">
					<div class="bg-gradient-to-r from-purple-900/50 via-rose-900/30 to-purple-900/50 border border-amber-600/15 px-8 md:px-12 py-8 shadow-[inset_0_2px_20px_rgba(0,0,0,0.3)]">
						<p class="text-purple-200 text-lg md:text-xl font-serif italic leading-relaxed">
							{t.notFound.description}
						</p>
					</div>
				</div>
			</div>

			<!-- Ornamental divider -->
			<div class="mb-10">
				<div class="flex items-center gap-3 max-w-xs mx-auto">
					<div class="flex-1 h-px bg-gradient-to-r from-transparent via-amber-500/40 to-amber-500/40"></div>
					<span class="text-amber-500/50 text-sm tracking-[0.3em]">◆ ✦ ◆</span>
					<div class="flex-1 h-px bg-gradient-to-l from-transparent via-amber-500/40 to-amber-500/40"></div>
				</div>
			</div>

			<!-- Action Buttons — Grand CTAs -->
			<div class="flex flex-col sm:flex-row gap-5 justify-center items-center">
				<a href={`${_base}/${lang}/${style}/`} class="group relative">
					<span class="absolute -inset-1.5 border border-amber-400/15 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
					<span class="relative inline-block px-12 py-5 bg-gradient-to-r from-amber-600 via-yellow-500 to-amber-600 text-amber-950 font-black uppercase tracking-[0.2em] text-lg shadow-[0_0_40px_rgba(245,158,11,0.3)] hover:shadow-[0_0_60px_rgba(245,158,11,0.45)] transition-all duration-500 border-2 border-amber-300">
						★ {t.notFound.backHome} ★
					</span>
				</a>
				<a href={`${_base}/${lang}/${style}/cats`} class="group relative">
					<span class="absolute -inset-1.5 border border-emerald-400/15 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
					<span class="relative inline-block px-12 py-5 bg-gradient-to-b from-emerald-700 via-emerald-600 to-emerald-800 text-emerald-50 font-black uppercase tracking-[0.2em] text-lg shadow-[0_0_40px_rgba(16,185,129,0.2)] hover:shadow-[0_0_60px_rgba(16,185,129,0.35)] transition-all duration-500 border-2 border-emerald-400">
						✿ {t.notFound.meetCats} ✿
					</span>
				</a>
			</div>

			<!-- Bottom ornament -->
			<p class="text-amber-500/60 tracking-[0.5em] text-xs mt-12">❋ ✦ ★ ◆ ✿ ◆ ★ ✦ ❋</p>
		</section>
	</main>
</div>
