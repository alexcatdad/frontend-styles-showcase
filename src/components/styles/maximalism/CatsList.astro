---
const { lang, style, nav, cats, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-indigo-950 via-purple-950 to-violet-950">
	<!-- Navigation -->
	<nav class="bg-gradient-to-r from-amber-900 via-yellow-800 to-amber-900 border-b-4 border-amber-400 shadow-2xl shadow-amber-900/50">
		<div class="max-w-7xl mx-auto px-4 py-4 flex flex-wrap items-center justify-center gap-2 md:gap-6">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 font-bold text-amber-100 uppercase tracking-widest text-sm hover:text-white hover:bg-amber-700/50 rounded-sm transition-all duration-300 border border-transparent hover:border-amber-400">
					{item.label}
				</a>
			))}
		</div>
		<div class="text-center text-amber-400 text-xs tracking-[0.5em] py-1">тЬж тЧЖ тЬж тЧЖ тЬж тЧЖ тЬж тЧЖ тЬж тЧЖ тЬж</div>
	</nav>

	<main class="max-w-7xl mx-auto px-4 py-12 md:py-20">
		<!-- Header -->
		<div class="text-center mb-16">
			<p class="text-amber-400 tracking-[0.4em] text-sm mb-4">тЭз тЬ┐ тЭз тЬ┐ тЭз</p>
			<h1 class="font-serif text-5xl md:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-yellow-200 to-amber-400 mb-6">
				{t.cats.title}
			</h1>
			<p class="text-purple-200 text-xl md:text-2xl font-serif italic max-w-2xl mx-auto">
				{t.cats.subtitle}
			</p>
			<p class="text-amber-400 tracking-[0.4em] text-sm mt-6">тЭз тЬ┐ тЭз тЬ┐ тЭз</p>
		</div>

		<!-- Cats Grid -->
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
			{cats.map((cat: any) => (
				<a href={`/${lang}/${style}/cats/${cat.id}`} class="group block">
					<div class="bg-gradient-to-b from-purple-900/80 to-indigo-950/80 border-2 border-amber-600/40 rounded-sm shadow-xl shadow-purple-900/50 hover:shadow-2xl hover:shadow-amber-500/20 hover:border-amber-400 transition-all duration-500 overflow-hidden">
						<!-- Card Top Ornament -->
						<div class="bg-gradient-to-r from-amber-700 via-yellow-600 to-amber-700 text-center py-2">
							<span class="text-amber-950 text-xs tracking-[0.3em] font-bold">тЬж тЧЖ тЬж</span>
						</div>

						<div class="p-6">
							<h2 class="font-serif text-2xl md:text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-yellow-200 mb-3 group-hover:from-yellow-200 group-hover:to-amber-300 transition-all">
								{cat.name}
							</h2>
							<p class="text-purple-300 font-semibold tracking-wide text-sm mb-4 uppercase">
								{cat.breed} тХС {cat.age} тХС {cat.gender}
							</p>
							<p class="text-purple-200/80 leading-relaxed mb-5 text-sm">
								{cat.description.slice(0, 100)}...
							</p>

							<!-- Personality Tags -->
							<div class="flex flex-wrap gap-2 mb-5">
								{cat.personality.map((trait: string) => (
									<span class="px-3 py-1 bg-gradient-to-r from-emerald-800/60 to-teal-800/60 border border-emerald-500/40 text-emerald-200 text-xs font-bold uppercase tracking-wider rounded-sm">
										тЬ┐ {trait}
									</span>
								))}
							</div>

							<!-- Status Badge -->
							<div class="flex justify-between items-center pt-4 border-t border-amber-600/30">
								<span class="px-4 py-1.5 bg-gradient-to-r from-rose-800/60 to-pink-800/60 border border-rose-500/40 text-rose-200 text-xs font-black uppercase tracking-widest rounded-sm shadow-lg">
									тШЕ {cat.status}
								</span>
								<span class="text-amber-400 text-sm font-bold group-hover:translate-x-1 transition-transform duration-300">
									тЭз &rarr;
								</span>
							</div>
						</div>

						<!-- Card Bottom Ornament -->
						<div class="bg-gradient-to-r from-amber-700/50 via-yellow-600/50 to-amber-700/50 text-center py-1.5">
							<span class="text-amber-300/60 text-xs tracking-[0.3em]">тЧЖ тЧЖ тЧЖ</span>
						</div>
					</div>
				</a>
			))}
		</div>
	</main>
</div>
