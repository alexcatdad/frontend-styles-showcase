---
const { lang, style, nav, cats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-gradient-to-b from-indigo-950 via-purple-950 to-violet-950">
	<!-- Navigation — Gilded Ribbon -->
	<nav class="relative bg-gradient-to-r from-amber-950 via-yellow-900 to-amber-950 border-b-4 border-double border-amber-400 shadow-[0_8px_32px_rgba(180,120,0,0.4)]">
		<div class="absolute inset-0 opacity-10 bg-[repeating-linear-gradient(90deg,transparent,transparent_12px,rgba(255,215,0,0.15)_12px,rgba(255,215,0,0.15)_14px)]"></div>
		<div class="relative max-w-7xl mx-auto px-4 pt-4 pb-2 flex flex-wrap items-center justify-center gap-1 md:gap-4">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 font-bold text-amber-200 uppercase tracking-[0.25em] text-xs hover:text-white hover:bg-amber-700/60 rounded-sm transition-all duration-300 border border-transparent hover:border-amber-300 hover:shadow-lg hover:shadow-amber-500/20">
					{item.label}
				</a>
			))}
		</div>
		<div class="relative text-center text-amber-500 text-xs tracking-[0.6em] py-1.5 border-t border-amber-700/50">❧ ✦ ◆ ★ ◆ ✦ ❧ ✦ ◆ ★ ◆ ✦ ❧</div>
	</nav>

	<main>
		<!-- ═══════════════════ HEADER — Deep Sapphire ═══════════════════ -->
		<section class="relative bg-gradient-to-b from-blue-950 via-indigo-950 to-purple-950 py-16 md:py-24 px-4 text-center overflow-hidden">
			<div class="absolute inset-0 opacity-[0.05] bg-[repeating-linear-gradient(45deg,transparent,transparent_18px,rgba(255,215,0,0.3)_18px,rgba(255,215,0,0.3)_20px)]"></div>
			<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(99,102,241,0.12)_0%,transparent_60%)]"></div>

			<div class="relative max-w-4xl mx-auto">
				<p class="text-amber-500 tracking-[0.5em] text-xs mb-5">❧ ✿ ★ ✿ ❧</p>
				<div class="border-2 border-amber-600/25 p-3 md:p-4 inline-block">
					<div class="border border-amber-500/15 px-8 md:px-16 py-4 md:py-6">
						<h1 class="font-serif text-5xl md:text-7xl lg:text-8xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-yellow-100 to-amber-400 leading-none">
							{t.cats.title}
						</h1>
					</div>
				</div>
				<p class="text-blue-200 text-xl md:text-2xl font-serif italic max-w-2xl mx-auto mt-6">
					{t.cats.subtitle}
				</p>
				<p class="text-amber-500 tracking-[0.5em] text-xs mt-6">❧ ✿ ★ ✿ ❧</p>
			</div>
		</section>

		<!-- Divider -->
		<div class="relative py-4 bg-gradient-to-r from-purple-950 via-amber-900/15 to-purple-950">
			<div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-amber-500/50 to-transparent"></div>
			<div class="text-center"><span class="text-amber-400 text-xl tracking-[0.4em]">❋ ◆ ✦ ★ ✦ ◆ ❋</span></div>
			<div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-amber-500/50 to-transparent"></div>
		</div>

		<!-- ═══════════════════ CATS GRID — Royal Purple ═══════════════════ -->
		<section class="relative bg-gradient-to-br from-purple-950 via-violet-950 to-indigo-950 py-14 md:py-20 px-4 overflow-hidden">
			<div class="absolute inset-0 opacity-[0.04] bg-[repeating-conic-gradient(rgba(168,85,247,0.3)_0%_25%,transparent_0%_50%)] bg-[length:28px_28px]"></div>

			<div class="relative max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
				{cats.map((cat: any) => (
					<a href={`${_base}/${lang}/${style}/cats/${cat.id}`} class="group block">
						<!-- Triple-layered card frame -->
						<div class="relative">
							<div class="absolute -inset-1.5 border border-amber-500/15 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
							<div class="absolute -inset-0.5 border border-amber-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

							<div class="relative bg-gradient-to-b from-purple-900/70 via-violet-900/50 to-indigo-950/90 border-2 border-amber-600/35 shadow-[0_8px_40px_rgba(88,28,135,0.5)] group-hover:shadow-[0_16px_60px_rgba(180,120,0,0.2),0_8px_40px_rgba(88,28,135,0.5)] group-hover:border-amber-400/70 transition-all duration-700 overflow-hidden">
								<!-- Top ornamental band -->
								<div class="bg-gradient-to-r from-amber-800 via-yellow-600 to-amber-800 text-center py-2.5 relative">
									<div class="absolute inset-0 opacity-20 bg-[repeating-linear-gradient(90deg,transparent,transparent_6px,rgba(0,0,0,0.2)_6px,rgba(0,0,0,0.2)_7px)]"></div>
									<span class="relative text-amber-950 text-xs tracking-[0.4em] font-black">✦ ◆ ★ ◆ ✦</span>
								</div>

								<div class="p-6 md:p-7">
									<!-- Cat thumbnail -->
									<img src={cat.thumbnail} alt={cat.name} class="w-full h-40 md:h-48 object-cover border-2 border-amber-500/30 shadow-[0_4px_20px_rgba(0,0,0,0.3)] mb-5" />

									<!-- Name with decorative rule -->
									<h2 class="font-serif text-2xl md:text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-yellow-200 to-amber-400 mb-1 group-hover:from-yellow-100 group-hover:to-amber-300 transition-all leading-tight">
										{cat.name}
									</h2>
									<div class="w-16 h-0.5 bg-gradient-to-r from-amber-500 to-transparent mb-4"></div>

									<p class="text-purple-300 font-semibold tracking-wider text-xs mb-5 uppercase flex items-center gap-2 flex-wrap">
										<span>{cat.breed}</span>
										<span class="text-amber-500/50">◆</span>
										<span>{cat.age}</span>
										<span class="text-amber-500/50">◆</span>
										<span>{cat.gender}</span>
									</p>

									<p class="text-purple-200/70 leading-relaxed mb-5 text-sm border-l-2 border-purple-500/30 pl-4">
										{cat.description.slice(0, 110)}...
									</p>

									<!-- Personality tags -->
									<div class="flex flex-wrap gap-2 mb-6">
										{cat.personality.map((trait: string) => (
											<span class="px-3 py-1 bg-gradient-to-r from-emerald-900/70 to-teal-900/70 border border-emerald-500/30 text-emerald-200 text-xs font-bold uppercase tracking-wider shadow-md">
												✿ {trait}
											</span>
										))}
									</div>

									<!-- Status & arrow -->
									<div class="flex justify-between items-center pt-5 border-t-2 border-amber-600/20">
										<span class="relative px-4 py-1.5 bg-gradient-to-r from-rose-900/70 to-pink-900/70 border border-rose-500/40 text-rose-200 text-xs font-black uppercase tracking-[0.15em] shadow-lg">
											<span class="absolute -top-px -left-px -right-px -bottom-px border border-rose-400/15"></span>
											★ {cat.status}
										</span>
										<span class="text-amber-400 font-bold group-hover:translate-x-2 transition-transform duration-500 text-lg">
											❧ &rarr;
										</span>
									</div>
								</div>

								<!-- Bottom ornamental band -->
								<div class="bg-gradient-to-r from-amber-800/40 via-yellow-700/40 to-amber-800/40 text-center py-1.5">
									<span class="text-amber-400/40 text-xs tracking-[0.4em]">◆ ✦ ◆</span>
								</div>
							</div>
						</div>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
