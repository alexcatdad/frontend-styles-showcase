---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-purple-950 via-indigo-950 to-violet-950">
	<!-- Navigation -->
	<nav class="bg-gradient-to-r from-amber-900 via-yellow-800 to-amber-900 border-b-4 border-amber-400 shadow-2xl shadow-amber-900/50">
		<div class="max-w-7xl mx-auto px-4 py-4 flex flex-wrap items-center justify-center gap-2 md:gap-6">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 font-bold text-amber-100 uppercase tracking-widest text-sm hover:text-white hover:bg-amber-700/50 rounded-sm transition-all duration-300 border border-transparent hover:border-amber-400">
					{item.label}
				</a>
			))}
		</div>
		<div class="text-center text-amber-400 text-xs tracking-[0.5em] py-1">✦ ◆ ✦ ◆ ✦ ◆ ✦ ◆ ✦ ◆ ✦</div>
	</nav>

	<main class="flex items-center justify-center px-4 py-16 md:py-24">
		<section class="w-full max-w-lg">
			<!-- Auth Card -->
			<div class="bg-gradient-to-b from-purple-900/70 to-indigo-950/90 border-2 border-amber-500/50 rounded-sm shadow-2xl shadow-purple-900/60 overflow-hidden">
				<!-- Top Ornament -->
				<div class="bg-gradient-to-r from-amber-700 via-yellow-600 to-amber-700 text-center py-3">
					<span class="text-amber-950 text-sm tracking-[0.4em] font-black">✦ ★ ◆ ★ ✦</span>
				</div>

				<div class="p-8 md:p-10">
					<!-- Header -->
					<div class="text-center mb-8">
						<p class="text-amber-400 tracking-[0.3em] text-sm mb-3">❧ ✿ ❧</p>
						<h1 class="font-serif text-4xl md:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-yellow-200 to-amber-400 mb-3">
							{t.auth.title}
						</h1>
						<p class="text-purple-300 font-serif italic text-lg">
							{t.auth.subtitle}
						</p>
						<p class="text-amber-400 tracking-[0.3em] text-sm mt-3">❧ ✿ ❧</p>
					</div>

					<!-- Form -->
					<form class="space-y-6">
						<div>
							<label for="email" class="block text-amber-300 text-sm font-bold uppercase tracking-widest mb-2">
								✦ {t.auth.email}
							</label>
							<input
								type="email"
								id="email"
								name="email"
								placeholder="you@example.com"
								class="w-full px-4 py-3 bg-purple-900/50 border-2 border-purple-600/50 text-purple-100 placeholder-purple-400/50 rounded-sm shadow-inner focus:border-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-400/30 transition-all duration-300 font-semibold"
							/>
						</div>
						<div>
							<label for="password" class="block text-amber-300 text-sm font-bold uppercase tracking-widest mb-2">
								✦ {t.auth.password}
							</label>
							<input
								type="password"
								id="password"
								name="password"
								placeholder="••••••••"
								class="w-full px-4 py-3 bg-purple-900/50 border-2 border-purple-600/50 text-purple-100 placeholder-purple-400/50 rounded-sm shadow-inner focus:border-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-400/30 transition-all duration-300 font-semibold"
							/>
						</div>

						<!-- Remember / Forgot -->
						<div class="flex items-center justify-between">
							<label class="flex items-center gap-2 cursor-pointer">
								<input type="checkbox" name="remember" class="w-4 h-4 rounded-sm border-2 border-purple-500 bg-purple-900/50 text-amber-500 focus:ring-amber-400/30 accent-amber-500" />
								<span class="text-purple-200 text-sm font-semibold">{t.auth.rememberMe}</span>
							</label>
							<a href="#" class="text-amber-400 hover:text-amber-300 text-sm font-bold tracking-wide transition-colors">
								{t.auth.forgotPassword}
							</a>
						</div>

						<!-- Sign In Button -->
						<button type="submit" class="w-full py-4 bg-gradient-to-r from-amber-600 via-yellow-500 to-amber-600 text-amber-950 font-black uppercase tracking-widest text-lg rounded-sm shadow-2xl shadow-amber-500/30 hover:from-amber-500 hover:via-yellow-400 hover:to-amber-500 transition-all duration-300 border-2 border-amber-300">
							★ {t.auth.signIn} ★
						</button>
					</form>

					<!-- Divider -->
					<div class="flex items-center gap-4 my-8">
						<div class="flex-1 h-px bg-gradient-to-r from-transparent via-purple-500/50 to-transparent"></div>
						<p class="text-purple-300 text-sm font-bold uppercase tracking-widest shrink-0">
							◆ {t.auth.continueWith} ◆
						</p>
						<div class="flex-1 h-px bg-gradient-to-r from-transparent via-purple-500/50 to-transparent"></div>
					</div>

					<!-- Social Buttons -->
					<div class="grid grid-cols-2 gap-4">
						<button type="button" class="py-3 bg-gradient-to-r from-rose-800 via-rose-700 to-rose-800 text-rose-100 font-black uppercase tracking-widest text-sm rounded-sm shadow-xl border-2 border-rose-500/50 hover:border-rose-400 hover:from-rose-700 hover:via-rose-600 hover:to-rose-700 transition-all duration-300">
							✦ Google
						</button>
						<button type="button" class="py-3 bg-gradient-to-r from-indigo-800 via-indigo-700 to-indigo-800 text-indigo-100 font-black uppercase tracking-widest text-sm rounded-sm shadow-xl border-2 border-indigo-500/50 hover:border-indigo-400 hover:from-indigo-700 hover:via-indigo-600 hover:to-indigo-700 transition-all duration-300">
							✦ Apple
						</button>
					</div>

					<!-- Sign Up Link -->
					<div class="text-center mt-8 pt-6 border-t border-purple-600/30">
						<p class="text-purple-300 text-sm">
							{t.auth.noAccount}{" "}
							<a href="#" class="text-amber-400 hover:text-amber-300 font-black uppercase tracking-wider transition-colors">
								{t.auth.signUp} &rarr;
							</a>
						</p>
					</div>
				</div>

				<!-- Bottom Ornament -->
				<div class="bg-gradient-to-r from-amber-700 via-yellow-600 to-amber-700 text-center py-3">
					<span class="text-amber-950 text-sm tracking-[0.4em] font-black">✦ ★ ◆ ★ ✦</span>
				</div>
			</div>
		</section>
	</main>
</div>
