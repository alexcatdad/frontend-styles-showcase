---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-purple-950 via-indigo-950 to-violet-950">
	<!-- Navigation -->
	<nav class="relative bg-gradient-to-r from-amber-950 via-yellow-900 to-amber-950 border-b-4 border-double border-amber-400 shadow-[0_8px_32px_rgba(180,120,0,0.4)]">
		<div class="absolute inset-0 opacity-10 bg-[repeating-linear-gradient(90deg,transparent,transparent_12px,rgba(255,215,0,0.15)_12px,rgba(255,215,0,0.15)_14px)]"></div>
		<div class="relative max-w-7xl mx-auto px-4 pt-4 pb-2 flex flex-wrap items-center justify-center gap-1 md:gap-4">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 font-bold text-amber-200 uppercase tracking-[0.25em] text-xs hover:text-white hover:bg-amber-700/60 rounded-sm transition-all duration-300 border border-transparent hover:border-amber-300 hover:shadow-lg hover:shadow-amber-500/20">
					{item.label}
				</a>
			))}
		</div>
		<div class="relative text-center text-amber-500 text-xs tracking-[0.6em] py-1.5 border-t border-amber-700/50">❧ ✦ ◆ ★ ◆ ✦ ❧ ✦ ◆ ★ ◆ ✦ ❧</div>
	</nav>

	<!-- ═══════ Full-bleed deep purple with diamond lattice ═══════ -->
	<main class="relative flex items-center justify-center px-4 py-16 md:py-28 overflow-hidden min-h-[calc(100vh-5rem)]">
		<div class="absolute inset-0 opacity-[0.04] bg-[repeating-conic-gradient(rgba(168,85,247,0.3)_0%_25%,transparent_0%_50%)] bg-[length:28px_28px]"></div>
		<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(88,28,135,0.2)_0%,transparent_60%)]"></div>

		<section class="relative w-full max-w-lg">
			<!-- Outer decorative frames -->
			<div class="absolute -inset-3 border border-amber-500/12 hidden md:block"></div>
			<div class="absolute -inset-2 border border-amber-500/8 hidden md:block"></div>

			<!-- Auth Card -->
			<div class="relative bg-gradient-to-b from-purple-900/60 via-violet-900/50 to-indigo-950/80 border-2 border-amber-500/50 shadow-[0_16px_80px_rgba(88,28,135,0.5),0_0_120px_rgba(180,120,0,0.06)] overflow-hidden">
				<!-- Top Grand Ornament -->
				<div class="relative bg-gradient-to-r from-amber-800 via-yellow-600 to-amber-800 text-center py-4 overflow-hidden">
					<div class="absolute inset-0 opacity-20 bg-[repeating-linear-gradient(90deg,transparent,transparent_8px,rgba(0,0,0,0.15)_8px,rgba(0,0,0,0.15)_9px)]"></div>
					<span class="relative text-amber-950 text-sm tracking-[0.5em] font-black">✦ ★ ◆ ❋ ◆ ★ ✦</span>
				</div>

				<div class="p-8 md:p-10">
					<!-- Header -->
					<div class="text-center mb-10">
						<p class="text-amber-500 tracking-[0.4em] text-xs mb-3">❧ ✿ ★ ✿ ❧</p>
						<div class="border-2 border-amber-600/20 p-2 inline-block">
							<div class="border border-amber-500/10 px-6 md:px-10 py-2 md:py-3">
								<h1 class="font-serif text-4xl md:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-yellow-100 to-amber-400 leading-none">
									{t.auth.title}
								</h1>
							</div>
						</div>
						<p class="text-purple-300 font-serif italic text-lg mt-4">
							{t.auth.subtitle}
						</p>
						<p class="text-amber-500 tracking-[0.4em] text-xs mt-3">❧ ✿ ★ ✿ ❧</p>
					</div>

					<!-- Form -->
					<form class="space-y-6">
						<div>
							<label for="email" class="block text-amber-300 text-xs font-bold uppercase tracking-[0.2em] mb-2">
								✦ {t.auth.email}
							</label>
							<div class="relative">
								<span class="absolute -inset-0.5 border border-purple-400/10"></span>
								<input
									type="email"
									id="email"
									name="email"
									placeholder="you@example.com"
									class="relative w-full px-4 py-3.5 bg-purple-900/50 border-2 border-purple-600/40 text-purple-100 placeholder-purple-500/40 shadow-[inset_0_2px_12px_rgba(0,0,0,0.3)] focus:border-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-400/20 focus:shadow-[inset_0_2px_12px_rgba(0,0,0,0.3),0_0_20px_rgba(245,158,11,0.1)] transition-all duration-300 font-semibold"
								/>
							</div>
						</div>
						<div>
							<label for="password" class="block text-amber-300 text-xs font-bold uppercase tracking-[0.2em] mb-2">
								✦ {t.auth.password}
							</label>
							<div class="relative">
								<span class="absolute -inset-0.5 border border-purple-400/10"></span>
								<input
									type="password"
									id="password"
									name="password"
									placeholder="••••••••"
									class="relative w-full px-4 py-3.5 bg-purple-900/50 border-2 border-purple-600/40 text-purple-100 placeholder-purple-500/40 shadow-[inset_0_2px_12px_rgba(0,0,0,0.3)] focus:border-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-400/20 focus:shadow-[inset_0_2px_12px_rgba(0,0,0,0.3),0_0_20px_rgba(245,158,11,0.1)] transition-all duration-300 font-semibold"
								/>
							</div>
						</div>

						<!-- Remember / Forgot -->
						<div class="flex items-center justify-between pt-1">
							<label class="flex items-center gap-2 cursor-pointer">
								<input type="checkbox" name="remember" class="w-4 h-4 border-2 border-purple-500 bg-purple-900/50 text-amber-500 focus:ring-amber-400/30 accent-amber-500" />
								<span class="text-purple-200 text-sm font-semibold">{t.auth.rememberMe}</span>
							</label>
							<a href="#" class="text-amber-400 hover:text-amber-300 text-xs font-bold tracking-wider transition-colors uppercase">
								{t.auth.forgotPassword}
							</a>
						</div>

						<!-- Sign In — Grand Button -->
						<div class="relative group pt-2">
							<span class="absolute -inset-1 border border-amber-400/15 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></span>
							<button type="submit" class="relative w-full py-4 bg-gradient-to-r from-amber-600 via-yellow-500 to-amber-600 text-amber-950 font-black uppercase tracking-[0.2em] text-lg shadow-[0_0_30px_rgba(245,158,11,0.3)] hover:shadow-[0_0_50px_rgba(245,158,11,0.45)] transition-all duration-500 border-2 border-amber-300">
								★ {t.auth.signIn} ★
							</button>
						</div>
					</form>

					<!-- Divider -->
					<div class="flex items-center gap-4 my-8">
						<div class="flex-1 h-px bg-gradient-to-r from-transparent via-purple-500/40 to-purple-500/40"></div>
						<p class="text-purple-300/80 text-xs font-bold uppercase tracking-[0.2em] shrink-0">
							◆ {t.auth.continueWith} ◆
						</p>
						<div class="flex-1 h-px bg-gradient-to-l from-transparent via-purple-500/40 to-purple-500/40"></div>
					</div>

					<!-- Social Buttons -->
					<div class="grid grid-cols-2 gap-4">
						<button type="button" class="group/btn relative py-3.5 bg-gradient-to-r from-rose-900/80 via-rose-800/80 to-rose-900/80 text-rose-100 font-black uppercase tracking-[0.15em] text-sm shadow-[0_4px_20px_rgba(136,19,55,0.3)] border-2 border-rose-500/40 hover:border-rose-400 hover:shadow-[0_8px_30px_rgba(136,19,55,0.4)] transition-all duration-300">
							<span class="absolute -inset-0.5 border border-rose-400/10 opacity-0 group-hover/btn:opacity-100 transition-opacity"></span>
							<span class="relative">✦ Google</span>
						</button>
						<button type="button" class="group/btn relative py-3.5 bg-gradient-to-r from-indigo-900/80 via-indigo-800/80 to-indigo-900/80 text-indigo-100 font-black uppercase tracking-[0.15em] text-sm shadow-[0_4px_20px_rgba(49,46,129,0.3)] border-2 border-indigo-500/40 hover:border-indigo-400 hover:shadow-[0_8px_30px_rgba(49,46,129,0.4)] transition-all duration-300">
							<span class="absolute -inset-0.5 border border-indigo-400/10 opacity-0 group-hover/btn:opacity-100 transition-opacity"></span>
							<span class="relative">✦ Apple</span>
						</button>
					</div>

					<!-- Sign Up Link -->
					<div class="text-center mt-8 pt-6 border-t-2 border-purple-600/20">
						<p class="text-purple-300 text-sm">
							{t.auth.noAccount}{" "}
							<a href="#" class="text-amber-400 hover:text-amber-300 font-black uppercase tracking-wider transition-colors">
								{t.auth.signUp} &rarr;
							</a>
						</p>
					</div>
				</div>

				<!-- Bottom Grand Ornament -->
				<div class="relative bg-gradient-to-r from-amber-800 via-yellow-600 to-amber-800 text-center py-4 overflow-hidden">
					<div class="absolute inset-0 opacity-20 bg-[repeating-linear-gradient(90deg,transparent,transparent_8px,rgba(0,0,0,0.15)_8px,rgba(0,0,0,0.15)_9px)]"></div>
					<span class="relative text-amber-950 text-sm tracking-[0.5em] font-black">✦ ★ ◆ ❋ ◆ ★ ✦</span>
				</div>
			</div>
		</section>
	</main>
</div>
