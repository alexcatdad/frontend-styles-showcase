---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-amber-950 via-yellow-950 to-amber-950">
	<!-- Navigation -->
	<nav class="bg-gradient-to-r from-amber-900 via-yellow-800 to-amber-900 border-b-4 border-amber-400 shadow-2xl shadow-amber-900/50">
		<div class="max-w-7xl mx-auto px-4 py-4 flex flex-wrap items-center justify-center gap-2 md:gap-6">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 font-bold text-amber-100 uppercase tracking-widest text-sm hover:text-white hover:bg-amber-700/50 rounded-sm transition-all duration-300 border border-transparent hover:border-amber-400">
					{item.label}
				</a>
			))}
		</div>
		<div class="text-center text-amber-400 text-xs tracking-[0.5em] py-1">✦ ◆ ✦ ◆ ✦ ◆ ✦ ◆ ✦ ◆ ✦</div>
	</nav>

	<main class="max-w-7xl mx-auto px-4 py-12 md:py-20">
		<!-- Header -->
		<div class="text-center mb-16">
			<p class="text-amber-400 tracking-[0.4em] text-sm mb-4">★ ✦ ★ ✦ ★</p>
			<h1 class="font-serif text-5xl md:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-yellow-200 to-amber-400 mb-6">
				{t.donate.title}
			</h1>
			<p class="text-amber-200 text-xl md:text-2xl font-serif italic max-w-2xl mx-auto">
				{t.donate.subtitle}
			</p>
			<p class="text-amber-400 tracking-[0.4em] text-sm mt-6">★ ✦ ★ ✦ ★</p>
		</div>

		<!-- Monthly Tiers -->
		<section class="mb-20">
			<div class="text-center mb-10">
				<p class="text-emerald-400 tracking-[0.3em] text-sm mb-3">✿ ◆ ✿</p>
				<h2 class="font-serif text-3xl md:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-emerald-300 via-teal-200 to-emerald-400">
					{t.donate.monthly}
				</h2>
				<p class="text-emerald-400 tracking-[0.3em] text-sm mt-3">✿ ◆ ✿</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
				{monthlyTiers.map((tier: any) => (
					<div class={`relative bg-gradient-to-b ${tier.highlighted ? 'from-amber-800/60 to-amber-950/80 border-amber-400 shadow-2xl shadow-amber-500/30 scale-105' : 'from-emerald-900/60 to-teal-950/80 border-emerald-600/40 shadow-xl shadow-emerald-900/40'} border-2 rounded-sm overflow-hidden transition-all duration-300 hover:shadow-2xl`}>
						{/* Top Ornament */}
						<div class={`text-center py-2.5 ${tier.highlighted ? 'bg-gradient-to-r from-amber-600 via-yellow-500 to-amber-600' : 'bg-gradient-to-r from-emerald-700/60 via-teal-600/60 to-emerald-700/60'}`}>
							{tier.highlighted ? (
								<span class="text-amber-950 text-xs tracking-[0.3em] font-black uppercase">★ {t.donate.mostPopular} ★</span>
							) : (
								<span class="text-emerald-200/60 text-xs tracking-[0.3em]">✦ ◆ ✦</span>
							)}
						</div>

						<div class="p-6 md:p-8">
							<h3 class="font-serif text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-yellow-200 mb-3">
								{tier.name}
							</h3>
							<p class="mb-4">
								<span class="font-serif text-5xl font-black text-transparent bg-clip-text bg-gradient-to-b from-amber-300 to-yellow-500">${tier.amount}</span>
								<span class="text-amber-300/70 text-sm font-bold uppercase tracking-wider ml-1">{t.donate.perMonth}</span>
							</p>
							<p class="text-emerald-200/80 leading-relaxed mb-6 text-sm">
								{tier.description}
							</p>

							{/* Perks */}
							<ul class="space-y-3 mb-8">
								{tier.perks.map((perk: string) => (
									<li class="flex items-start gap-2 text-emerald-100 text-sm">
										<span class="text-amber-400 font-bold mt-0.5 shrink-0">✦</span>
										<span>{perk}</span>
									</li>
								))}
							</ul>

							{/* Button */}
							<button type="button" class={`w-full py-3 font-black uppercase tracking-widest text-sm rounded-sm shadow-xl transition-all duration-300 ${tier.highlighted ? 'bg-gradient-to-r from-amber-600 via-yellow-500 to-amber-600 text-amber-950 hover:from-amber-500 hover:via-yellow-400 hover:to-amber-500 border-2 border-amber-300 shadow-amber-500/30' : 'bg-gradient-to-r from-emerald-700 via-emerald-600 to-emerald-700 text-emerald-50 hover:from-emerald-600 hover:via-emerald-500 hover:to-emerald-600 border-2 border-emerald-400/50 shadow-emerald-700/30'}`}>
								◆ {t.donate.choose} {tier.name} ◆
							</button>
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- Ornamental Divider -->
		<div class="text-center py-6">
			<span class="text-amber-500 text-2xl tracking-[0.3em]">║ ❋ ✦ ★ ✦ ❋ ✦ ★ ✦ ❋ ║</span>
		</div>

		<!-- One-Time Tiers -->
		<section>
			<div class="text-center mb-10">
				<p class="text-rose-400 tracking-[0.3em] text-sm mb-3">❋ ★ ❋</p>
				<h2 class="font-serif text-3xl md:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-rose-300 via-pink-200 to-rose-400">
					{t.donate.oneTime}
				</h2>
				<p class="text-rose-400 tracking-[0.3em] text-sm mt-3">❋ ★ ❋</p>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
				{oneTimeTiers.map((tier: any) => (
					<div class={`relative bg-gradient-to-b ${tier.highlighted ? 'from-amber-800/60 to-amber-950/80 border-amber-400 shadow-2xl shadow-amber-500/30 scale-105' : 'from-rose-900/60 to-pink-950/80 border-rose-600/40 shadow-xl shadow-rose-900/40'} border-2 rounded-sm overflow-hidden transition-all duration-300 hover:shadow-2xl`}>
						{/* Top Ornament */}
						<div class={`text-center py-2.5 ${tier.highlighted ? 'bg-gradient-to-r from-amber-600 via-yellow-500 to-amber-600' : 'bg-gradient-to-r from-rose-700/60 via-pink-600/60 to-rose-700/60'}`}>
							{tier.highlighted ? (
								<span class="text-amber-950 text-xs tracking-[0.3em] font-black uppercase">★ {t.donate.greatestImpact} ★</span>
							) : (
								<span class="text-rose-200/60 text-xs tracking-[0.3em]">❋ ◆ ❋</span>
							)}
						</div>

						<div class="p-6 md:p-8">
							<h3 class="font-serif text-2xl font-black text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-yellow-200 mb-3">
								{tier.name}
							</h3>
							<p class="mb-4">
								<span class="font-serif text-5xl font-black text-transparent bg-clip-text bg-gradient-to-b from-amber-300 to-yellow-500">${tier.amount}</span>
							</p>
							<p class="text-rose-200/80 leading-relaxed mb-6 text-sm">
								{tier.description}
							</p>

							{/* Perks */}
							<ul class="space-y-3 mb-8">
								{tier.perks.map((perk: string) => (
									<li class="flex items-start gap-2 text-rose-100 text-sm">
										<span class="text-amber-400 font-bold mt-0.5 shrink-0">✦</span>
										<span>{perk}</span>
									</li>
								))}
							</ul>

							{/* Button */}
							<button type="button" class={`w-full py-3 font-black uppercase tracking-widest text-sm rounded-sm shadow-xl transition-all duration-300 ${tier.highlighted ? 'bg-gradient-to-r from-amber-600 via-yellow-500 to-amber-600 text-amber-950 hover:from-amber-500 hover:via-yellow-400 hover:to-amber-500 border-2 border-amber-300 shadow-amber-500/30' : 'bg-gradient-to-r from-rose-700 via-pink-600 to-rose-700 text-rose-50 hover:from-rose-600 hover:via-pink-500 hover:to-rose-600 border-2 border-rose-400/50 shadow-rose-700/30'}`}>
								★ {t.donate.give} ${tier.amount} ★
							</button>
						</div>
					</div>
				))}
			</div>
		</section>
	</main>
</div>
