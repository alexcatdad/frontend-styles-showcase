---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-white text-neutral-900 font-sans antialiased">
	<nav class="pt-8 pb-4 px-6 lg:px-12">
		<div class="max-w-2xl mx-auto flex items-center justify-between">
			<a href={`/${lang}/${style}/`} class="text-xs text-stone-400 tracking-widest uppercase">{cat.name}</a>
			<div class="flex items-center gap-6 md:gap-8">
				{nav.map((item: any) => (
					<a href={item.href} class="text-xs text-stone-400 tracking-widest uppercase hover:text-neutral-900 transition-colors duration-500">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main>
		<section class="pt-24 md:pt-32 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto">
				<a href={`/${lang}/${style}/cats`} class="text-sm font-light text-stone-400 hover:text-neutral-900 transition-colors duration-500">&larr; {t.cats.backToAll}</a>
			</div>
		</section>

		<article class="pt-16 md:pt-24 pb-32 md:pb-48 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto">
				<div class="aspect-[3/2] bg-stone-100 mb-16 md:mb-24"></div>

				<h1 class="text-4xl md:text-6xl lg:text-7xl font-extralight tracking-tight leading-none">{cat.name}</h1>

				<div class="mt-16 md:mt-24 space-y-6">
					<div class="flex justify-between items-baseline">
						<span class="text-xs tracking-widest uppercase text-stone-400">{t.cats.breed}</span>
						<span class="text-sm font-light">{cat.breed}</span>
					</div>
					<div class="flex justify-between items-baseline">
						<span class="text-xs tracking-widest uppercase text-stone-400">{t.cats.age}</span>
						<span class="text-sm font-light">{cat.age}</span>
					</div>
					<div class="flex justify-between items-baseline">
						<span class="text-xs tracking-widest uppercase text-stone-400">{t.cats.gender}</span>
						<span class="text-sm font-light">{cat.gender}</span>
					</div>
					<div class="flex justify-between items-baseline">
						<span class="text-xs tracking-widest uppercase text-stone-400">{t.cats.color}</span>
						<span class="text-sm font-light">{cat.color}</span>
					</div>
					<div class="flex justify-between items-baseline">
						<span class="text-xs tracking-widest uppercase text-stone-400">{t.cats.arrived}</span>
						<span class="text-sm font-light">{cat.arrivalDate}</span>
					</div>
					<div class="flex justify-between items-baseline">
						<span class="text-xs tracking-widest uppercase text-stone-400">{t.cats.status}</span>
						<span class="text-sm font-light">{cat.status}</span>
					</div>
				</div>

				<p class="mt-16 md:mt-24 text-sm font-light text-stone-400">
					{cat.personality.join(', ')}
				</p>

				<p class="mt-16 md:mt-24 text-xl md:text-2xl font-extralight leading-relaxed text-neutral-600">{cat.description}</p>

				<a href={`/${lang}/${style}/auth`} class="mt-16 md:mt-24 inline-block text-sm font-light text-neutral-900 underline underline-offset-4 decoration-stone-300 hover:decoration-neutral-900 transition-colors duration-500">{t.cats.adopt} {cat.name} &rarr;</a>
			</div>
		</article>

		<section class="py-32 md:py-48 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto">
				<p class="text-xs tracking-widest uppercase text-stone-400 mb-16 md:mb-24">{t.cats.otherCats}</p>
				<div class="space-y-16 md:space-y-20">
					{otherCats.map((c: any) => (
						<a href={`/${lang}/${style}/cats/${c.id}`} class="group block">
							<h3 class="text-2xl md:text-3xl font-extralight tracking-tight group-hover:text-stone-400 transition-colors duration-500">{c.name}</h3>
							<p class="mt-2 text-sm font-light text-stone-400">{c.breed} &mdash; {c.age}</p>
						</a>
					))}
				</div>
			</div>
		</section>
	</main>
</div>
