---
const { lang, style, nav, posts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-white text-neutral-900 font-sans antialiased">
	<nav class="pt-8 pb-4 px-6 lg:px-12">
		<div class="max-w-2xl mx-auto flex items-center justify-between">
			<a href={`${_base}/${lang}/${style}/`} class="text-xs text-stone-400 tracking-widest uppercase">{t.blog.title}</a>
			<div class="flex items-center gap-6 md:gap-8">
				{nav.map((item: any) => (
					<a href={item.href} class="text-xs text-stone-400 tracking-widest uppercase hover:text-neutral-900 transition-colors duration-500">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main>
		<section class="pt-32 md:pt-48 pb-24 md:pb-32 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto">
				<h1 class="text-4xl md:text-6xl lg:text-7xl font-extralight tracking-tight leading-none">{t.blog.title}</h1>
				<p class="mt-8 md:mt-12 text-lg md:text-xl font-light text-stone-400 leading-relaxed max-w-md">{t.blog.subtitle}</p>
			</div>
		</section>

		<section class="pb-32 md:pb-48 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto">
				{posts.map((post: any) => (
					<a href={`${_base}/${lang}/${style}/blog/${post.slug}`} class="group block py-16 md:py-20 first:pt-0">
						<img src={post.image} alt={post.title} class="w-full h-48 md:h-56 object-cover mb-8" />
						<time datetime={post.date} class="text-xs tracking-widest uppercase text-stone-400 block">{post.date}</time>
						<h2 class="mt-6 text-2xl md:text-4xl font-extralight tracking-tight leading-tight group-hover:text-stone-400 transition-colors duration-500">{post.title}</h2>
						<p class="mt-6 text-base font-light text-neutral-500 leading-relaxed max-w-lg">{post.excerpt}</p>
						<p class="mt-6 text-xs font-light text-stone-400">{t.blog.by} {post.author}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
