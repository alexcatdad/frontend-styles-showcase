---
const { lang, style, nav, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-white text-neutral-900 font-sans antialiased">
	<nav class="pt-8 pb-4 px-6 lg:px-12">
		<div class="max-w-2xl mx-auto flex items-center justify-between">
			<a href={`${_base}/${lang}/${style}/`} class="text-xs text-stone-400 tracking-widest uppercase">{t.auth.title}</a>
			<div class="flex items-center gap-6 md:gap-8">
				{nav.map((item: any) => (
					<a href={item.href} class="text-xs text-stone-400 tracking-widest uppercase hover:text-neutral-900 transition-colors duration-500">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="px-6 lg:px-12">
		<div class="max-w-sm mx-auto pt-32 md:pt-48 pb-32 md:pb-48">
			<h1 class="text-3xl md:text-5xl font-extralight tracking-tight leading-none">{t.auth.title}</h1>
			<p class="mt-6 text-sm font-light text-stone-400 leading-relaxed">{t.auth.subtitle}</p>

			<form class="mt-20 md:mt-28 space-y-12">
				<div>
					<label for="email" class="block text-xs tracking-widest uppercase text-stone-400 mb-4">{t.auth.email}</label>
					<input type="email" id="email" name="email" placeholder="you@example.com" class="w-full bg-transparent border-b border-stone-200 pb-3 text-sm font-light focus:border-neutral-900 focus:outline-none transition-colors duration-500" />
				</div>
				<div>
					<label for="password" class="block text-xs tracking-widest uppercase text-stone-400 mb-4">{t.auth.password}</label>
					<input type="password" id="password" name="password" placeholder="--------" class="w-full bg-transparent border-b border-stone-200 pb-3 text-sm font-light focus:border-neutral-900 focus:outline-none transition-colors duration-500" />
				</div>
				<div class="flex items-center justify-between">
					<label class="flex items-center gap-3 cursor-pointer">
						<input type="checkbox" name="remember" class="w-3 h-3 accent-neutral-900" />
						<span class="text-xs font-light text-stone-400">{t.auth.rememberMe}</span>
					</label>
					<a href="#" class="text-xs font-light text-stone-400 hover:text-neutral-900 transition-colors duration-500">{t.auth.forgotPassword}</a>
				</div>
				<button type="submit" class="text-sm font-light text-neutral-900 underline underline-offset-4 decoration-stone-300 hover:decoration-neutral-900 transition-colors duration-500">{t.auth.signIn} &rarr;</button>
			</form>

			<div class="mt-20 md:mt-28">
				<p class="text-xs tracking-widest uppercase text-stone-400 mb-8">{t.auth.continueWith}</p>
				<div class="flex gap-8">
					<button type="button" class="text-sm font-light text-stone-400 hover:text-neutral-900 transition-colors duration-500 underline underline-offset-4 decoration-stone-200 hover:decoration-neutral-900">Google</button>
					<button type="button" class="text-sm font-light text-stone-400 hover:text-neutral-900 transition-colors duration-500 underline underline-offset-4 decoration-stone-200 hover:decoration-neutral-900">Apple</button>
				</div>
			</div>

			<p class="mt-20 md:mt-28 text-sm font-light text-stone-400">
				{t.auth.noAccount} <a href="#" class="text-neutral-900 underline underline-offset-4 decoration-stone-300 hover:decoration-neutral-900 transition-colors duration-500">{t.auth.signUp}</a>
			</p>
		</div>
	</main>
</div>
