---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-white text-neutral-900 font-sans antialiased">
	<nav class="pt-8 pb-4 px-6 lg:px-12">
		<div class="max-w-2xl mx-auto flex items-center justify-between">
			<a href={`/${lang}/${style}/`} class="text-xs text-stone-400 tracking-widest uppercase">404</a>
			<div class="flex items-center gap-6 md:gap-8">
				{nav.map((item: any) => (
					<a href={item.href} class="text-xs text-stone-400 tracking-widest uppercase hover:text-neutral-900 transition-colors duration-500">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="px-6 lg:px-12">
		<div class="max-w-2xl mx-auto pt-40 md:pt-56 pb-32 md:pb-48">
			<p class="text-[8rem] md:text-[12rem] font-extralight tracking-tighter leading-none text-stone-100">{t.notFound.title}</p>
			<h2 class="mt-8 md:mt-12 text-2xl md:text-4xl font-extralight tracking-tight">{t.notFound.heading}</h2>
			<p class="mt-6 md:mt-8 text-base font-light text-stone-400 leading-relaxed max-w-sm">{t.notFound.description}</p>
			<div class="mt-16 md:mt-24 flex flex-col sm:flex-row gap-6 sm:gap-12">
				<a href={`/${lang}/${style}/`} class="text-sm font-light text-neutral-900 underline underline-offset-4 decoration-stone-300 hover:decoration-neutral-900 transition-colors duration-500">{t.notFound.backHome} &rarr;</a>
				<a href={`/${lang}/${style}/cats`} class="text-sm font-light text-stone-400 underline underline-offset-4 decoration-stone-200 hover:decoration-neutral-900 hover:text-neutral-900 transition-colors duration-500">{t.notFound.meetCats} &rarr;</a>
			</div>
		</div>
	</main>
</div>
