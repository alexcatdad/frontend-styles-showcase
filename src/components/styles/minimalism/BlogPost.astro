---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-white text-neutral-900 font-sans antialiased">
	<nav class="pt-8 pb-4 px-6 lg:px-12">
		<div class="max-w-2xl mx-auto flex items-center justify-between">
			<a href={`${_base}/${lang}/${style}/`} class="text-xs text-stone-400 tracking-widest uppercase">{post.title}</a>
			<div class="flex items-center gap-6 md:gap-8">
				{nav.map((item: any) => (
					<a href={item.href} class="text-xs text-stone-400 tracking-widest uppercase hover:text-neutral-900 transition-colors duration-500">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main>
		<section class="pt-24 md:pt-32 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto">
				<a href={`${_base}/${lang}/${style}/blog`} class="text-sm font-light text-stone-400 hover:text-neutral-900 transition-colors duration-500">&larr; {t.blog.backToBlog}</a>
			</div>
		</section>

		<article class="pt-16 md:pt-24 pb-32 md:pb-48 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto">
				<header class="mb-24 md:mb-32">
					<img src={post.image} alt={post.title} class="w-full h-56 md:h-72 object-cover mb-12" />
					<time datetime={post.date} class="text-xs tracking-widest uppercase text-stone-400 block">{post.date}</time>
					<h1 class="mt-8 text-3xl md:text-5xl lg:text-6xl font-extralight tracking-tight leading-tight">{post.title}</h1>
					<p class="mt-8 text-sm font-light text-stone-400">{t.blog.by} {post.author}</p>
				</header>

				<div class="space-y-8 md:space-y-10">
					{post.content.map((paragraph: string) => (
						<p class="text-lg font-light leading-loose text-neutral-500">{paragraph}</p>
					))}
				</div>

				<p class="mt-16 text-xs font-light text-stone-400 tracking-wide">
					{post.tags.join(' / ')}
				</p>
			</div>
		</article>

		<section class="py-32 md:py-48 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto">
				<p class="text-xs tracking-widest uppercase text-stone-400 mb-16 md:mb-24">{t.blog.moreStories}</p>
				<div class="space-y-16 md:space-y-20">
					{otherPosts.map((p: any) => (
						<a href={`${_base}/${lang}/${style}/blog/${p.slug}`} class="group block">
							<time datetime={p.date} class="text-xs tracking-widest uppercase text-stone-400 block">{p.date}</time>
							<h3 class="mt-4 text-2xl md:text-3xl font-extralight tracking-tight group-hover:text-stone-400 transition-colors duration-500">{p.title}</h3>
							<p class="mt-4 text-base font-light text-neutral-500 leading-relaxed max-w-lg">{p.excerpt}</p>
						</a>
					))}
				</div>
			</div>
		</section>
	</main>
</div>
