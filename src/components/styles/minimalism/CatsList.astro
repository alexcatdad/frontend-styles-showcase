---
const { lang, style, nav, cats, t } = Astro.props;
---

<div class="min-h-screen bg-white text-neutral-900 font-sans antialiased">
	<nav class="pt-8 pb-4 px-6 lg:px-12">
		<div class="max-w-2xl mx-auto flex items-center justify-between">
			<a href={`/${lang}/${style}/`} class="text-xs text-stone-400 tracking-widest uppercase">{t.cats.title}</a>
			<div class="flex items-center gap-6 md:gap-8">
				{nav.map((item: any) => (
					<a href={item.href} class="text-xs text-stone-400 tracking-widest uppercase hover:text-neutral-900 transition-colors duration-500">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main>
		<section class="pt-32 md:pt-48 pb-24 md:pb-32 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto">
				<h1 class="text-4xl md:text-6xl lg:text-7xl font-extralight tracking-tight leading-none">{t.cats.title}</h1>
				<p class="mt-8 md:mt-12 text-lg md:text-xl font-light text-stone-400 leading-relaxed max-w-md">{t.cats.subtitle}</p>
			</div>
		</section>

		<section class="pb-32 md:pb-48 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto">
				{cats.map((cat: any) => (
					<a href={`/${lang}/${style}/cats/${cat.id}`} class="group block py-12 md:py-16 first:pt-0">
						<img src={cat.thumbnail} alt={cat.name} class="w-full aspect-video object-cover mb-10" />
						<h2 class="text-2xl md:text-3xl font-extralight tracking-tight group-hover:text-stone-400 transition-colors duration-500">{cat.name}</h2>
						<p class="mt-3 text-sm font-light text-stone-400">{cat.breed} &mdash; {cat.age}</p>
						<p class="mt-6 text-base font-light text-neutral-500 leading-relaxed max-w-lg">{cat.description.slice(0, 120)}...</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
