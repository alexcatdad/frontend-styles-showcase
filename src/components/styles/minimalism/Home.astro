---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-white text-neutral-900 font-sans antialiased">
	<nav class="pt-8 pb-4 px-6 lg:px-12">
		<div class="max-w-2xl mx-auto flex items-center justify-between">
			<a href={`${_base}/${lang}/${style}/`} class="text-xs text-stone-400 tracking-widest uppercase">{sanctuary.name}</a>
			<div class="flex items-center gap-6 md:gap-8">
				{nav.map((item: any) => (
					<a href={item.href} class="text-xs text-stone-400 tracking-widest uppercase hover:text-neutral-900 transition-colors duration-500">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main>
		<section class="pt-32 md:pt-48 pb-40 md:pb-56 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto">
				<img src={sanctuary.heroImage} alt={sanctuary.name} class="w-full h-64 md:h-80 object-cover mb-16 md:mb-24" />
				<h1 class="text-5xl md:text-7xl lg:text-8xl font-extralight tracking-tight leading-none">{sanctuary.name}</h1>
				<p class="mt-10 md:mt-16 text-xl md:text-2xl font-light text-stone-400 leading-relaxed max-w-lg">{sanctuary.tagline}</p>
				<div class="mt-16 md:mt-24 flex flex-col sm:flex-row gap-6 sm:gap-12">
					<a href={`${_base}/${lang}/${style}/cats`} class="text-sm font-light text-neutral-900 underline underline-offset-4 decoration-stone-300 hover:decoration-neutral-900 transition-colors duration-500">{t.home.meetCats} &rarr;</a>
					<a href={`${_base}/${lang}/${style}/donate`} class="text-sm font-light text-stone-400 underline underline-offset-4 decoration-stone-200 hover:decoration-neutral-900 hover:text-neutral-900 transition-colors duration-500">{t.home.donate} &rarr;</a>
				</div>
			</div>
		</section>

		<section class="py-32 md:py-40 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto">
				<p class="text-xs tracking-widest uppercase text-stone-400 mb-12">{t.home.mission}</p>
				<p class="text-2xl md:text-4xl font-extralight leading-relaxed tracking-tight text-neutral-800">{sanctuary.mission}</p>
			</div>
		</section>

		<section class="py-24 md:py-32 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto flex flex-wrap gap-x-16 md:gap-x-24 gap-y-12">
				{sanctuary.stats.map((stat: any) => (
					<div>
						<span class="block text-4xl md:text-5xl font-extralight tracking-tight">{stat.value}</span>
						<span class="text-xs tracking-widest uppercase text-stone-400 mt-2 block">{stat.label}</span>
					</div>
				))}
			</div>
		</section>

		<section class="py-32 md:py-48 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto">
				<p class="text-xs tracking-widest uppercase text-stone-400 mb-16">{t.home.aboutUs}</p>
				<div class="space-y-10">
					{sanctuary.about.map((paragraph: string) => (
						<p class="text-lg md:text-xl font-light leading-loose text-neutral-500">{paragraph}</p>
					))}
				</div>
			</div>
		</section>
	</main>

	<footer class="py-16 md:py-24 px-6 lg:px-12">
		<div class="max-w-2xl mx-auto">
			<p class="text-xs tracking-widest uppercase text-stone-400">{sanctuary.name} &mdash; {t.footer.style}: {meta.name}</p>
		</div>
	</footer>
</div>
