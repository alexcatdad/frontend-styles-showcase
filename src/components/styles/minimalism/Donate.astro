---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-white text-neutral-900 font-sans antialiased">
	<nav class="pt-8 pb-4 px-6 lg:px-12">
		<div class="max-w-2xl mx-auto flex items-center justify-between">
			<a href={`/${lang}/${style}/`} class="text-xs text-stone-400 tracking-widest uppercase">{t.donate.title}</a>
			<div class="flex items-center gap-6 md:gap-8">
				{nav.map((item: any) => (
					<a href={item.href} class="text-xs text-stone-400 tracking-widest uppercase hover:text-neutral-900 transition-colors duration-500">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main>
		<section class="pt-32 md:pt-48 pb-24 md:pb-32 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto">
				<h1 class="text-4xl md:text-6xl lg:text-7xl font-extralight tracking-tight leading-none">{t.donate.title}</h1>
				<p class="mt-8 md:mt-12 text-lg md:text-xl font-light text-stone-400 leading-relaxed max-w-md">{t.donate.subtitle}</p>
			</div>
		</section>

		<section class="pb-32 md:pb-40 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto">
				<p class="text-xs tracking-widest uppercase text-stone-400 mb-16 md:mb-20">{t.donate.monthly}</p>
				<div class="space-y-20 md:space-y-24">
					{monthlyTiers.map((tier: any) => (
						<div>
							<div class="flex items-baseline gap-4 mb-4">
								<span class="text-4xl md:text-5xl font-extralight tracking-tight">${tier.amount}</span>
								<span class="text-xs text-stone-400 tracking-widest uppercase">{t.donate.perMonth}</span>
							</div>
							<h3 class="text-lg font-light tracking-tight mb-4">{tier.name}</h3>
							{tier.highlighted && (
								<p class="text-xs tracking-widest uppercase text-neutral-900 mb-4">{t.donate.mostPopular}</p>
							)}
							<p class="text-base font-light text-neutral-500 leading-relaxed mb-6 max-w-md">{tier.description}</p>
							<div class="space-y-2 mb-8">
								{tier.perks.map((perk: string) => (
									<p class="text-sm font-light text-stone-400">{perk}</p>
								))}
							</div>
							<a href="#" class="text-sm font-light text-neutral-900 underline underline-offset-4 decoration-stone-300 hover:decoration-neutral-900 transition-colors duration-500">{t.donate.choose} {tier.name} &rarr;</a>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="py-32 md:py-48 px-6 lg:px-12">
			<div class="max-w-2xl mx-auto">
				<p class="text-xs tracking-widest uppercase text-stone-400 mb-16 md:mb-20">{t.donate.oneTime}</p>
				<div class="space-y-20 md:space-y-24">
					{oneTimeTiers.map((tier: any) => (
						<div>
							<span class="text-4xl md:text-5xl font-extralight tracking-tight block mb-4">${tier.amount}</span>
							<h3 class="text-lg font-light tracking-tight mb-4">{tier.name}</h3>
							{tier.highlighted && (
								<p class="text-xs tracking-widest uppercase text-neutral-900 mb-4">{t.donate.greatestImpact}</p>
							)}
							<p class="text-base font-light text-neutral-500 leading-relaxed mb-6 max-w-md">{tier.description}</p>
							<div class="space-y-2 mb-8">
								{tier.perks.map((perk: string) => (
									<p class="text-sm font-light text-stone-400">{perk}</p>
								))}
							</div>
							<a href="#" class="text-sm font-light text-neutral-900 underline underline-offset-4 decoration-stone-300 hover:decoration-neutral-900 transition-colors duration-500">{t.donate.give} ${tier.amount} &rarr;</a>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>
</div>
