---
const { lang, style, nav, cats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-[#0a0a0a] font-sans text-gray-200 antialiased">
	<nav class="sticky top-0 z-50 border-b border-white/[0.06] bg-[#0a0a0a]/90 backdrop-blur-xl">
		<div class="mx-auto flex h-12 max-w-[1200px] items-center gap-6 px-4 lg:px-6">
			<div class="hidden items-center gap-0.5 sm:flex">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-md px-2.5 py-1.5 text-[13px] text-gray-500 transition-all duration-150 hover:bg-white/[0.04] hover:text-gray-300">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<div class="flex items-center gap-1 overflow-x-auto border-b border-white/[0.06] px-4 sm:hidden">
		{nav.map((item: any) => (
			<a href={item.href} class="shrink-0 px-3 py-2.5 text-[13px] text-gray-500 transition-colors hover:text-gray-300">{item.label}</a>
		))}
	</div>

	<main class="mx-auto max-w-[1200px] px-4 py-8 lg:px-6 lg:py-10">
		<!-- Header with search hint -->
		<div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
			<div>
				<h1 class="text-2xl font-semibold tracking-tight text-white sm:text-3xl">{t.cats.title}</h1>
				<p class="mt-1 text-[14px] text-gray-500">{t.cats.subtitle}</p>
			</div>
			<div class="flex items-center gap-2 rounded-md border border-white/[0.06] bg-white/[0.03] px-3 py-1.5 text-[13px] text-gray-600">
				<svg class="h-3.5 w-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
				<span>{t.cats.title}...</span>
				<kbd class="ml-4 hidden rounded border border-white/[0.08] px-1.5 py-0.5 font-mono text-[10px] text-gray-600 sm:inline">/</kbd>
			</div>
		</div>

		<!-- Summary row -->
		<div class="mb-4 flex items-center gap-4 text-[12px] text-gray-600">
			<span class="font-mono text-gray-500">{cats.length}</span> {t.cats.title.toLowerCase()}
			<span class="h-3 w-px bg-white/[0.06]"></span>
			<span class="font-mono text-emerald-500/80">{cats.filter((c: any) => c.status === 'available').length}</span> available
		</div>

		<!-- Cat list/table -->
		<div class="overflow-hidden rounded-lg border border-white/[0.06]">
			<!-- Table header -->
			<div class="hidden border-b border-white/[0.06] bg-white/[0.02] px-4 py-2.5 sm:grid sm:grid-cols-[1fr_140px_80px_80px_100px_90px] sm:gap-4 lg:px-5">
				<span class="text-[11px] font-semibold uppercase tracking-wider text-gray-600">{t.cats.title}</span>
				<span class="text-[11px] font-semibold uppercase tracking-wider text-gray-600">{t.cats.breed}</span>
				<span class="text-[11px] font-semibold uppercase tracking-wider text-gray-600">{t.cats.age}</span>
				<span class="text-[11px] font-semibold uppercase tracking-wider text-gray-600">{t.cats.gender}</span>
				<span class="text-[11px] font-semibold uppercase tracking-wider text-gray-600">{t.cats.color}</span>
				<span class="text-[11px] font-semibold uppercase tracking-wider text-gray-600">{t.cats.status}</span>
			</div>

			{cats.map((cat: any, i: number) => (
				<a href={`${_base}/${lang}/${style}/cats/${cat.id}`} class={`group flex flex-col gap-2 px-4 py-3.5 transition-all duration-150 hover:bg-white/[0.03] sm:grid sm:grid-cols-[1fr_140px_80px_80px_100px_90px] sm:items-center sm:gap-4 sm:py-2.5 lg:px-5 ${i > 0 ? 'border-t border-white/[0.04]' : ''}`}>
					<!-- Name + personality -->
					<div class="flex items-center gap-3">
						<img src={cat.thumbnail} alt={cat.name} class="h-7 w-7 shrink-0 rounded-md object-cover border border-white/[0.06]" />
						<div class="min-w-0">
							<span class="block truncate text-[13px] font-medium text-gray-200 transition-colors group-hover:text-white">{cat.name}</span>
							<span class="block truncate text-[11px] text-gray-600 sm:hidden">{cat.breed} &middot; {cat.age}</span>
						</div>
					</div>
					<!-- Breed -->
					<span class="hidden text-[13px] text-gray-500 sm:block">{cat.breed}</span>
					<!-- Age -->
					<span class="hidden font-mono text-[13px] text-gray-500 sm:block">{cat.age}</span>
					<!-- Gender -->
					<span class="hidden text-[13px] text-gray-500 sm:block">{cat.gender}</span>
					<!-- Color -->
					<span class="hidden text-[13px] text-gray-500 sm:block">{cat.color}</span>
					<!-- Status -->
					<span class={`inline-flex w-fit items-center gap-1.5 rounded-full px-2 py-0.5 text-[11px] font-medium sm:w-auto ${cat.status === 'available' ? 'bg-emerald-500/[0.08] text-emerald-400/90' : 'bg-amber-500/[0.08] text-amber-400/90'}`}>
						<span class={`h-1 w-1 rounded-full ${cat.status === 'available' ? 'bg-emerald-400' : 'bg-amber-400'}`}></span>
						{cat.status}
					</span>

					<!-- Tags — mobile and desktop -->
					<div class="col-span-full mt-0.5 flex flex-wrap gap-1 sm:mt-0">
						{cat.personality.slice(0, 3).map((trait: string) => (
							<span class="rounded border border-white/[0.05] bg-white/[0.02] px-1.5 py-0.5 text-[11px] text-gray-600">{trait}</span>
						))}
						{cat.personality.length > 3 && (
							<span class="rounded border border-white/[0.05] bg-white/[0.02] px-1.5 py-0.5 text-[11px] text-gray-600">+{cat.personality.length - 3}</span>
						)}
					</div>
				</a>
			))}
		</div>
	</main>
</div>
