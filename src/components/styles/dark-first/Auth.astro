---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-[#0a0a0a] font-sans text-gray-200">
	<nav class="sticky top-0 z-50 border-b border-white/10 bg-[#0a0a0a]/80 backdrop-blur-xl">
		<div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
			<div class="flex items-center gap-1">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-lg px-3 py-2 text-sm text-gray-400 transition-colors hover:bg-white/5 hover:text-white">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="flex min-h-[calc(100vh-65px)] items-center justify-center px-4 py-12">
		<section class="w-full max-w-sm">
			<div class="mb-8 text-center">
				<h1 class="mb-2 text-2xl font-bold tracking-tight text-white">{t.auth.title}</h1>
				<p class="text-sm text-gray-500">{t.auth.subtitle}</p>
			</div>

			<div class="rounded-xl border border-white/5 bg-gray-900/50 p-6">
				<form class="space-y-4">
					<div>
						<label for="email" class="mb-1.5 block text-sm font-medium text-gray-300">{t.auth.email}</label>
						<input type="email" id="email" name="email" placeholder="you@example.com" class="w-full rounded-lg border border-white/10 bg-white/5 px-3.5 py-2.5 text-sm text-white placeholder-gray-600 outline-none transition-colors focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/30" />
					</div>
					<div>
						<label for="password" class="mb-1.5 block text-sm font-medium text-gray-300">{t.auth.password}</label>
						<input type="password" id="password" name="password" placeholder="••••••••" class="w-full rounded-lg border border-white/10 bg-white/5 px-3.5 py-2.5 text-sm text-white placeholder-gray-600 outline-none transition-colors focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/30" />
					</div>
					<div class="flex items-center justify-between">
						<label class="flex items-center gap-2 text-sm text-gray-400">
							<input type="checkbox" name="remember" class="h-4 w-4 rounded border-white/10 bg-white/5 text-emerald-500 focus:ring-emerald-500/30" />
							{t.auth.rememberMe}
						</label>
						<a href="#" class="text-sm text-gray-500 transition-colors hover:text-emerald-400">{t.auth.forgotPassword}</a>
					</div>
					<button type="submit" class="w-full rounded-lg bg-emerald-500 px-4 py-2.5 text-sm font-semibold text-white shadow-lg shadow-emerald-500/20 transition-all hover:bg-emerald-400 hover:shadow-emerald-500/30">{t.auth.signIn}</button>
				</form>

				<div class="my-6 flex items-center gap-3">
					<div class="h-px flex-1 bg-white/5"></div>
					<p class="text-xs text-gray-600">{t.auth.continueWith}</p>
					<div class="h-px flex-1 bg-white/5"></div>
				</div>

				<div class="grid grid-cols-2 gap-3">
					<button type="button" class="rounded-lg border border-white/10 bg-white/5 px-4 py-2.5 text-sm font-medium text-gray-300 transition-all hover:border-white/20 hover:bg-white/10 hover:text-white">Google</button>
					<button type="button" class="rounded-lg border border-white/10 bg-white/5 px-4 py-2.5 text-sm font-medium text-gray-300 transition-all hover:border-white/20 hover:bg-white/10 hover:text-white">Apple</button>
				</div>
			</div>

			<p class="mt-6 text-center text-sm text-gray-500">
				{t.auth.noAccount} <a href="#" class="font-medium text-emerald-400 transition-colors hover:text-emerald-300">{t.auth.signUp}</a>
			</p>
		</section>
	</main>
</div>
