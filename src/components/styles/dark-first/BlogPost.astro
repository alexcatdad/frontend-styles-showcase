---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
---

<div class="min-h-screen bg-[#0a0a0a] font-sans text-gray-200 antialiased">
	<nav class="sticky top-0 z-50 border-b border-white/[0.06] bg-[#0a0a0a]/90 backdrop-blur-xl">
		<div class="mx-auto flex h-12 max-w-[1200px] items-center gap-6 px-4 lg:px-6">
			<div class="hidden items-center gap-0.5 sm:flex">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-md px-2.5 py-1.5 text-[13px] text-gray-500 transition-all duration-150 hover:bg-white/[0.04] hover:text-gray-300">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<div class="flex items-center gap-1 overflow-x-auto border-b border-white/[0.06] px-4 sm:hidden">
		{nav.map((item: any) => (
			<a href={item.href} class="shrink-0 px-3 py-2.5 text-[13px] text-gray-500 transition-colors hover:text-gray-300">{item.label}</a>
		))}
	</div>

	<main class="mx-auto max-w-[720px] px-4 py-8 lg:py-10">
		<!-- Breadcrumb -->
		<div class="mb-6 flex items-center gap-2 text-[13px]">
			<a href={`/${lang}/${style}/blog`} class="text-gray-600 transition-colors hover:text-gray-400">{t.blog.backToBlog}</a>
			<span class="text-gray-700">/</span>
			<span class="truncate text-gray-400">{post.title}</span>
		</div>

		<article class="mb-16">
			<!-- Header -->
			<header class="mb-8 border-b border-white/[0.06] pb-6">
				<img src={post.image} alt={post.title} class="w-full rounded-lg object-cover border border-white/[0.06] mb-6" />
				<h1 class="mb-4 text-2xl font-semibold tracking-tight text-white sm:text-3xl">{post.title}</h1>
				<div class="flex flex-wrap items-center gap-3">
					<div class="flex items-center gap-3 text-[13px]">
						<time datetime={post.date} class="font-mono text-gray-600">{post.date}</time>
						<span class="h-3 w-px bg-white/[0.06]"></span>
						<span class="text-gray-500">{t.blog.by} {post.author}</span>
					</div>
					<span class="h-3 w-px bg-white/[0.06]"></span>
					<div class="flex flex-wrap gap-1.5">
						{post.tags.map((tag: string) => (
							<span class="rounded border border-emerald-500/10 bg-emerald-500/[0.05] px-1.5 py-0.5 text-[11px] text-emerald-400/70">{tag}</span>
						))}
					</div>
				</div>
			</header>

			<!-- Content -->
			<div class="space-y-5">
				{post.content.map((paragraph: string) => (
					<p class="text-[15px] leading-[1.75] text-gray-400">{paragraph}</p>
				))}
			</div>
		</article>

		<!-- More stories -->
		<section class="border-t border-white/[0.06] pt-8">
			<h2 class="mb-4 text-[12px] font-semibold uppercase tracking-widest text-gray-600">{t.blog.moreStories}</h2>
			<div class="divide-y divide-white/[0.04]">
				{otherPosts.map((p: any) => (
					<a href={`/${lang}/${style}/blog/${p.slug}`} class="group block py-4 transition-all duration-150 first:pt-0 last:pb-0">
						<div class="flex items-start justify-between gap-4">
							<div>
								<h3 class="mb-1 text-[14px] font-medium text-gray-300 transition-colors group-hover:text-white">{p.title}</h3>
								<p class="text-[13px] leading-relaxed text-gray-600">{p.excerpt}</p>
							</div>
							<span class="mt-1 shrink-0 text-[12px] text-gray-700 transition-colors group-hover:text-emerald-500/70">&rarr;</span>
						</div>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
