---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
---

<div class="min-h-screen bg-[#0a0a0a] font-sans text-gray-200">
	<nav class="sticky top-0 z-50 border-b border-white/10 bg-[#0a0a0a]/80 backdrop-blur-xl">
		<div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
			<div class="flex items-center gap-1">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-lg px-3 py-2 text-sm text-gray-400 transition-colors hover:bg-white/5 hover:text-white">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
		<a href={`/${lang}/${style}/blog`} class="mb-8 inline-flex items-center gap-1 text-sm text-gray-500 transition-colors hover:text-emerald-400">&larr; {t.blog.backToBlog}</a>

		<article class="mb-16">
			<header class="mb-10 border-b border-white/5 pb-8">
				<div class="mb-4 flex flex-wrap items-center gap-3">
					<time datetime={post.date} class="text-sm text-gray-600">{post.date}</time>
					<span class="text-xs text-gray-700">|</span>
					<span class="text-sm text-gray-500">{t.blog.by} {post.author}</span>
				</div>
				<h1 class="mb-5 text-3xl font-bold tracking-tight text-white sm:text-4xl">{post.title}</h1>
				<div class="flex flex-wrap gap-2">
					{post.tags.map((tag: string) => (
						<span class="rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-0.5 text-xs text-emerald-400">{tag}</span>
					))}
				</div>
			</header>

			<div class="space-y-5">
				{post.content.map((paragraph: string) => (
					<p class="text-base leading-relaxed text-gray-300">{paragraph}</p>
				))}
			</div>
		</article>

		<section class="border-t border-white/5 pt-12">
			<h2 class="mb-6 text-xl font-bold tracking-tight text-white">{t.blog.moreStories}</h2>
			<div class="grid gap-4 sm:grid-cols-2">
				{otherPosts.map((p: any) => (
					<a href={`/${lang}/${style}/blog/${p.slug}`} class="group rounded-xl border border-white/5 bg-gray-900/50 p-5 transition-all hover:border-emerald-500/30 hover:bg-gray-900">
						<h3 class="mb-2 font-semibold text-white group-hover:text-emerald-400 transition-colors">{p.title}</h3>
						<p class="text-sm leading-relaxed text-gray-500">{p.excerpt}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
