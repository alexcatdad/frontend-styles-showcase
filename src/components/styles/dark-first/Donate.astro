---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-[#0a0a0a] font-sans text-gray-200">
	<nav class="sticky top-0 z-50 border-b border-white/10 bg-[#0a0a0a]/80 backdrop-blur-xl">
		<div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
			<div class="flex items-center gap-1">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-lg px-3 py-2 text-sm text-gray-400 transition-colors hover:bg-white/5 hover:text-white">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
		<div class="mb-12 text-center">
			<h1 class="mb-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">{t.donate.title}</h1>
			<p class="mx-auto max-w-xl text-lg text-gray-500">{t.donate.subtitle}</p>
		</div>

		<section class="mb-16">
			<h2 class="mb-6 text-center text-sm font-semibold uppercase tracking-widest text-emerald-400">{t.donate.monthly}</h2>
			<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
				{monthlyTiers.map((tier: any) => (
					<div class={`relative rounded-xl border p-6 transition-all ${tier.highlighted ? 'border-emerald-500/40 bg-emerald-500/5 shadow-lg shadow-emerald-500/10' : 'border-white/5 bg-gray-900/50 hover:border-white/10'}`}>
						{tier.highlighted && (
							<span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-emerald-500 px-3 py-0.5 text-xs font-semibold text-white">{t.donate.mostPopular}</span>
						)}
						<h3 class="mb-1 text-lg font-semibold text-white">{tier.name}</h3>
						<p class="mb-4">
							<span class="text-3xl font-bold tracking-tight text-white">${tier.amount}</span>
							<span class="text-sm text-gray-500">{t.donate.perMonth}</span>
						</p>
						<p class="mb-5 text-sm text-gray-400">{tier.description}</p>
						<ul class="mb-6 space-y-2">
							{tier.perks.map((perk: string) => (
								<li class="flex items-start gap-2 text-sm text-gray-300">
									<span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-500"></span>
									{perk}
								</li>
							))}
						</ul>
						<button type="button" class={`w-full rounded-lg px-4 py-2.5 text-sm font-semibold transition-all ${tier.highlighted ? 'bg-emerald-500 text-white shadow-lg shadow-emerald-500/20 hover:bg-emerald-400' : 'border border-white/10 bg-white/5 text-gray-300 hover:border-white/20 hover:bg-white/10 hover:text-white'}`}>{t.donate.choose} {tier.name}</button>
					</div>
				))}
			</div>
		</section>

		<section>
			<h2 class="mb-6 text-center text-sm font-semibold uppercase tracking-widest text-emerald-400">{t.donate.oneTime}</h2>
			<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
				{oneTimeTiers.map((tier: any) => (
					<div class={`relative rounded-xl border p-6 transition-all ${tier.highlighted ? 'border-emerald-500/40 bg-emerald-500/5 shadow-lg shadow-emerald-500/10' : 'border-white/5 bg-gray-900/50 hover:border-white/10'}`}>
						{tier.highlighted && (
							<span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-emerald-500 px-3 py-0.5 text-xs font-semibold text-white">{t.donate.greatestImpact}</span>
						)}
						<h3 class="mb-1 text-base font-semibold text-white">{tier.name}</h3>
						<p class="mb-3">
							<span class="text-2xl font-bold tracking-tight text-white">${tier.amount}</span>
						</p>
						<p class="mb-4 text-sm text-gray-400">{tier.description}</p>
						<ul class="mb-5 space-y-2">
							{tier.perks.map((perk: string) => (
								<li class="flex items-start gap-2 text-sm text-gray-300">
									<span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-500"></span>
									{perk}
								</li>
							))}
						</ul>
						<button type="button" class={`w-full rounded-lg px-4 py-2.5 text-sm font-semibold transition-all ${tier.highlighted ? 'bg-emerald-500 text-white shadow-lg shadow-emerald-500/20 hover:bg-emerald-400' : 'border border-white/10 bg-white/5 text-gray-300 hover:border-white/20 hover:bg-white/10 hover:text-white'}`}>{t.donate.give} ${tier.amount}</button>
					</div>
				))}
			</div>
		</section>
	</main>
</div>
