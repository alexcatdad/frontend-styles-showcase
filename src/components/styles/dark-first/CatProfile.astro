---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-[#0a0a0a] font-sans text-gray-200 antialiased">
	<nav class="sticky top-0 z-50 border-b border-white/[0.06] bg-[#0a0a0a]/90 backdrop-blur-xl">
		<div class="mx-auto flex h-12 max-w-[1200px] items-center gap-6 px-4 lg:px-6">
			<div class="hidden items-center gap-0.5 sm:flex">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-md px-2.5 py-1.5 text-[13px] text-gray-500 transition-all duration-150 hover:bg-white/[0.04] hover:text-gray-300">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<div class="flex items-center gap-1 overflow-x-auto border-b border-white/[0.06] px-4 sm:hidden">
		{nav.map((item: any) => (
			<a href={item.href} class="shrink-0 px-3 py-2.5 text-[13px] text-gray-500 transition-colors hover:text-gray-300">{item.label}</a>
		))}
	</div>

	<main class="mx-auto max-w-[1200px] px-4 py-8 lg:px-6 lg:py-10">
		<!-- Breadcrumb -->
		<div class="mb-6 flex items-center gap-2 text-[13px]">
			<a href={`/${lang}/${style}/cats`} class="text-gray-600 transition-colors hover:text-gray-400">{t.cats.backToAll}</a>
			<span class="text-gray-700">/</span>
			<span class="text-gray-400">{cat.name}</span>
		</div>

		<!-- Two-column layout -->
		<div class="gap-8 lg:grid lg:grid-cols-[1fr_320px]">
			<!-- Main content -->
			<div>
				<!-- Title + action bar -->
				<div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
					<div class="flex items-center gap-3">
						<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-white/[0.06] bg-white/[0.03] text-lg font-semibold text-gray-400">
							{cat.name.charAt(0)}
						</div>
						<div>
							<h1 class="text-2xl font-semibold tracking-tight text-white">{cat.name}</h1>
							<span class={`mt-0.5 inline-flex items-center gap-1.5 text-[12px] font-medium ${cat.status === 'available' ? 'text-emerald-400/80' : 'text-amber-400/80'}`}>
								<span class={`h-1.5 w-1.5 rounded-full ${cat.status === 'available' ? 'bg-emerald-400' : 'bg-amber-400'}`}></span>
								{cat.status}
							</span>
						</div>
					</div>
					<a href={`/${lang}/${style}/auth`} class="inline-flex items-center gap-2 rounded-lg bg-white px-4 py-2 text-[13px] font-semibold text-[#0a0a0a] transition-all duration-150 hover:bg-gray-200">
						{t.cats.adopt} {cat.name}
					</a>
				</div>

				<!-- Description -->
				<div class="mb-8 rounded-lg border border-white/[0.06] bg-[#111111]/40 p-5">
					<p class="text-[14px] leading-relaxed text-gray-400">{cat.description}</p>
				</div>

				<!-- Personality traits -->
				<div class="mb-8">
					<h3 class="mb-3 text-[12px] font-semibold uppercase tracking-widest text-gray-600">Personality</h3>
					<div class="flex flex-wrap gap-2">
						{cat.personality.map((trait: string) => (
							<span class="rounded-md border border-emerald-500/10 bg-emerald-500/[0.05] px-2.5 py-1 text-[13px] text-emerald-400/80">{trait}</span>
						))}
					</div>
				</div>

				<!-- Other cats -->
				<section class="border-t border-white/[0.06] pt-8">
					<h2 class="mb-4 text-[12px] font-semibold uppercase tracking-widest text-gray-600">{t.cats.otherCats}</h2>
					<div class="overflow-hidden rounded-lg border border-white/[0.06]">
						{otherCats.map((c: any, i: number) => (
							<a href={`/${lang}/${style}/cats/${c.id}`} class={`group flex items-center gap-3 px-4 py-3 transition-all duration-150 hover:bg-white/[0.03] ${i > 0 ? 'border-t border-white/[0.04]' : ''}`}>
								<div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md border border-white/[0.06] bg-white/[0.03] text-[11px] font-semibold text-gray-500 transition-colors group-hover:border-emerald-500/20 group-hover:text-emerald-400">
									{c.name.charAt(0)}
								</div>
								<div>
									<span class="block text-[13px] font-medium text-gray-300 transition-colors group-hover:text-white">{c.name}</span>
									<span class="block text-[11px] text-gray-600">{c.breed} &middot; {c.age}</span>
								</div>
								<span class="ml-auto text-[12px] text-gray-700 transition-colors group-hover:text-gray-500">&rarr;</span>
							</a>
						))}
					</div>
				</section>
			</div>

			<!-- Sidebar — metadata panel -->
			<aside class="mt-8 lg:mt-0">
				<div class="rounded-lg border border-white/[0.06] bg-[#111111]/40">
					<div class="border-b border-white/[0.06] px-4 py-3">
						<h3 class="text-[12px] font-semibold uppercase tracking-widest text-gray-600">Details</h3>
					</div>
					<dl class="divide-y divide-white/[0.04]">
						<div class="flex items-center justify-between px-4 py-3">
							<dt class="text-[13px] text-gray-600">{t.cats.breed}</dt>
							<dd class="text-[13px] text-gray-300">{cat.breed}</dd>
						</div>
						<div class="flex items-center justify-between px-4 py-3">
							<dt class="text-[13px] text-gray-600">{t.cats.age}</dt>
							<dd class="font-mono text-[13px] text-gray-300">{cat.age}</dd>
						</div>
						<div class="flex items-center justify-between px-4 py-3">
							<dt class="text-[13px] text-gray-600">{t.cats.gender}</dt>
							<dd class="text-[13px] text-gray-300">{cat.gender}</dd>
						</div>
						<div class="flex items-center justify-between px-4 py-3">
							<dt class="text-[13px] text-gray-600">{t.cats.color}</dt>
							<dd class="text-[13px] text-gray-300">{cat.color}</dd>
						</div>
						<div class="flex items-center justify-between px-4 py-3">
							<dt class="text-[13px] text-gray-600">{t.cats.arrived}</dt>
							<dd class="font-mono text-[13px] text-gray-300">{cat.arrivalDate}</dd>
						</div>
						<div class="flex items-center justify-between px-4 py-3">
							<dt class="text-[13px] text-gray-600">{t.cats.status}</dt>
							<dd class={`inline-flex items-center gap-1.5 text-[13px] font-medium ${cat.status === 'available' ? 'text-emerald-400/80' : 'text-amber-400/80'}`}>
								<span class={`h-1 w-1 rounded-full ${cat.status === 'available' ? 'bg-emerald-400' : 'bg-amber-400'}`}></span>
								{cat.status}
							</dd>
						</div>
					</dl>
				</div>
			</aside>
		</div>
	</main>
</div>
