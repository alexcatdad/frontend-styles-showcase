---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-[#0a0a0a] font-sans text-gray-200">
	<nav class="sticky top-0 z-50 border-b border-white/10 bg-[#0a0a0a]/80 backdrop-blur-xl">
		<div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
			<div class="flex items-center gap-1">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-lg px-3 py-2 text-sm text-gray-400 transition-colors hover:bg-white/5 hover:text-white">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="mx-auto max-w-4xl px-4 py-12 sm:px-6 sm:py-16">
		<a href={`/${lang}/${style}/cats`} class="mb-8 inline-flex items-center gap-1 text-sm text-gray-500 transition-colors hover:text-emerald-400">&larr; {t.cats.backToAll}</a>

		<article class="mb-16">
			<div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
				<div>
					<h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{cat.name}</h1>
					<span class={`mt-2 inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ${cat.status === 'available' ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' : 'bg-amber-500/10 text-amber-400 border border-amber-500/20'}`}>{cat.status}</span>
				</div>
				<a href={`/${lang}/${style}/auth`} class="inline-flex items-center gap-2 rounded-lg bg-emerald-500 px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-emerald-500/20 transition-all hover:bg-emerald-400 hover:shadow-emerald-500/30">{t.cats.adopt} {cat.name}</a>
			</div>

			<div class="mb-8 grid grid-cols-2 gap-3 sm:grid-cols-3">
				<div class="rounded-lg border border-white/5 bg-gray-900/50 px-4 py-3">
					<dt class="text-xs font-medium uppercase tracking-wider text-gray-600">{t.cats.breed}</dt>
					<dd class="mt-1 text-sm font-medium text-gray-200">{cat.breed}</dd>
				</div>
				<div class="rounded-lg border border-white/5 bg-gray-900/50 px-4 py-3">
					<dt class="text-xs font-medium uppercase tracking-wider text-gray-600">{t.cats.age}</dt>
					<dd class="mt-1 text-sm font-medium text-gray-200">{cat.age}</dd>
				</div>
				<div class="rounded-lg border border-white/5 bg-gray-900/50 px-4 py-3">
					<dt class="text-xs font-medium uppercase tracking-wider text-gray-600">{t.cats.gender}</dt>
					<dd class="mt-1 text-sm font-medium text-gray-200">{cat.gender}</dd>
				</div>
				<div class="rounded-lg border border-white/5 bg-gray-900/50 px-4 py-3">
					<dt class="text-xs font-medium uppercase tracking-wider text-gray-600">{t.cats.color}</dt>
					<dd class="mt-1 text-sm font-medium text-gray-200">{cat.color}</dd>
				</div>
				<div class="rounded-lg border border-white/5 bg-gray-900/50 px-4 py-3">
					<dt class="text-xs font-medium uppercase tracking-wider text-gray-600">{t.cats.arrived}</dt>
					<dd class="mt-1 text-sm font-medium text-gray-200">{cat.arrivalDate}</dd>
				</div>
				<div class="rounded-lg border border-white/5 bg-gray-900/50 px-4 py-3">
					<dt class="text-xs font-medium uppercase tracking-wider text-gray-600">{t.cats.status}</dt>
					<dd class="mt-1 text-sm font-medium text-emerald-400">{cat.status}</dd>
				</div>
			</div>

			<div class="mb-8 flex flex-wrap gap-2">
				{cat.personality.map((trait: string) => (
					<span class="rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1 text-sm text-emerald-400">{trait}</span>
				))}
			</div>

			<p class="text-base leading-relaxed text-gray-400">{cat.description}</p>
		</article>

		<section class="border-t border-white/5 pt-12">
			<h2 class="mb-6 text-xl font-bold tracking-tight text-white">{t.cats.otherCats}</h2>
			<div class="grid gap-4 sm:grid-cols-3">
				{otherCats.map((c: any) => (
					<a href={`/${lang}/${style}/cats/${c.id}`} class="group rounded-xl border border-white/5 bg-gray-900/50 p-4 transition-all hover:border-emerald-500/30 hover:bg-gray-900">
						<h3 class="font-semibold text-white group-hover:text-emerald-400 transition-colors">{c.name}</h3>
						<p class="mt-1 text-sm text-gray-500">{c.breed} · {c.age}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
