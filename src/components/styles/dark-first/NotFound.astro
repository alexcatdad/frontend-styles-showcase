---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-[#0a0a0a] font-sans text-gray-200">
	<nav class="sticky top-0 z-50 border-b border-white/10 bg-[#0a0a0a]/80 backdrop-blur-xl">
		<div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
			<div class="flex items-center gap-1">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-lg px-3 py-2 text-sm text-gray-400 transition-colors hover:bg-white/5 hover:text-white">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="flex min-h-[calc(100vh-65px)] items-center justify-center px-4">
		<section class="text-center">
			<p class="mb-4 text-8xl font-bold tracking-tighter text-emerald-500/20 sm:text-9xl">{t.notFound.title}</p>
			<h2 class="mb-3 text-2xl font-bold tracking-tight text-white sm:text-3xl">{t.notFound.heading}</h2>
			<p class="mx-auto mb-8 max-w-md text-gray-500">{t.notFound.description}</p>
			<div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
				<a href={`/${lang}/${style}/`} class="inline-flex items-center gap-2 rounded-lg bg-emerald-500 px-5 py-2.5 text-sm font-semibold text-white shadow-lg shadow-emerald-500/20 transition-all hover:bg-emerald-400 hover:shadow-emerald-500/30">{t.notFound.backHome}</a>
				<a href={`/${lang}/${style}/cats`} class="inline-flex items-center gap-2 rounded-lg border border-white/10 bg-white/5 px-5 py-2.5 text-sm font-semibold text-gray-300 transition-all hover:border-white/20 hover:bg-white/10 hover:text-white">{t.notFound.meetCats}</a>
			</div>
		</section>
	</main>
</div>
