---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-[#0a0a0a] font-sans text-gray-200 antialiased">
	<nav class="sticky top-0 z-50 border-b border-white/[0.06] bg-[#0a0a0a]/90 backdrop-blur-xl">
		<div class="mx-auto flex h-12 max-w-[1200px] items-center gap-6 px-4 lg:px-6">
			<div class="hidden items-center gap-0.5 sm:flex">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-md px-2.5 py-1.5 text-[13px] text-gray-500 transition-all duration-150 hover:bg-white/[0.04] hover:text-gray-300">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<div class="flex items-center gap-1 overflow-x-auto border-b border-white/[0.06] px-4 sm:hidden">
		{nav.map((item: any) => (
			<a href={item.href} class="shrink-0 px-3 py-2.5 text-[13px] text-gray-500 transition-colors hover:text-gray-300">{item.label}</a>
		))}
	</div>

	<main class="mx-auto max-w-[720px] px-4 py-8 lg:py-10">
		<div class="mb-8">
			<h1 class="text-2xl font-semibold tracking-tight text-white sm:text-3xl">{t.blog.title}</h1>
			<p class="mt-1 text-[14px] text-gray-500">{t.blog.subtitle}</p>
		</div>

		<!-- Clean feed -->
		<div class="divide-y divide-white/[0.04]">
			{posts.map((post: any) => (
				<a href={`/${lang}/${style}/blog/${post.slug}`} class="group block py-5 transition-all duration-150 first:pt-0">
					<article>
						<div class="mb-2 flex items-center gap-3 text-[12px]">
							<time datetime={post.date} class="font-mono text-gray-600">{post.date}</time>
							<span class="h-3 w-px bg-white/[0.06]"></span>
							<span class="text-gray-600">{post.author}</span>
						</div>
						<h2 class="mb-1.5 text-[16px] font-medium text-gray-200 transition-colors group-hover:text-white">{post.title}</h2>
						<p class="mb-3 text-[14px] leading-relaxed text-gray-500">{post.excerpt}</p>
						<div class="flex items-center gap-3">
							<div class="flex flex-wrap gap-1.5">
								{post.tags.map((tag: string) => (
									<span class="rounded border border-white/[0.05] bg-white/[0.02] px-1.5 py-0.5 text-[11px] text-gray-600">{tag}</span>
								))}
							</div>
							<span class="ml-auto text-[12px] text-gray-700 transition-colors group-hover:text-emerald-500/70">&rarr;</span>
						</div>
					</article>
				</a>
			))}
		</div>
	</main>
</div>
