---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-[#0a0a0a] font-sans text-gray-200">
	<nav class="sticky top-0 z-50 border-b border-white/10 bg-[#0a0a0a]/80 backdrop-blur-xl">
		<div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
			<a href={`/${lang}/${style}/`} class="text-lg font-bold tracking-tight text-white">{sanctuary.name}</a>
			<div class="flex items-center gap-1">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-lg px-3 py-2 text-sm text-gray-400 transition-colors hover:bg-white/5 hover:text-white">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main>
		<section class="relative overflow-hidden border-b border-white/5 py-24 sm:py-32 lg:py-40">
			<div class="absolute inset-0 bg-gradient-to-b from-emerald-500/5 via-transparent to-transparent"></div>
			<div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6">
				<div class="mb-4 inline-flex items-center gap-2 rounded-full border border-emerald-500/20 bg-emerald-500/10 px-4 py-1.5 text-sm text-emerald-400">
					<span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
					{sanctuary.tagline}
				</div>
				<h1 class="mb-6 text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">{sanctuary.name}</h1>
				<p class="mx-auto mb-10 max-w-2xl text-lg text-gray-400 sm:text-xl">{sanctuary.mission}</p>
				<div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
					<a href={`/${lang}/${style}/cats`} class="inline-flex items-center gap-2 rounded-lg bg-emerald-500 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-500/20 transition-all hover:bg-emerald-400 hover:shadow-emerald-500/30">{t.home.meetCats} &rarr;</a>
					<a href={`/${lang}/${style}/donate`} class="inline-flex items-center gap-2 rounded-lg border border-white/10 bg-white/5 px-6 py-3 text-sm font-semibold text-gray-300 transition-all hover:border-white/20 hover:bg-white/10 hover:text-white">{t.home.donate}</a>
				</div>
			</div>
		</section>

		<section class="border-b border-white/5 py-16 sm:py-20">
			<div class="mx-auto max-w-6xl px-4 sm:px-6">
				<div class="grid grid-cols-2 gap-4 sm:grid-cols-4 sm:gap-6">
					{sanctuary.stats.map((stat: any) => (
						<div class="rounded-xl border border-white/5 bg-gray-900/50 p-6 text-center">
							<span class="block text-3xl font-bold tracking-tight text-emerald-400 sm:text-4xl">{stat.value}</span>
							<span class="mt-1 block text-sm text-gray-500">{stat.label}</span>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="border-b border-white/5 py-16 sm:py-20">
			<div class="mx-auto max-w-3xl px-4 sm:px-6">
				<h2 class="mb-3 text-sm font-semibold uppercase tracking-widest text-emerald-400">{t.home.mission}</h2>
				<p class="text-xl leading-relaxed text-gray-300 sm:text-2xl">{sanctuary.mission}</p>
			</div>
		</section>

		<section class="py-16 sm:py-20">
			<div class="mx-auto max-w-3xl px-4 sm:px-6">
				<h2 class="mb-8 text-2xl font-bold tracking-tight text-white">{t.home.aboutUs}</h2>
				<div class="space-y-5">
					{sanctuary.about.map((paragraph: string) => (
						<p class="text-base leading-relaxed text-gray-400">{paragraph}</p>
					))}
				</div>
			</div>
		</section>
	</main>

	<footer class="border-t border-white/5 py-8">
		<div class="mx-auto max-w-6xl px-4 text-center sm:px-6">
			<p class="text-sm text-gray-600">&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.</p>
		</div>
	</footer>
</div>
