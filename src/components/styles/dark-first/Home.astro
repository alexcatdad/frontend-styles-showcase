---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-[#0a0a0a] font-sans text-gray-200 antialiased">
	<!-- Compact persistent top bar -->
	<nav class="sticky top-0 z-50 border-b border-white/[0.06] bg-[#0a0a0a]/90 backdrop-blur-xl">
		<div class="mx-auto flex h-12 max-w-[1200px] items-center justify-between px-4 lg:px-6">
			<div class="flex items-center gap-6">
				<a href={`${_base}/${lang}/${style}/`} class="flex items-center gap-2 text-[13px] font-semibold tracking-tight text-white">
					<span class="flex h-5 w-5 items-center justify-center rounded bg-emerald-500/90 text-[10px] font-bold text-white">S</span>
					{sanctuary.name}
				</a>
				<span class="hidden h-4 w-px bg-white/[0.08] sm:block"></span>
				<div class="hidden items-center gap-0.5 sm:flex">
					{nav.map((item: any) => (
						<a href={item.href} class="rounded-md px-2.5 py-1.5 text-[13px] text-gray-500 transition-all duration-150 hover:bg-white/[0.04] hover:text-gray-300">{item.label}</a>
					))}
				</div>
			</div>
			<div class="flex items-center gap-2">
				<div class="hidden items-center gap-1.5 rounded-md border border-white/[0.06] bg-white/[0.03] px-2.5 py-1 text-[12px] text-gray-600 sm:flex">
					<kbd class="font-mono text-[11px] text-gray-500">&#8984;K</kbd>
				</div>
			</div>
		</div>
	</nav>

	<!-- Mobile nav -->
	<div class="flex items-center gap-1 overflow-x-auto border-b border-white/[0.06] px-4 sm:hidden">
		{nav.map((item: any) => (
			<a href={item.href} class="shrink-0 border-b-2 border-transparent px-3 py-2.5 text-[13px] text-gray-500 transition-colors hover:text-gray-300">{item.label}</a>
		))}
	</div>

	<main class="mx-auto max-w-[1200px] px-4 lg:px-6">
		<!-- Dashboard metrics bar -->
		<div class="grid grid-cols-2 gap-px overflow-hidden rounded-lg border border-white/[0.06] bg-white/[0.03] sm:grid-cols-4 mt-6 lg:mt-8">
			{sanctuary.stats.map((stat: any) => (
				<div class="bg-[#0a0a0a] px-4 py-4 sm:px-5 sm:py-5">
					<span class="block font-mono text-2xl font-semibold tracking-tight text-white sm:text-3xl">{stat.value}</span>
					<span class="mt-0.5 block text-[12px] font-medium uppercase tracking-wider text-gray-600">{stat.label}</span>
				</div>
			))}
		</div>

		<!-- Hero section — clean, restrained -->
		<section class="relative mt-12 sm:mt-16 lg:mt-20">
			<div class="max-w-2xl">
				<div class="mb-4 inline-flex items-center gap-2 rounded-full border border-emerald-500/15 bg-emerald-500/[0.07] px-3 py-1 text-[12px] font-medium text-emerald-400/90">
					<span class="h-1.5 w-1.5 animate-pulse rounded-full bg-emerald-400"></span>
					{sanctuary.tagline}
				</div>
				<h1 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl lg:text-[42px] lg:leading-[1.15]">{sanctuary.name}</h1>
				<p class="mt-4 text-base leading-relaxed text-gray-500 sm:text-[17px]">{sanctuary.mission}</p>
				<img src={sanctuary.heroImage} alt={sanctuary.name} class="w-full mt-8 rounded-lg object-cover border border-white/[0.06]" />
				<div class="mt-8 flex items-center gap-3">
					<a href={`${_base}/${lang}/${style}/cats`} class="inline-flex items-center gap-2 rounded-lg bg-white px-4 py-2 text-[13px] font-semibold text-[#0a0a0a] transition-all duration-150 hover:bg-gray-200">
						{t.home.meetCats}
						<span class="text-gray-500">&rarr;</span>
					</a>
					<a href={`${_base}/${lang}/${style}/donate`} class="inline-flex items-center gap-2 rounded-lg border border-white/[0.08] bg-white/[0.03] px-4 py-2 text-[13px] font-medium text-gray-400 transition-all duration-150 hover:border-white/[0.12] hover:bg-white/[0.05] hover:text-gray-300">{t.home.donate}</a>
				</div>
			</div>
		</section>

		<!-- Mission panel -->
		<section class="mt-16 rounded-lg border border-white/[0.06] bg-[#111111]/50 p-6 sm:mt-20 sm:p-8">
			<div class="flex items-center gap-2 mb-4">
				<span class="h-1.5 w-1.5 rounded-full bg-emerald-500/70"></span>
				<h2 class="text-[12px] font-semibold uppercase tracking-widest text-gray-500">{t.home.mission}</h2>
			</div>
			<p class="max-w-2xl text-lg leading-relaxed text-gray-300 sm:text-xl">{sanctuary.mission}</p>
		</section>

		<!-- About section — constrained-width content panel -->
		<section class="mt-12 sm:mt-16">
			<div class="flex items-center gap-2 mb-6">
				<span class="h-1.5 w-1.5 rounded-full bg-emerald-500/70"></span>
				<h2 class="text-[12px] font-semibold uppercase tracking-widest text-gray-500">{t.home.aboutUs}</h2>
			</div>
			<div class="max-w-2xl space-y-4">
				{sanctuary.about.map((paragraph: string) => (
					<p class="text-[15px] leading-relaxed text-gray-400">{paragraph}</p>
				))}
			</div>
		</section>

		<!-- Contact -->
		{sanctuary.contact && (
			<section class="mt-12 mb-4 rounded-lg border border-white/[0.06] bg-[#111111]/30 p-5 sm:p-6">
				<div class="flex flex-wrap items-center gap-x-6 gap-y-2">
					{sanctuary.contact.email && (
						<div class="flex items-center gap-2 text-[13px]">
							<span class="text-gray-600">Email</span>
							<span class="text-gray-400">{sanctuary.contact.email}</span>
						</div>
					)}
					{sanctuary.contact.phone && (
						<div class="flex items-center gap-2 text-[13px]">
							<span class="text-gray-600">Phone</span>
							<span class="font-mono text-gray-400">{sanctuary.contact.phone}</span>
						</div>
					)}
					{sanctuary.contact.address && (
						<div class="flex items-center gap-2 text-[13px]">
							<span class="text-gray-600">Address</span>
							<span class="text-gray-400">{sanctuary.contact.address}</span>
						</div>
					)}
				</div>
			</section>
		)}
	</main>

	<footer class="mt-16 border-t border-white/[0.04] py-6">
		<div class="mx-auto max-w-[1200px] px-4 lg:px-6">
			<p class="text-[12px] text-gray-700">&copy; 2026 {sanctuary.name} &middot; {t.footer.style}: {meta.name}</p>
		</div>
	</footer>
</div>
