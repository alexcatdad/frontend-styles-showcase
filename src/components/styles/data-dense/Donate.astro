---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
const totalMonthlyOptions = monthlyTiers.length;
const totalOneTimeOptions = oneTimeTiers.length;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-gray-100 text-gray-800 font-sans text-xs leading-tight">
	<!-- Metrics strip -->
	<div class="bg-gray-900 text-gray-300 px-2 py-0.5 flex items-center gap-4 text-[10px] font-mono overflow-x-auto">
		<div class="flex items-center gap-1 whitespace-nowrap">
			<span class="text-gray-500 uppercase">Monthly Plans:</span>
			<span class="text-green-400 font-bold">{totalMonthlyOptions}</span>
		</div>
		<div class="flex items-center gap-1 whitespace-nowrap">
			<span class="text-gray-500 uppercase">One-Time Options:</span>
			<span class="text-amber-400 font-bold">{totalOneTimeOptions}</span>
		</div>
		<div class="flex items-center gap-1 whitespace-nowrap">
			<span class="text-gray-500 uppercase">Range:</span>
			<span class="text-white">${Math.min(...monthlyTiers.map((t: any) => t.amount), ...oneTimeTiers.map((t: any) => t.amount))}&ndash;${Math.max(...monthlyTiers.map((t: any) => t.amount), ...oneTimeTiers.map((t: any) => t.amount))}</span>
		</div>
		<div class="ml-auto flex items-center gap-1 whitespace-nowrap">
			<span class="w-1 h-1 rounded-full bg-green-400 inline-block animate-pulse"></span>
			<span class="text-gray-500">ACCEPTING</span>
		</div>
	</div>

	<!-- Toolbar with breadcrumbs -->
	<nav class="bg-white border-b border-gray-300 px-2 py-1 flex items-center gap-1 text-xs sticky top-0 z-50">
		<a href={`${_base}/${lang}/${style}/`} class="text-gray-400 hover:text-gray-700 text-[11px] transition-colors">Home</a>
		<span class="text-gray-300 mx-0.5">/</span>
		<span class="font-bold text-gray-900 text-[11px]">{t.donate.title}</span>
		<div class="ml-auto flex items-center gap-0.5">
			{nav.map((item: any) => (
				<a href={item.href} class="text-gray-600 hover:text-white hover:bg-gray-700 px-1.5 py-0.5 rounded transition-colors text-[11px]">{item.label}</a>
			))}
		</div>
	</nav>

	<!-- Sidebar + Main -->
	<div class="flex min-h-[calc(100vh-52px)]">
		<!-- Left sidebar -->
		<aside class="hidden lg:block w-44 shrink-0 bg-white border-r border-gray-300 overflow-y-auto">
			<div class="p-2 border-b border-gray-200">
				<div class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Overview</div>
				<p class="text-[10px] text-gray-500 leading-relaxed">{t.donate.subtitle}</p>
			</div>
			<div class="p-2 border-b border-gray-200">
				<div class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Plan Types</div>
				<div class="space-y-0.5">
					<div class="flex items-center justify-between text-[10px] py-0.5 px-1 rounded hover:bg-gray-50">
						<span class="flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span> {t.donate.monthly}</span>
						<span class="font-mono font-bold text-gray-700">{totalMonthlyOptions}</span>
					</div>
					<div class="flex items-center justify-between text-[10px] py-0.5 px-1 rounded hover:bg-gray-50">
						<span class="flex items-center gap-1"><span class="w-1.5 h-1.5 rounded-full bg-amber-400 inline-block"></span> {t.donate.oneTime}</span>
						<span class="font-mono font-bold text-gray-700">{totalOneTimeOptions}</span>
					</div>
				</div>
			</div>
			<div class="p-2">
				<div class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Navigation</div>
				{nav.map((item: any) => (
					<a href={item.href} class="flex items-center gap-1.5 py-0.5 px-1 text-[10px] text-gray-600 hover:bg-blue-50 hover:text-blue-700 rounded transition-colors">
						<span class="w-1 h-1 rounded-full bg-gray-300 inline-block"></span>
						{item.label}
					</a>
				))}
			</div>
		</aside>

		<!-- Main: tables for tiers -->
		<main class="flex-1 p-2 overflow-y-auto">
			<div class="grid grid-cols-1 xl:grid-cols-2 gap-2">
				<!-- Monthly tiers table -->
				<div class="bg-white border border-gray-300 rounded">
					<div class="bg-gray-50 border-b border-gray-200 px-2 py-1 flex items-center justify-between">
						<div class="flex items-center gap-1.5">
							<span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>
							<span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">{t.donate.monthly}</span>
						</div>
						<span class="text-[9px] text-gray-400 font-mono">{totalMonthlyOptions} plans</span>
					</div>
					<table class="w-full text-[10px] border-collapse">
						<thead>
							<tr class="bg-gray-100 border-b border-gray-200">
								<th class="text-left px-2 py-0.5 font-bold text-gray-600 uppercase tracking-wider border-r border-gray-200" style="font-size:9px">Plan</th>
								<th class="text-right px-2 py-0.5 font-bold text-gray-600 uppercase tracking-wider border-r border-gray-200" style="font-size:9px">Amount</th>
								<th class="text-left px-2 py-0.5 font-bold text-gray-600 uppercase tracking-wider border-r border-gray-200 hidden sm:table-cell" style="font-size:9px">Description</th>
								<th class="text-left px-2 py-0.5 font-bold text-gray-600 uppercase tracking-wider border-r border-gray-200 hidden md:table-cell" style="font-size:9px">Perks</th>
								<th class="text-center px-2 py-0.5 font-bold text-gray-600 uppercase tracking-wider" style="font-size:9px">Action</th>
							</tr>
						</thead>
						<tbody>
							{monthlyTiers.map((tier: any, i: number) => (
								<tr class={`border-b border-gray-100 hover:bg-blue-50/60 transition-colors ${tier.highlighted ? 'bg-blue-50/30' : i % 2 === 0 ? 'bg-white' : 'bg-gray-50/30'}`}>
									<td class="px-2 py-1 border-r border-gray-100">
										<div class="flex items-center gap-1">
											<span class="font-semibold text-gray-900">{tier.name}</span>
											{tier.highlighted && (
												<span class="bg-blue-600 text-white text-[8px] px-1 py-0 rounded font-bold uppercase">{t.donate.mostPopular}</span>
											)}
										</div>
									</td>
									<td class="px-2 py-1 text-right font-mono font-bold text-gray-900 border-r border-gray-100 whitespace-nowrap">
										${tier.amount}<span class="text-[8px] text-gray-400 font-normal">{t.donate.perMonth}</span>
									</td>
									<td class="px-2 py-1 text-gray-500 border-r border-gray-100 hidden sm:table-cell">
										<span class="line-clamp-2">{tier.description}</span>
									</td>
									<td class="px-2 py-1 border-r border-gray-100 hidden md:table-cell">
										<div class="flex flex-wrap gap-0.5">
											{tier.perks.map((perk: string) => (
												<span class="bg-gray-200 text-gray-600 px-1 py-0 rounded text-[9px]">{perk}</span>
											))}
										</div>
									</td>
									<td class="px-2 py-1 text-center">
										<button type="button" class={`text-[9px] px-2 py-0.5 rounded font-semibold whitespace-nowrap ${tier.highlighted ? 'bg-blue-600 text-white hover:bg-blue-700' : 'bg-gray-200 text-gray-700 hover:bg-gray-300 border border-gray-300'} transition-colors`}>
											{t.donate.choose}
										</button>
									</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>

				<!-- One-time tiers table -->
				<div class="bg-white border border-gray-300 rounded">
					<div class="bg-gray-50 border-b border-gray-200 px-2 py-1 flex items-center justify-between">
						<div class="flex items-center gap-1.5">
							<span class="w-1.5 h-1.5 rounded-full bg-amber-400 inline-block"></span>
							<span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">{t.donate.oneTime}</span>
						</div>
						<span class="text-[9px] text-gray-400 font-mono">{totalOneTimeOptions} options</span>
					</div>
					<table class="w-full text-[10px] border-collapse">
						<thead>
							<tr class="bg-gray-100 border-b border-gray-200">
								<th class="text-left px-2 py-0.5 font-bold text-gray-600 uppercase tracking-wider border-r border-gray-200" style="font-size:9px">Tier</th>
								<th class="text-right px-2 py-0.5 font-bold text-gray-600 uppercase tracking-wider border-r border-gray-200" style="font-size:9px">Amount</th>
								<th class="text-left px-2 py-0.5 font-bold text-gray-600 uppercase tracking-wider border-r border-gray-200 hidden sm:table-cell" style="font-size:9px">Description</th>
								<th class="text-left px-2 py-0.5 font-bold text-gray-600 uppercase tracking-wider border-r border-gray-200 hidden md:table-cell" style="font-size:9px">Perks</th>
								<th class="text-center px-2 py-0.5 font-bold text-gray-600 uppercase tracking-wider" style="font-size:9px">Action</th>
							</tr>
						</thead>
						<tbody>
							{oneTimeTiers.map((tier: any, i: number) => (
								<tr class={`border-b border-gray-100 hover:bg-amber-50/60 transition-colors ${tier.highlighted ? 'bg-amber-50/30' : i % 2 === 0 ? 'bg-white' : 'bg-gray-50/30'}`}>
									<td class="px-2 py-1 border-r border-gray-100">
										<div class="flex items-center gap-1">
											<span class="font-semibold text-gray-900">{tier.name}</span>
											{tier.highlighted && (
												<span class="bg-amber-500 text-white text-[8px] px-1 py-0 rounded font-bold uppercase">{t.donate.greatestImpact}</span>
											)}
										</div>
									</td>
									<td class="px-2 py-1 text-right font-mono font-bold text-gray-900 border-r border-gray-100 whitespace-nowrap">
										${tier.amount}
									</td>
									<td class="px-2 py-1 text-gray-500 border-r border-gray-100 hidden sm:table-cell">
										<span class="line-clamp-2">{tier.description}</span>
									</td>
									<td class="px-2 py-1 border-r border-gray-100 hidden md:table-cell">
										<div class="flex flex-wrap gap-0.5">
											{tier.perks.map((perk: string) => (
												<span class="bg-gray-200 text-gray-600 px-1 py-0 rounded text-[9px]">{perk}</span>
											))}
										</div>
									</td>
									<td class="px-2 py-1 text-center">
										<button type="button" class={`text-[9px] px-2 py-0.5 rounded font-semibold whitespace-nowrap ${tier.highlighted ? 'bg-amber-500 text-white hover:bg-amber-600' : 'bg-gray-200 text-gray-700 hover:bg-gray-300 border border-gray-300'} transition-colors`}>
											{t.donate.give} ${tier.amount}
										</button>
									</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</div>

			<!-- Dense form: custom donation (visible below tables) -->
			<div class="mt-2 bg-white border border-gray-300 rounded">
				<div class="bg-gray-50 border-b border-gray-200 px-2 py-1">
					<span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Custom Amount</span>
				</div>
				<div class="p-2">
					<form class="flex items-center gap-2 flex-wrap">
						<label for="custom-amount" class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider whitespace-nowrap">Amount ($)</label>
						<input type="number" id="custom-amount" name="amount" placeholder="0.00" min="1" class="w-24 text-xs border border-gray-200 rounded px-2 py-1 bg-gray-50 focus:bg-white focus:border-blue-400 focus:outline-none transition-colors placeholder:text-gray-300 font-mono" />
						<label for="custom-freq" class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider whitespace-nowrap">Frequency</label>
						<select id="custom-freq" name="frequency" class="text-xs border border-gray-200 rounded px-2 py-1 bg-gray-50 focus:bg-white focus:border-blue-400 focus:outline-none transition-colors">
							<option>{t.donate.oneTime}</option>
							<option>{t.donate.monthly}</option>
						</select>
						<button type="submit" class="bg-blue-600 text-white text-[10px] px-3 py-1 rounded hover:bg-blue-700 transition-colors font-semibold whitespace-nowrap">{t.donate.give}</button>
					</form>
				</div>
			</div>
		</main>
	</div>
</div>
