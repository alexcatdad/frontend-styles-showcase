---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-gray-50 text-gray-800 text-sm">
	<nav class="bg-white border-b border-gray-200 px-3 py-1.5 flex items-center gap-4 text-xs sticky top-0 z-50">
		<span class="font-semibold text-gray-900 tracking-tight text-sm mr-2">{cat.name}</span>
		<div class="flex items-center gap-3">
			{nav.map((item: any) => (
				<a href={item.href} class="text-gray-500 hover:text-gray-900 transition-colors">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="max-w-6xl mx-auto px-3 py-3">
		<!-- Breadcrumb -->
		<div class="text-xs text-gray-400 mb-2">
			<a href={`/${lang}/${style}/cats`} class="hover:text-gray-700 transition-colors">&larr; {t.cats.backToAll}</a>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-3">
			<!-- Left panel: key data -->
			<div class="md:col-span-1 space-y-3">
				<!-- Data card -->
				<div class="bg-white border border-gray-200 rounded p-3">
					<div class="flex items-center justify-between mb-2">
						<h1 class="text-base font-bold text-gray-900 leading-tight">{cat.name}</h1>
						<span class={`inline-flex items-center gap-1 text-[10px] font-medium px-1.5 py-0.5 rounded-full ${cat.status === 'Available' ? 'bg-green-50 text-green-700' : cat.status === 'Adopted' ? 'bg-blue-50 text-blue-700' : 'bg-amber-50 text-amber-700'}`}>
							<span class={`w-1.5 h-1.5 rounded-full ${cat.status === 'Available' ? 'bg-green-400' : cat.status === 'Adopted' ? 'bg-blue-400' : 'bg-amber-400'}`}></span>
							{cat.status}
						</span>
					</div>

					<dl class="text-xs divide-y divide-gray-100">
						<div class="flex justify-between py-1">
							<dt class="text-gray-400">{t.cats.breed}</dt>
							<dd class="text-gray-800 font-medium">{cat.breed}</dd>
						</div>
						<div class="flex justify-between py-1">
							<dt class="text-gray-400">{t.cats.age}</dt>
							<dd class="text-gray-800 font-mono">{cat.age}</dd>
						</div>
						<div class="flex justify-between py-1">
							<dt class="text-gray-400">{t.cats.gender}</dt>
							<dd class="text-gray-800">{cat.gender}</dd>
						</div>
						<div class="flex justify-between py-1">
							<dt class="text-gray-400">{t.cats.color}</dt>
							<dd class="text-gray-800">{cat.color}</dd>
						</div>
						<div class="flex justify-between py-1">
							<dt class="text-gray-400">{t.cats.arrived}</dt>
							<dd class="text-gray-800 font-mono text-[10px]">{cat.arrivalDate}</dd>
						</div>
					</dl>
				</div>

				<!-- Traits -->
				<div class="bg-white border border-gray-200 rounded p-3">
					<h2 class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Personality</h2>
					<div class="flex flex-wrap gap-1">
						{cat.personality.map((trait: string) => (
							<span class="bg-blue-50 text-blue-700 text-[10px] px-1.5 py-0.5 rounded-full font-medium">{trait}</span>
						))}
					</div>
				</div>

				<!-- CTA -->
				<a href={`/${lang}/${style}/auth`} class="block w-full bg-blue-600 text-white text-xs text-center px-3 py-2 rounded hover:bg-blue-700 transition-colors font-medium">
					{t.cats.adopt} {cat.name}
				</a>
			</div>

			<!-- Right panel: description + other cats -->
			<div class="md:col-span-2 space-y-3">
				<div class="bg-white border border-gray-200 rounded p-3">
					<h2 class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider mb-1.5">Description</h2>
					<p class="text-xs text-gray-700 leading-relaxed">{cat.description}</p>
				</div>

				<!-- Other cats as compact table -->
				<div class="bg-white border border-gray-200 rounded p-3">
					<h2 class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider mb-2">{t.cats.otherCats}</h2>
					<div class="divide-y divide-gray-100">
						{otherCats.map((c: any) => (
							<a href={`/${lang}/${style}/cats/${c.id}`} class="flex items-center justify-between py-1.5 hover:bg-gray-50 -mx-1 px-1 rounded transition-colors group">
								<div>
									<span class="text-xs font-medium text-blue-600 group-hover:text-blue-800">{c.name}</span>
									<span class="text-[10px] text-gray-400 ml-1.5">{c.breed} · {c.age}</span>
								</div>
								<span class={`text-[10px] px-1.5 py-0.5 rounded-full font-medium ${c.status === 'Available' ? 'bg-green-50 text-green-700' : 'bg-amber-50 text-amber-700'}`}>{c.status}</span>
							</a>
						))}
					</div>
				</div>
			</div>
		</div>
	</main>
</div>
