---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-gray-50 text-gray-800 text-sm">
	<nav class="bg-white border-b border-gray-200 px-3 py-1.5 flex items-center gap-4 text-xs sticky top-0 z-50">
		<span class="font-semibold text-gray-900 tracking-tight text-sm mr-2">{t.blog.title}</span>
		<div class="flex items-center gap-3">
			{nav.map((item: any) => (
				<a href={item.href} class="text-gray-500 hover:text-gray-900 transition-colors">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="max-w-6xl mx-auto px-3 py-3">
		<div class="flex items-baseline justify-between mb-2">
			<div>
				<h1 class="text-base font-bold text-gray-900 leading-tight">{t.blog.title}</h1>
				<p class="text-xs text-gray-500 mt-0.5">{t.blog.subtitle}</p>
			</div>
			<span class="text-xs text-gray-400 font-mono">{posts.length} posts</span>
		</div>

		<!-- Dense list view -->
		<div class="bg-white border border-gray-200 rounded divide-y divide-gray-100">
			{posts.map((post: any) => (
				<a href={`/${lang}/${style}/blog/${post.slug}`} class="block px-3 py-2 hover:bg-blue-50/50 transition-colors group">
					<div class="flex items-start justify-between gap-3">
						<div class="min-w-0 flex-1">
							<div class="flex items-center gap-2 mb-0.5">
								<h2 class="text-xs font-semibold text-gray-900 group-hover:text-blue-700 truncate transition-colors">{post.title}</h2>
							</div>
							<p class="text-[10px] text-gray-500 line-clamp-1">{post.excerpt}</p>
							<div class="flex items-center gap-2 mt-1">
								<span class="text-[10px] text-gray-400">{t.blog.by} {post.author}</span>
								<span class="text-gray-300">|</span>
								<div class="flex gap-1">
									{post.tags.map((tag: string) => (
										<span class="bg-gray-100 text-gray-500 text-[10px] px-1 rounded">{tag}</span>
									))}
								</div>
							</div>
						</div>
						<time datetime={post.date} class="text-[10px] text-gray-400 font-mono whitespace-nowrap shrink-0">{post.date}</time>
					</div>
				</a>
			))}
		</div>
	</main>
</div>
