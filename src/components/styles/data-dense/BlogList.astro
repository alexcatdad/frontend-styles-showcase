---
const { lang, style, nav, posts, t } = Astro.props;
const allTags = [...new Set(posts.flatMap((p: any) => p.tags))];
const authors = [...new Set(posts.map((p: any) => p.author))];
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-gray-100 text-gray-800 font-sans text-xs leading-tight">
	<!-- Metrics strip -->
	<div class="bg-gray-900 text-gray-300 px-2 py-0.5 flex items-center gap-4 text-[10px] font-mono overflow-x-auto">
		<div class="flex items-center gap-1 whitespace-nowrap">
			<span class="text-gray-500 uppercase">Posts:</span>
			<span class="text-white font-bold">{posts.length}</span>
		</div>
		<div class="flex items-center gap-1 whitespace-nowrap">
			<span class="text-gray-500 uppercase">Authors:</span>
			<span class="text-cyan-400 font-bold">{authors.length}</span>
		</div>
		<div class="flex items-center gap-1 whitespace-nowrap">
			<span class="text-gray-500 uppercase">Tags:</span>
			<span class="text-amber-400 font-bold">{allTags.length}</span>
		</div>
		<div class="ml-auto flex items-center gap-1 whitespace-nowrap">
			<span class="w-1 h-1 rounded-full bg-green-400 inline-block animate-pulse"></span>
			<span class="text-gray-500">LIVE</span>
		</div>
	</div>

	<!-- Toolbar with breadcrumbs -->
	<nav class="bg-white border-b border-gray-300 px-2 py-1 flex items-center gap-1 text-xs sticky top-0 z-50">
		<a href={`${_base}/${lang}/${style}/`} class="text-gray-400 hover:text-gray-700 text-[11px] transition-colors">Home</a>
		<span class="text-gray-300 mx-0.5">/</span>
		<span class="font-bold text-gray-900 text-[11px]">{t.blog.title}</span>
		<span class="text-gray-400 font-mono text-[10px] ml-1">({posts.length})</span>
		<div class="ml-auto flex items-center gap-0.5">
			{nav.map((item: any) => (
				<a href={item.href} class="text-gray-600 hover:text-white hover:bg-gray-700 px-1.5 py-0.5 rounded transition-colors text-[11px]">{item.label}</a>
			))}
		</div>
	</nav>

	<!-- Sidebar + Main -->
	<div class="flex min-h-[calc(100vh-52px)]">
		<!-- Left sidebar: tags + authors index -->
		<aside class="hidden lg:block w-44 shrink-0 bg-white border-r border-gray-300 overflow-y-auto">
			<div class="p-2 border-b border-gray-200">
				<div class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">{t.blog.subtitle}</div>
			</div>
			<div class="p-2 border-b border-gray-200">
				<div class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Tags</div>
				<div class="flex flex-wrap gap-0.5">
					{allTags.map((tag: string) => (
						<span class="bg-gray-100 text-gray-600 text-[9px] px-1 py-0 rounded border border-gray-200">{tag}</span>
					))}
				</div>
			</div>
			<div class="p-2 border-b border-gray-200">
				<div class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Authors</div>
				<div class="space-y-0.5">
					{authors.map((author: string) => (
						<div class="flex items-center gap-1 text-[10px] text-gray-600">
							<span class="w-1.5 h-1.5 rounded-full bg-cyan-400 inline-block"></span>
							{author}
						</div>
					))}
				</div>
			</div>
			<div class="p-2">
				<div class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Navigation</div>
				{nav.map((item: any) => (
					<a href={item.href} class="flex items-center gap-1.5 py-0.5 px-1 text-[10px] text-gray-600 hover:bg-blue-50 hover:text-blue-700 rounded transition-colors">
						<span class="w-1 h-1 rounded-full bg-gray-300 inline-block"></span>
						{item.label}
					</a>
				))}
			</div>
		</aside>

		<!-- Main: table-style feed -->
		<main class="flex-1 overflow-x-auto">
			<div class="bg-gray-50 border-b border-gray-200 px-2 py-1 flex items-center justify-between">
				<div class="flex items-center gap-2">
					<h1 class="text-xs font-bold text-gray-800">{t.blog.title}</h1>
					<span class="text-[10px] text-gray-400 font-mono bg-gray-200 px-1 rounded">{posts.length} entries</span>
				</div>
			</div>

			<!-- Blog as spreadsheet rows -->
			<table class="w-full text-[10px] border-collapse">
				<thead>
					<tr class="bg-gray-100 border-b border-gray-300">
						<th class="text-left px-2 py-1 font-bold text-gray-600 uppercase tracking-wider border-r border-gray-200 whitespace-nowrap" style="font-size:9px">#</th>
						<th class="text-left px-2 py-1 font-bold text-gray-600 uppercase tracking-wider border-r border-gray-200 whitespace-nowrap" style="font-size:9px">Date</th>
						<th class="text-left px-2 py-1 font-bold text-gray-600 uppercase tracking-wider border-r border-gray-200" style="font-size:9px">Title</th>
						<th class="text-left px-2 py-1 font-bold text-gray-600 uppercase tracking-wider border-r border-gray-200 hidden md:table-cell" style="font-size:9px">Author</th>
						<th class="text-left px-2 py-1 font-bold text-gray-600 uppercase tracking-wider border-r border-gray-200 hidden lg:table-cell" style="font-size:9px">Excerpt</th>
						<th class="text-left px-2 py-1 font-bold text-gray-600 uppercase tracking-wider hidden sm:table-cell" style="font-size:9px">Tags</th>
					</tr>
				</thead>
				<tbody>
					{posts.map((post: any, idx: number) => (
						<tr class={`border-b border-gray-100 hover:bg-blue-50/60 transition-colors group ${idx % 2 === 0 ? 'bg-white' : 'bg-gray-50/30'}`}>
							<td class="px-2 py-1 text-gray-400 font-mono border-r border-gray-100 whitespace-nowrap">{idx + 1}</td>
							<td class="px-2 py-1 font-mono text-gray-500 border-r border-gray-100 whitespace-nowrap">{post.date}</td>
							<td class="px-2 py-1 border-r border-gray-100">
								<a href={`${_base}/${lang}/${style}/blog/${post.slug}`} class="font-semibold text-blue-600 hover:text-blue-800 hover:underline inline-flex items-center gap-1">
									<img src={post.image} alt={post.title} class="w-4 h-4 rounded-sm object-cover inline-block border border-gray-200" />
									{post.title}
								</a>
							</td>
							<td class="px-2 py-1 text-gray-600 border-r border-gray-100 hidden md:table-cell whitespace-nowrap">
								<span class="flex items-center gap-1">
									<span class="w-1.5 h-1.5 rounded-full bg-cyan-400 inline-block"></span>
									{post.author}
								</span>
							</td>
							<td class="px-2 py-1 text-gray-500 border-r border-gray-100 hidden lg:table-cell">
								<span class="line-clamp-1">{post.excerpt}</span>
							</td>
							<td class="px-2 py-1 hidden sm:table-cell">
								<div class="flex flex-wrap gap-0.5">
									{post.tags.map((tag: string) => (
										<span class="bg-gray-200 text-gray-600 px-1 py-0 rounded text-[9px]">{tag}</span>
									))}
								</div>
							</td>
						</tr>
					))}
				</tbody>
			</table>

			<!-- Table footer -->
			<div class="bg-gray-50 border-t border-gray-200 px-2 py-1 flex items-center justify-between text-[10px] text-gray-500 font-mono">
				<span>{posts.length} rows</span>
				<span>End of feed</span>
			</div>

			<!-- Mobile compact list -->
			<div class="sm:hidden p-2 space-y-0.5">
				{posts.map((post: any, idx: number) => (
					<a href={`${_base}/${lang}/${style}/blog/${post.slug}`} class="block bg-white border border-gray-200 rounded px-2 py-1 hover:border-blue-300 transition-colors">
						<div class="flex items-center justify-between">
							<span class="font-semibold text-[10px] text-gray-900 truncate">{post.title}</span>
							<span class="text-[9px] text-gray-400 font-mono shrink-0 ml-1">{post.date}</span>
						</div>
						<div class="text-[9px] text-gray-500 mt-0.5">{t.blog.by} {post.author}</div>
					</a>
				))}
			</div>
		</main>
	</div>
</div>
