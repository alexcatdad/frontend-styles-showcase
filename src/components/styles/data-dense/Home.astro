---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
const statusCounts = { available: 0, adopted: 0, pending: 0 };
---

<div class="min-h-screen bg-gray-100 text-gray-800 font-sans text-xs leading-tight">
	<!-- Persistent metrics header strip -->
	<div class="bg-gray-900 text-gray-300 px-2 py-0.5 flex items-center gap-4 text-[10px] font-mono overflow-x-auto">
		{sanctuary.stats.map((stat: any) => (
			<div class="flex items-center gap-1 whitespace-nowrap">
				<span class="text-gray-500 uppercase">{stat.label}:</span>
				<span class="text-green-400 font-bold">{stat.value}</span>
			</div>
		))}
		<div class="ml-auto flex items-center gap-1 whitespace-nowrap">
			<span class="w-1 h-1 rounded-full bg-green-400 inline-block animate-pulse"></span>
			<span class="text-gray-500">LIVE</span>
		</div>
	</div>

	<!-- Compact toolbar nav with breadcrumbs -->
	<nav class="bg-white border-b border-gray-300 px-2 py-1 flex items-center gap-1 text-xs sticky top-0 z-50">
		<span class="font-bold text-gray-900 text-sm tracking-tight mr-1">{sanctuary.name}</span>
		<span class="text-gray-300 mx-0.5">/</span>
		<span class="text-gray-500">{t.home.mission}</span>
		<div class="ml-auto flex items-center gap-0.5">
			{nav.map((item: any) => (
				<a href={item.href} class="text-gray-600 hover:text-white hover:bg-gray-700 px-1.5 py-0.5 rounded transition-colors text-[11px]">{item.label}</a>
			))}
		</div>
	</nav>

	<!-- Sidebar + Main content layout -->
	<div class="flex min-h-[calc(100vh-52px)]">
		<!-- Left sidebar panel -->
		<aside class="hidden lg:block w-52 shrink-0 bg-white border-r border-gray-300 overflow-y-auto">
			<div class="p-2 border-b border-gray-200">
				<div class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Quick Links</div>
				{nav.map((item: any) => (
					<a href={item.href} class="flex items-center gap-1.5 py-0.5 px-1 text-xs text-gray-600 hover:bg-blue-50 hover:text-blue-700 rounded transition-colors">
						<span class="w-1 h-1 rounded-full bg-gray-300 inline-block"></span>
						{item.label}
					</a>
				))}
			</div>
			<div class="p-2 border-b border-gray-200">
				<div class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Contact</div>
				<div class="space-y-1 text-[10px]">
					<div class="flex items-start gap-1">
						<span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block mt-0.5 shrink-0"></span>
						<div>
							<div class="text-gray-400 uppercase" style="font-size:9px">Email</div>
							<div class="font-mono text-gray-700 break-all">{sanctuary.contact.email}</div>
						</div>
					</div>
					<div class="flex items-start gap-1">
						<span class="w-1.5 h-1.5 rounded-full bg-blue-400 inline-block mt-0.5 shrink-0"></span>
						<div>
							<div class="text-gray-400 uppercase" style="font-size:9px">Phone</div>
							<div class="font-mono text-gray-700">{sanctuary.contact.phone}</div>
						</div>
					</div>
					<div class="flex items-start gap-1">
						<span class="w-1.5 h-1.5 rounded-full bg-amber-400 inline-block mt-0.5 shrink-0"></span>
						<div>
							<div class="text-gray-400 uppercase" style="font-size:9px">Address</div>
							<div class="text-gray-700">{sanctuary.contact.address}</div>
						</div>
					</div>
				</div>
			</div>
			<div class="p-2">
				<div class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Actions</div>
				<a href={`/${lang}/${style}/cats`} class="block w-full bg-blue-600 text-white text-[10px] text-center px-2 py-1 rounded hover:bg-blue-700 transition-colors font-semibold mb-1">{t.home.meetCats}</a>
				<a href={`/${lang}/${style}/donate`} class="block w-full bg-gray-200 text-gray-700 text-[10px] text-center px-2 py-1 rounded hover:bg-gray-300 transition-colors font-semibold border border-gray-300">{t.home.donate}</a>
			</div>
		</aside>

		<!-- Main content area - multi-panel -->
		<main class="flex-1 p-2 overflow-y-auto">
			<!-- Top: 3-column dense panels -->
			<div class="grid grid-cols-1 md:grid-cols-3 gap-2 mb-2">
				<!-- Panel 1: Identity -->
				<div class="bg-white border border-gray-300 rounded">
					<div class="bg-gray-50 border-b border-gray-200 px-2 py-1">
						<span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Overview</span>
					</div>
					<div class="p-2">
						<h1 class="text-sm font-bold text-gray-900 leading-none mb-0.5">{sanctuary.name}</h1>
						<p class="text-[10px] text-gray-500 leading-snug">{sanctuary.tagline}</p>
							<img src={sanctuary.heroImage} alt={sanctuary.name} class="w-full mt-1.5 rounded object-cover border border-gray-200" />
						<div class="mt-2 pt-1.5 border-t border-gray-100">
							<div class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider mb-0.5">{t.home.mission}</div>
							<p class="text-[10px] text-gray-700 leading-relaxed">{sanctuary.mission}</p>
						</div>
					</div>
				</div>

				<!-- Panel 2: Key Metrics (table format) -->
				<div class="bg-white border border-gray-300 rounded">
					<div class="bg-gray-50 border-b border-gray-200 px-2 py-1">
						<span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Key Metrics</span>
					</div>
					<table class="w-full text-[10px]">
						<tbody>
							{sanctuary.stats.map((stat: any, i: number) => (
								<tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}>
									<td class="px-2 py-1 text-gray-500 uppercase tracking-wide font-medium">{stat.label}</td>
									<td class="px-2 py-1 text-right font-mono font-bold text-gray-900 text-sm">{stat.value}</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>

				<!-- Panel 3: Status / mobile actions -->
				<div class="bg-white border border-gray-300 rounded">
					<div class="bg-gray-50 border-b border-gray-200 px-2 py-1">
						<span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">System Status</span>
					</div>
					<div class="p-2 space-y-1.5">
						<div class="flex items-center justify-between text-[10px]">
							<span class="text-gray-500">Sanctuary</span>
							<span class="flex items-center gap-1 font-medium text-green-700"><span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span> Operational</span>
						</div>
						<div class="flex items-center justify-between text-[10px]">
							<span class="text-gray-500">Adoptions</span>
							<span class="flex items-center gap-1 font-medium text-green-700"><span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span> Active</span>
						</div>
						<div class="flex items-center justify-between text-[10px]">
							<span class="text-gray-500">Donations</span>
							<span class="flex items-center gap-1 font-medium text-green-700"><span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span> Accepting</span>
						</div>
						<div class="flex items-center justify-between text-[10px]">
							<span class="text-gray-500">Volunteers</span>
							<span class="flex items-center gap-1 font-medium text-blue-700"><span class="w-1.5 h-1.5 rounded-full bg-blue-400 inline-block"></span> Recruiting</span>
						</div>
						<!-- Mobile actions -->
						<div class="lg:hidden pt-1.5 border-t border-gray-100 flex gap-1">
							<a href={`/${lang}/${style}/cats`} class="flex-1 bg-blue-600 text-white text-[10px] text-center px-2 py-1 rounded hover:bg-blue-700 transition-colors font-semibold">{t.home.meetCats}</a>
							<a href={`/${lang}/${style}/donate`} class="flex-1 bg-gray-200 text-gray-700 text-[10px] text-center px-2 py-1 rounded hover:bg-gray-300 transition-colors font-semibold border border-gray-300">{t.home.donate}</a>
						</div>
					</div>
				</div>
			</div>

			<!-- Bottom: About in dense 2-column newspaper layout -->
			<div class="bg-white border border-gray-300 rounded mb-2">
				<div class="bg-gray-50 border-b border-gray-200 px-2 py-1 flex items-center justify-between">
					<span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">{t.home.aboutUs}</span>
					<span class="text-[10px] text-gray-400 font-mono">{sanctuary.about.length} sections</span>
				</div>
				<div class="p-2 columns-1 md:columns-2 lg:columns-3 gap-3 text-[10px] text-gray-700 leading-relaxed">
					{sanctuary.about.map((paragraph: string) => (
						<p class="mb-1.5 break-inside-avoid">{paragraph}</p>
					))}
				</div>
			</div>

			<!-- Contact row (visible on smaller screens without sidebar) -->
			<div class="lg:hidden bg-white border border-gray-300 rounded mb-2">
				<div class="bg-gray-50 border-b border-gray-200 px-2 py-1">
					<span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">Contact</span>
				</div>
				<div class="px-2 py-1.5 flex flex-wrap gap-3 text-[10px] text-gray-600">
					<div class="flex items-center gap-1">
						<span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>
						<span class="text-gray-400">Email</span>
						<span class="font-mono text-gray-800">{sanctuary.contact.email}</span>
					</div>
					<div class="flex items-center gap-1">
						<span class="w-1.5 h-1.5 rounded-full bg-blue-400 inline-block"></span>
						<span class="text-gray-400">Phone</span>
						<span class="font-mono text-gray-800">{sanctuary.contact.phone}</span>
					</div>
					<div class="flex items-center gap-1">
						<span class="w-1.5 h-1.5 rounded-full bg-amber-400 inline-block"></span>
						<span class="text-gray-400">Address</span>
						<span class="text-gray-800">{sanctuary.contact.address}</span>
					</div>
				</div>
			</div>
		</main>
	</div>

	<footer class="border-t border-gray-300 bg-gray-900 px-2 py-0.5 text-[10px] text-gray-500 font-mono flex items-center justify-between">
		<p>&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.</p>
		<span class="text-gray-600">v1.0.0</span>
	</footer>
</div>
