---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
---

<div class="min-h-screen bg-gray-50 text-gray-800 text-sm">
	<nav class="bg-white border-b border-gray-200 px-3 py-1.5 flex items-center gap-4 text-xs sticky top-0 z-50">
		<span class="font-semibold text-gray-900 tracking-tight text-sm mr-2">{t.blog.title}</span>
		<div class="flex items-center gap-3">
			{nav.map((item: any) => (
				<a href={item.href} class="text-gray-500 hover:text-gray-900 transition-colors">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="max-w-6xl mx-auto px-3 py-3">
		<div class="text-xs text-gray-400 mb-2">
			<a href={`/${lang}/${style}/blog`} class="hover:text-gray-700 transition-colors">&larr; {t.blog.backToBlog}</a>
		</div>

		<div class="grid grid-cols-1 lg:grid-cols-4 gap-3">
			<!-- Main content: 3 cols -->
			<article class="lg:col-span-3 bg-white border border-gray-200 rounded p-3">
				<header class="border-b border-gray-100 pb-2 mb-3">
					<div class="flex items-center gap-2 mb-1">
						<time datetime={post.date} class="text-[10px] font-mono text-gray-400">{post.date}</time>
						<span class="text-gray-300">|</span>
						<span class="text-[10px] text-gray-400">{t.blog.by} {post.author}</span>
					</div>
					<h1 class="text-base font-bold text-gray-900 leading-tight mb-1.5">{post.title}</h1>
					<div class="flex gap-1">
						{post.tags.map((tag: string) => (
							<span class="bg-blue-50 text-blue-700 text-[10px] px-1.5 py-0.5 rounded-full font-medium">{tag}</span>
						))}
					</div>
				</header>

				<div class="text-xs text-gray-700 leading-relaxed columns-1 md:columns-2 gap-4">
					{post.content.map((paragraph: string) => (
						<p class="mb-2 break-inside-avoid">{paragraph}</p>
					))}
				</div>
			</article>

			<!-- Sidebar: other posts -->
			<aside class="lg:col-span-1">
				<div class="bg-white border border-gray-200 rounded p-3">
					<h2 class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider mb-2">{t.blog.moreStories}</h2>
					<div class="divide-y divide-gray-100">
						{otherPosts.map((p: any) => (
							<a href={`/${lang}/${style}/blog/${p.slug}`} class="block py-1.5 hover:bg-gray-50 -mx-1 px-1 rounded transition-colors group">
								<h3 class="text-xs font-medium text-blue-600 group-hover:text-blue-800 leading-tight">{p.title}</h3>
								<p class="text-[10px] text-gray-400 line-clamp-2 mt-0.5">{p.excerpt}</p>
								<div class="flex items-center gap-1.5 mt-0.5">
									<time datetime={p.date} class="text-[10px] font-mono text-gray-300">{p.date}</time>
									<span class="text-[10px] text-gray-300">{t.blog.by} {p.author}</span>
								</div>
							</a>
						))}
					</div>
				</div>
			</aside>
		</div>
	</main>
</div>
