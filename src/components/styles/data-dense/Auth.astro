---
const { lang, style, nav, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-gray-100 text-gray-800 font-sans text-xs leading-tight">
	<!-- Metrics strip -->
	<div class="bg-gray-900 text-gray-300 px-2 py-0.5 flex items-center gap-3 text-[10px] font-mono overflow-x-auto">
		<div class="flex items-center gap-1 whitespace-nowrap">
			<span class="text-gray-500">System:</span>
			<span class="text-green-400">Authentication</span>
		</div>
		<div class="flex items-center gap-1 whitespace-nowrap">
			<span class="text-gray-500">Protocol:</span>
			<span class="text-gray-200">OAuth 2.0 / Email</span>
		</div>
		<div class="ml-auto flex items-center gap-1 whitespace-nowrap">
			<span class="w-1 h-1 rounded-full bg-green-400 inline-block animate-pulse"></span>
			<span class="text-gray-500">SECURE</span>
		</div>
	</div>

	<!-- Toolbar with breadcrumbs -->
	<nav class="bg-white border-b border-gray-300 px-2 py-1 flex items-center gap-1 text-xs sticky top-0 z-50">
		<a href={`${_base}/${lang}/${style}/`} class="text-gray-400 hover:text-gray-700 text-[11px] transition-colors">Home</a>
		<span class="text-gray-300 mx-0.5">/</span>
		<span class="font-bold text-gray-900 text-[11px]">{t.auth.title}</span>
		<div class="ml-auto flex items-center gap-0.5">
			{nav.map((item: any) => (
				<a href={item.href} class="text-gray-600 hover:text-white hover:bg-gray-700 px-1.5 py-0.5 rounded transition-colors text-[11px]">{item.label}</a>
			))}
		</div>
	</nav>

	<!-- Sidebar + Main -->
	<div class="flex min-h-[calc(100vh-52px)]">
		<!-- Left sidebar -->
		<aside class="hidden md:block w-44 shrink-0 bg-white border-r border-gray-300 overflow-y-auto">
			<div class="p-2 border-b border-gray-200">
				<div class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Auth Methods</div>
				<div class="space-y-0.5">
					<div class="flex items-center gap-1 text-[10px] py-0.5 px-1 rounded bg-blue-50 text-blue-700 font-medium">
						<span class="w-1.5 h-1.5 rounded-full bg-blue-400 inline-block"></span>
						Email / Password
					</div>
					<div class="flex items-center gap-1 text-[10px] py-0.5 px-1 rounded text-gray-600 hover:bg-gray-50">
						<span class="w-1.5 h-1.5 rounded-full bg-gray-300 inline-block"></span>
						Google OAuth
					</div>
					<div class="flex items-center gap-1 text-[10px] py-0.5 px-1 rounded text-gray-600 hover:bg-gray-50">
						<span class="w-1.5 h-1.5 rounded-full bg-gray-300 inline-block"></span>
						Apple Sign-In
					</div>
				</div>
			</div>
			<div class="p-2 border-b border-gray-200">
				<div class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Status</div>
				<div class="space-y-0.5 text-[10px]">
					<div class="flex items-center justify-between py-0.5 px-1">
						<span class="text-gray-500">Session</span>
						<span class="flex items-center gap-0.5 text-gray-400"><span class="w-1.5 h-1.5 rounded-full bg-gray-300 inline-block"></span>None</span>
					</div>
					<div class="flex items-center justify-between py-0.5 px-1">
						<span class="text-gray-500">2FA</span>
						<span class="flex items-center gap-0.5 text-green-600"><span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>Supported</span>
					</div>
				</div>
			</div>
			<div class="p-2">
				<div class="text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Navigation</div>
				{nav.map((item: any) => (
					<a href={item.href} class="flex items-center gap-1.5 py-0.5 px-1 text-[10px] text-gray-600 hover:bg-blue-50 hover:text-blue-700 rounded transition-colors">
						<span class="w-1 h-1 rounded-full bg-gray-300 inline-block"></span>
						{item.label}
					</a>
				))}
			</div>
		</aside>

		<!-- Main: dense form panels -->
		<main class="flex-1 p-2 overflow-y-auto">
			<div class="max-w-lg mx-auto">
				<!-- Sign-in form panel -->
				<div class="bg-white border border-gray-300 rounded mb-2">
					<div class="bg-gray-50 border-b border-gray-200 px-2 py-1 flex items-center justify-between">
						<span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">{t.auth.title}</span>
						<span class="text-[9px] text-gray-400 font-mono">Email/Password</span>
					</div>
					<div class="p-2">
						<p class="text-[10px] text-gray-500 mb-2">{t.auth.subtitle}</p>
						<form class="space-y-1.5">
							<!-- Dense: labels beside inputs -->
							<div class="flex items-center gap-2">
								<label for="email" class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider w-20 shrink-0 text-right">{t.auth.email}</label>
								<input type="email" id="email" name="email" placeholder="you@example.com" class="flex-1 text-xs border border-gray-200 rounded px-2 py-1 bg-gray-50 focus:bg-white focus:border-blue-400 focus:outline-none transition-colors placeholder:text-gray-300 font-mono" />
							</div>
							<div class="flex items-center gap-2">
								<label for="password" class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider w-20 shrink-0 text-right">{t.auth.password}</label>
								<input type="password" id="password" name="password" placeholder="••••••••" class="flex-1 text-xs border border-gray-200 rounded px-2 py-1 bg-gray-50 focus:bg-white focus:border-blue-400 focus:outline-none transition-colors placeholder:text-gray-300" />
							</div>
							<div class="flex items-center gap-2 pl-22">
								<div class="flex items-center justify-between flex-1 text-[10px]">
									<label class="flex items-center gap-1 text-gray-600 cursor-pointer">
										<input type="checkbox" name="remember" class="rounded border-gray-300 text-blue-600 h-3 w-3" />
										{t.auth.rememberMe}
									</label>
									<a href="#" class="text-blue-600 hover:text-blue-800 transition-colors">{t.auth.forgotPassword}</a>
								</div>
							</div>
							<div class="flex items-center gap-2 pt-0.5">
								<div class="w-20 shrink-0"></div>
								<button type="submit" class="flex-1 bg-blue-600 text-white text-xs px-3 py-1.5 rounded hover:bg-blue-700 transition-colors font-semibold">{t.auth.signIn}</button>
							</div>
						</form>
					</div>
				</div>

				<!-- OAuth panel -->
				<div class="bg-white border border-gray-300 rounded mb-2">
					<div class="bg-gray-50 border-b border-gray-200 px-2 py-1">
						<span class="text-[10px] font-bold text-gray-500 uppercase tracking-wider">{t.auth.continueWith}</span>
					</div>
					<div class="p-2">
						<div class="grid grid-cols-2 gap-1.5">
							<button type="button" class="flex items-center justify-center gap-1 text-xs border border-gray-200 rounded px-2 py-1 text-gray-700 hover:bg-gray-50 transition-colors font-medium">
								<span class="w-1.5 h-1.5 rounded-full bg-red-400 inline-block"></span>
								Google
							</button>
							<button type="button" class="flex items-center justify-center gap-1 text-xs border border-gray-200 rounded px-2 py-1 text-gray-700 hover:bg-gray-50 transition-colors font-medium">
								<span class="w-1.5 h-1.5 rounded-full bg-gray-800 inline-block"></span>
								Apple
							</button>
						</div>
					</div>
				</div>

				<!-- Register prompt -->
				<div class="bg-white border border-gray-300 rounded">
					<div class="px-2 py-1.5 flex items-center justify-between text-[10px]">
						<span class="text-gray-500">{t.auth.noAccount}</span>
						<a href="#" class="text-blue-600 hover:text-blue-800 font-semibold transition-colors">{t.auth.signUp}</a>
					</div>
				</div>
			</div>
		</main>
	</div>
</div>
