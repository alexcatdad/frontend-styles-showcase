---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gray-50 text-gray-800 text-sm">
	<nav class="bg-white border-b border-gray-200 px-3 py-1.5 flex items-center gap-4 text-xs sticky top-0 z-50">
		<span class="font-semibold text-gray-900 tracking-tight text-sm mr-2">{t.auth.title}</span>
		<div class="flex items-center gap-3">
			{nav.map((item: any) => (
				<a href={item.href} class="text-gray-500 hover:text-gray-900 transition-colors">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="max-w-6xl mx-auto px-3 py-3">
		<div class="max-w-sm mx-auto">
			<div class="bg-white border border-gray-200 rounded p-3">
				<div class="mb-3 border-b border-gray-100 pb-2">
					<h1 class="text-base font-bold text-gray-900 leading-tight">{t.auth.title}</h1>
					<p class="text-[10px] text-gray-500 mt-0.5">{t.auth.subtitle}</p>
				</div>

				<form class="space-y-2">
					<div>
						<label for="email" class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider block mb-0.5">{t.auth.email}</label>
						<input type="email" id="email" name="email" placeholder="you@example.com" class="w-full text-xs border border-gray-200 rounded px-2 py-1.5 bg-gray-50 focus:bg-white focus:border-blue-400 focus:outline-none transition-colors placeholder:text-gray-300" />
					</div>
					<div>
						<label for="password" class="text-[10px] font-semibold text-gray-500 uppercase tracking-wider block mb-0.5">{t.auth.password}</label>
						<input type="password" id="password" name="password" placeholder="••••••••" class="w-full text-xs border border-gray-200 rounded px-2 py-1.5 bg-gray-50 focus:bg-white focus:border-blue-400 focus:outline-none transition-colors placeholder:text-gray-300" />
					</div>
					<div class="flex items-center justify-between text-[10px]">
						<label class="flex items-center gap-1 text-gray-600 cursor-pointer">
							<input type="checkbox" name="remember" class="rounded border-gray-300 text-blue-600 h-3 w-3" />
							{t.auth.rememberMe}
						</label>
						<a href="#" class="text-blue-600 hover:text-blue-800 transition-colors">{t.auth.forgotPassword}</a>
					</div>
					<button type="submit" class="w-full bg-blue-600 text-white text-xs px-3 py-1.5 rounded hover:bg-blue-700 transition-colors font-medium">{t.auth.signIn}</button>
				</form>

				<div class="mt-3 pt-2 border-t border-gray-100">
					<p class="text-[10px] text-gray-400 text-center mb-2">{t.auth.continueWith}</p>
					<div class="grid grid-cols-2 gap-1.5">
						<button type="button" class="text-xs border border-gray-200 rounded px-2 py-1 text-gray-700 hover:bg-gray-50 transition-colors font-medium">Google</button>
						<button type="button" class="text-xs border border-gray-200 rounded px-2 py-1 text-gray-700 hover:bg-gray-50 transition-colors font-medium">Apple</button>
					</div>
				</div>

				<p class="text-[10px] text-gray-400 text-center mt-3">
					{t.auth.noAccount} <a href="#" class="text-blue-600 hover:text-blue-800 font-medium transition-colors">{t.auth.signUp}</a>
				</p>
			</div>
		</div>
	</main>
</div>
