---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gray-50 text-gray-800 text-sm">
	<nav class="bg-white border-b border-gray-200 px-3 py-1.5 flex items-center gap-4 text-xs sticky top-0 z-50">
		<span class="font-semibold text-gray-900 tracking-tight text-sm mr-2">Error</span>
		<div class="flex items-center gap-3">
			{nav.map((item: any) => (
				<a href={item.href} class="text-gray-500 hover:text-gray-900 transition-colors">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="max-w-6xl mx-auto px-3 py-3">
		<div class="bg-white border border-gray-200 rounded p-3 max-w-md mx-auto text-center">
			<div class="flex items-center justify-center gap-2 mb-2">
				<span class="w-2 h-2 rounded-full bg-red-400 inline-block"></span>
				<span class="font-mono text-2xl font-bold text-gray-900">{t.notFound.title}</span>
			</div>
			<h2 class="text-sm font-semibold text-gray-700 mb-1">{t.notFound.heading}</h2>
			<p class="text-xs text-gray-500 mb-3">{t.notFound.description}</p>
			<div class="flex gap-1.5 justify-center">
				<a href={`/${lang}/${style}/`} class="bg-blue-600 text-white text-xs px-2.5 py-1 rounded hover:bg-blue-700 transition-colors font-medium">{t.notFound.backHome}</a>
				<a href={`/${lang}/${style}/cats`} class="bg-gray-100 text-gray-700 text-xs px-2.5 py-1 rounded hover:bg-gray-200 border border-gray-200 transition-colors font-medium">{t.notFound.meetCats}</a>
			</div>
		</div>
	</main>
</div>
