---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-sans">
	<nav class="border-b border-black">
		<div class="grid grid-cols-12 gap-x-4 px-4 md:px-6 lg:px-8">
			<div class="col-span-12 flex items-center gap-x-6 md:gap-x-8 py-3">
				{nav.map((item: any) => (
					<a href={item.href} class="text-xs uppercase tracking-[0.2em] text-black hover:text-red-600 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="px-4 md:px-6 lg:px-8">
		<!-- Hero -->
		<section class="border-b border-black">
			<div class="grid grid-cols-12 gap-x-4">
				<div class="col-span-12 md:col-span-1 pt-16 md:pt-24">
					<span class="hidden md:block text-[10px] uppercase tracking-[0.25em] text-neutral-400">001</span>
				</div>
				<div class="col-span-12 md:col-span-7 pt-8 md:pt-24 pb-16 md:pb-24">
					<h1 class="text-7xl md:text-8xl lg:text-9xl font-bold tracking-tighter leading-[0.85] text-left">{sanctuary.name}</h1>
					<p class="mt-8 text-sm leading-relaxed text-neutral-600 max-w-md text-left">{sanctuary.tagline}</p>
					<div class="mt-12 flex gap-x-6">
						<a href={`/${lang}/${style}/cats`} class="bg-red-600 text-white text-[10px] uppercase tracking-[0.25em] px-8 py-3 hover:bg-red-700 transition-colors">{t.home.meetCats}</a>
						<a href={`/${lang}/${style}/donate`} class="border border-black text-black text-[10px] uppercase tracking-[0.25em] px-8 py-3 hover:bg-black hover:text-white transition-colors">{t.home.donate}</a>
					</div>
				</div>
				<div class="hidden md:block md:col-span-3 md:col-start-10 pt-24 pb-24">
					<img src={sanctuary.heroImage} alt={sanctuary.name} class="w-full aspect-[3/4] object-cover grayscale" />
				</div>
			</div>
		</section>

		<!-- Mission -->
		<section class="border-b border-black">
			<div class="grid grid-cols-12 gap-x-4 py-16 md:py-20">
				<div class="col-span-12 md:col-span-2 md:col-start-1">
					<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.home.mission}</span>
				</div>
				<div class="col-span-12 md:col-span-5 md:col-start-4 mt-4 md:mt-0">
					<p class="text-sm leading-relaxed text-left">{sanctuary.mission}</p>
				</div>
			</div>
		</section>

		<!-- Stats -->
		<section class="border-b border-black">
			<div class="grid grid-cols-12 gap-x-4 py-16 md:py-20">
				<div class="col-span-12 md:col-span-2 md:col-start-1 mb-8 md:mb-0">
					<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">Data</span>
				</div>
				<div class="col-span-12 md:col-span-8 md:col-start-4">
					<div class="grid grid-cols-2 md:grid-cols-4 gap-y-10">
						{sanctuary.stats.map((stat: any) => (
							<div>
								<span class="block text-6xl md:text-7xl font-bold tracking-tighter leading-none">{stat.value}</span>
								<span class="block mt-3 text-[10px] uppercase tracking-[0.25em] text-neutral-400">{stat.label}</span>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- About -->
		<section class="border-b border-black">
			<div class="grid grid-cols-12 gap-x-4 py-16 md:py-20">
				<div class="col-span-12 md:col-span-2 md:col-start-1">
					<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.home.aboutUs}</span>
				</div>
				<div class="col-span-12 md:col-span-5 md:col-start-4 mt-4 md:mt-0 space-y-5">
					{sanctuary.about.map((paragraph: string) => (
						<p class="text-sm leading-relaxed text-neutral-700 text-left">{paragraph}</p>
					))}
				</div>
			</div>
		</section>

		<!-- Contact -->
		<section class="border-b border-black">
			<div class="grid grid-cols-12 gap-x-4 py-16 md:py-20">
				<div class="col-span-12 md:col-span-2 md:col-start-1">
					<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">Contact</span>
				</div>
				<div class="col-span-12 md:col-span-5 md:col-start-4 mt-4 md:mt-0">
					<dl class="space-y-4">
						{sanctuary.contact && Object.entries(sanctuary.contact).map(([key, value]: [string, any]) => (
							<div class="flex gap-x-8">
								<dt class="text-[10px] uppercase tracking-[0.25em] text-neutral-400 w-20 shrink-0">{key}</dt>
								<dd class="text-sm text-left">{value}</dd>
							</div>
						))}
					</dl>
				</div>
			</div>
		</section>
	</main>

	<footer class="border-t border-black px-4 md:px-6 lg:px-8">
		<div class="grid grid-cols-12 gap-x-4 py-4">
			<div class="col-span-12 md:col-span-6 md:col-start-4">
				<p class="text-[10px] uppercase tracking-[0.25em] text-neutral-400 text-left">&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.</p>
			</div>
		</div>
	</footer>
</div>
