---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-sans">
	<nav class="border-b border-black px-6 md:px-12 lg:px-24 py-4 flex flex-wrap items-center gap-x-8 gap-y-2">
		{nav.map((item: any) => (
			<a href={item.href} class="text-xs uppercase tracking-widest text-black hover:text-red-600 transition-colors">{item.label}</a>
		))}
	</nav>

	<main class="px-6 md:px-12 lg:px-24">
		<section class="pt-16 pb-12 md:pt-24 md:pb-16 border-b border-black">
			<div class="grid grid-cols-1 md:grid-cols-12 gap-8">
				<div class="md:col-span-8">
					<h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight leading-none text-left">{sanctuary.name}</h1>
					<p class="mt-6 text-lg md:text-xl text-neutral-600 max-w-xl text-left">{sanctuary.tagline}</p>
					<div class="mt-10 flex flex-wrap gap-4">
						<a href={`/${lang}/${style}/cats`} class="inline-block bg-red-600 text-white text-xs uppercase tracking-widest px-8 py-3 hover:bg-red-700 transition-colors">{t.home.meetCats}</a>
						<a href={`/${lang}/${style}/donate`} class="inline-block border border-black text-black text-xs uppercase tracking-widest px-8 py-3 hover:bg-black hover:text-white transition-colors">{t.home.donate}</a>
					</div>
				</div>
				<div class="hidden md:block md:col-span-4">
					<div class="w-full aspect-square bg-neutral-200 grayscale"></div>
				</div>
			</div>
		</section>

		<section class="py-12 md:py-16 border-b border-black">
			<div class="grid grid-cols-1 md:grid-cols-12 gap-8">
				<div class="md:col-span-3">
					<h2 class="text-xs uppercase tracking-widest font-bold text-left">{t.home.mission}</h2>
				</div>
				<div class="md:col-span-7">
					<p class="text-lg md:text-xl leading-relaxed text-left">{sanctuary.mission}</p>
				</div>
			</div>
		</section>

		<section class="py-12 md:py-16 border-b border-black">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-8">
				{sanctuary.stats.map((stat: any) => (
					<div class="border-l-2 border-red-600 pl-4">
						<span class="block text-4xl md:text-5xl font-bold tracking-tight">{stat.value}</span>
						<span class="block mt-2 text-xs uppercase tracking-widest text-neutral-500">{stat.label}</span>
					</div>
				))}
			</div>
		</section>

		<section class="py-12 md:py-16 border-b border-black">
			<div class="grid grid-cols-1 md:grid-cols-12 gap-8">
				<div class="md:col-span-3">
					<h2 class="text-xs uppercase tracking-widest font-bold text-left">{t.home.aboutUs}</h2>
				</div>
				<div class="md:col-span-7 space-y-4">
					{sanctuary.about.map((paragraph: string) => (
						<p class="text-sm leading-relaxed text-neutral-700 text-left">{paragraph}</p>
					))}
				</div>
			</div>
		</section>
	</main>

	<footer class="border-t border-black px-6 md:px-12 lg:px-24 py-6">
		<p class="text-xs uppercase tracking-widest text-neutral-400 text-left">&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.</p>
	</footer>
</div>
