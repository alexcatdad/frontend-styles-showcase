---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-sans">
	<nav class="border-b border-black">
		<div class="grid grid-cols-12 gap-x-4 px-4 md:px-6 lg:px-8">
			<div class="col-span-12 flex items-center gap-x-6 md:gap-x-8 py-3">
				{nav.map((item: any) => (
					<a href={item.href} class="text-xs uppercase tracking-[0.2em] text-black hover:text-red-600 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="px-4 md:px-6 lg:px-8">
		<div class="grid grid-cols-12 gap-x-4">
			<!-- Form column -->
			<div class="col-span-12 md:col-span-5 md:col-start-3 pt-16 md:pt-24 pb-16 md:pb-24">
				<h1 class="text-5xl md:text-7xl font-bold tracking-tighter leading-[0.85] text-left">{t.auth.title}</h1>
				<p class="mt-4 text-sm text-neutral-600 text-left">{t.auth.subtitle}</p>

				<div class="mt-12 border-t border-black pt-10">
					<form class="space-y-8">
						<div>
							<label for="email" class="block text-[10px] uppercase tracking-[0.25em] text-neutral-400 mb-3">{t.auth.email}</label>
							<input type="email" id="email" name="email" placeholder="you@example.com" class="w-full border-b border-black bg-transparent px-0 py-3 text-sm font-sans placeholder-neutral-300 focus:outline-none focus:border-red-600 transition-colors" />
						</div>
						<div>
							<label for="password" class="block text-[10px] uppercase tracking-[0.25em] text-neutral-400 mb-3">{t.auth.password}</label>
							<input type="password" id="password" name="password" placeholder="--------" class="w-full border-b border-black bg-transparent px-0 py-3 text-sm font-sans placeholder-neutral-300 focus:outline-none focus:border-red-600 transition-colors" />
						</div>
						<div class="flex items-center justify-between pt-2">
							<label class="flex items-center gap-2 cursor-pointer">
								<input type="checkbox" name="remember" class="w-3 h-3 border-black accent-red-600" />
								<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-500">{t.auth.rememberMe}</span>
							</label>
							<a href="#" class="text-[10px] uppercase tracking-[0.25em] text-neutral-400 hover:text-black transition-colors">{t.auth.forgotPassword}</a>
						</div>
						<button type="submit" class="w-full bg-red-600 text-white text-[10px] uppercase tracking-[0.25em] px-6 py-4 hover:bg-red-700 transition-colors">{t.auth.signIn}</button>
					</form>
				</div>

				<div class="mt-12 border-t border-neutral-200 pt-8">
					<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400 block mb-4">{t.auth.continueWith}</span>
					<div class="flex gap-4">
						<button type="button" class="border border-black text-[10px] uppercase tracking-[0.25em] px-8 py-3 hover:bg-black hover:text-white transition-colors">Google</button>
						<button type="button" class="border border-black text-[10px] uppercase tracking-[0.25em] px-8 py-3 hover:bg-black hover:text-white transition-colors">Apple</button>
					</div>
				</div>

				<p class="mt-10 text-xs text-neutral-500 text-left">
					{t.auth.noAccount} <a href="#" class="text-black font-bold text-[10px] uppercase tracking-[0.25em] hover:text-red-600 transition-colors">{t.auth.signUp}</a>
				</p>
			</div>

			<!-- Image column -->
			<div class="hidden md:block md:col-span-3 md:col-start-9 pt-24 pb-24">
				<div class="w-full aspect-[3/4] bg-neutral-200 grayscale"></div>
			</div>
		</div>
	</main>
</div>
