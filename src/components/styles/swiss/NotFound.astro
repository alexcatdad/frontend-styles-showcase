---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-sans">
	<nav class="border-b border-black px-6 md:px-12 lg:px-24 py-4 flex flex-wrap items-center gap-x-8 gap-y-2">
		{nav.map((item: any) => (
			<a href={item.href} class="text-xs uppercase tracking-widest text-black hover:text-red-600 transition-colors">{item.label}</a>
		))}
	</nav>

	<main class="px-6 md:px-12 lg:px-24">
		<section class="pt-24 md:pt-32 pb-16">
			<div class="grid grid-cols-1 md:grid-cols-12 gap-8">
				<div class="md:col-span-8">
					<h1 class="text-8xl md:text-9xl font-bold tracking-tighter leading-none text-left text-red-600">{t.notFound.title}</h1>
					<h2 class="mt-6 text-3xl md:text-4xl font-bold tracking-tight text-left">{t.notFound.heading}</h2>
					<p class="mt-4 text-sm text-neutral-600 max-w-md text-left">{t.notFound.description}</p>

					<hr class="border-black border-t mt-10 mb-10 w-full max-w-md" />

					<div class="flex flex-wrap gap-4">
						<a href={`/${lang}/${style}/`} class="inline-block bg-red-600 text-white text-xs uppercase tracking-widest px-8 py-3 hover:bg-red-700 transition-colors">{t.notFound.backHome}</a>
						<a href={`/${lang}/${style}/cats`} class="inline-block border border-black text-black text-xs uppercase tracking-widest px-8 py-3 hover:bg-black hover:text-white transition-colors">{t.notFound.meetCats}</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</div>
