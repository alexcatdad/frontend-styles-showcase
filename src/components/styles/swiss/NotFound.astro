---
const { lang, style, nav, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-white text-black font-sans">
	<nav class="border-b border-black">
		<div class="grid grid-cols-12 gap-x-4 px-4 md:px-6 lg:px-8">
			<div class="col-span-12 flex items-center gap-x-6 md:gap-x-8 py-3">
				{nav.map((item: any) => (
					<a href={item.href} class="text-xs uppercase tracking-[0.2em] text-black hover:text-red-600 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="px-4 md:px-6 lg:px-8">
		<div class="grid grid-cols-12 gap-x-4">
			<div class="col-span-12 md:col-span-1 pt-24 md:pt-32">
				<span class="hidden md:block text-[10px] uppercase tracking-[0.25em] text-neutral-400">ERR</span>
			</div>
			<div class="col-span-12 md:col-span-7 md:col-start-3 pt-12 md:pt-32 pb-24 md:pb-40">
				<span class="text-[180px] md:text-[240px] lg:text-[300px] font-bold tracking-tighter leading-none text-red-600 block" style="line-height:0.75">{t.notFound.title}</span>
				<div class="border-t border-black mt-12 pt-8">
					<h2 class="text-2xl md:text-3xl font-bold tracking-tight text-left">{t.notFound.heading}</h2>
					<p class="mt-4 text-sm text-neutral-600 max-w-md text-left">{t.notFound.description}</p>
				</div>
				<div class="mt-12 flex gap-x-6">
					<a href={`${_base}/${lang}/${style}/`} class="bg-red-600 text-white text-[10px] uppercase tracking-[0.25em] px-8 py-3 hover:bg-red-700 transition-colors">{t.notFound.backHome}</a>
					<a href={`${_base}/${lang}/${style}/cats`} class="border border-black text-black text-[10px] uppercase tracking-[0.25em] px-8 py-3 hover:bg-black hover:text-white transition-colors">{t.notFound.meetCats}</a>
				</div>
			</div>
		</div>
	</main>
</div>
