---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-white text-black font-sans">
	<nav class="border-b border-black">
		<div class="grid grid-cols-12 gap-x-4 px-4 md:px-6 lg:px-8">
			<div class="col-span-12 flex items-center gap-x-6 md:gap-x-8 py-3">
				{nav.map((item: any) => (
					<a href={item.href} class="text-xs uppercase tracking-[0.2em] text-black hover:text-red-600 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="px-4 md:px-6 lg:px-8">
		<!-- Back link -->
		<div class="grid grid-cols-12 gap-x-4 border-b border-neutral-200">
			<div class="col-span-12 md:col-span-6 md:col-start-3 py-3">
				<a href={`${_base}/${lang}/${style}/cats`} class="text-[10px] uppercase tracking-[0.25em] text-neutral-400 hover:text-black transition-colors">&larr; {t.cats.backToAll}</a>
			</div>
		</div>

		<!-- Cat name -->
		<section class="border-b border-black">
			<div class="grid grid-cols-12 gap-x-4">
				<div class="col-span-12 md:col-span-1 pt-12 md:pt-20">
					<span class="hidden md:block text-[10px] uppercase tracking-[0.25em] text-red-600">{cat.status}</span>
				</div>
				<div class="col-span-12 md:col-span-8 md:col-start-3 pt-6 md:pt-20 pb-12 md:pb-20">
					<h1 class="text-7xl md:text-8xl lg:text-9xl font-bold tracking-tighter leading-[0.85] text-left">{cat.name}</h1>
				</div>
			</div>
		</section>

		<!-- Image + Data -->
		<section class="border-b border-black">
			<div class="grid grid-cols-12 gap-x-4 py-12 md:py-20">
				<div class="col-span-12 md:col-span-4 md:col-start-1 mb-8 md:mb-0">
					<img src={cat.image} alt={cat.name} class="w-full aspect-[3/4] object-cover grayscale" />
				</div>
				<div class="col-span-12 md:col-span-5 md:col-start-6">
					<!-- Label/value pairs -->
					<dl class="space-y-6">
						<div class="border-b border-neutral-200 pb-4">
							<dt class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.cats.breed}</dt>
							<dd class="mt-1 text-sm font-bold text-left">{cat.breed}</dd>
						</div>
						<div class="border-b border-neutral-200 pb-4">
							<dt class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.cats.age}</dt>
							<dd class="mt-1 text-sm font-bold text-left">{cat.age}</dd>
						</div>
						<div class="border-b border-neutral-200 pb-4">
							<dt class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.cats.gender}</dt>
							<dd class="mt-1 text-sm font-bold text-left">{cat.gender}</dd>
						</div>
						<div class="border-b border-neutral-200 pb-4">
							<dt class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.cats.color}</dt>
							<dd class="mt-1 text-sm font-bold text-left">{cat.color}</dd>
						</div>
						<div class="border-b border-neutral-200 pb-4">
							<dt class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.cats.arrived}</dt>
							<dd class="mt-1 text-sm font-bold text-left">{cat.arrivalDate}</dd>
						</div>
						<div class="pb-4">
							<dt class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.cats.status}</dt>
							<dd class="mt-1 text-sm font-bold text-red-600 text-left">{cat.status}</dd>
						</div>
					</dl>
				</div>
			</div>
		</section>

		<!-- Personality + Description -->
		<section class="border-b border-black">
			<div class="grid grid-cols-12 gap-x-4 py-12 md:py-20">
				<div class="col-span-12 md:col-span-2 md:col-start-1 mb-4 md:mb-0">
					<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">Personality</span>
				</div>
				<div class="col-span-12 md:col-span-3 md:col-start-4 mb-8 md:mb-0">
					<div class="flex flex-wrap gap-2">
						{cat.personality.map((trait: string) => (
							<span class="text-[10px] uppercase tracking-[0.25em] border border-black px-3 py-1">{trait}</span>
						))}
					</div>
				</div>
				<div class="col-span-12 md:col-span-4 md:col-start-8">
					<p class="text-sm leading-relaxed text-neutral-700 text-left">{cat.description}</p>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="border-b border-black">
			<div class="grid grid-cols-12 gap-x-4 py-12 md:py-16">
				<div class="col-span-12 md:col-span-6 md:col-start-4">
					<a href={`${_base}/${lang}/${style}/auth`} class="inline-block bg-red-600 text-white text-[10px] uppercase tracking-[0.25em] px-10 py-4 hover:bg-red-700 transition-colors">{t.cats.adopt} {cat.name}</a>
				</div>
			</div>
		</section>

		<!-- Other cats -->
		<section class="py-12 md:py-20">
			<div class="grid grid-cols-12 gap-x-4">
				<div class="col-span-12 md:col-span-2 md:col-start-1 mb-6 md:mb-0">
					<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.cats.otherCats}</span>
				</div>
				<div class="col-span-12 md:col-span-8 md:col-start-4">
					{otherCats.map((c: any) => (
						<a href={`${_base}/${lang}/${style}/cats/${c.id}`} class="group flex items-baseline justify-between border-b border-neutral-200 hover:border-black py-4 transition-colors">
							<span class="text-xl font-bold tracking-tight text-left group-hover:text-red-600 transition-colors">{c.name}</span>
							<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{c.breed} — {c.age}</span>
						</a>
					))}
				</div>
			</div>
		</section>
	</main>
</div>
