---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-sans">
	<nav class="border-b border-black px-6 md:px-12 lg:px-24 py-4 flex flex-wrap items-center gap-x-8 gap-y-2">
		{nav.map((item: any) => (
			<a href={item.href} class="text-xs uppercase tracking-widest text-black hover:text-red-600 transition-colors">{item.label}</a>
		))}
	</nav>

	<main class="px-6 md:px-12 lg:px-24">
		<div class="pt-8 pb-4">
			<a href={`/${lang}/${style}/cats`} class="text-xs uppercase tracking-widest text-neutral-500 hover:text-black transition-colors">&larr; {t.cats.backToAll}</a>
		</div>

		<article class="border-t border-black">
			<div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 pt-12 pb-16">
				<div class="md:col-span-5">
					<div class="w-full aspect-4/5 bg-neutral-200 grayscale"></div>
				</div>
				<div class="md:col-span-7">
					<h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-none text-left">{cat.name}</h1>

					<hr class="border-red-600 border-t-2 mt-6 mb-8 w-16" />

					<dl class="grid grid-cols-2 gap-x-8 gap-y-4">
						<div>
							<dt class="text-xs uppercase tracking-widest text-neutral-400">{t.cats.breed}</dt>
							<dd class="mt-1 text-sm font-bold">{cat.breed}</dd>
						</div>
						<div>
							<dt class="text-xs uppercase tracking-widest text-neutral-400">{t.cats.age}</dt>
							<dd class="mt-1 text-sm font-bold">{cat.age}</dd>
						</div>
						<div>
							<dt class="text-xs uppercase tracking-widest text-neutral-400">{t.cats.gender}</dt>
							<dd class="mt-1 text-sm font-bold">{cat.gender}</dd>
						</div>
						<div>
							<dt class="text-xs uppercase tracking-widest text-neutral-400">{t.cats.color}</dt>
							<dd class="mt-1 text-sm font-bold">{cat.color}</dd>
						</div>
						<div>
							<dt class="text-xs uppercase tracking-widest text-neutral-400">{t.cats.arrived}</dt>
							<dd class="mt-1 text-sm font-bold">{cat.arrivalDate}</dd>
						</div>
						<div>
							<dt class="text-xs uppercase tracking-widest text-neutral-400">{t.cats.status}</dt>
							<dd class="mt-1 text-sm font-bold text-red-600">{cat.status}</dd>
						</div>
					</dl>

					<div class="mt-8 flex flex-wrap gap-2">
						{cat.personality.map((trait: string) => (
							<span class="text-xs uppercase tracking-widest border border-black px-3 py-1">{trait}</span>
						))}
					</div>

					<p class="mt-8 text-sm leading-relaxed text-neutral-700 text-left max-w-lg">{cat.description}</p>

					<div class="mt-10">
						<a href={`/${lang}/${style}/auth`} class="inline-block bg-red-600 text-white text-xs uppercase tracking-widest px-8 py-3 hover:bg-red-700 transition-colors">{t.cats.adopt} {cat.name}</a>
					</div>
				</div>
			</div>
		</article>

		<section class="border-t border-black py-12 md:py-16">
			<h2 class="text-xs uppercase tracking-widest font-bold mb-8 text-left">{t.cats.otherCats}</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-black">
				{otherCats.map((c: any) => (
					<a href={`/${lang}/${style}/cats/${c.id}`} class="group bg-white p-6 md:p-8 hover:bg-neutral-50 transition-colors">
						<div class="w-full aspect-square bg-neutral-200 grayscale mb-4"></div>
						<h3 class="text-lg font-bold tracking-tight text-left group-hover:text-red-600 transition-colors">{c.name}</h3>
						<p class="mt-1 text-xs uppercase tracking-widest text-neutral-500 text-left">{c.breed} — {c.age}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
