---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-sans">
	<nav class="border-b border-black">
		<div class="grid grid-cols-12 gap-x-4 px-4 md:px-6 lg:px-8">
			<div class="col-span-12 flex items-center gap-x-6 md:gap-x-8 py-3">
				{nav.map((item: any) => (
					<a href={item.href} class="text-xs uppercase tracking-[0.2em] text-black hover:text-red-600 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="px-4 md:px-6 lg:px-8">
		<!-- Header -->
		<section class="border-b border-black">
			<div class="grid grid-cols-12 gap-x-4">
				<div class="col-span-12 md:col-span-7 md:col-start-3 pt-12 md:pt-24 pb-12 md:pb-20">
					<h1 class="text-7xl md:text-8xl lg:text-9xl font-bold tracking-tighter leading-[0.85] text-left">{t.donate.title}</h1>
					<p class="mt-6 text-sm text-neutral-600 max-w-sm text-left">{t.donate.subtitle}</p>
				</div>
			</div>
		</section>

		<!-- Monthly tiers -->
		<section class="border-b border-black">
			<div class="grid grid-cols-12 gap-x-4 py-12 md:py-20">
				<div class="col-span-12 md:col-span-2 md:col-start-1 mb-8 md:mb-0">
					<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.donate.monthly}</span>
				</div>
				<div class="col-span-12 md:col-span-8 md:col-start-4">
					{monthlyTiers.map((tier: any) => (
						<div class={`border-b border-neutral-200 last:border-b-0 py-8 ${tier.highlighted ? 'border-l-2 border-l-red-600 pl-6' : ''}`}>
							<div class="grid grid-cols-12 gap-x-4 items-start">
								<div class="col-span-4 md:col-span-3">
									<span class="text-5xl md:text-6xl font-bold tracking-tighter leading-none">${tier.amount}</span>
									<span class="block mt-1 text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.donate.perMonth}</span>
								</div>
								<div class="col-span-8 md:col-span-5">
									<span class="text-sm font-bold text-left block">{tier.name}</span>
									{tier.highlighted && (
										<span class="text-[10px] uppercase tracking-[0.25em] text-red-600 block mt-1">{t.donate.mostPopular}</span>
									)}
									<p class="mt-2 text-sm text-neutral-600 leading-relaxed text-left">{tier.description}</p>
									<ul class="mt-3 space-y-1">
										{tier.perks.map((perk: string) => (
											<li class="text-xs text-neutral-500 text-left">{perk}</li>
										))}
									</ul>
								</div>
								<div class="col-span-12 md:col-span-4 mt-4 md:mt-0 flex md:justify-end">
									<button type="button" class={`text-[10px] uppercase tracking-[0.25em] px-8 py-3 transition-colors ${tier.highlighted ? 'bg-red-600 text-white hover:bg-red-700' : 'border border-black text-black hover:bg-black hover:text-white'}`}>{t.donate.choose} {tier.name}</button>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- One-time tiers -->
		<section class="border-b border-black">
			<div class="grid grid-cols-12 gap-x-4 py-12 md:py-20">
				<div class="col-span-12 md:col-span-2 md:col-start-1 mb-8 md:mb-0">
					<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.donate.oneTime}</span>
				</div>
				<div class="col-span-12 md:col-span-8 md:col-start-4">
					{oneTimeTiers.map((tier: any) => (
						<div class={`border-b border-neutral-200 last:border-b-0 py-8 ${tier.highlighted ? 'border-l-2 border-l-red-600 pl-6' : ''}`}>
							<div class="grid grid-cols-12 gap-x-4 items-start">
								<div class="col-span-4 md:col-span-3">
									<span class="text-5xl md:text-6xl font-bold tracking-tighter leading-none">${tier.amount}</span>
								</div>
								<div class="col-span-8 md:col-span-5">
									<span class="text-sm font-bold text-left block">{tier.name}</span>
									{tier.highlighted && (
										<span class="text-[10px] uppercase tracking-[0.25em] text-red-600 block mt-1">{t.donate.greatestImpact}</span>
									)}
									<p class="mt-2 text-sm text-neutral-600 leading-relaxed text-left">{tier.description}</p>
									<ul class="mt-3 space-y-1">
										{tier.perks.map((perk: string) => (
											<li class="text-xs text-neutral-500 text-left">{perk}</li>
										))}
									</ul>
								</div>
								<div class="col-span-12 md:col-span-4 mt-4 md:mt-0 flex md:justify-end">
									<button type="button" class={`text-[10px] uppercase tracking-[0.25em] px-8 py-3 transition-colors ${tier.highlighted ? 'bg-red-600 text-white hover:bg-red-700' : 'border border-black text-black hover:bg-black hover:text-white'}`}>{t.donate.give} ${tier.amount}</button>
								</div>
							</div>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>
</div>
