---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-sans">
	<nav class="border-b border-black">
		<div class="grid grid-cols-12 gap-x-4 px-4 md:px-6 lg:px-8">
			<div class="col-span-12 flex items-center gap-x-6 md:gap-x-8 py-3">
				{nav.map((item: any) => (
					<a href={item.href} class="text-xs uppercase tracking-[0.2em] text-black hover:text-red-600 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="px-4 md:px-6 lg:px-8">
		<!-- Header -->
		<section class="border-b border-black">
			<div class="grid grid-cols-12 gap-x-4">
				<div class="col-span-12 md:col-span-1 pt-16 md:pt-24">
					<span class="hidden md:block text-[10px] uppercase tracking-[0.25em] text-neutral-400">{String(posts.length).padStart(3, '0')}</span>
				</div>
				<div class="col-span-12 md:col-span-7 md:col-start-3 pt-8 md:pt-24 pb-12 md:pb-20">
					<h1 class="text-7xl md:text-8xl lg:text-9xl font-bold tracking-tighter leading-[0.85] text-left">{t.blog.title}</h1>
					<p class="mt-6 text-sm text-neutral-600 max-w-sm text-left">{t.blog.subtitle}</p>
				</div>
			</div>
		</section>

		<!-- Table header -->
		<div class="hidden md:grid grid-cols-12 gap-x-4 border-b border-black py-3">
			<div class="col-span-2">
				<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">Date</span>
			</div>
			<div class="col-span-5 col-start-4">
				<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">Title</span>
			</div>
			<div class="col-span-2 col-start-9">
				<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.blog.by}</span>
			</div>
			<div class="col-span-2 col-start-11">
				<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">Tags</span>
			</div>
		</div>

		<!-- Post index -->
		<div>
			{posts.map((post: any) => (
				<a href={`/${lang}/${style}/blog/${post.slug}`} class="group block border-b border-neutral-200 hover:border-black transition-colors">
					<div class="grid grid-cols-12 gap-x-4 py-5 md:py-6 items-baseline">
						<div class="col-span-12 md:col-span-2">
							<time datetime={post.date} class="text-[10px] tracking-[0.25em] text-neutral-400 font-mono">{post.date}</time>
						</div>
						<div class="hidden md:block md:col-span-1 md:col-start-3">
								<img src={post.image} alt={post.title} class="w-full h-12 object-cover grayscale group-hover:grayscale-0 transition-all" />
							</div>
							<div class="col-span-12 md:col-span-5 md:col-start-4 mt-2 md:mt-0">
							<span class="text-lg md:text-xl font-bold tracking-tight text-left group-hover:text-red-600 transition-colors">{post.title}</span>
							<span class="block mt-1 text-sm text-neutral-500 leading-relaxed text-left md:hidden">{post.excerpt}</span>
						</div>
						<div class="hidden md:block md:col-span-2 md:col-start-9">
							<span class="text-xs text-neutral-500">{post.author}</span>
						</div>
						<div class="hidden md:block md:col-span-2 md:col-start-11">
							<div class="flex flex-wrap gap-1">
								{post.tags.map((tag: string) => (
									<span class="text-[10px] uppercase tracking-[0.15em] text-neutral-400">{tag}</span>
								))}
							</div>
						</div>
					</div>
				</a>
			))}
		</div>
	</main>
</div>
