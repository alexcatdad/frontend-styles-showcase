---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-sans">
	<nav class="border-b border-black px-6 md:px-12 lg:px-24 py-4 flex flex-wrap items-center gap-x-8 gap-y-2">
		{nav.map((item: any) => (
			<a href={item.href} class="text-xs uppercase tracking-widest text-black hover:text-red-600 transition-colors">{item.label}</a>
		))}
	</nav>

	<main class="px-6 md:px-12 lg:px-24">
		<section class="pt-16 pb-12 md:pt-24 md:pb-16 border-b border-black">
			<h1 class="text-5xl md:text-7xl font-bold tracking-tight leading-none text-left">{t.blog.title}</h1>
			<p class="mt-4 text-lg text-neutral-600 max-w-lg text-left">{t.blog.subtitle}</p>
		</section>

		<div class="py-8">
			{posts.map((post: any) => (
				<a href={`/${lang}/${style}/blog/${post.slug}`} class="group block border-b border-neutral-200 hover:border-black transition-colors">
					<article class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 py-8 md:py-10">
						<div class="md:col-span-2">
							<time datetime={post.date} class="text-xs tracking-widest text-neutral-400 font-mono">{post.date}</time>
						</div>
						<div class="md:col-span-6">
							<h2 class="text-xl md:text-2xl font-bold tracking-tight text-left group-hover:text-red-600 transition-colors">{post.title}</h2>
							<p class="mt-2 text-sm text-neutral-600 leading-relaxed text-left">{post.excerpt}</p>
						</div>
						<div class="md:col-span-3">
							<div class="flex flex-wrap gap-2">
								{post.tags.map((tag: string) => (
									<span class="text-xs uppercase tracking-widest text-neutral-400 border border-neutral-300 px-2 py-0.5">{tag}</span>
								))}
							</div>
						</div>
						<div class="md:col-span-1 flex items-start md:justify-end">
							<span class="text-xs uppercase tracking-widest text-neutral-500">{t.blog.by} {post.author}</span>
						</div>
					</article>
				</a>
			))}
		</div>
	</main>
</div>
