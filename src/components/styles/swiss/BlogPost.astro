---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-white text-black font-sans">
	<nav class="border-b border-black">
		<div class="grid grid-cols-12 gap-x-4 px-4 md:px-6 lg:px-8">
			<div class="col-span-12 flex items-center gap-x-6 md:gap-x-8 py-3">
				{nav.map((item: any) => (
					<a href={item.href} class="text-xs uppercase tracking-[0.2em] text-black hover:text-red-600 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="px-4 md:px-6 lg:px-8">
		<!-- Back link -->
		<div class="grid grid-cols-12 gap-x-4 border-b border-neutral-200">
			<div class="col-span-12 md:col-span-6 md:col-start-3 py-3">
				<a href={`${_base}/${lang}/${style}/blog`} class="text-[10px] uppercase tracking-[0.25em] text-neutral-400 hover:text-black transition-colors">&larr; {t.blog.backToBlog}</a>
			</div>
		</div>

		<!-- Article header -->
		<article class="border-b border-black">
			<header class="border-b border-black">
				<div class="grid grid-cols-12 gap-x-4">
					<div class="col-span-12 md:col-span-2 md:col-start-1 pt-12 md:pt-20">
						<time datetime={post.date} class="text-[10px] tracking-[0.25em] text-neutral-400 font-mono block">{post.date}</time>
						<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400 block mt-2">{t.blog.by} {post.author}</span>
					</div>
					<div class="col-span-12 md:col-span-7 md:col-start-3 pt-6 md:pt-20 pb-12 md:pb-20">
						<img src={post.image} alt={post.title} class="w-full h-48 md:h-64 object-cover grayscale mb-8" />
						<h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tighter leading-[0.9] text-left">{post.title}</h1>
						<div class="mt-6 flex flex-wrap gap-2">
							{post.tags.map((tag: string) => (
								<span class="text-[10px] uppercase tracking-[0.25em] border border-black px-3 py-1">{tag}</span>
							))}
						</div>
					</div>
				</div>
			</header>

			<!-- Content -->
			<div class="grid grid-cols-12 gap-x-4 py-16 md:py-24">
				<div class="col-span-12 md:col-span-5 md:col-start-4 space-y-6">
					{post.content.map((paragraph: string) => (
						<p class="text-sm leading-relaxed text-neutral-700 text-left">{paragraph}</p>
					))}
				</div>
			</div>
		</article>

		<!-- More stories -->
		<section class="py-12 md:py-20">
			<div class="grid grid-cols-12 gap-x-4">
				<div class="col-span-12 md:col-span-2 md:col-start-1 mb-6 md:mb-0">
					<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.blog.moreStories}</span>
				</div>
				<div class="col-span-12 md:col-span-8 md:col-start-4">
					{otherPosts.map((p: any) => (
						<a href={`${_base}/${lang}/${style}/blog/${p.slug}`} class="group flex items-baseline justify-between border-b border-neutral-200 hover:border-black py-4 transition-colors">
							<span class="text-lg font-bold tracking-tight text-left group-hover:text-red-600 transition-colors">{p.title}</span>
							<time class="text-[10px] tracking-[0.25em] text-neutral-400 font-mono shrink-0 ml-4">{p.date}</time>
						</a>
					))}
				</div>
			</div>
		</section>
	</main>
</div>
