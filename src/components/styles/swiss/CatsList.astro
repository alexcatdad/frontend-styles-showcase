---
const { lang, style, nav, cats, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-sans">
	<nav class="border-b border-black px-6 md:px-12 lg:px-24 py-4 flex flex-wrap items-center gap-x-8 gap-y-2">
		{nav.map((item: any) => (
			<a href={item.href} class="text-xs uppercase tracking-widest text-black hover:text-red-600 transition-colors">{item.label}</a>
		))}
	</nav>

	<main class="px-6 md:px-12 lg:px-24">
		<section class="pt-16 pb-12 md:pt-24 md:pb-16 border-b border-black">
			<h1 class="text-5xl md:text-7xl font-bold tracking-tight leading-none text-left">{t.cats.title}</h1>
			<p class="mt-4 text-lg text-neutral-600 max-w-lg text-left">{t.cats.subtitle}</p>
		</section>

		<div class="py-8">
			{cats.map((cat: any, i: number) => (
				<a href={`/${lang}/${style}/cats/${cat.id}`} class="group block border-b border-neutral-200 hover:border-black transition-colors">
					<div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 py-6 md:py-8">
						<div class="md:col-span-1">
							<span class="text-xs text-neutral-400 font-mono">{String(i + 1).padStart(2, '0')}</span>
						</div>
						<div class="md:col-span-2">
							<div class="w-full aspect-square bg-neutral-200 grayscale max-w-24 md:max-w-full"></div>
						</div>
						<div class="md:col-span-5">
							<h2 class="text-2xl md:text-3xl font-bold tracking-tight text-left group-hover:text-red-600 transition-colors">{cat.name}</h2>
							<p class="mt-1 text-xs uppercase tracking-widest text-neutral-500 text-left">{cat.breed} — {cat.age} — {cat.gender}</p>
							<p class="mt-3 text-sm text-neutral-600 leading-relaxed text-left">{cat.description.slice(0, 100)}...</p>
						</div>
						<div class="md:col-span-3">
							<div class="flex flex-wrap gap-2">
								{cat.personality.map((trait: string) => (
									<span class="text-xs uppercase tracking-widest border border-black px-2 py-1">{trait}</span>
								))}
							</div>
						</div>
						<div class="md:col-span-1 flex items-start md:justify-end">
							<span class="text-xs uppercase tracking-widest text-red-600 font-bold">{cat.status}</span>
						</div>
					</div>
				</a>
			))}
		</div>
	</main>
</div>
