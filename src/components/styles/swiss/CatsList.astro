---
const { lang, style, nav, cats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-white text-black font-sans">
	<nav class="border-b border-black">
		<div class="grid grid-cols-12 gap-x-4 px-4 md:px-6 lg:px-8">
			<div class="col-span-12 flex items-center gap-x-6 md:gap-x-8 py-3">
				{nav.map((item: any) => (
					<a href={item.href} class="text-xs uppercase tracking-[0.2em] text-black hover:text-red-600 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="px-4 md:px-6 lg:px-8">
		<!-- Header -->
		<section class="border-b border-black">
			<div class="grid grid-cols-12 gap-x-4">
				<div class="col-span-12 md:col-span-1 pt-16 md:pt-24">
					<span class="hidden md:block text-[10px] uppercase tracking-[0.25em] text-neutral-400">{String(cats.length).padStart(3, '0')}</span>
				</div>
				<div class="col-span-12 md:col-span-7 md:col-start-3 pt-8 md:pt-24 pb-12 md:pb-20">
					<h1 class="text-7xl md:text-8xl lg:text-9xl font-bold tracking-tighter leading-[0.85] text-left">{t.cats.title}</h1>
					<p class="mt-6 text-sm text-neutral-600 max-w-sm text-left">{t.cats.subtitle}</p>
				</div>
			</div>
		</section>

		<!-- Table header -->
		<div class="hidden md:grid grid-cols-12 gap-x-4 border-b border-black py-3">
			<div class="col-span-1">
				<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">No.</span>
			</div>
			<div class="col-span-3 col-start-3">
				<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.cats.breed}</span>
			</div>
			<div class="col-span-4 col-start-6">
				<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">Name</span>
			</div>
			<div class="col-span-1 col-start-10">
				<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.cats.age}</span>
			</div>
			<div class="col-span-2 col-start-11">
				<span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400">{t.cats.status}</span>
			</div>
		</div>

		<!-- Cat index -->
		<div>
			{cats.map((cat: any, i: number) => (
				<a href={`${_base}/${lang}/${style}/cats/${cat.id}`} class="group block border-b border-neutral-200 hover:border-black transition-colors">
					<div class="grid grid-cols-12 gap-x-4 py-5 md:py-6 items-baseline">
						<div class="col-span-2 md:col-span-1">
							<span class="text-[10px] tracking-[0.25em] text-neutral-300 font-mono">{String(i + 1).padStart(2, '0')}</span>
						</div>
						<div class="hidden md:block md:col-span-3 md:col-start-3">
							<span class="text-xs uppercase tracking-[0.15em] text-neutral-400">{cat.breed}</span>
						</div>
						<div class="hidden md:block md:col-span-1 md:col-start-2">
								<img src={cat.thumbnail} alt={cat.name} class="w-full h-12 object-cover grayscale group-hover:grayscale-0 transition-all" />
							</div>
							<div class="col-span-7 md:col-span-4 md:col-start-6">
							<span class="text-2xl md:text-3xl font-bold tracking-tight text-left group-hover:text-red-600 transition-colors">{cat.name}</span>
							<span class="block md:hidden mt-1 text-[10px] uppercase tracking-[0.15em] text-neutral-400">{cat.breed} — {cat.gender}</span>
						</div>
						<div class="hidden md:block md:col-span-1 md:col-start-10">
							<span class="text-sm text-neutral-600">{cat.age}</span>
						</div>
						<div class="col-span-3 md:col-span-2 md:col-start-11 text-right md:text-left">
							<span class="text-[10px] uppercase tracking-[0.25em] text-red-600 font-bold">{cat.status}</span>
						</div>
					</div>
				</a>
			))}
		</div>
	</main>
</div>
