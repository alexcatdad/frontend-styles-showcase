---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<main class="bg-white font-mono text-black overflow-x-hidden">
	<!-- HERO: MASSIVE, CONFRONTATIONAL -->
	<section class="relative min-h-screen bg-yellow-400 px-4 py-8 md:py-0 md:flex md:items-end">
		<img src={sanctuary.heroImage} alt={sanctuary.name} class="absolute inset-0 w-full h-full object-cover opacity-30 mix-blend-multiply" />
		<h1 class="text-7xl md:text-9xl lg:text-[14rem] font-black uppercase leading-none tracking-tighter text-black -mb-2 md:-mb-6 lg:-mb-12 relative z-10">{sanctuary.name}</h1>
		<p class="absolute top-4 right-4 md:top-8 md:right-8 text-sm md:text-base font-black uppercase tracking-widest bg-black text-yellow-400 px-4 py-2 rotate-3">{sanctuary.tagline}</p>
		<div class="absolute bottom-4 left-4 md:bottom-8 md:left-8 flex flex-col gap-2 z-20">
			<a href={`/${lang}/${style}/cats`} class="bg-black text-white uppercase font-black text-base md:text-xl px-6 py-3 border-4 border-black hover:bg-white hover:text-black cursor-pointer tracking-wider">{t.home.meetCats}</a>
			<a href={`/${lang}/${style}/donate`} class="bg-red-600 text-white uppercase font-black text-base md:text-xl px-6 py-3 border-4 border-black hover:bg-white hover:text-black cursor-pointer tracking-wider">{t.home.donate}</a>
		</div>
	</section>

	<!-- STATS: MASSIVE NUMBERS SCATTERED -->
	<section class="relative bg-black text-white min-h-[60vh] md:min-h-[80vh] px-4 py-16">
		{sanctuary.stats.map((stat: any, i: number) => (
			<div class={`${i === 0 ? 'ml-0 mt-0' : ''} ${i === 1 ? 'md:ml-[40%] -mt-4 md:-mt-8' : ''} ${i === 2 ? 'ml-0 md:ml-[10%] -mt-2 md:-mt-4' : ''} ${i === 3 ? 'md:ml-[55%] -mt-4 md:-mt-12' : ''} relative`}>
				<span class="block text-6xl md:text-8xl lg:text-[10rem] font-black leading-none tracking-tighter text-yellow-400">{stat.value}</span>
				<span class="block text-xs md:text-sm uppercase tracking-[0.3em] font-black mt-1 ml-1 md:ml-2">{stat.label}</span>
			</div>
		))}
	</section>

	<!-- MISSION: RAW BLOCK -->
	<section class="bg-white border-t-8 border-black px-4 py-12 md:py-20 relative">
		<h2 class="text-5xl md:text-7xl lg:text-8xl font-black uppercase tracking-tighter -rotate-2 md:-rotate-1 bg-red-600 text-white px-4 py-2 inline-block -ml-2">{t.home.mission}</h2>
		<p class="text-xl md:text-3xl lg:text-4xl font-black mt-8 md:mt-12 leading-tight uppercase max-w-4xl">{sanctuary.mission}</p>
	</section>

	<!-- ABOUT: STACKED RAW PARAGRAPHS -->
	<section class="bg-yellow-400 border-t-8 border-black px-4 py-12 md:py-20">
		<h2 class="text-4xl md:text-6xl font-black uppercase tracking-tighter mb-8 md:mb-12 border-b-8 border-black pb-4 inline-block">{t.home.aboutUs}</h2>
		<div class="space-y-0">
			{sanctuary.about.map((paragraph: string, i: number) => (
				<p class={`text-base md:text-lg lg:text-xl font-black leading-relaxed border-l-8 border-black pl-4 md:pl-6 py-4 ${i % 2 === 0 ? 'bg-white' : 'bg-black text-yellow-400'} ${i % 2 === 1 ? 'md:ml-16' : 'md:mr-16'}`}>{paragraph}</p>
			))}
		</div>
	</section>

	<!-- CONTACT BLOCK -->
	{sanctuary.contact && (
		<section class="bg-black text-white border-t-8 border-red-600 px-4 py-8 md:py-12">
			<p class="text-xs md:text-sm font-black uppercase tracking-[0.3em] text-red-500">{sanctuary.contact.email} // {sanctuary.contact.phone}</p>
			<p class="text-xs font-black uppercase tracking-[0.3em] text-red-500 mt-2">{sanctuary.contact.address}</p>
		</section>
	)}
</main>

<!-- NAV AT BOTTOM: CONFRONTATIONAL -->
<nav class="bg-black border-t-8 border-yellow-400 px-4 py-6 font-mono">
	<div class="flex flex-wrap gap-x-6 gap-y-2">
		{nav.map((item: any) => (
			<a href={item.href} class="text-yellow-400 uppercase font-black text-xs md:text-sm tracking-[0.3em] hover:text-white cursor-pointer">{item.label}</a>
		))}
	</div>
	<p class="uppercase text-xs tracking-[0.2em] text-yellow-400 mt-6 font-black">&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.</p>
</nav>
