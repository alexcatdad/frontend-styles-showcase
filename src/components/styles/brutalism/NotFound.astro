---
const { lang, style, nav, t } = Astro.props;
---

<nav class="bg-black border-b-4 border-yellow-400 px-4 py-3 flex flex-wrap items-center gap-2 font-mono sticky top-0 z-50">
	{nav.map((item: any) => (
		<a href={item.href} class="text-yellow-400 uppercase font-black text-sm md:text-base tracking-widest border-2 border-yellow-400 px-3 py-1 hover:bg-yellow-400 hover:text-black transition-none cursor-pointer">{item.label}</a>
	))}
</nav>

<main class="bg-white font-mono text-black min-h-screen flex items-center justify-center px-4">
	<section class="text-center max-w-3xl">
		<h1 class="text-8xl md:text-[12rem] lg:text-[16rem] font-black leading-none tracking-tighter text-red-600">{t.notFound.title}</h1>
		<h2 class="text-3xl md:text-5xl font-black uppercase tracking-tighter mt-4 bg-black text-white px-4 py-2 inline-block">{t.notFound.heading}</h2>
		<p class="text-base md:text-xl font-bold mt-6 border-l-4 border-black pl-4 text-left">{t.notFound.description}</p>
		<div class="flex flex-wrap gap-4 mt-8 justify-center">
			<a href={`/${lang}/${style}/`} class="bg-black text-white uppercase font-black text-lg px-6 py-3 border-4 border-black hover:bg-yellow-400 hover:text-black transition-none cursor-pointer tracking-wider">{t.notFound.backHome}</a>
			<a href={`/${lang}/${style}/cats`} class="bg-red-600 text-white uppercase font-black text-lg px-6 py-3 border-4 border-black hover:bg-yellow-400 hover:text-black transition-none cursor-pointer tracking-wider">{t.notFound.meetCats}</a>
		</div>
	</section>
</main>
