---
const { lang, style, nav, t } = Astro.props;
---

<main class="bg-black font-mono text-white min-h-screen overflow-x-hidden relative">
	<!-- 404: TAKES OVER EVERYTHING -->
	<div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none overflow-hidden">
		<span class="text-[12rem] md:text-[24rem] lg:text-[36rem] font-black leading-none tracking-tighter text-red-600 opacity-20">{t.notFound.title}</span>
	</div>

	<!-- CONTENT: SCATTERED ACROSS THE VOID -->
	<div class="relative z-10 min-h-screen flex flex-col justify-between px-4 py-8">
		<div class="mt-16 md:mt-24">
			<h1 class="text-6xl md:text-8xl lg:text-9xl font-black uppercase leading-none tracking-tighter text-red-600">{t.notFound.title}</h1>
			<h2 class="text-2xl md:text-4xl lg:text-5xl font-black uppercase tracking-tighter mt-4 md:mt-6 text-yellow-400">{t.notFound.heading}</h2>
		</div>

		<div class="md:ml-auto md:max-w-xl md:mr-16 my-12">
			<p class="text-base md:text-xl lg:text-2xl font-black uppercase leading-relaxed border-l-8 border-red-600 pl-4 md:pl-6">{t.notFound.description}</p>
		</div>

		<div class="flex flex-col sm:flex-row gap-4 mb-8 md:mb-16">
			<a href={`/${lang}/${style}/`} class="bg-yellow-400 text-black uppercase font-black text-lg md:text-2xl px-6 md:px-10 py-4 md:py-5 border-4 border-yellow-400 hover:bg-white hover:border-white cursor-pointer tracking-[0.2em] text-center">{t.notFound.backHome}</a>
			<a href={`/${lang}/${style}/cats`} class="bg-red-600 text-white uppercase font-black text-lg md:text-2xl px-6 md:px-10 py-4 md:py-5 border-4 border-red-600 hover:bg-yellow-400 hover:text-black hover:border-yellow-400 cursor-pointer tracking-[0.2em] text-center">{t.notFound.meetCats}</a>
		</div>
	</div>
</main>

<!-- NAV AT BOTTOM -->
<nav class="bg-black border-t-8 border-red-600 px-4 py-6 font-mono">
	<div class="flex flex-wrap gap-x-6 gap-y-2">
		{nav.map((item: any) => (
			<a href={item.href} class="text-red-500 uppercase font-black text-xs md:text-sm tracking-[0.3em] hover:text-white cursor-pointer">{item.label}</a>
		))}
	</div>
</nav>
