---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<main class="bg-white font-mono text-black overflow-x-hidden">
	<!-- HEADER: CONFRONTATIONAL -->
	<section class="bg-red-600 text-white px-4 pt-16 pb-28 md:pt-24 md:pb-40 relative overflow-hidden">
		<h1 class="text-7xl md:text-9xl lg:text-[14rem] font-black uppercase leading-none tracking-tighter -ml-1">{t.donate.title}</h1>
		<p class="text-sm md:text-xl font-black uppercase tracking-[0.3em] mt-4 text-black bg-yellow-400 px-4 py-2 inline-block -rotate-1">{t.donate.subtitle}</p>
	</section>

	<!-- MONTHLY: OVERLAPPING CARDS, BROKEN GRID -->
	<section class="px-2 md:px-4 -mt-16 md:-mt-24 relative z-10 pb-12 md:pb-16">
		<h2 class="text-3xl md:text-5xl lg:text-6xl font-black uppercase tracking-tighter bg-black text-white px-4 py-3 inline-block mb-6 md:mb-8 ml-2 md:ml-4">{t.donate.monthly}</h2>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-0">
			{monthlyTiers.map((tier: any, i: number) => (
				<div class={`border-4 border-black p-4 md:p-6 relative -mt-1 md:mt-0 md:-ml-1 first:mt-0 first:md:ml-0
					${tier.highlighted ? 'bg-yellow-400 md:-mt-4 md:mb-4 md:z-10 md:border-8' : 'bg-white'}
				`} data-highlighted={tier.highlighted}>
					{tier.highlighted && <span class="absolute -top-4 md:-top-5 left-4 bg-black text-yellow-400 text-xs font-black uppercase px-4 py-1 tracking-[0.3em] border-4 border-black">{t.donate.mostPopular}</span>}
					<h3 class="text-xl md:text-2xl font-black uppercase tracking-tighter mt-2">{tier.name}</h3>
					<p class="mt-3">
						<span class="text-5xl md:text-7xl font-black leading-none">${tier.amount}</span>
						<span class="text-xs font-black uppercase tracking-[0.2em] ml-1">{t.donate.perMonth}</span>
					</p>
					<p class="text-sm font-bold mt-4 leading-snug border-l-4 border-black pl-3 uppercase">{tier.description}</p>
					<ul class="mt-4 space-y-2">
						{tier.perks.map((perk: string) => (
							<li class="text-xs font-black uppercase tracking-wider pl-4 border-l-4 border-red-600">{perk}</li>
						))}
					</ul>
					<button type="button" class={`mt-6 w-full uppercase font-black text-sm md:text-base px-4 py-3 md:py-4 border-4 border-black tracking-[0.2em] cursor-pointer
						${tier.highlighted ? 'bg-black text-yellow-400 hover:bg-red-600 hover:text-white hover:border-red-600' : 'bg-black text-white hover:bg-yellow-400 hover:text-black'}
					`}>{t.donate.choose} {tier.name}</button>
				</div>
			))}
		</div>
	</section>

	<!-- ONE-TIME: DARK, RAW -->
	<section class="bg-black text-white border-t-8 border-red-600 px-2 md:px-4 py-12 md:py-20">
		<h2 class="text-3xl md:text-5xl lg:text-7xl font-black uppercase tracking-tighter text-red-500 mb-6 md:mb-10 ml-2 md:ml-4">{t.donate.oneTime}</h2>
		<div class="grid grid-cols-1 md:grid-cols-3 gap-0">
			{oneTimeTiers.map((tier: any, i: number) => (
				<div class={`border-4 p-4 md:p-6 relative -mt-1 md:mt-0 md:-ml-1 first:mt-0 first:md:ml-0
					${tier.highlighted ? 'border-red-600 bg-red-600 md:border-8' : 'border-white bg-black'}
					${i % 2 === 1 && !tier.highlighted ? 'md:mt-8' : ''}
				`} data-highlighted={tier.highlighted}>
					{tier.highlighted && <span class="absolute -top-4 md:-top-5 right-4 bg-yellow-400 text-black text-xs font-black uppercase px-4 py-1 tracking-[0.3em] border-4 border-yellow-400 -rotate-2">{t.donate.greatestImpact}</span>}
					<h3 class="text-xl md:text-2xl font-black uppercase tracking-tighter mt-2">{tier.name}</h3>
					<p class="mt-3">
						<span class="text-5xl md:text-8xl font-black leading-none">${tier.amount}</span>
					</p>
					<p class="text-sm font-bold mt-4 leading-snug border-l-4 border-red-500 pl-3 uppercase">{tier.description}</p>
					<ul class="mt-4 space-y-2">
						{tier.perks.map((perk: string) => (
							<li class="text-xs font-black uppercase tracking-wider pl-4 border-l-4 border-yellow-400">{perk}</li>
						))}
					</ul>
					<button type="button" class={`mt-6 w-full uppercase font-black text-sm md:text-base px-4 py-3 md:py-4 border-4 tracking-[0.2em] cursor-pointer
						${tier.highlighted ? 'border-white bg-white text-red-600 hover:bg-yellow-400 hover:text-black hover:border-yellow-400' : 'border-white bg-white text-black hover:bg-red-600 hover:text-white hover:border-red-600'}
					`}>{t.donate.give} ${tier.amount}</button>
				</div>
			))}
		</div>
	</section>
</main>

<!-- NAV AT BOTTOM -->
<nav class="bg-black border-t-8 border-yellow-400 px-4 py-6 font-mono">
	<div class="flex flex-wrap gap-x-6 gap-y-2">
		{nav.map((item: any) => (
			<a href={item.href} class="text-yellow-400 uppercase font-black text-xs md:text-sm tracking-[0.3em] hover:text-white cursor-pointer">{item.label}</a>
		))}
	</div>
</nav>
