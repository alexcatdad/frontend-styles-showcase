---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<nav class="bg-black border-b-4 border-yellow-400 px-4 py-3 flex flex-wrap items-center gap-2 font-mono sticky top-0 z-50">
	{nav.map((item: any) => (
		<a href={item.href} class="text-yellow-400 uppercase font-black text-sm md:text-base tracking-widest border-2 border-yellow-400 px-3 py-1 hover:bg-yellow-400 hover:text-black transition-none cursor-pointer">{item.label}</a>
	))}
</nav>

<main class="bg-white font-mono text-black min-h-screen">
	<div class="border-b-4 border-black px-4 py-12 md:py-16 bg-red-600 text-white">
		<div class="max-w-6xl mx-auto">
			<h1 class="text-4xl md:text-6xl lg:text-8xl font-black uppercase tracking-tighter">{t.donate.title}</h1>
			<p class="text-lg md:text-2xl font-bold uppercase mt-2 border-l-4 border-white pl-4">{t.donate.subtitle}</p>
		</div>
	</div>

	<!-- MONTHLY TIERS -->
	<section class="border-b-4 border-black px-4 py-12 md:py-16">
		<div class="max-w-6xl mx-auto">
			<h2 class="text-3xl md:text-5xl font-black uppercase tracking-tighter bg-black text-white px-4 py-2 inline-block">{t.donate.monthly}</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-0 mt-8">
				{monthlyTiers.map((tier: any) => (
					<div class={`border-4 border-black p-6 -mt-1 -ml-1 ${tier.highlighted ? 'bg-yellow-400' : 'bg-white'}`} data-highlighted={tier.highlighted}>
						{tier.highlighted && <span class="block bg-black text-yellow-400 text-xs font-black uppercase px-3 py-1 tracking-widest mb-3 border-2 border-black inline-block">{t.donate.mostPopular}</span>}
						<h3 class="text-2xl font-black uppercase tracking-tighter">{tier.name}</h3>
						<p class="mt-2">
							<span class="text-4xl md:text-5xl font-black">${tier.amount}</span><span class="text-sm font-bold uppercase">{t.donate.perMonth}</span>
						</p>
						<p class="text-sm mt-3 leading-snug border-l-4 border-black pl-3">{tier.description}</p>
						<ul class="mt-4 space-y-1">
							{tier.perks.map((perk: string) => (
								<li class="text-sm font-bold before:content-['//'] before:mr-1">{perk}</li>
							))}
						</ul>
						<button type="button" class={`mt-6 w-full uppercase font-black text-sm px-4 py-3 border-4 border-black tracking-widest cursor-pointer transition-none ${tier.highlighted ? 'bg-black text-yellow-400 hover:bg-white hover:text-black' : 'bg-black text-white hover:bg-yellow-400 hover:text-black'}`}>{t.donate.choose} {tier.name}</button>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ONE-TIME TIERS -->
	<section class="px-4 py-12 md:py-16 bg-black text-white">
		<div class="max-w-6xl mx-auto">
			<h2 class="text-3xl md:text-5xl font-black uppercase tracking-tighter text-red-500 border-b-4 border-red-500 pb-2 inline-block">{t.donate.oneTime}</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-0 mt-8">
				{oneTimeTiers.map((tier: any) => (
					<div class={`border-4 p-6 -mt-1 -ml-1 ${tier.highlighted ? 'border-red-500 bg-red-600' : 'border-white bg-black'}`} data-highlighted={tier.highlighted}>
						{tier.highlighted && <span class="block bg-white text-red-600 text-xs font-black uppercase px-3 py-1 tracking-widest mb-3 border-2 border-white inline-block">{t.donate.greatestImpact}</span>}
						<h3 class="text-2xl font-black uppercase tracking-tighter">{tier.name}</h3>
						<p class="mt-2">
							<span class="text-4xl md:text-5xl font-black">${tier.amount}</span>
						</p>
						<p class="text-sm mt-3 leading-snug border-l-4 border-white pl-3 opacity-90">{tier.description}</p>
						<ul class="mt-4 space-y-1">
							{tier.perks.map((perk: string) => (
								<li class="text-sm font-bold before:content-['//'] before:mr-1">{perk}</li>
							))}
						</ul>
						<button type="button" class={`mt-6 w-full uppercase font-black text-sm px-4 py-3 border-4 tracking-widest cursor-pointer transition-none ${tier.highlighted ? 'border-white bg-white text-red-600 hover:bg-yellow-400 hover:text-black hover:border-yellow-400' : 'border-white bg-white text-black hover:bg-red-600 hover:text-white hover:border-red-600'}`}>{t.donate.give} ${tier.amount}</button>
					</div>
				))}
			</div>
		</div>
	</section>
</main>
