---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<main class="bg-white font-mono text-black overflow-x-hidden">
	<!-- CAT NAME: TAKES OVER THE VIEWPORT -->
	<section class="relative bg-black text-white px-4 pt-16 pb-20 md:pt-24 md:pb-28 overflow-hidden">
		<a href={`/${lang}/${style}/cats`} class="inline-block text-yellow-400 uppercase font-black text-xs tracking-[0.3em] mb-8 hover:text-white cursor-pointer border-b-2 border-yellow-400 hover:border-white pb-1">&larr; {t.cats.backToAll}</a>
		<img src={cat.image} alt={cat.name} class="w-full h-64 md:h-96 object-cover border-4 border-yellow-400 mb-8" />
		<h1 class="text-7xl md:text-9xl lg:text-[14rem] font-black uppercase leading-none tracking-tighter text-white">{cat.name}</h1>
		<span class="absolute top-4 right-4 md:top-8 md:right-8 bg-red-600 text-white text-xs md:text-sm font-black uppercase px-4 py-2 tracking-[0.3em] border-4 border-red-600 rotate-3">{cat.status}</span>
	</section>

	<!-- DATA DUMP: RAW, ASYMMETRIC -->
	<section class="border-t-8 border-yellow-400 bg-yellow-400 px-4 py-8 md:py-12">
		<div class="grid grid-cols-2 md:grid-cols-3 gap-0">
			<div class="border-4 border-black bg-black text-yellow-400 p-3 md:p-6">
				<span class="block text-xs font-black uppercase tracking-[0.2em]">{t.cats.breed}</span>
				<span class="block text-lg md:text-2xl font-black uppercase mt-1 leading-tight">{cat.breed}</span>
			</div>
			<div class="border-4 border-black bg-white p-3 md:p-6 -ml-1">
				<span class="block text-xs font-black uppercase tracking-[0.2em]">{t.cats.age}</span>
				<span class="block text-3xl md:text-5xl font-black leading-none mt-1">{cat.age}</span>
			</div>
			<div class="border-4 border-black bg-black text-white p-3 md:p-6 col-span-2 md:col-span-1 -mt-1 md:-mt-0 md:-ml-1">
				<span class="block text-xs font-black uppercase tracking-[0.2em]">{t.cats.gender}</span>
				<span class="block text-lg md:text-2xl font-black uppercase mt-1">{cat.gender}</span>
			</div>
			<div class="border-4 border-black bg-red-600 text-white p-3 md:p-6 -mt-1">
				<span class="block text-xs font-black uppercase tracking-[0.2em]">{t.cats.color}</span>
				<span class="block text-lg md:text-2xl font-black uppercase mt-1">{cat.color}</span>
			</div>
			<div class="border-4 border-black bg-white p-3 md:p-6 -mt-1 -ml-1 col-span-1">
				<span class="block text-xs font-black uppercase tracking-[0.2em]">{t.cats.arrived}</span>
				<span class="block text-sm md:text-base font-black uppercase mt-1">{cat.arrivalDate}</span>
			</div>
		</div>
	</section>

	<!-- PERSONALITY: SCATTERED TAGS -->
	<section class="bg-white border-t-8 border-black px-4 py-8 md:py-12">
		<div class="flex flex-wrap gap-2 md:gap-4">
			{cat.personality.map((trait: string, i: number) => (
				<span class={`font-black uppercase tracking-wider border-4 border-black px-3 md:px-5 py-2 md:py-3 cursor-pointer
					${i % 3 === 0 ? 'bg-yellow-400 text-black text-xl md:text-3xl' : ''}
					${i % 3 === 1 ? 'bg-black text-white text-base md:text-xl' : ''}
					${i % 3 === 2 ? 'bg-red-600 text-white text-lg md:text-2xl rotate-1' : ''}
					hover:bg-black hover:text-yellow-400
				`}>{trait}</span>
			))}
		</div>
	</section>

	<!-- DESCRIPTION: MASSIVE TEXT BLOCK -->
	<section class="bg-black text-white px-4 py-12 md:py-20 border-t-8 border-red-600">
		<p class="text-lg md:text-2xl lg:text-3xl font-black leading-relaxed uppercase max-w-4xl">{cat.description}</p>
	</section>

	<!-- ADOPT CTA: IMPOSSIBLE TO MISS -->
	<section class="bg-red-600 text-white px-4 py-12 md:py-16 border-t-8 border-black text-center">
		<a href={`/${lang}/${style}/auth`} class="inline-block bg-black text-white uppercase font-black text-2xl md:text-4xl lg:text-5xl px-8 md:px-12 py-4 md:py-6 border-4 border-white hover:bg-yellow-400 hover:text-black hover:border-black cursor-pointer tracking-wider">{t.cats.adopt} {cat.name}</a>
	</section>

	<!-- OTHER CATS: FOOTER MID-PAGE FEEL -->
	<section class="bg-white border-t-8 border-black px-4 py-12 md:py-16">
		<h2 class="text-3xl md:text-5xl lg:text-6xl font-black uppercase tracking-tighter mb-6 md:mb-8">{t.cats.otherCats}</h2>
		<div class="flex flex-col md:flex-row gap-0">
			{otherCats.map((c: any, i: number) => (
				<a href={`/${lang}/${style}/cats/${c.id}`} class={`block border-4 border-black p-4 md:p-6 flex-1 hover:bg-yellow-400 cursor-pointer -mt-1 md:mt-0 md:-ml-1 first:mt-0 first:md:ml-0
					${i === 0 ? 'bg-black text-white hover:text-black' : 'bg-white'}
				`}>
					<h3 class="text-xl md:text-2xl font-black uppercase tracking-tighter">{c.name}</h3>
					<p class="text-xs font-black uppercase tracking-[0.2em] mt-1">{c.breed} // {c.age}</p>
				</a>
			))}
		</div>
	</section>
</main>

<!-- NAV AT BOTTOM -->
<nav class="bg-black border-t-8 border-yellow-400 px-4 py-6 font-mono">
	<div class="flex flex-wrap gap-x-6 gap-y-2">
		{nav.map((item: any) => (
			<a href={item.href} class="text-yellow-400 uppercase font-black text-xs md:text-sm tracking-[0.3em] hover:text-white cursor-pointer">{item.label}</a>
		))}
	</div>
</nav>
