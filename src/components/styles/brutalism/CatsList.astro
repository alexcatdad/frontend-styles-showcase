---
const { lang, style, nav, cats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<main class="bg-white font-mono text-black overflow-x-hidden">
	<!-- TITLE: BLEEDS OFF SCREEN -->
	<section class="bg-black text-white px-4 pt-16 pb-24 md:pt-24 md:pb-32 relative overflow-hidden">
		<h1 class="text-7xl md:text-9xl lg:text-[12rem] font-black uppercase leading-none tracking-tighter -ml-1 md:-ml-2">{t.cats.title}</h1>
		<p class="text-base md:text-xl font-black uppercase tracking-[0.3em] mt-4 text-yellow-400">{t.cats.subtitle}</p>
		<div class="absolute -bottom-6 -right-4 text-[8rem] md:text-[16rem] font-black text-yellow-400 opacity-20 leading-none select-none pointer-events-none">{cats.length}</div>
	</section>

	<!-- CATS: DELIBERATELY BROKEN GRID -->
	<div class="px-2 md:px-4 py-8 md:py-12">
		{cats.map((cat: any, i: number) => (
			<a href={`${_base}/${lang}/${style}/cats/${cat.id}`} class={`block border-4 border-black p-4 md:p-6 hover:bg-yellow-400 cursor-pointer group relative
				${i % 3 === 0 ? 'w-full' : ''}
				${i % 3 === 1 ? 'w-full md:w-3/4 md:ml-auto' : ''}
				${i % 3 === 2 ? 'w-full md:w-2/3' : ''}
				${i > 0 ? '-mt-1' : ''}
				${i % 5 === 0 ? 'bg-red-600 text-white hover:bg-yellow-400 hover:text-black' : 'bg-white'}
			`}>
				<img src={cat.thumbnail} alt={cat.name} class="w-full h-48 md:h-56 object-cover border-b-4 border-black mb-4" />
				<div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 md:gap-8">
					<div class="flex-1">
						<h2 class="text-3xl md:text-5xl lg:text-6xl font-black uppercase tracking-tighter leading-none">{cat.name}</h2>
						<p class="text-xs md:text-sm font-black uppercase tracking-[0.2em] mt-2">{cat.breed} // {cat.age} // {cat.gender}</p>
					</div>
					<span class={`inline-block self-start text-xs font-black uppercase px-3 py-2 tracking-[0.3em] border-4 border-black ${i % 5 === 0 ? 'bg-black text-red-500 group-hover:bg-black group-hover:text-yellow-400' : 'bg-black text-white group-hover:bg-black group-hover:text-yellow-400'}`}>{cat.status}</span>
				</div>
				<p class="text-sm md:text-base mt-4 leading-snug font-bold max-w-2xl">{cat.description.slice(0, 120)}...</p>
				<div class="flex flex-wrap gap-1 mt-4">
					{cat.personality.map((trait: string) => (
						<span class="bg-yellow-400 text-black text-xs font-black uppercase px-2 py-1 tracking-wider border-2 border-black group-hover:bg-black group-hover:text-yellow-400">{trait}</span>
					))}
				</div>
			</a>
		))}
	</div>
</main>

<!-- NAV: RAW LIST AT BOTTOM -->
<nav class="bg-black border-t-8 border-yellow-400 px-4 py-6 font-mono">
	<div class="flex flex-wrap gap-x-6 gap-y-2">
		{nav.map((item: any) => (
			<a href={item.href} class="text-yellow-400 uppercase font-black text-xs md:text-sm tracking-[0.3em] hover:text-white cursor-pointer">{item.label}</a>
		))}
	</div>
</nav>
