---
const { lang, style, nav, posts, t } = Astro.props;
---

<main class="bg-white font-mono text-black overflow-x-hidden">
	<!-- HEADER: AGGRESSIVE, ROTATED -->
	<section class="bg-red-600 text-white px-4 pt-16 pb-24 md:pt-24 md:pb-36 relative overflow-hidden">
		<h1 class="text-7xl md:text-9xl lg:text-[12rem] font-black uppercase leading-none tracking-tighter -ml-1">{t.blog.title}</h1>
		<p class="text-sm md:text-lg font-black uppercase tracking-[0.3em] mt-4 bg-black text-red-500 px-4 py-2 inline-block rotate-1">{t.blog.subtitle}</p>
	</section>

	<!-- POSTS: ALTERNATING WIDTHS, SLAMMING INTO EACH OTHER -->
	<div class="px-2 md:px-4 py-0">
		{posts.map((post: any, i: number) => (
			<a href={`/${lang}/${style}/blog/${post.slug}`} class={`block border-4 border-black p-4 md:p-8 cursor-pointer group -mt-1
				${i % 4 === 0 ? 'w-full bg-black text-white hover:bg-yellow-400 hover:text-black' : ''}
				${i % 4 === 1 ? 'w-full md:w-5/6 md:ml-auto bg-white hover:bg-red-600 hover:text-white' : ''}
				${i % 4 === 2 ? 'w-full md:w-4/5 bg-yellow-400 text-black hover:bg-black hover:text-yellow-400' : ''}
				${i % 4 === 3 ? 'w-full md:w-11/12 md:ml-auto bg-white hover:bg-red-600 hover:text-white' : ''}
			`}>
				<img src={post.image} alt={post.title} class="w-full h-40 md:h-52 object-cover border-b-4 border-current mb-4" />
				<div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 md:gap-8">
					<div class="flex-1">
						<h2 class="text-2xl md:text-4xl lg:text-5xl font-black uppercase tracking-tighter leading-none">{post.title}</h2>
						<p class="text-sm md:text-base mt-3 leading-snug font-bold max-w-2xl">{post.excerpt}</p>
					</div>
					<time datetime={post.date} class={`text-xs font-black uppercase tracking-[0.3em] shrink-0 border-4 border-current px-3 py-2 self-start
						${i % 4 === 0 ? 'text-yellow-400 border-yellow-400' : ''}
						${i % 4 === 2 ? 'text-black border-black' : ''}
					`}>{post.date}</time>
				</div>
				<div class="flex flex-wrap items-center gap-2 mt-4">
					{post.tags.map((tag: string) => (
						<span class="border-2 border-current text-xs font-black uppercase px-2 py-1 tracking-wider">{tag}</span>
					))}
					<span class="text-xs font-black uppercase tracking-[0.2em] ml-auto">{t.blog.by} {post.author}</span>
				</div>
			</a>
		))}
	</div>
</main>

<!-- NAV: BOTTOM -->
<nav class="bg-black border-t-8 border-red-600 px-4 py-6 font-mono">
	<div class="flex flex-wrap gap-x-6 gap-y-2">
		{nav.map((item: any) => (
			<a href={item.href} class="text-red-500 uppercase font-black text-xs md:text-sm tracking-[0.3em] hover:text-white cursor-pointer">{item.label}</a>
		))}
	</div>
</nav>
