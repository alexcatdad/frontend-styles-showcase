---
const { lang, style, nav, posts, t } = Astro.props;
---

<nav class="bg-black border-b-4 border-yellow-400 px-4 py-3 flex flex-wrap items-center gap-2 font-mono sticky top-0 z-50">
	{nav.map((item: any) => (
		<a href={item.href} class="text-yellow-400 uppercase font-black text-sm md:text-base tracking-widest border-2 border-yellow-400 px-3 py-1 hover:bg-yellow-400 hover:text-black transition-none cursor-pointer">{item.label}</a>
	))}
</nav>

<main class="bg-white font-mono text-black min-h-screen">
	<div class="border-b-4 border-black px-4 py-12 md:py-16 bg-fuchsia-500 text-white">
		<div class="max-w-5xl mx-auto">
			<h1 class="text-4xl md:text-6xl lg:text-8xl font-black uppercase tracking-tighter">{t.blog.title}</h1>
			<p class="text-lg md:text-2xl font-bold uppercase mt-2 border-l-4 border-black pl-4">{t.blog.subtitle}</p>
		</div>
	</div>

	<div class="max-w-5xl mx-auto px-4 py-8 space-y-0">
		{posts.map((post: any) => (
			<a href={`/${lang}/${style}/blog/${post.slug}`} class="block border-4 border-black p-6 md:p-8 hover:bg-yellow-400 transition-none cursor-pointer -mt-1 group">
				<article>
					<time datetime={post.date} class="text-xs font-black uppercase tracking-widest bg-black text-white px-2 py-1 inline-block group-hover:bg-white group-hover:text-black border-2 border-black">{post.date}</time>
					<h2 class="text-2xl md:text-4xl font-black uppercase tracking-tighter mt-3">{post.title}</h2>
					<p class="text-sm md:text-base mt-2 leading-snug">{post.excerpt}</p>
					<div class="flex flex-wrap gap-1 mt-4">
						{post.tags.map((tag: string) => (
							<span class="border-2 border-black text-xs font-black uppercase px-2 py-1 tracking-wider group-hover:bg-black group-hover:text-yellow-400">{tag}</span>
						))}
					</div>
					<span class="block mt-3 text-sm font-bold uppercase tracking-wider">{t.blog.by} {post.author}</span>
				</article>
			</a>
		))}
	</div>
</main>
