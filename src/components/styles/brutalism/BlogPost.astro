---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
---

<nav class="bg-black border-b-4 border-yellow-400 px-4 py-3 flex flex-wrap items-center gap-2 font-mono sticky top-0 z-50">
	{nav.map((item: any) => (
		<a href={item.href} class="text-yellow-400 uppercase font-black text-sm md:text-base tracking-widest border-2 border-yellow-400 px-3 py-1 hover:bg-yellow-400 hover:text-black transition-none cursor-pointer">{item.label}</a>
	))}
</nav>

<main class="bg-white font-mono text-black min-h-screen">
	<div class="max-w-4xl mx-auto px-4 py-6">
		<a href={`/${lang}/${style}/blog`} class="inline-block bg-black text-white uppercase font-black text-sm px-4 py-2 border-4 border-black hover:bg-fuchsia-500 hover:text-white transition-none cursor-pointer tracking-wider">&larr; {t.blog.backToBlog}</a>
	</div>

	<article class="max-w-4xl mx-auto px-4 pb-12">
		<header class="border-b-4 border-black pb-6">
			<time datetime={post.date} class="text-xs font-black uppercase tracking-widest bg-black text-white px-2 py-1 inline-block">{post.date}</time>
			<h1 class="text-4xl md:text-6xl lg:text-7xl font-black uppercase tracking-tighter mt-4 leading-none">{post.title}</h1>
			<span class="block mt-3 text-base font-bold uppercase tracking-wider">{t.blog.by} {post.author}</span>
			<div class="flex flex-wrap gap-1 mt-4">
				{post.tags.map((tag: string) => (
					<span class="border-2 border-black bg-yellow-400 text-black text-xs font-black uppercase px-2 py-1 tracking-wider">{tag}</span>
				))}
			</div>
		</header>

		<div class="mt-8 space-y-6">
			{post.content.map((paragraph: string) => (
				<p class="text-base md:text-lg leading-relaxed border-l-4 border-black pl-4">{paragraph}</p>
			))}
		</div>
	</article>

	<section class="border-t-4 border-black px-4 py-12 bg-black text-white">
		<div class="max-w-4xl mx-auto">
			<h2 class="text-3xl md:text-4xl font-black uppercase tracking-tighter text-fuchsia-400 border-b-4 border-fuchsia-400 pb-2 inline-block">{t.blog.moreStories}</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-0 mt-8">
				{otherPosts.map((p: any) => (
					<a href={`/${lang}/${style}/blog/${p.slug}`} class="block border-2 border-white p-6 hover:bg-fuchsia-500 transition-none cursor-pointer">
						<h3 class="text-xl font-black uppercase tracking-tighter">{p.title}</h3>
						<p class="text-sm mt-2 leading-snug opacity-80">{p.excerpt}</p>
					</a>
				))}
			</div>
		</div>
	</section>
</main>
