---
const { lang, style, nav, meta, t } = Astro.props;
---

<div class="min-h-screen bg-rose-500 font-sans">
	<!-- Nav — colored pill tabs -->
	<nav class="bg-rose-500 px-4 py-5 sm:px-8">
		<div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4">
			<div class="flex flex-wrap items-center gap-2">
				{nav.map((item: any, i: number) => (
					<a href={item.href} class={`rounded-full px-5 py-2 text-sm font-bold transition-colors ${
						i % 4 === 0
							? 'bg-white text-rose-500 hover:bg-rose-50'
							: i % 4 === 1
								? 'bg-rose-400 text-white hover:bg-rose-300'
								: i % 4 === 2
									? 'bg-teal-500 text-white hover:bg-teal-600'
									: 'bg-amber-400 text-amber-900 hover:bg-amber-500'
					}`}>
						{item.label}
					</a>
				))}
			</div>
			<span class="rounded-full bg-white px-4 py-1.5 text-xs font-bold text-rose-500 uppercase tracking-wider">
				{meta.name}
			</span>
		</div>
	</nav>

	<main class="flex items-center justify-center px-4 py-20 sm:px-8">
		<section class="mx-auto max-w-lg text-center">
			<!-- Large geometric decoration -->
			<div class="mb-10 flex items-center justify-center gap-6">
				<div class="h-12 w-12 rounded-full bg-amber-400"></div>
				<div class="h-12 w-12 rounded-2xl bg-white"></div>
				<div class="h-12 w-12 rotate-45 rounded-xl bg-teal-500"></div>
			</div>

			<!-- 404 in a card -->
			<div class="mx-auto mb-8 inline-flex h-36 w-36 items-center justify-center rounded-2xl bg-white sm:h-44 sm:w-44">
				<span class="text-7xl font-extrabold text-rose-500 sm:text-8xl">{t.notFound.title}</span>
			</div>

			<h2 class="mb-4 text-3xl font-extrabold text-white sm:text-4xl">{t.notFound.heading}</h2>
			<p class="mb-12 text-lg font-medium text-rose-100">{t.notFound.description}</p>

			<div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
				<a href={`/${lang}/${style}/`} class="rounded-2xl bg-white px-10 py-4 text-base font-extrabold text-rose-500 transition-colors hover:bg-rose-50">
					{t.notFound.backHome}
				</a>
				<a href={`/${lang}/${style}/cats`} class="rounded-2xl bg-amber-400 px-10 py-4 text-base font-extrabold text-amber-900 transition-colors hover:bg-amber-300">
					{t.notFound.meetCats}
				</a>
			</div>

			<!-- Bottom geometric strip -->
			<div class="mt-16 flex items-center justify-center gap-3">
				<div class="h-2 w-14 rounded-full bg-white/40"></div>
				<div class="h-4 w-4 rounded-full bg-amber-400"></div>
				<div class="h-2 w-14 rounded-full bg-teal-400/60"></div>
				<div class="h-4 w-4 rounded-lg bg-blue-500"></div>
				<div class="h-2 w-14 rounded-full bg-white/40"></div>
			</div>
		</section>
	</main>
</div>
