---
const { lang, style, nav, meta, t } = Astro.props;
---

<div class="min-h-screen bg-white font-sans">
	<!-- Nav -->
	<nav class="bg-blue-500 px-4 py-4 sm:px-8">
		<div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3">
			<div class="flex flex-wrap items-center gap-1 sm:gap-4">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-lg px-3 py-2 text-sm font-semibold text-white hover:bg-blue-600 transition-colors">
						{item.label}
					</a>
				))}
			</div>
			<span class="rounded-full bg-white px-3 py-1 text-xs font-bold text-blue-500 uppercase tracking-wide">
				{meta.name}
			</span>
		</div>
	</nav>

	<main class="flex items-center justify-center px-4 py-20 sm:px-8">
		<section class="mx-auto max-w-lg text-center">
			<!-- Decorative geometric shapes -->
			<div class="mb-8 flex justify-center gap-4">
				<div class="h-8 w-8 rounded-full bg-amber-400"></div>
				<div class="h-8 w-8 rotate-12 rounded-lg bg-rose-500"></div>
				<div class="h-8 w-8 rotate-45 bg-teal-500"></div>
			</div>

			<h1 class="mb-2 text-8xl font-extrabold text-blue-500 sm:text-9xl">{t.notFound.title}</h1>
			<h2 class="mb-4 text-2xl font-extrabold text-gray-800 sm:text-3xl">{t.notFound.heading}</h2>
			<p class="mb-10 text-lg text-gray-500">{t.notFound.description}</p>

			<div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
				<a href={`/${lang}/${style}/`} class="rounded-xl bg-blue-500 px-8 py-3 text-sm font-bold text-white hover:bg-blue-600 transition-colors">
					{t.notFound.backHome}
				</a>
				<a href={`/${lang}/${style}/cats`} class="rounded-xl bg-amber-400 px-8 py-3 text-sm font-bold text-amber-900 hover:bg-amber-300 transition-colors">
					{t.notFound.meetCats}
				</a>
			</div>

			<!-- Bottom decorative bar -->
			<div class="mt-14 flex justify-center gap-2">
				<div class="h-2 w-16 rounded-full bg-blue-500"></div>
				<div class="h-2 w-16 rounded-full bg-rose-500"></div>
				<div class="h-2 w-16 rounded-full bg-teal-500"></div>
			</div>
		</section>
	</main>
</div>
