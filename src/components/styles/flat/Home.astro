---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-white font-sans">
	<!-- Nav — colored pill tabs -->
	<nav class="bg-white px-4 py-5 sm:px-8">
		<div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4">
			<div class="flex flex-wrap items-center gap-2">
				{nav.map((item: any, i: number) => (
					<a href={item.href} class={`rounded-full px-5 py-2 text-sm font-bold transition-colors ${
						i % 4 === 0
							? 'bg-blue-500 text-white hover:bg-blue-600'
							: i % 4 === 1
								? 'bg-rose-500 text-white hover:bg-rose-600'
								: i % 4 === 2
									? 'bg-teal-500 text-white hover:bg-teal-600'
									: 'bg-amber-400 text-amber-900 hover:bg-amber-500'
					}`}>
						{item.label}
					</a>
				))}
			</div>
			<span class="rounded-full bg-gray-800 px-4 py-1.5 text-xs font-bold text-white uppercase tracking-wider">
				{meta.name}
			</span>
		</div>
	</nav>

	<main>
		<!-- Hero — bold blue block -->
		<section class="bg-blue-500 px-4 pb-24 pt-20 sm:px-8">
			<div class="mx-auto max-w-5xl text-center">
				<img src={sanctuary.heroImage} alt={sanctuary.name} class="w-full h-56 md:h-72 object-cover rounded-2xl mb-10" />
				<!-- Geometric decoration row -->
				<div class="mb-8 flex items-center justify-center gap-4">
					<div class="h-6 w-6 rounded-full bg-amber-400"></div>
					<div class="h-1.5 w-20 rounded-full bg-white/40"></div>
					<div class="h-6 w-6 rounded-lg bg-rose-400"></div>
					<div class="h-1.5 w-20 rounded-full bg-white/40"></div>
					<div class="h-6 w-6 rotate-45 rounded-sm bg-teal-400"></div>
				</div>
				<h1 class="mb-5 text-5xl font-extrabold text-white sm:text-6xl md:text-7xl">
					{sanctuary.name}
				</h1>
				<p class="mx-auto mb-12 max-w-2xl text-xl text-blue-100 sm:text-2xl">
					{sanctuary.tagline}
				</p>
				<div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
					<a href={`${_base}/${lang}/${style}/cats`} class="rounded-2xl bg-amber-400 px-10 py-4 text-lg font-extrabold text-amber-900 transition-colors hover:bg-amber-300">
						{t.home.meetCats}
					</a>
					<a href={`${_base}/${lang}/${style}/donate`} class="rounded-2xl bg-white px-10 py-4 text-lg font-extrabold text-blue-500 transition-colors hover:bg-blue-50">
						{t.home.donate}
					</a>
				</div>
			</div>
		</section>

		<!-- Stats — horizontal teal strip -->
		<section class="bg-teal-500 px-4 py-10 sm:px-8">
			<div class="mx-auto flex max-w-5xl flex-wrap items-center justify-center gap-6 md:gap-10">
				{sanctuary.stats.map((stat: any, i: number) => (
					<div class="flex items-center gap-3">
						<div class={`flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl text-2xl font-extrabold ${
							i % 3 === 0
								? 'bg-white text-teal-500'
								: i % 3 === 1
									? 'bg-teal-400 text-white'
									: 'bg-amber-400 text-amber-900'
						}`}>
							{stat.value}
						</div>
						<span class="text-sm font-bold text-teal-50 uppercase tracking-wide">{stat.label}</span>
					</div>
				))}
			</div>
		</section>

		<!-- Mission — rose block with centered card -->
		<section class="bg-rose-500 px-4 py-20 sm:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<div class="mb-6 inline-flex items-center gap-2 rounded-full bg-white px-6 py-2">
					<div class="h-3 w-3 rounded-full bg-rose-500"></div>
					<span class="text-sm font-extrabold text-rose-500 uppercase tracking-wider">{t.home.mission}</span>
				</div>
				<p class="text-2xl font-bold leading-relaxed text-white sm:text-3xl">
					{sanctuary.mission}
				</p>
			</div>
		</section>

		<!-- About — white section with color-accented cards -->
		<section class="bg-white px-4 py-20 sm:px-8">
			<div class="mx-auto max-w-4xl">
				<div class="mb-10 text-center">
					<h2 class="mb-3 text-4xl font-extrabold text-gray-800 sm:text-5xl">
						{t.home.aboutUs}
					</h2>
					<div class="mx-auto flex justify-center gap-2">
						<div class="h-2 w-12 rounded-full bg-blue-500"></div>
						<div class="h-2 w-12 rounded-full bg-rose-500"></div>
					</div>
				</div>
				<div class="grid gap-6 sm:grid-cols-2">
					{sanctuary.about.map((paragraph: string, i: number) => (
						<div class={`rounded-2xl p-6 sm:p-8 ${
							i % 4 === 0
								? 'bg-blue-50'
								: i % 4 === 1
									? 'bg-amber-50'
									: i % 4 === 2
										? 'bg-teal-50'
										: 'bg-rose-50'
						}`}>
							<div class={`mb-4 flex h-10 w-10 items-center justify-center rounded-xl text-lg font-extrabold text-white ${
								i % 4 === 0
									? 'bg-blue-500'
									: i % 4 === 1
										? 'bg-amber-400'
										: i % 4 === 2
											? 'bg-teal-500'
											: 'bg-rose-500'
							}`}>
								{i + 1}
							</div>
							<p class="text-base leading-relaxed text-gray-600">{paragraph}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Contact — amber horizontal strip -->
		<section class="bg-amber-400 px-4 py-14 sm:px-8">
			<div class="mx-auto flex max-w-4xl flex-col items-center gap-6 sm:flex-row sm:justify-between">
				<div class="flex items-center gap-4">
					<div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-amber-600">
						<div class="h-6 w-6 rounded-full bg-white"></div>
					</div>
					<div>
						<p class="text-lg font-extrabold text-amber-900">{sanctuary.contact.email}</p>
						<p class="font-semibold text-amber-800">{sanctuary.contact.phone}</p>
					</div>
				</div>
				<div class="rounded-2xl bg-white px-6 py-3 text-center">
					<p class="font-bold text-amber-900">{sanctuary.contact.address}</p>
				</div>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="bg-gray-800 px-4 py-8 sm:px-8">
		<div class="mx-auto max-w-6xl text-center">
			<div class="mb-3 flex justify-center gap-2">
				<div class="h-2 w-8 rounded-full bg-blue-500"></div>
				<div class="h-2 w-8 rounded-full bg-rose-500"></div>
				<div class="h-2 w-8 rounded-full bg-teal-500"></div>
				<div class="h-2 w-8 rounded-full bg-amber-400"></div>
			</div>
			<p class="text-sm font-medium text-gray-400">
				&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.
			</p>
		</div>
	</footer>
</div>
