---
const { lang, style, nav, meta, post, otherPosts, t } = Astro.props;
---

<div class="min-h-screen bg-white font-sans">
	<!-- Nav -->
	<nav class="bg-blue-500 px-4 py-4 sm:px-8">
		<div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3">
			<div class="flex flex-wrap items-center gap-1 sm:gap-4">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-lg px-3 py-2 text-sm font-semibold text-white hover:bg-blue-600 transition-colors">
						{item.label}
					</a>
				))}
			</div>
			<span class="rounded-full bg-white px-3 py-1 text-xs font-bold text-blue-500 uppercase tracking-wide">
				{meta.name}
			</span>
		</div>
	</nav>

	<main class="px-4 py-10 sm:px-8">
		<div class="mx-auto max-w-3xl">
			<!-- Back link -->
			<a href={`/${lang}/${style}/blog`} class="mb-8 inline-block rounded-lg bg-gray-100 px-4 py-2 text-sm font-semibold text-gray-600 hover:bg-gray-200 transition-colors">
				&larr; {t.blog.backToBlog}
			</a>

			<article>
				<!-- Header -->
				<header class="mb-10 rounded-2xl bg-blue-500 p-8 sm:p-10">
					<div class="mb-4 flex flex-wrap items-center gap-3">
						<time datetime={post.date} class="rounded-full bg-white px-3 py-1 text-xs font-bold text-blue-500">
							{post.date}
						</time>
						<span class="text-sm font-medium text-blue-100">{t.blog.by} {post.author}</span>
					</div>
					<h1 class="mb-4 text-3xl font-extrabold text-white sm:text-4xl">
						{post.title}
					</h1>
					<div class="flex flex-wrap gap-2">
						{post.tags.map((tag: string) => (
							<span class="rounded-full bg-blue-400 px-3 py-1 text-xs font-bold text-white">
								{tag}
							</span>
						))}
					</div>
				</header>

				<!-- Content -->
				<div class="mb-12 space-y-5">
					{post.content.map((paragraph: string) => (
						<p class="text-lg leading-relaxed text-gray-700">{paragraph}</p>
					))}
				</div>
			</article>

			<!-- Decorative divider -->
			<div class="mb-10 flex items-center gap-3">
				<div class="h-1.5 flex-1 rounded-full bg-amber-400"></div>
				<div class="h-4 w-4 rounded-full bg-rose-500"></div>
				<div class="h-1.5 flex-1 rounded-full bg-teal-500"></div>
			</div>

			<!-- More Stories -->
			<section>
				<h2 class="mb-6 text-2xl font-extrabold text-gray-800">{t.blog.moreStories}</h2>
				<div class="grid gap-4 sm:grid-cols-2">
					{otherPosts.map((p: any) => (
						<a href={`/${lang}/${style}/blog/${p.slug}`} class="group rounded-2xl bg-gray-100 p-6 transition-colors hover:bg-rose-500">
							<h3 class="mb-2 text-lg font-extrabold text-gray-800 group-hover:text-white">{p.title}</h3>
							<p class="text-sm text-gray-500 group-hover:text-rose-100">{p.excerpt}</p>
						</a>
					))}
				</div>
			</section>
		</div>
	</main>
</div>
