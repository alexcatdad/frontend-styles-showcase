---
const { lang, style, nav, meta, posts, t } = Astro.props;

const sectionColors = [
	{
		bg: "bg-blue-500",
		cardBg: "bg-blue-400",
		text: "text-white",
		excerpt: "text-blue-100",
		tagBg: "bg-white text-blue-500",
		dateBg: "bg-white text-blue-500",
		meta: "text-blue-100",
	},
	{
		bg: "bg-rose-500",
		cardBg: "bg-rose-400",
		text: "text-white",
		excerpt: "text-rose-100",
		tagBg: "bg-white text-rose-500",
		dateBg: "bg-white text-rose-500",
		meta: "text-rose-100",
	},
	{
		bg: "bg-teal-500",
		cardBg: "bg-teal-400",
		text: "text-white",
		excerpt: "text-teal-100",
		tagBg: "bg-white text-teal-500",
		dateBg: "bg-white text-teal-500",
		meta: "text-teal-100",
	},
	{
		bg: "bg-amber-400",
		cardBg: "bg-amber-300",
		text: "text-amber-900",
		excerpt: "text-amber-800",
		tagBg: "bg-amber-900 text-white",
		dateBg: "bg-amber-900 text-amber-400",
		meta: "text-amber-800",
	},
];
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-white font-sans">
	<!-- Nav — colored pill tabs -->
	<nav class="bg-white px-4 py-5 sm:px-8">
		<div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4">
			<div class="flex flex-wrap items-center gap-2">
				{nav.map((item: any, i: number) => (
					<a href={item.href} class={`rounded-full px-5 py-2 text-sm font-bold transition-colors ${
						i % 4 === 0
							? 'bg-blue-500 text-white hover:bg-blue-600'
							: i % 4 === 1
								? 'bg-rose-500 text-white hover:bg-rose-600'
								: i % 4 === 2
									? 'bg-teal-500 text-white hover:bg-teal-600'
									: 'bg-amber-400 text-amber-900 hover:bg-amber-500'
					}`}>
						{item.label}
					</a>
				))}
			</div>
			<span class="rounded-full bg-gray-800 px-4 py-1.5 text-xs font-bold text-white uppercase tracking-wider">
				{meta.name}
			</span>
		</div>
	</nav>

	<!-- Header strip — amber block -->
	<section class="bg-amber-400 px-4 py-16 sm:px-8">
		<div class="mx-auto max-w-4xl text-center">
			<div class="mb-5 flex items-center justify-center gap-3">
				<div class="h-5 w-5 rounded-full bg-amber-900"></div>
				<div class="h-1 w-16 rounded-full bg-amber-600"></div>
				<div class="h-5 w-5 rounded-lg bg-white"></div>
				<div class="h-1 w-16 rounded-full bg-amber-600"></div>
				<div class="h-5 w-5 rotate-45 rounded-sm bg-rose-500"></div>
			</div>
			<h1 class="mb-3 text-4xl font-extrabold text-amber-900 sm:text-5xl md:text-6xl">{t.blog.title}</h1>
			<p class="text-lg font-medium text-amber-800 sm:text-xl">{t.blog.subtitle}</p>
		</div>
	</section>

	<!-- Posts — alternating color block sections -->
	<main>
		{posts.map((post: any, index: number) => {
			const c = sectionColors[index % sectionColors.length];
			return (
				<section class={`${c.bg} px-4 py-12 sm:px-8`}>
					<a href={`${_base}/${lang}/${style}/blog/${post.slug}`} class="group mx-auto block max-w-4xl">
						<article class="flex flex-col gap-6 sm:flex-row sm:items-center">
							<!-- Post image -->
							<img src={post.image} alt={post.title} class="w-20 h-20 sm:w-28 sm:h-28 shrink-0 object-cover rounded-2xl" />
							<!-- Content -->
							<div class="flex-1">
								<div class="mb-3 flex flex-wrap items-center gap-3">
									<time datetime={post.date} class={`rounded-full ${c.dateBg} px-3 py-1 text-xs font-bold`}>
										{post.date}
									</time>
									<span class={`text-sm font-semibold ${c.meta}`}>{t.blog.by} {post.author}</span>
								</div>
								<h2 class={`mb-2 text-2xl font-extrabold ${c.text} sm:text-3xl`}>
									{post.title}
								</h2>
								<p class={`mb-4 text-base leading-relaxed ${c.excerpt}`}>
									{post.excerpt}
								</p>
								<div class="flex flex-wrap gap-2">
									{post.tags.map((tag: string) => (
										<span class={`rounded-full px-3 py-1 text-xs font-bold ${c.tagBg}`}>
											{tag}
										</span>
									))}
								</div>
							</div>
						</article>
					</a>
				</section>
			);
		})}
	</main>
</div>
