---
const { lang, style, nav, meta, posts, t } = Astro.props;
---

<div class="min-h-screen bg-white font-sans">
	<!-- Nav -->
	<nav class="bg-blue-500 px-4 py-4 sm:px-8">
		<div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3">
			<div class="flex flex-wrap items-center gap-1 sm:gap-4">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-lg px-3 py-2 text-sm font-semibold text-white hover:bg-blue-600 transition-colors">
						{item.label}
					</a>
				))}
			</div>
			<span class="rounded-full bg-white px-3 py-1 text-xs font-bold text-blue-500 uppercase tracking-wide">
				{meta.name}
			</span>
		</div>
	</nav>

	<main class="px-4 py-12 sm:px-8">
		<div class="mx-auto max-w-4xl">
			<!-- Header -->
			<div class="mb-12 text-center">
				<h1 class="mb-3 text-4xl font-extrabold text-gray-800 sm:text-5xl">{t.blog.title}</h1>
				<p class="text-lg text-gray-500">{t.blog.subtitle}</p>
				<div class="mx-auto mt-4 h-1.5 w-20 rounded-full bg-rose-500"></div>
			</div>

			<!-- Posts list -->
			<div class="space-y-6">
				{posts.map((post: any, index: number) => (
					<a href={`/${lang}/${style}/blog/${post.slug}`} class="group block">
						<article class={`rounded-2xl p-6 sm:p-8 transition-colors ${
							index % 3 === 0
								? 'bg-blue-50 hover:bg-blue-100'
								: index % 3 === 1
									? 'bg-rose-50 hover:bg-rose-100'
									: 'bg-teal-50 hover:bg-teal-100'
						}`}>
							<div class="mb-3 flex flex-wrap items-center gap-3">
								<time datetime={post.date} class="rounded-full bg-gray-800 px-3 py-1 text-xs font-bold text-white">
									{post.date}
								</time>
								<span class="text-sm font-medium text-gray-500">{t.blog.by} {post.author}</span>
							</div>
							<h2 class="mb-2 text-2xl font-extrabold text-gray-800 group-hover:text-blue-500 sm:text-3xl">
								{post.title}
							</h2>
							<p class="mb-4 text-base leading-relaxed text-gray-600">
								{post.excerpt}
							</p>
							<div class="flex flex-wrap gap-2">
								{post.tags.map((tag: string) => (
									<span class="rounded-full bg-white px-3 py-1 text-xs font-bold text-gray-600">
										{tag}
									</span>
								))}
							</div>
						</article>
					</a>
				))}
			</div>
		</div>
	</main>
</div>
