---
const { lang, style, nav, meta, cat, otherCats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-white font-sans">
	<!-- Nav — colored pill tabs -->
	<nav class="bg-white px-4 py-5 sm:px-8">
		<div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4">
			<div class="flex flex-wrap items-center gap-2">
				{nav.map((item: any, i: number) => (
					<a href={item.href} class={`rounded-full px-5 py-2 text-sm font-bold transition-colors ${
						i % 4 === 0
							? 'bg-blue-500 text-white hover:bg-blue-600'
							: i % 4 === 1
								? 'bg-rose-500 text-white hover:bg-rose-600'
								: i % 4 === 2
									? 'bg-teal-500 text-white hover:bg-teal-600'
									: 'bg-amber-400 text-amber-900 hover:bg-amber-500'
					}`}>
						{item.label}
					</a>
				))}
			</div>
			<span class="rounded-full bg-gray-800 px-4 py-1.5 text-xs font-bold text-white uppercase tracking-wider">
				{meta.name}
			</span>
		</div>
	</nav>

	<!-- Hero header — teal block with cat identity -->
	<section class="bg-teal-500 px-4 pb-20 pt-10 sm:px-8">
		<div class="mx-auto max-w-4xl">
			<!-- Back link -->
			<a href={`${_base}/${lang}/${style}/cats`} class="mb-8 inline-flex items-center gap-2 rounded-full bg-white px-5 py-2 text-sm font-bold text-teal-500 transition-colors hover:bg-teal-50">
				&larr; {t.cats.backToAll}
			</a>

			<img src={cat.image} alt={cat.name} class="w-full h-64 md:h-80 object-cover rounded-2xl mb-10" />

			<div class="flex flex-col items-start gap-8 sm:flex-row sm:items-center">
				<!-- Large avatar -->
				<div class="flex h-28 w-28 shrink-0 items-center justify-center rounded-2xl bg-white text-5xl font-extrabold text-teal-500 sm:h-32 sm:w-32">
					{cat.name.charAt(0)}
				</div>
				<div>
					<h1 class="mb-3 text-4xl font-extrabold text-white sm:text-5xl">
						{cat.name}
					</h1>
					<div class="flex flex-wrap gap-2">
						{cat.personality.map((trait: string) => (
							<span class="rounded-full bg-teal-400 px-4 py-1.5 text-sm font-bold text-white">
								{trait}
							</span>
						))}
						<span class={`rounded-full px-4 py-1.5 text-sm font-bold uppercase tracking-wide ${
							cat.status === 'available'
								? 'bg-amber-400 text-amber-900'
								: cat.status === 'adopted'
									? 'bg-rose-500 text-white'
									: 'bg-gray-300 text-gray-700'
						}`}>
							{cat.status}
						</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Details strip — horizontal colored band -->
	<section class="bg-blue-500 px-4 py-8 sm:px-8">
		<div class="mx-auto grid max-w-4xl grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-6">
			<div class="rounded-2xl bg-blue-400 px-4 py-4 text-center">
				<dt class="mb-1 text-xs font-bold text-blue-100 uppercase tracking-wide">{t.cats.breed}</dt>
				<dd class="text-base font-extrabold text-white">{cat.breed}</dd>
			</div>
			<div class="rounded-2xl bg-blue-400 px-4 py-4 text-center">
				<dt class="mb-1 text-xs font-bold text-blue-100 uppercase tracking-wide">{t.cats.age}</dt>
				<dd class="text-base font-extrabold text-white">{cat.age}</dd>
			</div>
			<div class="rounded-2xl bg-blue-400 px-4 py-4 text-center">
				<dt class="mb-1 text-xs font-bold text-blue-100 uppercase tracking-wide">{t.cats.gender}</dt>
				<dd class="text-base font-extrabold text-white">{cat.gender}</dd>
			</div>
			<div class="rounded-2xl bg-blue-400 px-4 py-4 text-center">
				<dt class="mb-1 text-xs font-bold text-blue-100 uppercase tracking-wide">{t.cats.color}</dt>
				<dd class="text-base font-extrabold text-white">{cat.color}</dd>
			</div>
			<div class="rounded-2xl bg-blue-400 px-4 py-4 text-center">
				<dt class="mb-1 text-xs font-bold text-blue-100 uppercase tracking-wide">{t.cats.arrived}</dt>
				<dd class="text-base font-extrabold text-white">{cat.arrivalDate}</dd>
			</div>
			<div class="rounded-2xl bg-blue-400 px-4 py-4 text-center">
				<dt class="mb-1 text-xs font-bold text-blue-100 uppercase tracking-wide">{t.cats.status}</dt>
				<dd class="text-base font-extrabold text-white">{cat.status}</dd>
			</div>
		</div>
	</section>

	<main>
		<!-- Description — amber section -->
		<section class="bg-amber-400 px-4 py-16 sm:px-8">
			<div class="mx-auto max-w-3xl">
				<div class="rounded-2xl bg-white p-8 sm:p-10">
					<div class="mb-4 flex items-center gap-3">
						<div class="h-4 w-4 rounded-full bg-amber-400"></div>
						<div class="h-4 w-4 rounded-lg bg-rose-500"></div>
						<div class="h-4 w-4 rotate-45 rounded-sm bg-teal-500"></div>
					</div>
					<p class="text-lg leading-relaxed text-gray-700 sm:text-xl">{cat.description}</p>
				</div>
			</div>
		</section>

		<!-- Adopt CTA — rose strip -->
		<section class="bg-rose-500 px-4 py-12 sm:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<a href={`${_base}/${lang}/${style}/auth`} class="inline-block rounded-2xl bg-white px-12 py-5 text-xl font-extrabold text-rose-500 transition-colors hover:bg-rose-50">
					{t.cats.adopt} {cat.name}
				</a>
			</div>
		</section>

		<!-- Other cats — white section with grid cards -->
		<section class="bg-white px-4 py-16 sm:px-8">
			<div class="mx-auto max-w-4xl">
				<h2 class="mb-8 text-center text-3xl font-extrabold text-gray-800">{t.cats.otherCats}</h2>
				<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
					{otherCats.map((c: any, i: number) => (
						<a href={`${_base}/${lang}/${style}/cats/${c.id}`} class={`group rounded-2xl p-6 transition-colors ${
							i % 3 === 0
								? 'bg-blue-50 hover:bg-blue-500'
								: i % 3 === 1
									? 'bg-teal-50 hover:bg-teal-500'
									: 'bg-amber-50 hover:bg-amber-400'
						}`}>
							<div class={`mb-4 flex h-14 w-14 items-center justify-center rounded-2xl text-xl font-extrabold ${
								i % 3 === 0
									? 'bg-blue-500 text-white group-hover:bg-white group-hover:text-blue-500'
									: i % 3 === 1
										? 'bg-teal-500 text-white group-hover:bg-white group-hover:text-teal-500'
										: 'bg-amber-400 text-amber-900 group-hover:bg-white group-hover:text-amber-500'
							}`}>
								{c.name.charAt(0)}
							</div>
							<h3 class="text-lg font-extrabold text-gray-800 group-hover:text-white">{c.name}</h3>
							<p class="text-sm font-medium text-gray-500 group-hover:text-white/80">{c.breed} &middot; {c.age}</p>
						</a>
					))}
				</div>
			</div>
		</section>
	</main>
</div>
