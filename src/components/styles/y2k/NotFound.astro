---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-purple-50 via-pink-50 to-blue-50 overflow-hidden">
	<!-- Floating sparkles -->
	<div class="fixed inset-0 pointer-events-none z-0 select-none" aria-hidden="true">
		<span class="absolute top-[12%] left-[8%] text-pink-200/50 text-2xl animate-pulse">✦</span>
		<span class="absolute top-[18%] right-[10%] text-purple-200/40 text-lg animate-pulse" style="animation-delay: 0.6s">✧</span>
		<span class="absolute top-[45%] left-[4%] text-blue-200/40 text-xl animate-pulse" style="animation-delay: 1.2s">⋆</span>
		<span class="absolute top-[70%] right-[7%] text-pink-200/40 text-lg animate-pulse" style="animation-delay: 0.8s">✦</span>
		<span class="absolute top-[55%] left-[15%] text-purple-200/30 text-sm animate-pulse" style="animation-delay: 1.8s">✧</span>
		<span class="absolute top-[30%] right-[20%] text-blue-200/30 text-xs animate-pulse" style="animation-delay: 2.2s">⋆</span>
	</div>

	<!-- Floating Chrome Bubble Nav -->
	<nav class="sticky top-4 z-50 mx-auto max-w-fit px-2">
		<div class="flex flex-wrap items-center justify-center gap-1.5 px-3 py-2.5 rounded-full bg-gradient-to-b from-white/90 via-slate-100/85 to-slate-200/80 backdrop-blur-xl border border-white/70 shadow-[0_8px_32px_rgba(168,130,220,0.25),inset_0_1px_0_rgba(255,255,255,0.8)]">
			{nav.map((item: any) => (
				<a href={item.href} class="px-4 py-1.5 rounded-full text-xs font-semibold tracking-wide text-slate-500 bg-gradient-to-b from-white/80 to-slate-100/60 border border-white/50 shadow-sm hover:shadow-md hover:shadow-pink-200/40 hover:from-pink-50 hover:to-purple-50 hover:text-purple-500 transition-all duration-300 hover:scale-105">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="relative z-10 flex items-center justify-center min-h-[calc(100vh-80px)] px-4">
		<!-- Center orb glow -->
		<div class="absolute inset-0 flex items-center justify-center pointer-events-none">
			<div class="w-[450px] h-[450px] md:w-[600px] md:h-[600px] rounded-full bg-gradient-to-br from-pink-200/25 via-purple-100/15 to-blue-200/25 blur-3xl"></div>
		</div>

		<section class="relative text-center max-w-xl">
			<!-- Giant 404 as chrome orb -->
			<div class="relative inline-block mb-8">
				<!-- Circular chrome backdrop -->
				<div class="w-48 h-48 md:w-64 md:h-64 rounded-full bg-gradient-to-br from-slate-200 via-white to-slate-300 border-2 border-white/80 shadow-[0_16px_64px_rgba(168,130,220,0.25)] mx-auto flex items-center justify-center overflow-hidden">
					<div class="absolute inset-0 bg-gradient-to-t from-transparent via-white/10 to-white/60 rounded-full pointer-events-none"></div>
					<h1 class="relative text-7xl md:text-8xl font-extrabold bg-gradient-to-br from-purple-400 via-pink-300 to-blue-400 bg-clip-text text-transparent">{t.notFound.title}</h1>
				</div>
				<!-- Decorative sparkles around the orb -->
				<span class="absolute -top-2 -left-4 text-pink-300/60 text-lg animate-pulse">✦</span>
				<span class="absolute -top-1 -right-3 text-blue-300/50 text-sm animate-pulse" style="animation-delay: 0.5s">✧</span>
				<span class="absolute -bottom-1 left-2 text-purple-300/40 text-xs animate-pulse" style="animation-delay: 1s">⋆</span>
				<span class="absolute -bottom-2 -right-4 text-pink-300/50 text-sm animate-pulse" style="animation-delay: 1.5s">✦</span>
			</div>

			<!-- Message chrome card -->
			<div class="relative rounded-[2rem] bg-gradient-to-br from-slate-100 via-white to-slate-200 border-2 border-white/80 shadow-[0_10px_40px_rgba(168,130,220,0.18)] overflow-hidden mb-8">
				<div class="h-1 bg-gradient-to-r from-pink-300 via-purple-300 to-blue-300 rounded-t-[2rem]"></div>
				<div class="absolute top-1 left-0 right-0 h-1/3 bg-gradient-to-b from-white/50 to-transparent pointer-events-none"></div>
				<div class="relative p-8 md:p-10">
					<h2 class="text-2xl md:text-3xl font-extrabold bg-gradient-to-r from-purple-400 via-pink-400 to-blue-400 bg-clip-text text-transparent mb-4">{t.notFound.heading}</h2>
					<p class="text-slate-400 text-base md:text-lg leading-relaxed mb-8 font-light">{t.notFound.description}</p>

					<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
						<a href={`/${lang}/${style}/`} class="group relative px-8 py-3 rounded-full bg-gradient-to-r from-pink-300 via-purple-300 to-blue-300 text-white font-bold shadow-[0_6px_24px_rgba(219,130,220,0.4)] hover:shadow-[0_10px_40px_rgba(219,130,220,0.55)] hover:scale-105 transition-all duration-300 overflow-hidden">
							<span class="absolute inset-0 bg-gradient-to-t from-transparent to-white/25 rounded-full pointer-events-none"></span>
							<span class="relative">{t.notFound.backHome} ✦</span>
						</a>
						<a href={`/${lang}/${style}/cats`} class="group relative px-8 py-3 rounded-full bg-gradient-to-b from-white/90 via-slate-50/80 to-slate-200/70 text-purple-500 font-bold border border-white/60 shadow-[0_4px_16px_rgba(168,130,220,0.15)] hover:shadow-[0_8px_30px_rgba(219,130,220,0.25)] hover:scale-105 transition-all duration-300 overflow-hidden">
							<span class="absolute inset-0 bg-gradient-to-t from-transparent to-white/40 rounded-full pointer-events-none"></span>
							<span class="relative">{t.notFound.meetCats} ✧</span>
						</a>
					</div>
				</div>
				<div class="h-0.5 bg-gradient-to-r from-blue-300 via-pink-300 to-purple-300"></div>
			</div>

			<p class="text-purple-300/50 tracking-[0.5em] text-sm">⋆ ✧ ⋆</p>
		</section>
	</main>
</div>
