---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-blue-100 via-purple-50 to-pink-100">
	<!-- Nav -->
	<nav class="sticky top-0 z-50 bg-gradient-to-r from-slate-200/80 via-white/80 to-slate-300/80 backdrop-blur-md border-b border-white/60 shadow-lg shadow-purple-200/30">
		<div class="max-w-6xl mx-auto px-4 py-3 flex flex-wrap items-center justify-center gap-2">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 rounded-full bg-gradient-to-b from-white via-slate-100 to-slate-200 text-slate-600 text-sm font-medium shadow-md shadow-purple-200/40 hover:shadow-lg hover:shadow-pink-300/40 hover:from-pink-100 hover:to-purple-100 transition-all duration-300 border border-white/80">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="max-w-2xl mx-auto px-4 py-20 md:py-32">
		<section class="text-center">
			<!-- Big 404 with chrome/iridescent effect -->
			<div class="mb-8">
				<p class="text-purple-300 text-lg tracking-widest mb-4">✦ ⋆ ✧ ⋆ ✦</p>
				<h1 class="text-8xl md:text-9xl font-bold bg-gradient-to-br from-slate-300 via-white to-slate-400 bg-clip-text text-transparent drop-shadow-lg">{t.notFound.title}</h1>
			</div>

			<!-- Chrome card -->
			<div class="rounded-3xl bg-gradient-to-br from-slate-200 via-white to-slate-300 border border-white/80 shadow-2xl shadow-purple-300/30 p-8 md:p-12 mb-8 relative overflow-hidden">
				<div class="absolute inset-0 bg-gradient-to-t from-transparent via-white/20 to-white/50 pointer-events-none rounded-3xl"></div>
				<div class="relative">
					<h2 class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-purple-400 via-pink-400 to-blue-400 bg-clip-text text-transparent mb-4">{t.notFound.heading}</h2>
					<p class="text-slate-400 text-lg leading-relaxed mb-8">{t.notFound.description}</p>

					<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
						<a href={`/${lang}/${style}/`} class="px-8 py-3 rounded-full bg-gradient-to-r from-pink-300 via-purple-300 to-blue-300 text-white font-semibold shadow-lg shadow-pink-300/50 hover:shadow-xl hover:shadow-purple-300/60 hover:scale-105 transition-all duration-300">{t.notFound.backHome} ✦</a>
						<a href={`/${lang}/${style}/cats`} class="px-8 py-3 rounded-full bg-gradient-to-b from-white via-slate-100 to-slate-200 text-purple-500 font-semibold shadow-lg shadow-slate-300/50 border border-white/80 hover:shadow-xl hover:shadow-pink-200/40 hover:scale-105 transition-all duration-300">{t.notFound.meetCats} ✧</a>
					</div>
				</div>
			</div>

			<p class="text-purple-300 tracking-widest text-sm">⋆ ✧ ⋆</p>
		</section>
	</main>
</div>
