---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-pink-50 via-blue-50 to-purple-50 overflow-hidden">
	<!-- Floating sparkle accents -->
	<div class="fixed inset-0 pointer-events-none z-0 select-none overflow-hidden" aria-hidden="true">
		<span class="absolute top-[8%] left-[5%] text-pink-200/60 text-2xl animate-pulse">✦</span>
		<span class="absolute top-[15%] right-[10%] text-purple-200/50 text-lg animate-pulse" style="animation-delay: 0.5s">✧</span>
		<span class="absolute top-[40%] left-[8%] text-blue-200/40 text-xl animate-pulse" style="animation-delay: 1s">⋆</span>
		<span class="absolute top-[60%] right-[6%] text-pink-200/50 text-2xl animate-pulse" style="animation-delay: 1.5s">✦</span>
		<span class="absolute top-[80%] left-[15%] text-purple-200/40 text-lg animate-pulse" style="animation-delay: 0.8s">✧</span>
		<span class="absolute top-[30%] right-[20%] text-blue-200/30 text-sm animate-pulse" style="animation-delay: 2s">⋆</span>
	</div>

	<!-- Floating Chrome Bubble Nav -->
	<nav class="sticky top-4 z-50 mx-auto max-w-fit px-2">
		<div class="flex flex-wrap items-center justify-center gap-1.5 px-3 py-2.5 rounded-full bg-gradient-to-b from-white/90 via-slate-100/85 to-slate-200/80 backdrop-blur-xl border border-white/70 shadow-[0_8px_32px_rgba(168,130,220,0.25),inset_0_1px_0_rgba(255,255,255,0.8)]">
			{nav.map((item: any) => (
				<a href={item.href} class="px-4 py-1.5 rounded-full text-xs font-semibold tracking-wide text-slate-500 bg-gradient-to-b from-white/80 to-slate-100/60 border border-white/50 shadow-sm hover:shadow-md hover:shadow-pink-200/40 hover:bg-gradient-to-b hover:from-pink-50 hover:to-purple-50 hover:text-purple-500 transition-all duration-300 hover:scale-105">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="relative z-10 max-w-5xl mx-auto px-4 pt-8 pb-12">
		<!-- Hero Orb Section -->
		<section class="relative flex flex-col items-center justify-center text-center py-16 md:py-28 mb-16">
			<!-- Background orb glow -->
			<div class="absolute inset-0 flex items-center justify-center pointer-events-none">
				<div class="w-[500px] h-[500px] md:w-[700px] md:h-[700px] rounded-full bg-gradient-to-br from-pink-200/30 via-purple-100/20 to-blue-200/30 blur-3xl"></div>
			</div>
			<!-- Chrome orb container -->
			<div class="relative w-full max-w-2xl mx-auto px-8 py-14 md:py-20 rounded-[3rem] bg-gradient-to-br from-slate-100 via-white to-slate-200 border border-white/90 shadow-[0_20px_80px_rgba(168,130,220,0.2),0_4px_20px_rgba(200,160,240,0.15)] overflow-hidden">
				<!-- Glossy overlay -->
				<div class="absolute inset-0 bg-gradient-to-b from-white/70 via-white/10 to-transparent rounded-[3rem] pointer-events-none"></div>
				<!-- Iridescent shimmer band -->
				<div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-pink-300 via-purple-300 via-blue-300 to-pink-300 rounded-t-[3rem]"></div>

				<div class="relative z-10">
					<p class="text-purple-300/70 text-sm tracking-[0.4em] mb-6">✦ &middot; ✧ &middot; ⋆ &middot; ✧ &middot; ✦</p>
					<h1 class="text-5xl md:text-7xl lg:text-8xl font-extrabold bg-gradient-to-r from-purple-400 via-pink-300 to-blue-400 bg-clip-text text-transparent leading-tight mb-5 drop-shadow-sm">{sanctuary.name}</h1>
					<p class="text-base md:text-lg text-slate-400 max-w-lg mx-auto mb-10 font-light leading-relaxed">{sanctuary.tagline}</p>
					<img src={sanctuary.heroImage} alt={sanctuary.name} class="w-full max-w-2xl mx-auto rounded-[2rem] object-cover shadow-[0_8px_32px_rgba(168,130,220,0.2)] border-2 border-white/60 mb-8" />
					<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
						<a href={`/${lang}/${style}/cats`} class="group relative px-8 py-3.5 rounded-full bg-gradient-to-r from-pink-300 via-purple-300 to-blue-300 text-white font-bold shadow-[0_6px_24px_rgba(219,130,220,0.45)] hover:shadow-[0_10px_40px_rgba(219,130,220,0.55)] hover:scale-105 transition-all duration-300 text-base overflow-hidden">
							<span class="absolute inset-0 bg-gradient-to-t from-transparent to-white/25 rounded-full pointer-events-none"></span>
							<span class="relative">{t.home.meetCats} ✦</span>
						</a>
						<a href={`/${lang}/${style}/donate`} class="group relative px-8 py-3.5 rounded-full bg-gradient-to-b from-white via-slate-50 to-slate-200 text-purple-500 font-bold shadow-[0_4px_16px_rgba(168,130,220,0.2)] border border-white/70 hover:shadow-[0_8px_30px_rgba(219,130,220,0.3)] hover:scale-105 transition-all duration-300 text-base overflow-hidden">
							<span class="absolute inset-0 bg-gradient-to-t from-transparent to-white/40 rounded-full pointer-events-none"></span>
							<span class="relative">{t.home.donate} ✧</span>
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Mission Pill -->
		<section class="mb-16 max-w-3xl mx-auto">
			<div class="relative p-8 md:p-12 rounded-[2.5rem] bg-gradient-to-br from-white/80 via-purple-50/50 to-pink-50/40 backdrop-blur-sm border border-white/70 shadow-[0_8px_40px_rgba(168,130,220,0.12)] overflow-hidden">
				<div class="absolute inset-0 bg-gradient-to-t from-transparent to-white/40 rounded-[2.5rem] pointer-events-none"></div>
				<div class="relative text-center">
					<span class="inline-block px-4 py-1 rounded-full bg-gradient-to-r from-pink-100/80 to-purple-100/80 text-purple-400 text-xs font-bold tracking-widest uppercase mb-4 border border-purple-200/30">⋆ {t.home.mission} ⋆</span>
					<p class="text-slate-500 text-lg md:text-xl leading-relaxed font-light">{sanctuary.mission}</p>
				</div>
			</div>
		</section>

		<!-- Stats Bubbles - floating orb layout -->
		<section class="mb-16">
			<div class="flex flex-wrap items-center justify-center gap-5 md:gap-8">
				{sanctuary.stats.map((stat: any, i: number) => (
					<div class={`relative group flex flex-col items-center justify-center w-36 h-36 md:w-44 md:h-44 rounded-full bg-gradient-to-br from-slate-100 via-white to-slate-200 border border-white/80 shadow-[0_8px_32px_rgba(168,130,220,0.18)] hover:shadow-[0_12px_48px_rgba(219,130,220,0.3)] hover:scale-110 transition-all duration-500 cursor-default ${i % 2 === 0 ? 'mt-0' : 'mt-6 md:mt-10'}`}>
						<div class="absolute inset-0 rounded-full bg-gradient-to-t from-transparent to-white/50 pointer-events-none"></div>
						<span class="relative text-3xl md:text-4xl font-extrabold bg-gradient-to-br from-purple-400 via-pink-400 to-blue-400 bg-clip-text text-transparent">{stat.value}</span>
						<span class="relative text-[10px] md:text-xs text-slate-400 mt-1.5 font-semibold tracking-wider uppercase text-center px-2 leading-tight">{stat.label}</span>
					</div>
				))}
			</div>
		</section>

		<!-- About Section - stacked chrome cards -->
		<section class="mb-16 max-w-3xl mx-auto">
			<div class="text-center mb-8">
				<span class="inline-block px-4 py-1 rounded-full bg-gradient-to-r from-blue-100/80 to-purple-100/80 text-blue-400 text-xs font-bold tracking-widest uppercase border border-blue-200/30">✦ {t.home.aboutUs} ✦</span>
			</div>
			<div class="space-y-4">
				{sanctuary.about.map((paragraph: string, i: number) => (
					<div class="relative p-6 md:p-8 rounded-2xl bg-gradient-to-br from-white/70 via-slate-50/50 to-pink-50/30 border border-white/60 shadow-[0_4px_20px_rgba(168,130,220,0.1)] overflow-hidden">
						<div class="absolute inset-0 bg-gradient-to-t from-transparent to-white/30 rounded-2xl pointer-events-none"></div>
						<p class="relative text-slate-500 text-base md:text-lg leading-relaxed">{paragraph}</p>
					</div>
				))}
			</div>
		</section>

		<!-- Contact Bubble -->
		<section class="mb-12 flex justify-center">
			<div class="relative inline-flex flex-col sm:flex-row items-center gap-4 sm:gap-6 px-8 py-5 rounded-full bg-gradient-to-r from-slate-100 via-white to-slate-100 border border-white/70 shadow-[0_6px_24px_rgba(168,130,220,0.15)]">
				<div class="absolute inset-0 bg-gradient-to-t from-transparent to-white/40 rounded-full pointer-events-none"></div>
				<span class="relative text-sm text-slate-400">✧ {sanctuary.contact.email}</span>
				<span class="relative hidden sm:inline text-purple-200">|</span>
				<span class="relative text-sm text-slate-400">{sanctuary.contact.phone} ✧</span>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="relative z-10">
		<div class="max-w-5xl mx-auto px-4 py-6">
			<div class="flex justify-center">
				<div class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-gradient-to-b from-white/80 to-slate-100/70 border border-white/60 shadow-sm">
					<span class="text-xs text-slate-400 font-medium">✧ &copy; 2026 {sanctuary.name} &middot; {t.footer.style}: {meta.name} ✧</span>
				</div>
			</div>
		</div>
	</footer>
</div>
