---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-blue-100 via-purple-50 to-pink-100">
	<!-- Nav -->
	<nav class="sticky top-0 z-50 bg-gradient-to-r from-slate-200/80 via-white/80 to-slate-300/80 backdrop-blur-md border-b border-white/60 shadow-lg shadow-purple-200/30">
		<div class="max-w-6xl mx-auto px-4 py-3 flex flex-wrap items-center justify-center gap-2">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 rounded-full bg-gradient-to-b from-white via-slate-100 to-slate-200 text-slate-600 text-sm font-medium shadow-md shadow-purple-200/40 hover:shadow-lg hover:shadow-pink-300/40 hover:from-pink-100 hover:to-purple-100 transition-all duration-300 border border-white/80">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="max-w-6xl mx-auto px-4 py-8">
		<!-- Hero Section -->
		<section class="relative text-center py-16 md:py-24 mb-12 rounded-3xl bg-gradient-to-br from-slate-200 via-white to-slate-300 border border-white/80 shadow-2xl shadow-purple-300/30 overflow-hidden">
			<div class="absolute inset-0 bg-gradient-to-t from-transparent via-white/20 to-white/60 rounded-3xl"></div>
			<div class="relative z-10">
				<p class="text-purple-300 text-lg tracking-widest mb-4">✦ ⋆ ✧ ⋆ ✦</p>
				<h1 class="text-5xl md:text-7xl font-bold bg-gradient-to-r from-purple-400 via-pink-300 to-blue-400 bg-clip-text text-transparent drop-shadow-sm mb-4">{sanctuary.name}</h1>
				<p class="text-lg md:text-xl text-slate-500 max-w-2xl mx-auto mb-8 font-light">{sanctuary.tagline}</p>
				<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
					<a href={`/${lang}/${style}/cats`} class="px-8 py-3 rounded-full bg-gradient-to-r from-pink-300 via-purple-300 to-blue-300 text-white font-semibold shadow-lg shadow-pink-300/50 hover:shadow-xl hover:shadow-purple-300/60 hover:scale-105 transition-all duration-300 text-lg">{t.home.meetCats} ✦</a>
					<a href={`/${lang}/${style}/donate`} class="px-8 py-3 rounded-full bg-gradient-to-b from-white via-slate-100 to-slate-200 text-purple-500 font-semibold shadow-lg shadow-slate-300/50 border border-white/80 hover:shadow-xl hover:shadow-pink-200/40 hover:scale-105 transition-all duration-300 text-lg">{t.home.donate} ✧</a>
				</div>
			</div>
		</section>

		<!-- Mission Section -->
		<section class="mb-12 p-8 md:p-12 rounded-3xl bg-gradient-to-br from-white/70 via-purple-50/50 to-pink-50/50 backdrop-blur-sm border border-white/60 shadow-xl shadow-purple-200/20">
			<div class="text-center mb-6">
				<span class="text-pink-300 tracking-widest text-sm">⋆ ✧ ⋆</span>
				<h2 class="text-3xl md:text-4xl font-bold bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent mt-2">{t.home.mission}</h2>
			</div>
			<p class="text-slate-500 text-center text-lg leading-relaxed max-w-3xl mx-auto">{sanctuary.mission}</p>
		</section>

		<!-- Stats Section -->
		<section class="mb-12 grid grid-cols-2 md:grid-cols-4 gap-4">
			{sanctuary.stats.map((stat: any) => (
				<div class="text-center p-6 rounded-2xl bg-gradient-to-br from-slate-200 via-white to-slate-300 border border-white/80 shadow-lg shadow-purple-200/30 hover:shadow-xl hover:shadow-pink-300/30 transition-all duration-300 hover:scale-105">
					<div class="absolute inset-0 bg-gradient-to-t from-transparent to-white/40 rounded-2xl pointer-events-none"></div>
					<span class="block text-3xl md:text-4xl font-bold bg-gradient-to-br from-purple-400 via-pink-400 to-blue-400 bg-clip-text text-transparent">{stat.value}</span>
					<span class="block text-sm text-slate-400 mt-2 font-medium tracking-wide uppercase">{stat.label}</span>
				</div>
			))}
		</section>

		<!-- About Section -->
		<section class="mb-12 p-8 md:p-12 rounded-3xl bg-gradient-to-br from-pink-50/60 via-white/70 to-blue-50/60 backdrop-blur-sm border border-white/60 shadow-xl shadow-blue-200/20">
			<div class="text-center mb-8">
				<span class="text-blue-300 tracking-widest text-sm">✦ ⋆ ✦</span>
				<h2 class="text-3xl md:text-4xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent mt-2">{t.home.aboutUs}</h2>
			</div>
			<div class="space-y-4 max-w-3xl mx-auto">
				{sanctuary.about.map((paragraph: string) => (
					<p class="text-slate-500 text-lg leading-relaxed">{paragraph}</p>
				))}
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="bg-gradient-to-r from-slate-200/80 via-white/80 to-slate-300/80 backdrop-blur-md border-t border-white/60 shadow-inner">
		<div class="max-w-6xl mx-auto px-4 py-6 text-center">
			<p class="text-slate-400 text-sm">✧ &copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}. ✧</p>
		</div>
	</footer>
</div>
