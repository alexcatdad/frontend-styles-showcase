---
const { lang, style, nav, cats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-gradient-to-b from-purple-50 via-pink-50 to-blue-50 overflow-hidden">
	<!-- Floating sparkles -->
	<div class="fixed inset-0 pointer-events-none z-0 select-none" aria-hidden="true">
		<span class="absolute top-[12%] left-[7%] text-pink-200/50 text-xl animate-pulse">✦</span>
		<span class="absolute top-[25%] right-[12%] text-purple-200/40 text-lg animate-pulse" style="animation-delay: 0.7s">✧</span>
		<span class="absolute top-[55%] left-[4%] text-blue-200/40 text-sm animate-pulse" style="animation-delay: 1.2s">⋆</span>
		<span class="absolute top-[70%] right-[8%] text-pink-200/40 text-xl animate-pulse" style="animation-delay: 1.8s">✦</span>
	</div>

	<!-- Floating Chrome Bubble Nav -->
	<nav class="sticky top-4 z-50 mx-auto max-w-fit px-2">
		<div class="flex flex-wrap items-center justify-center gap-1.5 px-3 py-2.5 rounded-full bg-gradient-to-b from-white/90 via-slate-100/85 to-slate-200/80 backdrop-blur-xl border border-white/70 shadow-[0_8px_32px_rgba(168,130,220,0.25),inset_0_1px_0_rgba(255,255,255,0.8)]">
			{nav.map((item: any) => (
				<a href={item.href} class="px-4 py-1.5 rounded-full text-xs font-semibold tracking-wide text-slate-500 bg-gradient-to-b from-white/80 to-slate-100/60 border border-white/50 shadow-sm hover:shadow-md hover:shadow-pink-200/40 hover:from-pink-50 hover:to-purple-50 hover:text-purple-500 transition-all duration-300 hover:scale-105">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="relative z-10 max-w-6xl mx-auto px-4 pt-8 pb-12">
		<!-- Header with orbiting sparkles -->
		<div class="text-center mb-14">
			<div class="inline-block relative">
				<span class="absolute -top-3 -left-6 text-pink-300/50 text-sm animate-pulse">✦</span>
				<span class="absolute -top-2 -right-5 text-blue-300/50 text-xs animate-pulse" style="animation-delay: 0.5s">✧</span>
				<h1 class="text-5xl md:text-7xl font-extrabold bg-gradient-to-r from-purple-400 via-pink-300 to-blue-400 bg-clip-text text-transparent">{t.cats.title}</h1>
			</div>
			<p class="text-slate-400 text-base md:text-lg mt-4 max-w-md mx-auto font-light">{t.cats.subtitle}</p>
		</div>

		<!-- Cat Trading Cards Grid -->
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-7">
			{cats.map((cat: any, i: number) => (
				<a href={`${_base}/${lang}/${style}/cats/${cat.id}`} class="group block relative">
					<!-- Card with chrome border effect -->
					<div class="relative rounded-[2rem] bg-gradient-to-br from-slate-100 via-white to-slate-200 border-2 border-white/80 shadow-[0_8px_32px_rgba(168,130,220,0.15)] group-hover:shadow-[0_16px_56px_rgba(219,130,220,0.3)] transition-all duration-500 group-hover:scale-[1.04] group-hover:-translate-y-1 overflow-hidden">
						<!-- Glossy top shine -->
						<div class="absolute top-0 left-0 right-0 h-1/2 bg-gradient-to-b from-white/60 to-transparent rounded-t-[2rem] pointer-events-none"></div>
						<!-- Iridescent top band -->
						<div class="h-1.5 bg-gradient-to-r from-pink-300 via-purple-300 to-blue-300 rounded-t-[2rem]"></div>

						<img src={cat.thumbnail} alt={cat.name} class="w-full h-40 object-cover" />

						<div class="relative p-5 md:p-6">
							<!-- Name and status row -->
							<div class="flex items-start justify-between mb-3">
								<h2 class="text-xl font-extrabold bg-gradient-to-r from-purple-500 via-pink-400 to-purple-500 bg-clip-text text-transparent leading-tight">{cat.name}</h2>
								<span class="shrink-0 ml-2 px-3 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-gradient-to-r from-pink-200/80 via-purple-200/80 to-blue-200/80 text-purple-600 border border-purple-200/40 shadow-sm">{cat.status}</span>
							</div>

							<!-- Chrome detail pills -->
							<div class="flex flex-wrap gap-1.5 mb-4">
								<span class="px-3 py-1 rounded-full text-[11px] font-medium text-slate-500 bg-gradient-to-b from-white/90 to-slate-100/80 border border-slate-200/50 shadow-sm">{cat.breed}</span>
								<span class="px-3 py-1 rounded-full text-[11px] font-medium text-slate-500 bg-gradient-to-b from-white/90 to-slate-100/80 border border-slate-200/50 shadow-sm">{cat.age}</span>
								<span class="px-3 py-1 rounded-full text-[11px] font-medium text-slate-500 bg-gradient-to-b from-white/90 to-slate-100/80 border border-slate-200/50 shadow-sm">{cat.gender}</span>
							</div>

							<!-- Description -->
							<p class="text-slate-400 text-sm leading-relaxed mb-4">{cat.description.slice(0, 100)}...</p>

							<!-- Personality trait bubbles -->
							<div class="flex flex-wrap gap-1.5">
								{cat.personality.map((trait: string) => (
									<span class="px-3 py-1 rounded-full text-[10px] font-semibold bg-gradient-to-r from-blue-100/70 via-purple-100/70 to-pink-100/70 text-purple-500 border border-purple-100/50">✧ {trait}</span>
								))}
							</div>
						</div>

						<!-- Bottom iridescent bar -->
						<div class="h-0.5 bg-gradient-to-r from-blue-300 via-pink-300 to-purple-300"></div>
					</div>
				</a>
			))}
		</div>
	</main>
</div>
