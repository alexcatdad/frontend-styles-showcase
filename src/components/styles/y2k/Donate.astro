---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-blue-50 via-pink-50 to-purple-50 overflow-hidden">
	<!-- Floating sparkles -->
	<div class="fixed inset-0 pointer-events-none z-0 select-none" aria-hidden="true">
		<span class="absolute top-[10%] left-[8%] text-pink-200/50 text-xl animate-pulse">✦</span>
		<span class="absolute top-[20%] right-[7%] text-purple-200/40 text-lg animate-pulse" style="animation-delay: 0.6s">✧</span>
		<span class="absolute top-[45%] left-[3%] text-blue-200/40 text-sm animate-pulse" style="animation-delay: 1.1s">⋆</span>
		<span class="absolute top-[70%] right-[5%] text-pink-200/40 text-xl animate-pulse" style="animation-delay: 1.7s">✦</span>
		<span class="absolute top-[85%] left-[12%] text-purple-200/30 text-lg animate-pulse" style="animation-delay: 0.4s">✧</span>
	</div>

	<!-- Floating Chrome Bubble Nav -->
	<nav class="sticky top-4 z-50 mx-auto max-w-fit px-2">
		<div class="flex flex-wrap items-center justify-center gap-1.5 px-3 py-2.5 rounded-full bg-gradient-to-b from-white/90 via-slate-100/85 to-slate-200/80 backdrop-blur-xl border border-white/70 shadow-[0_8px_32px_rgba(168,130,220,0.25),inset_0_1px_0_rgba(255,255,255,0.8)]">
			{nav.map((item: any) => (
				<a href={item.href} class="px-4 py-1.5 rounded-full text-xs font-semibold tracking-wide text-slate-500 bg-gradient-to-b from-white/80 to-slate-100/60 border border-white/50 shadow-sm hover:shadow-md hover:shadow-pink-200/40 hover:from-pink-50 hover:to-purple-50 hover:text-purple-500 transition-all duration-300 hover:scale-105">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="relative z-10 max-w-6xl mx-auto px-4 pt-8 pb-12">
		<!-- Header -->
		<div class="text-center mb-16">
			<div class="inline-block relative">
				<span class="absolute -top-4 -left-8 text-pink-300/40 text-sm animate-pulse">✦</span>
				<span class="absolute -top-3 -right-6 text-blue-300/40 text-xs animate-pulse" style="animation-delay: 0.5s">✧</span>
				<span class="absolute -bottom-3 left-1/2 text-purple-300/30 text-xs animate-pulse" style="animation-delay: 1s">⋆</span>
				<h1 class="text-5xl md:text-7xl font-extrabold bg-gradient-to-r from-pink-400 via-purple-400 to-blue-400 bg-clip-text text-transparent">{t.donate.title}</h1>
			</div>
			<p class="text-slate-400 text-base md:text-lg mt-4 max-w-lg mx-auto font-light">{t.donate.subtitle}</p>
		</div>

		<!-- Monthly Tiers -->
		<section class="mb-20">
			<div class="text-center mb-10">
				<span class="inline-block px-5 py-1.5 rounded-full bg-gradient-to-r from-pink-100/80 to-purple-100/80 text-pink-500 text-xs font-bold tracking-widest uppercase border border-pink-200/40 shadow-sm">⋆ {t.donate.monthly} ⋆</span>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-7 items-start">
				{monthlyTiers.map((tier: any) => (
					<div class={`relative group rounded-[2rem] overflow-hidden transition-all duration-500 hover:scale-[1.04] hover:-translate-y-2 ${tier.highlighted ? 'md:-translate-y-4' : ''}`}>
						{/* Chrome badge card */}
						<div class={`relative border-2 rounded-[2rem] shadow-[0_8px_32px_rgba(168,130,220,0.15)] group-hover:shadow-[0_16px_56px_rgba(219,130,220,0.3)] transition-shadow duration-500 ${tier.highlighted ? 'bg-gradient-to-br from-pink-100 via-purple-50 to-blue-100 border-purple-300/50 shadow-[0_12px_48px_rgba(168,130,220,0.25)]' : 'bg-gradient-to-br from-slate-100 via-white to-slate-200 border-white/80'}`}>
							{/* Top iridescent band */}
							<div class={`h-1.5 rounded-t-[2rem] ${tier.highlighted ? 'bg-gradient-to-r from-pink-400 via-purple-400 to-blue-400' : 'bg-gradient-to-r from-pink-300/60 via-purple-300/60 to-blue-300/60'}`}></div>

							{/* Most Popular badge */}
							{tier.highlighted && (
								<div class="flex justify-center -mt-0 pt-3">
									<span class="inline-block px-5 py-1 rounded-full bg-gradient-to-r from-pink-300 via-purple-300 to-blue-300 text-white text-[10px] font-bold tracking-widest uppercase shadow-[0_4px_16px_rgba(219,130,220,0.35)]">✦ {t.donate.mostPopular} ✦</span>
								</div>
							)}

							{/* Glossy shine */}
							<div class="absolute top-1.5 left-0 right-0 h-1/3 bg-gradient-to-b from-white/50 to-transparent rounded-t-[2rem] pointer-events-none"></div>

							<div class="relative p-6 md:p-8">
								<h3 class="text-lg font-extrabold text-slate-600 mb-4">{tier.name}</h3>

								{/* Price orb */}
								<div class="flex items-center justify-center mb-5">
									<div class="inline-flex items-baseline gap-1 px-6 py-3 rounded-full bg-gradient-to-b from-white/80 to-slate-50/60 border border-white/60 shadow-inner">
										<span class="text-3xl md:text-4xl font-extrabold bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">${tier.amount}</span>
										<span class="text-slate-400 text-xs font-medium">/{t.donate.perMonth}</span>
									</div>
								</div>

								<p class="text-slate-400 text-sm mb-6 leading-relaxed text-center">{tier.description}</p>

								{/* Perks as mini bubbles */}
								<ul class="space-y-2.5 mb-8">
									{tier.perks.map((perk: string) => (
										<li class="flex items-start gap-2.5 text-sm text-slate-500">
											<span class="shrink-0 mt-0.5 w-5 h-5 rounded-full bg-gradient-to-br from-pink-200/60 to-purple-200/60 flex items-center justify-center text-[10px] text-purple-500 border border-purple-100/40">✧</span>
											<span>{perk}</span>
										</li>
									))}
								</ul>

								{/* CTA button */}
								<button type="button" class={`w-full py-3 rounded-full font-bold text-sm shadow-lg transition-all duration-300 hover:scale-105 relative overflow-hidden ${tier.highlighted ? 'bg-gradient-to-r from-pink-300 via-purple-300 to-blue-300 text-white shadow-[0_6px_24px_rgba(219,130,220,0.4)] hover:shadow-[0_10px_36px_rgba(219,130,220,0.5)]' : 'bg-gradient-to-b from-white via-slate-50 to-slate-200 text-purple-500 border border-white/70 shadow-[0_4px_16px_rgba(168,130,220,0.12)] hover:shadow-[0_6px_24px_rgba(219,130,220,0.2)]'}`}>
									<span class="absolute inset-0 bg-gradient-to-t from-transparent to-white/20 rounded-full pointer-events-none"></span>
									<span class="relative">{t.donate.choose} {tier.name}</span>
								</button>
							</div>

							{/* Bottom band */}
							<div class={`h-0.5 ${tier.highlighted ? 'bg-gradient-to-r from-blue-400 via-pink-400 to-purple-400' : 'bg-gradient-to-r from-blue-300/40 via-pink-300/40 to-purple-300/40'}`}></div>
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- One-Time Tiers -->
		<section class="mb-12">
			<div class="text-center mb-10">
				<span class="inline-block px-5 py-1.5 rounded-full bg-gradient-to-r from-blue-100/80 to-purple-100/80 text-blue-500 text-xs font-bold tracking-widest uppercase border border-blue-200/40 shadow-sm">✦ {t.donate.oneTime} ✦</span>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-7 items-start">
				{oneTimeTiers.map((tier: any) => (
					<div class={`relative group rounded-[2rem] overflow-hidden transition-all duration-500 hover:scale-[1.04] hover:-translate-y-2 ${tier.highlighted ? 'md:-translate-y-4' : ''}`}>
						<div class={`relative border-2 rounded-[2rem] shadow-[0_8px_32px_rgba(168,130,220,0.15)] group-hover:shadow-[0_16px_56px_rgba(168,180,240,0.3)] transition-shadow duration-500 ${tier.highlighted ? 'bg-gradient-to-br from-blue-100 via-purple-50 to-pink-100 border-blue-300/50 shadow-[0_12px_48px_rgba(130,168,220,0.25)]' : 'bg-gradient-to-br from-slate-100 via-white to-slate-200 border-white/80'}`}>
							{/* Top band */}
							<div class={`h-1.5 rounded-t-[2rem] ${tier.highlighted ? 'bg-gradient-to-r from-blue-400 via-purple-400 to-pink-400' : 'bg-gradient-to-r from-blue-300/60 via-purple-300/60 to-pink-300/60'}`}></div>

							{tier.highlighted && (
								<div class="flex justify-center pt-3">
									<span class="inline-block px-5 py-1 rounded-full bg-gradient-to-r from-blue-300 via-purple-300 to-pink-300 text-white text-[10px] font-bold tracking-widest uppercase shadow-[0_4px_16px_rgba(130,168,220,0.35)]">✦ {t.donate.greatestImpact} ✦</span>
								</div>
							)}

							<div class="absolute top-1.5 left-0 right-0 h-1/3 bg-gradient-to-b from-white/50 to-transparent rounded-t-[2rem] pointer-events-none"></div>

							<div class="relative p-6 md:p-8">
								<h3 class="text-lg font-extrabold text-slate-600 mb-4">{tier.name}</h3>

								{/* Price orb */}
								<div class="flex items-center justify-center mb-5">
									<div class="inline-flex items-baseline px-6 py-3 rounded-full bg-gradient-to-b from-white/80 to-slate-50/60 border border-white/60 shadow-inner">
										<span class="text-3xl md:text-4xl font-extrabold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">${tier.amount}</span>
									</div>
								</div>

								<p class="text-slate-400 text-sm mb-6 leading-relaxed text-center">{tier.description}</p>

								<ul class="space-y-2.5 mb-8">
									{tier.perks.map((perk: string) => (
										<li class="flex items-start gap-2.5 text-sm text-slate-500">
											<span class="shrink-0 mt-0.5 w-5 h-5 rounded-full bg-gradient-to-br from-blue-200/60 to-purple-200/60 flex items-center justify-center text-[10px] text-blue-500 border border-blue-100/40">✧</span>
											<span>{perk}</span>
										</li>
									))}
								</ul>

								<button type="button" class={`w-full py-3 rounded-full font-bold text-sm shadow-lg transition-all duration-300 hover:scale-105 relative overflow-hidden ${tier.highlighted ? 'bg-gradient-to-r from-blue-300 via-purple-300 to-pink-300 text-white shadow-[0_6px_24px_rgba(130,168,220,0.4)] hover:shadow-[0_10px_36px_rgba(130,168,220,0.5)]' : 'bg-gradient-to-b from-white via-slate-50 to-slate-200 text-purple-500 border border-white/70 shadow-[0_4px_16px_rgba(168,130,220,0.12)] hover:shadow-[0_6px_24px_rgba(219,130,220,0.2)]'}`}>
									<span class="absolute inset-0 bg-gradient-to-t from-transparent to-white/20 rounded-full pointer-events-none"></span>
									<span class="relative">{t.donate.give} ${tier.amount}</span>
								</button>
							</div>

							<div class={`h-0.5 ${tier.highlighted ? 'bg-gradient-to-r from-pink-400 via-purple-400 to-blue-400' : 'bg-gradient-to-r from-pink-300/40 via-purple-300/40 to-blue-300/40'}`}></div>
						</div>
					</div>
				))}
			</div>
		</section>
	</main>
</div>
