---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-blue-100 via-purple-50 to-pink-100">
	<!-- Nav -->
	<nav class="sticky top-0 z-50 bg-gradient-to-r from-slate-200/80 via-white/80 to-slate-300/80 backdrop-blur-md border-b border-white/60 shadow-lg shadow-purple-200/30">
		<div class="max-w-6xl mx-auto px-4 py-3 flex flex-wrap items-center justify-center gap-2">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 rounded-full bg-gradient-to-b from-white via-slate-100 to-slate-200 text-slate-600 text-sm font-medium shadow-md shadow-purple-200/40 hover:shadow-lg hover:shadow-pink-300/40 hover:from-pink-100 hover:to-purple-100 transition-all duration-300 border border-white/80">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="max-w-6xl mx-auto px-4 py-8">
		<!-- Header -->
		<div class="text-center mb-12">
			<p class="text-purple-300 text-lg tracking-widest mb-2">✦ ✧ ⋆ ✧ ✦</p>
			<h1 class="text-4xl md:text-6xl font-bold bg-gradient-to-r from-pink-400 via-purple-400 to-blue-400 bg-clip-text text-transparent mb-4">{t.donate.title}</h1>
			<p class="text-slate-400 text-lg max-w-xl mx-auto">{t.donate.subtitle}</p>
		</div>

		<!-- Monthly Tiers -->
		<section class="mb-16">
			<div class="text-center mb-8">
				<span class="text-pink-300 tracking-widest text-sm">⋆ ✧ ⋆</span>
				<h2 class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent mt-2">{t.donate.monthly}</h2>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				{monthlyTiers.map((tier: any) => (
					<div class={`relative rounded-3xl border shadow-lg overflow-hidden transition-all duration-300 hover:scale-[1.03] ${tier.highlighted ? 'bg-gradient-to-br from-pink-200 via-purple-100 to-blue-200 border-purple-300/60 shadow-2xl shadow-purple-300/40 ring-2 ring-purple-300/30' : 'bg-gradient-to-br from-slate-200 via-white to-slate-300 border-white/80 shadow-purple-200/20 hover:shadow-xl hover:shadow-pink-300/30'}`}>
						{tier.highlighted && (
							<div class="bg-gradient-to-r from-pink-300 via-purple-300 to-blue-300 text-white text-center py-2 text-sm font-bold tracking-wide">✦ {t.donate.mostPopular} ✦</div>
						)}
						<div class="relative p-6 md:p-8">
							<div class="absolute inset-0 bg-gradient-to-t from-transparent to-white/30 pointer-events-none rounded-b-3xl"></div>
							<div class="relative">
								<h3 class="text-xl font-bold text-slate-600 mb-3">{tier.name}</h3>
								<p class="mb-4">
									<span class="text-4xl font-bold bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">${tier.amount}</span>
									<span class="text-slate-400 text-sm ml-1">{t.donate.perMonth}</span>
								</p>
								<p class="text-slate-500 text-sm mb-6 leading-relaxed">{tier.description}</p>
								<ul class="space-y-2 mb-8">
									{tier.perks.map((perk: string) => (
										<li class="flex items-start gap-2 text-sm text-slate-500">
											<span class="text-pink-400 mt-0.5 shrink-0">✧</span>
											{perk}
										</li>
									))}
								</ul>
								<button type="button" class={`w-full py-3 rounded-full font-semibold text-sm shadow-lg transition-all duration-300 hover:scale-105 ${tier.highlighted ? 'bg-gradient-to-r from-pink-300 via-purple-300 to-blue-300 text-white shadow-purple-300/50 hover:shadow-xl hover:shadow-pink-300/50' : 'bg-gradient-to-b from-white via-slate-100 to-slate-200 text-purple-500 border border-white/80 shadow-slate-300/40 hover:shadow-lg hover:shadow-purple-200/40'}`}>{t.donate.choose} {tier.name}</button>
							</div>
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- One-Time Tiers -->
		<section class="mb-12">
			<div class="text-center mb-8">
				<span class="text-blue-300 tracking-widest text-sm">✦ ⋆ ✦</span>
				<h2 class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent mt-2">{t.donate.oneTime}</h2>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				{oneTimeTiers.map((tier: any) => (
					<div class={`relative rounded-3xl border shadow-lg overflow-hidden transition-all duration-300 hover:scale-[1.03] ${tier.highlighted ? 'bg-gradient-to-br from-blue-200 via-purple-100 to-pink-200 border-blue-300/60 shadow-2xl shadow-blue-300/40 ring-2 ring-blue-300/30' : 'bg-gradient-to-br from-slate-200 via-white to-slate-300 border-white/80 shadow-purple-200/20 hover:shadow-xl hover:shadow-pink-300/30'}`}>
						{tier.highlighted && (
							<div class="bg-gradient-to-r from-blue-300 via-purple-300 to-pink-300 text-white text-center py-2 text-sm font-bold tracking-wide">✦ {t.donate.greatestImpact} ✦</div>
						)}
						<div class="relative p-6 md:p-8">
							<div class="absolute inset-0 bg-gradient-to-t from-transparent to-white/30 pointer-events-none rounded-b-3xl"></div>
							<div class="relative">
								<h3 class="text-xl font-bold text-slate-600 mb-3">{tier.name}</h3>
								<p class="mb-4">
									<span class="text-4xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">${tier.amount}</span>
								</p>
								<p class="text-slate-500 text-sm mb-6 leading-relaxed">{tier.description}</p>
								<ul class="space-y-2 mb-8">
									{tier.perks.map((perk: string) => (
										<li class="flex items-start gap-2 text-sm text-slate-500">
											<span class="text-blue-400 mt-0.5 shrink-0">✧</span>
											{perk}
										</li>
									))}
								</ul>
								<button type="button" class={`w-full py-3 rounded-full font-semibold text-sm shadow-lg transition-all duration-300 hover:scale-105 ${tier.highlighted ? 'bg-gradient-to-r from-blue-300 via-purple-300 to-pink-300 text-white shadow-blue-300/50 hover:shadow-xl hover:shadow-purple-300/50' : 'bg-gradient-to-b from-white via-slate-100 to-slate-200 text-purple-500 border border-white/80 shadow-slate-300/40 hover:shadow-lg hover:shadow-purple-200/40'}`}>{t.donate.give} ${tier.amount}</button>
							</div>
						</div>
					</div>
				))}
			</div>
		</section>
	</main>
</div>
