---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-blue-100 via-purple-50 to-pink-100">
	<!-- Nav -->
	<nav class="sticky top-0 z-50 bg-gradient-to-r from-slate-200/80 via-white/80 to-slate-300/80 backdrop-blur-md border-b border-white/60 shadow-lg shadow-purple-200/30">
		<div class="max-w-6xl mx-auto px-4 py-3 flex flex-wrap items-center justify-center gap-2">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 rounded-full bg-gradient-to-b from-white via-slate-100 to-slate-200 text-slate-600 text-sm font-medium shadow-md shadow-purple-200/40 hover:shadow-lg hover:shadow-pink-300/40 hover:from-pink-100 hover:to-purple-100 transition-all duration-300 border border-white/80">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="max-w-3xl mx-auto px-4 py-8">
		<!-- Back Link -->
		<a href={`/${lang}/${style}/blog`} class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-gradient-to-b from-white via-slate-100 to-slate-200 text-purple-400 text-sm font-medium shadow-md shadow-purple-200/30 border border-white/80 hover:shadow-lg hover:shadow-pink-200/40 transition-all duration-300 mb-8">&larr; {t.blog.backToBlog}</a>

		<!-- Article -->
		<article class="rounded-3xl bg-gradient-to-br from-slate-200 via-white to-slate-300 border border-white/80 shadow-2xl shadow-purple-300/30 overflow-hidden mb-12">
			<div class="relative p-8 md:p-12">
				<div class="absolute top-0 left-0 right-0 h-1/4 bg-gradient-to-b from-white/50 to-transparent rounded-t-3xl pointer-events-none"></div>
				<header class="relative text-center mb-10">
					<time datetime={post.date} class="text-xs font-semibold text-purple-300 uppercase tracking-wider">{post.date}</time>
					<h1 class="text-3xl md:text-4xl font-bold bg-gradient-to-r from-purple-400 via-pink-400 to-blue-400 bg-clip-text text-transparent mt-3 mb-4">{post.title}</h1>
					<span class="text-pink-400 font-medium">{t.blog.by} {post.author} ✦</span>
					<div class="flex flex-wrap justify-center gap-2 mt-4">
						{post.tags.map((tag: string) => (
							<span class="px-4 py-1 rounded-full text-xs bg-gradient-to-r from-blue-100 to-purple-100 text-purple-500 border border-purple-200/50 shadow-sm font-semibold">{tag}</span>
						))}
					</div>
				</header>

				<div class="relative space-y-6 max-w-2xl mx-auto">
					{post.content.map((paragraph: string) => (
						<p class="text-slate-500 text-lg leading-relaxed">{paragraph}</p>
					))}
				</div>
			</div>
		</article>

		<!-- More Stories -->
		<section>
			<div class="text-center mb-8">
				<span class="text-purple-300 tracking-widest text-sm">⋆ ✧ ⋆</span>
				<h2 class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent mt-2">{t.blog.moreStories}</h2>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
				{otherPosts.map((p: any) => (
					<a href={`/${lang}/${style}/blog/${p.slug}`} class="group block p-6 rounded-2xl bg-gradient-to-br from-slate-200 via-white to-slate-300 border border-white/80 shadow-lg shadow-purple-200/20 hover:shadow-xl hover:shadow-pink-300/30 transition-all duration-300 hover:scale-[1.03]">
						<h3 class="text-lg font-bold bg-gradient-to-r from-purple-500 to-pink-500 bg-clip-text text-transparent mb-2">{p.title}</h3>
						<p class="text-slate-400 text-sm leading-relaxed">{p.excerpt}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
