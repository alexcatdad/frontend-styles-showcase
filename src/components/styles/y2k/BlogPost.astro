---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-gradient-to-b from-purple-50 via-blue-50 to-pink-50 overflow-hidden">
	<!-- Floating sparkles -->
	<div class="fixed inset-0 pointer-events-none z-0 select-none" aria-hidden="true">
		<span class="absolute top-[8%] left-[4%] text-pink-200/40 text-lg animate-pulse">✧</span>
		<span class="absolute top-[30%] right-[6%] text-purple-200/40 text-sm animate-pulse" style="animation-delay: 0.8s">✦</span>
		<span class="absolute top-[60%] left-[7%] text-blue-200/30 text-xl animate-pulse" style="animation-delay: 1.5s">⋆</span>
	</div>

	<!-- Floating Chrome Bubble Nav -->
	<nav class="sticky top-4 z-50 mx-auto max-w-fit px-2">
		<div class="flex flex-wrap items-center justify-center gap-1.5 px-3 py-2.5 rounded-full bg-gradient-to-b from-white/90 via-slate-100/85 to-slate-200/80 backdrop-blur-xl border border-white/70 shadow-[0_8px_32px_rgba(168,130,220,0.25),inset_0_1px_0_rgba(255,255,255,0.8)]">
			{nav.map((item: any) => (
				<a href={item.href} class="px-4 py-1.5 rounded-full text-xs font-semibold tracking-wide text-slate-500 bg-gradient-to-b from-white/80 to-slate-100/60 border border-white/50 shadow-sm hover:shadow-md hover:shadow-pink-200/40 hover:from-pink-50 hover:to-purple-50 hover:text-purple-500 transition-all duration-300 hover:scale-105">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="relative z-10 max-w-3xl mx-auto px-4 pt-8 pb-12">
		<!-- Back pill -->
		<a href={`${_base}/${lang}/${style}/blog`} class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-gradient-to-b from-white/90 to-slate-100/80 text-purple-400 text-sm font-semibold border border-white/60 shadow-[0_4px_16px_rgba(168,130,220,0.12)] hover:shadow-[0_6px_24px_rgba(219,130,220,0.2)] hover:scale-105 transition-all duration-300 mb-10">&larr; {t.blog.backToBlog}</a>

		<!-- Article Chrome Card -->
		<article class="relative rounded-[2.5rem] bg-gradient-to-br from-slate-100 via-white to-slate-200 border-2 border-white/80 shadow-[0_16px_64px_rgba(168,130,220,0.18),0_4px_20px_rgba(200,160,240,0.1)] overflow-hidden mb-14">
			<!-- Top iridescent band -->
			<div class="h-2 bg-gradient-to-r from-pink-300 via-purple-300 via-blue-300 to-pink-300"></div>
			<!-- Glossy overlay -->
			<div class="absolute top-2 left-0 right-0 h-1/4 bg-gradient-to-b from-white/50 to-transparent pointer-events-none"></div>

			<div class="relative p-8 md:p-14">
				<!-- Header area -->
				<header class="text-center mb-12">
					<!-- Date bubble -->
					<time datetime={post.date} class="inline-block px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-gradient-to-r from-purple-100/70 to-pink-100/70 text-purple-400 border border-purple-100/40 mb-4">{post.date}</time>

					<h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold bg-gradient-to-r from-purple-400 via-pink-400 to-blue-400 bg-clip-text text-transparent leading-tight mb-5">{post.title}</h1>

					<!-- Author chrome pill -->
					<div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-gradient-to-b from-white/80 to-slate-100/60 border border-white/60 shadow-sm">
						<span class="text-sm text-pink-400 font-semibold">{t.blog.by} {post.author} ✦</span>
					</div>

					<!-- Tags -->
					<div class="flex flex-wrap justify-center gap-2 mt-5">
						{post.tags.map((tag: string) => (
							<span class="px-4 py-1 rounded-full text-[10px] font-bold bg-gradient-to-r from-blue-100/60 via-purple-100/60 to-pink-100/60 text-purple-500 border border-purple-100/40 uppercase tracking-wider">⋆ {tag}</span>
						))}
					</div>

					<img src={post.image} alt={post.title} class="w-full max-w-2xl mx-auto mt-8 rounded-2xl object-cover shadow-[0_6px_24px_rgba(168,130,220,0.15)] border border-white/50" />
				</header>

				<!-- Content - paragraphs as frosted bubbles -->
				<div class="space-y-5 max-w-2xl mx-auto">
					{post.content.map((paragraph: string) => (
						<div class="relative p-5 md:p-6 rounded-2xl bg-gradient-to-br from-white/50 via-purple-50/20 to-pink-50/20 border border-white/50">
							<p class="text-slate-500 text-base md:text-lg leading-relaxed">{paragraph}</p>
						</div>
					))}
				</div>
			</div>

			<!-- Bottom iridescent band -->
			<div class="h-1 bg-gradient-to-r from-blue-300 via-pink-300 to-purple-300"></div>
		</article>

		<!-- More Stories -->
		<section>
			<div class="text-center mb-8">
				<span class="inline-block px-4 py-1 rounded-full bg-gradient-to-r from-purple-100/80 to-pink-100/80 text-purple-400 text-xs font-bold tracking-widest uppercase border border-purple-200/30">⋆ {t.blog.moreStories} ⋆</span>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
				{otherPosts.map((p: any) => (
					<a href={`${_base}/${lang}/${style}/blog/${p.slug}`} class="group block relative rounded-2xl bg-gradient-to-br from-slate-100 via-white to-slate-200 border border-white/70 shadow-[0_4px_16px_rgba(168,130,220,0.12)] hover:shadow-[0_10px_40px_rgba(219,130,220,0.25)] transition-all duration-400 hover:scale-[1.04] hover:-translate-y-1 overflow-hidden">
						<div class="absolute inset-0 bg-gradient-to-t from-transparent to-white/30 rounded-2xl pointer-events-none"></div>
						<div class="relative p-5 md:p-6">
							<h3 class="text-lg font-extrabold bg-gradient-to-r from-purple-500 to-pink-500 bg-clip-text text-transparent mb-2 leading-tight">{p.title}</h3>
							<p class="text-slate-400 text-sm leading-relaxed">{p.excerpt}</p>
						</div>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
