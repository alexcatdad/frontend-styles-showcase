---
const { lang, style, nav, cat, otherCats, t } = Astro.props;

const detailColors = [
	{
		bg: "from-pink-50/60 to-purple-50/40",
		label: "text-pink-400",
		border: "border-pink-100/50",
	},
	{
		bg: "from-purple-50/60 to-blue-50/40",
		label: "text-purple-400",
		border: "border-purple-100/50",
	},
	{
		bg: "from-blue-50/60 to-pink-50/40",
		label: "text-blue-400",
		border: "border-blue-100/50",
	},
];

const catDetails = [
	{ key: t.cats.breed, value: cat.breed },
	{ key: t.cats.age, value: cat.age },
	{ key: t.cats.gender, value: cat.gender },
	{ key: t.cats.color, value: cat.color },
	{ key: t.cats.arrived, value: cat.arrivalDate },
	{ key: t.cats.status, value: cat.status },
];
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-gradient-to-b from-blue-50 via-purple-50 to-pink-50 overflow-hidden">
	<!-- Floating sparkles -->
	<div class="fixed inset-0 pointer-events-none z-0 select-none" aria-hidden="true">
		<span class="absolute top-[10%] left-[6%] text-pink-200/50 text-xl animate-pulse">✦</span>
		<span class="absolute top-[20%] right-[8%] text-purple-200/40 text-sm animate-pulse" style="animation-delay: 0.6s">✧</span>
		<span class="absolute top-[50%] left-[3%] text-blue-200/40 text-lg animate-pulse" style="animation-delay: 1.3s">⋆</span>
		<span class="absolute top-[75%] right-[5%] text-pink-200/50 text-lg animate-pulse" style="animation-delay: 0.9s">✦</span>
	</div>

	<!-- Floating Chrome Bubble Nav -->
	<nav class="sticky top-4 z-50 mx-auto max-w-fit px-2">
		<div class="flex flex-wrap items-center justify-center gap-1.5 px-3 py-2.5 rounded-full bg-gradient-to-b from-white/90 via-slate-100/85 to-slate-200/80 backdrop-blur-xl border border-white/70 shadow-[0_8px_32px_rgba(168,130,220,0.25),inset_0_1px_0_rgba(255,255,255,0.8)]">
			{nav.map((item: any) => (
				<a href={item.href} class="px-4 py-1.5 rounded-full text-xs font-semibold tracking-wide text-slate-500 bg-gradient-to-b from-white/80 to-slate-100/60 border border-white/50 shadow-sm hover:shadow-md hover:shadow-pink-200/40 hover:from-pink-50 hover:to-purple-50 hover:text-purple-500 transition-all duration-300 hover:scale-105">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="relative z-10 max-w-4xl mx-auto px-4 pt-8 pb-12">
		<!-- Back pill -->
		<a href={`${_base}/${lang}/${style}/cats`} class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-gradient-to-b from-white/90 to-slate-100/80 text-purple-400 text-sm font-semibold border border-white/60 shadow-[0_4px_16px_rgba(168,130,220,0.12)] hover:shadow-[0_6px_24px_rgba(219,130,220,0.2)] hover:scale-105 transition-all duration-300 mb-10">&larr; {t.cats.backToAll}</a>

		<!-- Profile Trading Card -->
		<article class="relative rounded-[2.5rem] bg-gradient-to-br from-slate-100 via-white to-slate-200 border-2 border-white/80 shadow-[0_16px_64px_rgba(168,130,220,0.2),0_4px_20px_rgba(200,160,240,0.12)] overflow-hidden mb-14">
			<!-- Top iridescent band -->
			<div class="h-2 bg-gradient-to-r from-pink-300 via-purple-300 via-blue-300 to-pink-300"></div>
			<!-- Glossy top shine -->
			<div class="absolute top-2 left-0 right-0 h-1/3 bg-gradient-to-b from-white/60 to-transparent rounded-t-[2.5rem] pointer-events-none"></div>

			<div class="relative p-8 md:p-14">
				<!-- Name orb area -->
				<div class="text-center mb-10">
					<div class="inline-flex flex-col items-center">
						<span class="text-purple-300/60 text-sm tracking-[0.5em] mb-3">✦ &middot; ✧ &middot; ⋆ &middot; ✧ &middot; ✦</span>
						<h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold bg-gradient-to-r from-purple-400 via-pink-400 to-blue-400 bg-clip-text text-transparent leading-tight">{cat.name}</h1>
					</div>
				</div>

				<!-- Cat photo -->
				<div class="flex justify-center mb-10">
					<img src={cat.image} alt={cat.name} class="w-64 h-64 md:w-80 md:h-80 rounded-[2rem] object-cover border-2 border-white/70 shadow-[0_8px_32px_rgba(168,130,220,0.25)]" />
				</div>

				<!-- Detail bubbles - arranged in floating orbs -->
				<div class="flex flex-wrap justify-center gap-3 md:gap-4 mb-10">
					{catDetails.map((detail: any, i: number) => (
						<div class={`flex flex-col items-center justify-center w-28 h-28 md:w-32 md:h-32 rounded-full bg-gradient-to-br ${detailColors[i % 3].bg} border ${detailColors[i % 3].border} shadow-[0_4px_16px_rgba(168,130,220,0.1)] hover:shadow-[0_8px_28px_rgba(219,130,220,0.2)] hover:scale-110 transition-all duration-400`}>
							<dt class={`text-[9px] md:text-[10px] font-bold uppercase tracking-wider ${detailColors[i % 3].label} mb-1`}>{detail.key}</dt>
							<dd class="text-slate-600 font-semibold text-sm md:text-base text-center px-2 leading-tight">{detail.value}</dd>
						</div>
					))}
				</div>

				<!-- Personality chrome pills -->
				<div class="flex flex-wrap justify-center gap-2.5 mb-10">
					{cat.personality.map((trait: string) => (
						<span class="px-5 py-2 rounded-full bg-gradient-to-r from-pink-100/70 via-purple-100/70 to-blue-100/70 text-purple-600 text-sm font-bold border border-purple-200/40 shadow-[0_3px_12px_rgba(168,130,220,0.12)]">✧ {trait}</span>
					))}
				</div>

				<!-- Description in frosted bubble -->
				<div class="relative max-w-2xl mx-auto p-6 md:p-8 rounded-[2rem] bg-gradient-to-br from-white/60 via-purple-50/30 to-pink-50/30 border border-white/60 shadow-inner mb-10">
					<p class="text-slate-500 text-base md:text-lg leading-relaxed text-center font-light">{cat.description}</p>
				</div>

				<!-- Adopt CTA - chrome button -->
				<div class="text-center">
					<a href={`${_base}/${lang}/${style}/auth`} class="group relative inline-block px-12 py-4 rounded-full bg-gradient-to-r from-pink-300 via-purple-300 to-blue-300 text-white font-extrabold text-lg shadow-[0_8px_32px_rgba(219,130,220,0.4)] hover:shadow-[0_12px_48px_rgba(219,130,220,0.55)] hover:scale-105 transition-all duration-300 overflow-hidden">
						<span class="absolute inset-0 bg-gradient-to-t from-transparent to-white/25 rounded-full pointer-events-none"></span>
						<span class="relative">✦ {t.cats.adopt} {cat.name} ✦</span>
					</a>
				</div>
			</div>

			<!-- Bottom iridescent band -->
			<div class="h-1.5 bg-gradient-to-r from-blue-300 via-pink-300 to-purple-300"></div>
		</article>

		<!-- Other Cats -->
		<section>
			<div class="text-center mb-8">
				<span class="inline-block px-4 py-1 rounded-full bg-gradient-to-r from-purple-100/80 to-pink-100/80 text-purple-400 text-xs font-bold tracking-widest uppercase border border-purple-200/30">⋆ {t.cats.otherCats} ⋆</span>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
				{otherCats.map((c: any) => (
					<a href={`${_base}/${lang}/${style}/cats/${c.id}`} class="group block relative rounded-2xl bg-gradient-to-br from-slate-100 via-white to-slate-200 border border-white/70 shadow-[0_4px_16px_rgba(168,130,220,0.12)] hover:shadow-[0_10px_40px_rgba(219,130,220,0.25)] transition-all duration-400 hover:scale-[1.05] hover:-translate-y-1 overflow-hidden text-center p-5">
						<div class="absolute inset-0 bg-gradient-to-t from-transparent to-white/40 rounded-2xl pointer-events-none"></div>
						<h3 class="relative text-lg font-extrabold bg-gradient-to-r from-purple-500 to-pink-500 bg-clip-text text-transparent mb-1">{c.name}</h3>
						<p class="relative text-slate-400 text-sm">{c.breed} &middot; {c.age}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
