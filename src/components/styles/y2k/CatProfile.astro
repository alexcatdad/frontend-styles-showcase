---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-blue-100 via-purple-50 to-pink-100">
	<!-- Nav -->
	<nav class="sticky top-0 z-50 bg-gradient-to-r from-slate-200/80 via-white/80 to-slate-300/80 backdrop-blur-md border-b border-white/60 shadow-lg shadow-purple-200/30">
		<div class="max-w-6xl mx-auto px-4 py-3 flex flex-wrap items-center justify-center gap-2">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 rounded-full bg-gradient-to-b from-white via-slate-100 to-slate-200 text-slate-600 text-sm font-medium shadow-md shadow-purple-200/40 hover:shadow-lg hover:shadow-pink-300/40 hover:from-pink-100 hover:to-purple-100 transition-all duration-300 border border-white/80">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="max-w-4xl mx-auto px-4 py-8">
		<!-- Back Link -->
		<a href={`/${lang}/${style}/cats`} class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-gradient-to-b from-white via-slate-100 to-slate-200 text-purple-400 text-sm font-medium shadow-md shadow-purple-200/30 border border-white/80 hover:shadow-lg hover:shadow-pink-200/40 transition-all duration-300 mb-8">&larr; {t.cats.backToAll}</a>

		<!-- Cat Profile Card -->
		<article class="rounded-3xl bg-gradient-to-br from-slate-200 via-white to-slate-300 border border-white/80 shadow-2xl shadow-purple-300/30 overflow-hidden mb-12">
			<div class="relative">
				<div class="absolute inset-0 bg-gradient-to-b from-white/40 to-transparent pointer-events-none"></div>
				<div class="relative p-8 md:p-12">
					<!-- Name and sparkles -->
					<div class="text-center mb-8">
						<p class="text-pink-300 tracking-widest text-sm mb-2">✦ ⋆ ✧ ⋆ ✦</p>
						<h1 class="text-4xl md:text-5xl font-bold bg-gradient-to-r from-purple-400 via-pink-400 to-blue-400 bg-clip-text text-transparent">{cat.name}</h1>
					</div>

					<!-- Details Grid -->
					<dl class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-8">
						<div class="p-4 rounded-2xl bg-gradient-to-br from-white/60 to-purple-50/40 border border-white/60 text-center">
							<dt class="text-xs font-semibold text-purple-300 uppercase tracking-wider mb-1">{t.cats.breed}</dt>
							<dd class="text-slate-600 font-medium">{cat.breed}</dd>
						</div>
						<div class="p-4 rounded-2xl bg-gradient-to-br from-white/60 to-pink-50/40 border border-white/60 text-center">
							<dt class="text-xs font-semibold text-pink-300 uppercase tracking-wider mb-1">{t.cats.age}</dt>
							<dd class="text-slate-600 font-medium">{cat.age}</dd>
						</div>
						<div class="p-4 rounded-2xl bg-gradient-to-br from-white/60 to-blue-50/40 border border-white/60 text-center">
							<dt class="text-xs font-semibold text-blue-300 uppercase tracking-wider mb-1">{t.cats.gender}</dt>
							<dd class="text-slate-600 font-medium">{cat.gender}</dd>
						</div>
						<div class="p-4 rounded-2xl bg-gradient-to-br from-white/60 to-purple-50/40 border border-white/60 text-center">
							<dt class="text-xs font-semibold text-purple-300 uppercase tracking-wider mb-1">{t.cats.color}</dt>
							<dd class="text-slate-600 font-medium">{cat.color}</dd>
						</div>
						<div class="p-4 rounded-2xl bg-gradient-to-br from-white/60 to-pink-50/40 border border-white/60 text-center">
							<dt class="text-xs font-semibold text-pink-300 uppercase tracking-wider mb-1">{t.cats.arrived}</dt>
							<dd class="text-slate-600 font-medium">{cat.arrivalDate}</dd>
						</div>
						<div class="p-4 rounded-2xl bg-gradient-to-br from-white/60 to-blue-50/40 border border-white/60 text-center">
							<dt class="text-xs font-semibold text-blue-300 uppercase tracking-wider mb-1">{t.cats.status}</dt>
							<dd class="text-slate-600 font-medium">{cat.status}</dd>
						</div>
					</dl>

					<!-- Personality Tags -->
					<div class="flex flex-wrap justify-center gap-3 mb-8">
						{cat.personality.map((trait: string) => (
							<span class="px-5 py-2 rounded-full bg-gradient-to-r from-pink-200 via-purple-200 to-blue-200 text-purple-600 text-sm font-semibold shadow-md shadow-purple-200/30 border border-white/60">✧ {trait}</span>
						))}
					</div>

					<!-- Description -->
					<p class="text-slate-500 text-lg leading-relaxed text-center max-w-2xl mx-auto mb-8">{cat.description}</p>

					<!-- Adopt CTA -->
					<div class="text-center">
						<a href={`/${lang}/${style}/auth`} class="inline-block px-10 py-4 rounded-full bg-gradient-to-r from-pink-300 via-purple-300 to-blue-300 text-white font-bold text-lg shadow-xl shadow-pink-300/50 hover:shadow-2xl hover:shadow-purple-300/60 hover:scale-105 transition-all duration-300">✦ {t.cats.adopt} {cat.name} ✦</a>
					</div>
				</div>
			</div>
		</article>

		<!-- Other Cats -->
		<section>
			<div class="text-center mb-8">
				<span class="text-purple-300 tracking-widest text-sm">⋆ ✧ ⋆</span>
				<h2 class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent mt-2">{t.cats.otherCats}</h2>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
				{otherCats.map((c: any) => (
					<a href={`/${lang}/${style}/cats/${c.id}`} class="group block p-6 rounded-2xl bg-gradient-to-br from-slate-200 via-white to-slate-300 border border-white/80 shadow-lg shadow-purple-200/20 hover:shadow-xl hover:shadow-pink-300/30 transition-all duration-300 hover:scale-[1.03] text-center">
						<h3 class="text-lg font-bold bg-gradient-to-r from-purple-500 to-pink-500 bg-clip-text text-transparent mb-1">{c.name}</h3>
						<p class="text-slate-400 text-sm">{c.breed} · {c.age}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
