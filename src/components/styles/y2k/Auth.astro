---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-blue-100 via-purple-50 to-pink-100">
	<!-- Nav -->
	<nav class="sticky top-0 z-50 bg-gradient-to-r from-slate-200/80 via-white/80 to-slate-300/80 backdrop-blur-md border-b border-white/60 shadow-lg shadow-purple-200/30">
		<div class="max-w-6xl mx-auto px-4 py-3 flex flex-wrap items-center justify-center gap-2">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 rounded-full bg-gradient-to-b from-white via-slate-100 to-slate-200 text-slate-600 text-sm font-medium shadow-md shadow-purple-200/40 hover:shadow-lg hover:shadow-pink-300/40 hover:from-pink-100 hover:to-purple-100 transition-all duration-300 border border-white/80">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="max-w-md mx-auto px-4 py-12 md:py-20">
		<section class="rounded-3xl bg-gradient-to-br from-slate-200 via-white to-slate-300 border border-white/80 shadow-2xl shadow-purple-300/30 overflow-hidden">
			<div class="relative p-8 md:p-10">
				<div class="absolute inset-0 bg-gradient-to-b from-white/40 to-transparent pointer-events-none rounded-3xl"></div>
				<div class="relative">
					<!-- Header -->
					<div class="text-center mb-8">
						<p class="text-pink-300 tracking-widest text-sm mb-2">✦ ⋆ ✧ ⋆ ✦</p>
						<h1 class="text-3xl font-bold bg-gradient-to-r from-purple-400 via-pink-400 to-blue-400 bg-clip-text text-transparent mb-2">{t.auth.title}</h1>
						<p class="text-slate-400 text-sm">{t.auth.subtitle}</p>
					</div>

					<!-- Form -->
					<form class="space-y-5">
						<div>
							<label for="email" class="block text-sm font-semibold text-slate-500 mb-2">{t.auth.email}</label>
							<input type="email" id="email" name="email" placeholder="you@example.com" class="w-full px-5 py-3 rounded-full bg-gradient-to-b from-white to-slate-50 border border-slate-200/80 text-slate-600 placeholder-slate-300 shadow-inner shadow-slate-200/50 focus:outline-none focus:ring-2 focus:ring-purple-300/50 focus:border-purple-300 transition-all duration-300" />
						</div>
						<div>
							<label for="password" class="block text-sm font-semibold text-slate-500 mb-2">{t.auth.password}</label>
							<input type="password" id="password" name="password" placeholder="••••••••" class="w-full px-5 py-3 rounded-full bg-gradient-to-b from-white to-slate-50 border border-slate-200/80 text-slate-600 placeholder-slate-300 shadow-inner shadow-slate-200/50 focus:outline-none focus:ring-2 focus:ring-purple-300/50 focus:border-purple-300 transition-all duration-300" />
						</div>
						<div class="flex items-center justify-between">
							<label class="flex items-center gap-2 text-sm text-slate-400 cursor-pointer">
								<input type="checkbox" name="remember" class="w-4 h-4 rounded-md border-slate-300 text-purple-400 focus:ring-purple-300/50" />
								{t.auth.rememberMe}
							</label>
							<a href="#" class="text-sm text-purple-400 hover:text-pink-400 transition-colors duration-300">{t.auth.forgotPassword}</a>
						</div>
						<button type="submit" class="w-full py-3 rounded-full bg-gradient-to-r from-pink-300 via-purple-300 to-blue-300 text-white font-bold shadow-lg shadow-pink-300/50 hover:shadow-xl hover:shadow-purple-300/60 hover:scale-[1.02] transition-all duration-300 text-lg">✦ {t.auth.signIn}</button>
					</form>

					<!-- Divider -->
					<div class="relative my-8">
						<div class="absolute inset-0 flex items-center">
							<div class="w-full border-t border-slate-200/60"></div>
						</div>
						<div class="relative flex justify-center">
							<span class="bg-gradient-to-r from-slate-200 via-white to-slate-200 px-4 text-sm text-slate-400">{t.auth.continueWith}</span>
						</div>
					</div>

					<!-- Social Buttons -->
					<div class="grid grid-cols-2 gap-3">
						<button type="button" class="flex items-center justify-center gap-2 py-3 rounded-full bg-gradient-to-b from-white via-slate-100 to-slate-200 text-slate-600 font-semibold text-sm shadow-md shadow-purple-200/30 border border-white/80 hover:shadow-lg hover:shadow-pink-200/40 hover:scale-[1.02] transition-all duration-300">Google</button>
						<button type="button" class="flex items-center justify-center gap-2 py-3 rounded-full bg-gradient-to-b from-white via-slate-100 to-slate-200 text-slate-600 font-semibold text-sm shadow-md shadow-purple-200/30 border border-white/80 hover:shadow-lg hover:shadow-pink-200/40 hover:scale-[1.02] transition-all duration-300">Apple</button>
					</div>

					<!-- Sign up link -->
					<p class="text-center text-sm text-slate-400 mt-8">
						{t.auth.noAccount} <a href="#" class="font-semibold bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent hover:from-pink-400 hover:to-blue-400 transition-all duration-300">{t.auth.signUp}</a>
					</p>
				</div>
			</div>
		</section>
	</main>
</div>
