---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-pink-50 via-blue-50 to-purple-50 overflow-hidden">
	<!-- Floating sparkles -->
	<div class="fixed inset-0 pointer-events-none z-0 select-none" aria-hidden="true">
		<span class="absolute top-[15%] left-[10%] text-pink-200/50 text-lg animate-pulse">✦</span>
		<span class="absolute top-[25%] right-[8%] text-purple-200/40 text-sm animate-pulse" style="animation-delay: 0.7s">✧</span>
		<span class="absolute top-[60%] left-[5%] text-blue-200/40 text-xl animate-pulse" style="animation-delay: 1.3s">⋆</span>
		<span class="absolute top-[75%] right-[12%] text-pink-200/40 text-sm animate-pulse" style="animation-delay: 0.4s">✦</span>
	</div>

	<!-- Floating Chrome Bubble Nav -->
	<nav class="sticky top-4 z-50 mx-auto max-w-fit px-2">
		<div class="flex flex-wrap items-center justify-center gap-1.5 px-3 py-2.5 rounded-full bg-gradient-to-b from-white/90 via-slate-100/85 to-slate-200/80 backdrop-blur-xl border border-white/70 shadow-[0_8px_32px_rgba(168,130,220,0.25),inset_0_1px_0_rgba(255,255,255,0.8)]">
			{nav.map((item: any) => (
				<a href={item.href} class="px-4 py-1.5 rounded-full text-xs font-semibold tracking-wide text-slate-500 bg-gradient-to-b from-white/80 to-slate-100/60 border border-white/50 shadow-sm hover:shadow-md hover:shadow-pink-200/40 hover:from-pink-50 hover:to-purple-50 hover:text-purple-500 transition-all duration-300 hover:scale-105">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="relative z-10 flex items-center justify-center min-h-[calc(100vh-80px)] px-4 py-12">
		<!-- Background orb -->
		<div class="absolute inset-0 flex items-center justify-center pointer-events-none">
			<div class="w-[400px] h-[400px] md:w-[550px] md:h-[550px] rounded-full bg-gradient-to-br from-pink-200/25 via-purple-100/15 to-blue-200/25 blur-3xl"></div>
		</div>

		<!-- Auth Card - Chrome Orb -->
		<section class="relative w-full max-w-md">
			<div class="relative rounded-[2.5rem] bg-gradient-to-br from-slate-100 via-white to-slate-200 border-2 border-white/80 shadow-[0_16px_64px_rgba(168,130,220,0.22),0_4px_20px_rgba(200,160,240,0.12)] overflow-hidden">
				<!-- Top iridescent band -->
				<div class="h-1.5 bg-gradient-to-r from-pink-300 via-purple-300 via-blue-300 to-pink-300 rounded-t-[2.5rem]"></div>
				<!-- Glossy shine -->
				<div class="absolute top-1.5 left-0 right-0 h-1/3 bg-gradient-to-b from-white/60 to-transparent pointer-events-none"></div>

				<div class="relative p-8 md:p-10">
					<!-- Header -->
					<div class="text-center mb-8">
						<p class="text-purple-300/60 text-sm tracking-[0.4em] mb-3">✦ &middot; ✧ &middot; ✦</p>
						<h1 class="text-3xl md:text-4xl font-extrabold bg-gradient-to-r from-purple-400 via-pink-400 to-blue-400 bg-clip-text text-transparent mb-2">{t.auth.title}</h1>
						<p class="text-slate-400 text-sm font-light">{t.auth.subtitle}</p>
					</div>

					<!-- Form -->
					<form class="space-y-5">
						<div>
							<label for="email" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">{t.auth.email}</label>
							<div class="relative">
								<input type="email" id="email" name="email" placeholder="you@example.com" class="w-full px-5 py-3 rounded-full bg-gradient-to-b from-white/90 to-slate-50/80 border border-slate-200/60 text-slate-600 placeholder-slate-300 shadow-[inset_0_2px_6px_rgba(168,130,220,0.08)] focus:outline-none focus:ring-2 focus:ring-purple-300/40 focus:border-purple-300/60 transition-all duration-300 text-sm" />
							</div>
						</div>
						<div>
							<label for="password" class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">{t.auth.password}</label>
							<div class="relative">
								<input type="password" id="password" name="password" placeholder="••••••••" class="w-full px-5 py-3 rounded-full bg-gradient-to-b from-white/90 to-slate-50/80 border border-slate-200/60 text-slate-600 placeholder-slate-300 shadow-[inset_0_2px_6px_rgba(168,130,220,0.08)] focus:outline-none focus:ring-2 focus:ring-purple-300/40 focus:border-purple-300/60 transition-all duration-300 text-sm" />
							</div>
						</div>

						<!-- Remember / Forgot row -->
						<div class="flex items-center justify-between px-1">
							<label class="flex items-center gap-2 text-xs text-slate-400 cursor-pointer group">
								<span class="relative w-4 h-4 rounded-full bg-gradient-to-b from-white to-slate-100 border border-slate-200/60 shadow-sm flex items-center justify-center">
									<input type="checkbox" name="remember" class="absolute inset-0 opacity-0 cursor-pointer" />
								</span>
								{t.auth.rememberMe}
							</label>
							<a href="#" class="text-xs text-purple-400 hover:text-pink-400 transition-colors duration-300 font-medium">{t.auth.forgotPassword}</a>
						</div>

						<!-- Submit -->
						<button type="submit" class="group relative w-full py-3.5 rounded-full bg-gradient-to-r from-pink-300 via-purple-300 to-blue-300 text-white font-bold text-base shadow-[0_6px_24px_rgba(219,130,220,0.4)] hover:shadow-[0_10px_40px_rgba(219,130,220,0.55)] hover:scale-[1.02] transition-all duration-300 overflow-hidden">
							<span class="absolute inset-0 bg-gradient-to-t from-transparent to-white/25 rounded-full pointer-events-none"></span>
							<span class="relative">✦ {t.auth.signIn}</span>
						</button>
					</form>

					<!-- Divider -->
					<div class="relative my-8">
						<div class="absolute inset-0 flex items-center">
							<div class="w-full h-px bg-gradient-to-r from-transparent via-slate-200/80 to-transparent"></div>
						</div>
						<div class="relative flex justify-center">
							<span class="bg-gradient-to-r from-slate-100 via-white to-slate-100 px-4 text-xs text-slate-400 font-medium">{t.auth.continueWith}</span>
						</div>
					</div>

					<!-- Social buttons as chrome orbs -->
					<div class="grid grid-cols-2 gap-3">
						<button type="button" class="relative py-3 rounded-full bg-gradient-to-b from-white/90 via-slate-50/80 to-slate-200/70 text-slate-600 font-bold text-sm border border-white/60 shadow-[0_4px_16px_rgba(168,130,220,0.1)] hover:shadow-[0_6px_24px_rgba(219,130,220,0.2)] hover:scale-105 transition-all duration-300 overflow-hidden">
							<span class="absolute inset-0 bg-gradient-to-t from-transparent to-white/40 rounded-full pointer-events-none"></span>
							<span class="relative">Google</span>
						</button>
						<button type="button" class="relative py-3 rounded-full bg-gradient-to-b from-white/90 via-slate-50/80 to-slate-200/70 text-slate-600 font-bold text-sm border border-white/60 shadow-[0_4px_16px_rgba(168,130,220,0.1)] hover:shadow-[0_6px_24px_rgba(219,130,220,0.2)] hover:scale-105 transition-all duration-300 overflow-hidden">
							<span class="absolute inset-0 bg-gradient-to-t from-transparent to-white/40 rounded-full pointer-events-none"></span>
							<span class="relative">Apple</span>
						</button>
					</div>

					<!-- Sign up -->
					<p class="text-center text-xs text-slate-400 mt-8">
						{t.auth.noAccount}
						<a href="#" class="font-bold bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent hover:from-pink-400 hover:to-blue-400 transition-all duration-300 ml-1">{t.auth.signUp}</a>
					</p>
				</div>

				<!-- Bottom band -->
				<div class="h-1 bg-gradient-to-r from-blue-300 via-pink-300 to-purple-300"></div>
			</div>
		</section>
	</main>
</div>
