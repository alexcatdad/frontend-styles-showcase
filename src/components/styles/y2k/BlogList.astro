---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-blue-100 via-purple-50 to-pink-100">
	<!-- Nav -->
	<nav class="sticky top-0 z-50 bg-gradient-to-r from-slate-200/80 via-white/80 to-slate-300/80 backdrop-blur-md border-b border-white/60 shadow-lg shadow-purple-200/30">
		<div class="max-w-6xl mx-auto px-4 py-3 flex flex-wrap items-center justify-center gap-2">
			{nav.map((item: any) => (
				<a href={item.href} class="px-5 py-2 rounded-full bg-gradient-to-b from-white via-slate-100 to-slate-200 text-slate-600 text-sm font-medium shadow-md shadow-purple-200/40 hover:shadow-lg hover:shadow-pink-300/40 hover:from-pink-100 hover:to-purple-100 transition-all duration-300 border border-white/80">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="max-w-4xl mx-auto px-4 py-8">
		<!-- Header -->
		<div class="text-center mb-12">
			<p class="text-pink-300 text-lg tracking-widest mb-2">✧ ⋆ ✦ ⋆ ✧</p>
			<h1 class="text-4xl md:text-6xl font-bold bg-gradient-to-r from-pink-400 via-purple-400 to-blue-400 bg-clip-text text-transparent mb-4">{t.blog.title}</h1>
			<p class="text-slate-400 text-lg max-w-xl mx-auto">{t.blog.subtitle}</p>
		</div>

		<!-- Posts -->
		<div class="space-y-6">
			{posts.map((post: any) => (
				<a href={`/${lang}/${style}/blog/${post.slug}`} class="group block rounded-3xl bg-gradient-to-br from-slate-200 via-white to-slate-300 border border-white/80 shadow-lg shadow-purple-200/20 hover:shadow-2xl hover:shadow-pink-300/40 transition-all duration-300 hover:scale-[1.02] overflow-hidden">
					<article class="relative p-6 md:p-8">
						<div class="absolute top-0 left-0 right-0 h-1/3 bg-gradient-to-b from-white/50 to-transparent rounded-t-3xl pointer-events-none"></div>
						<div class="relative">
							<time datetime={post.date} class="text-xs font-semibold text-purple-300 uppercase tracking-wider">{post.date}</time>
							<h2 class="text-xl md:text-2xl font-bold bg-gradient-to-r from-purple-500 to-pink-500 bg-clip-text text-transparent mt-2 mb-3">{post.title}</h2>
							<p class="text-slate-500 leading-relaxed mb-4">{post.excerpt}</p>
							<div class="flex flex-wrap items-center gap-2 mb-3">
								{post.tags.map((tag: string) => (
									<span class="px-3 py-1 rounded-full text-xs bg-gradient-to-r from-blue-100 to-purple-100 text-purple-500 border border-purple-200/50 shadow-sm">{tag}</span>
								))}
							</div>
							<span class="text-sm text-pink-400 font-medium">{t.blog.by} {post.author} ✦</span>
						</div>
					</article>
				</a>
			))}
		</div>
	</main>
</div>
