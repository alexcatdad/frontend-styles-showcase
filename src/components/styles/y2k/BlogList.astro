---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-b from-pink-50 via-purple-50 to-blue-50 overflow-hidden">
	<!-- Floating sparkles -->
	<div class="fixed inset-0 pointer-events-none z-0 select-none" aria-hidden="true">
		<span class="absolute top-[10%] right-[9%] text-pink-200/50 text-lg animate-pulse">✦</span>
		<span class="absolute top-[35%] left-[5%] text-purple-200/40 text-sm animate-pulse" style="animation-delay: 0.9s">✧</span>
		<span class="absolute top-[65%] right-[4%] text-blue-200/40 text-xl animate-pulse" style="animation-delay: 1.4s">⋆</span>
	</div>

	<!-- Floating Chrome Bubble Nav -->
	<nav class="sticky top-4 z-50 mx-auto max-w-fit px-2">
		<div class="flex flex-wrap items-center justify-center gap-1.5 px-3 py-2.5 rounded-full bg-gradient-to-b from-white/90 via-slate-100/85 to-slate-200/80 backdrop-blur-xl border border-white/70 shadow-[0_8px_32px_rgba(168,130,220,0.25),inset_0_1px_0_rgba(255,255,255,0.8)]">
			{nav.map((item: any) => (
				<a href={item.href} class="px-4 py-1.5 rounded-full text-xs font-semibold tracking-wide text-slate-500 bg-gradient-to-b from-white/80 to-slate-100/60 border border-white/50 shadow-sm hover:shadow-md hover:shadow-pink-200/40 hover:from-pink-50 hover:to-purple-50 hover:text-purple-500 transition-all duration-300 hover:scale-105">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="relative z-10 max-w-4xl mx-auto px-4 pt-8 pb-12">
		<!-- Header -->
		<div class="text-center mb-14">
			<div class="inline-block relative">
				<span class="absolute -top-4 -left-8 text-pink-300/40 text-xs animate-pulse">✧</span>
				<span class="absolute -bottom-2 -right-6 text-blue-300/40 text-xs animate-pulse" style="animation-delay: 0.7s">✦</span>
				<h1 class="text-5xl md:text-7xl font-extrabold bg-gradient-to-r from-pink-400 via-purple-400 to-blue-400 bg-clip-text text-transparent">{t.blog.title}</h1>
			</div>
			<p class="text-slate-400 text-base md:text-lg mt-4 max-w-md mx-auto font-light">{t.blog.subtitle}</p>
		</div>

		<!-- Post Cards -->
		<div class="space-y-7">
			{posts.map((post: any, i: number) => (
				<a href={`/${lang}/${style}/blog/${post.slug}`} class="group block relative">
					<article class="relative rounded-[2rem] bg-gradient-to-br from-slate-100 via-white to-slate-200 border-2 border-white/80 shadow-[0_6px_28px_rgba(168,130,220,0.12)] group-hover:shadow-[0_14px_52px_rgba(219,130,220,0.25)] transition-all duration-500 group-hover:scale-[1.02] group-hover:-translate-y-1 overflow-hidden">
						<!-- Top iridescent accent -->
						<div class={`h-1 bg-gradient-to-r ${i % 2 === 0 ? 'from-pink-300 via-purple-300 to-blue-300' : 'from-blue-300 via-purple-300 to-pink-300'}`}></div>
						<!-- Glossy shine -->
						<div class="absolute top-1 left-0 right-0 h-1/3 bg-gradient-to-b from-white/50 to-transparent pointer-events-none"></div>

						<div class="relative p-6 md:p-8">
							<!-- Date pill -->
							<div class="mb-3">
								<time datetime={post.date} class="inline-block px-3 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-gradient-to-r from-purple-100/60 to-pink-100/60 text-purple-400 border border-purple-100/40">{post.date}</time>
							</div>

							<!-- Title -->
							<h2 class="text-xl md:text-2xl font-extrabold bg-gradient-to-r from-purple-500 via-pink-400 to-purple-500 bg-clip-text text-transparent mb-3 leading-tight">{post.title}</h2>

							<!-- Excerpt -->
							<p class="text-slate-400 text-sm md:text-base leading-relaxed mb-4">{post.excerpt}</p>

							<!-- Tags + Author row -->
							<div class="flex flex-wrap items-center gap-2">
								{post.tags.map((tag: string) => (
									<span class="px-3 py-0.5 rounded-full text-[10px] font-semibold bg-gradient-to-r from-blue-100/60 via-purple-100/60 to-pink-100/60 text-purple-500 border border-purple-100/40">⋆ {tag}</span>
								))}
								<span class="ml-auto text-sm text-pink-400/80 font-medium shrink-0">{t.blog.by} {post.author} ✦</span>
							</div>
						</div>
					</article>
				</a>
			))}
		</div>
	</main>
</div>
