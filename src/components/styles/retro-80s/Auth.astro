---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gray-950 text-white font-mono relative overflow-hidden">
	<!-- Perspective grid background -->
	<div class="fixed inset-0 z-0 pointer-events-none" aria-hidden="true">
		<div class="absolute inset-0 bg-[linear-gradient(rgba(255,0,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,0,255,0.03)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
		<div class="absolute bottom-0 left-0 right-0 h-[50vh] bg-[linear-gradient(rgba(0,255,255,0.07)_1px,transparent_1px),linear-gradient(90deg,rgba(0,255,255,0.07)_1px,transparent_1px)] bg-[size:40px_40px] [transform:perspective(400px)_rotateX(60deg)] origin-bottom"></div>
		<div class="absolute inset-0 bg-gradient-to-b from-gray-950 via-transparent to-gray-950"></div>
	</div>

	<!-- Scanline overlay -->
	<div class="fixed inset-0 z-[1] pointer-events-none bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,rgba(0,0,0,0.08)_2px,rgba(0,0,0,0.08)_4px)]" aria-hidden="true"></div>

	<!-- Nav -->
	<nav class="relative z-50 sticky top-0">
		<div class="mx-4 mt-3 rounded-lg border border-fuchsia-500/40 bg-gray-950/95 backdrop-blur-md shadow-[0_0_20px_#ff00ff33,inset_0_0_20px_#ff00ff11]">
			<div class="max-w-6xl mx-auto px-4 py-3 flex flex-wrap gap-1 items-center justify-center sm:justify-start">
				{nav.map((item: any) => (
					<a
						href={item.href}
						class="px-4 py-2 text-sm font-bold uppercase tracking-[0.2em] text-fuchsia-300 hover:text-white rounded transition-all duration-300 hover:bg-fuchsia-500/20 hover:shadow-[0_0_15px_#ff00ff55] relative after:absolute after:bottom-0 after:left-2 after:right-2 after:h-px after:bg-fuchsia-500 after:opacity-0 hover:after:opacity-100 after:shadow-[0_0_8px_#ff00ff] after:transition-opacity"
					>
						{item.label}
					</a>
				))}
			</div>
		</div>
	</nav>

	<main class="relative z-10 flex items-center justify-center px-4 py-16 sm:py-24">
		<section class="w-full max-w-md">
			<!-- Terminal login frame -->
			<div class="rounded-sm border border-fuchsia-500/40 bg-gray-900/60 overflow-hidden shadow-[0_0_40px_#ff00ff33,0_0_80px_#ff00ff11,inset_0_0_40px_#00000066] relative">
				<!-- Top glow bar -->
				<div class="h-1 bg-gradient-to-r from-fuchsia-500 via-cyan-400 to-fuchsia-500 shadow-[0_0_20px_#ff00ff] retro-pulse"></div>

				<!-- Terminal title bar -->
				<div class="flex items-center gap-3 px-6 py-3 border-b border-fuchsia-500/20 bg-gray-950/60">
					<div class="flex gap-1.5">
						<div class="w-2.5 h-2.5 rounded-full bg-fuchsia-500/60 shadow-[0_0_6px_#ff00ff]"></div>
						<div class="w-2.5 h-2.5 rounded-full bg-cyan-400/60 shadow-[0_0_6px_#00ffff]"></div>
						<div class="w-2.5 h-2.5 rounded-full bg-purple-400/60 shadow-[0_0_6px_#a855f7]"></div>
					</div>
					<span class="text-[10px] font-bold uppercase tracking-[0.3em] text-fuchsia-500/50">sys://auth_terminal</span>
				</div>

				<!-- Corner decorations -->
				<div class="absolute top-14 left-2 w-3 h-3 border-t border-l border-cyan-400/30"></div>
				<div class="absolute top-14 right-2 w-3 h-3 border-t border-r border-cyan-400/30"></div>
				<div class="absolute bottom-2 left-2 w-3 h-3 border-b border-l border-cyan-400/30"></div>
				<div class="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-cyan-400/30"></div>

				<div class="p-8">
					<!-- Header -->
					<div class="text-center mb-8">
						<h1 class="text-3xl sm:text-4xl font-black uppercase tracking-tight">
							<span class="bg-gradient-to-r from-fuchsia-400 via-cyan-300 to-fuchsia-400 bg-clip-text text-transparent drop-shadow-[0_0_20px_#ff00ff]">
								{t.auth.title}
							</span>
						</h1>
						<p class="mt-3 text-xs text-fuchsia-300/50 tracking-[0.2em] uppercase">{t.auth.subtitle}</p>
					</div>

					<!-- Form — terminal inputs -->
					<form class="space-y-5">
						<div>
							<label for="email" class="block text-[10px] font-black uppercase tracking-[0.25em] text-fuchsia-400 mb-2">
								{t.auth.email}
							</label>
							<input
								type="email"
								id="email"
								name="email"
								placeholder="you@example.com"
								class="w-full px-4 py-3 rounded-sm bg-gray-950/80 border border-fuchsia-500/25 text-cyan-200 placeholder-gray-600 focus:border-fuchsia-400 focus:shadow-[0_0_20px_#ff00ff44,inset_0_0_10px_#ff00ff11] focus:outline-none transition-all duration-300 font-mono text-sm"
							/>
						</div>
						<div>
							<label for="password" class="block text-[10px] font-black uppercase tracking-[0.25em] text-fuchsia-400 mb-2">
								{t.auth.password}
							</label>
							<input
								type="password"
								id="password"
								name="password"
								placeholder="••••••••"
								class="w-full px-4 py-3 rounded-sm bg-gray-950/80 border border-fuchsia-500/25 text-cyan-200 placeholder-gray-600 focus:border-fuchsia-400 focus:shadow-[0_0_20px_#ff00ff44,inset_0_0_10px_#ff00ff11] focus:outline-none transition-all duration-300 font-mono text-sm"
							/>
						</div>
						<div class="flex items-center justify-between">
							<label class="flex items-center gap-2 cursor-pointer group">
								<input
									type="checkbox"
									name="remember"
									class="w-4 h-4 rounded-sm border-fuchsia-500/50 bg-gray-950 accent-fuchsia-500"
								/>
								<span class="text-xs text-gray-400 group-hover:text-gray-300 transition-colors tracking-wide">{t.auth.rememberMe}</span>
							</label>
							<a href="#" class="text-xs text-cyan-400 hover:text-cyan-300 font-bold transition-all duration-300 tracking-wide hover:drop-shadow-[0_0_8px_#00ffff66]">
								{t.auth.forgotPassword}
							</a>
						</div>
						<button
							type="submit"
							class="group w-full py-3.5 bg-fuchsia-600/90 text-white font-black uppercase tracking-[0.2em] rounded-sm border border-fuchsia-400 shadow-[0_0_25px_#ff00ff,0_0_50px_#ff00ff44] hover:shadow-[0_0_40px_#ff00ff,0_0_80px_#ff00ff66] hover:bg-fuchsia-500 transition-all duration-500 relative overflow-hidden"
						>
							<span class="relative z-10">{t.auth.signIn}</span>
							<span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></span>
						</button>
					</form>

					<!-- Divider -->
					<div class="flex items-center gap-4 my-8">
						<div class="flex-1 h-px bg-gradient-to-r from-transparent to-fuchsia-500/30"></div>
						<p class="text-[10px] text-gray-500 uppercase tracking-[0.25em] font-bold">{t.auth.continueWith}</p>
						<div class="flex-1 h-px bg-gradient-to-l from-transparent to-fuchsia-500/30"></div>
					</div>

					<!-- Social buttons -->
					<div class="grid grid-cols-2 gap-4">
						<button
							type="button"
							class="py-3 rounded-sm border border-cyan-500/25 bg-gray-950/60 text-cyan-300 font-bold uppercase tracking-[0.15em] text-sm hover:bg-cyan-500/10 hover:border-cyan-400/50 hover:shadow-[0_0_20px_#00ffff44] transition-all duration-300"
						>
							Google
						</button>
						<button
							type="button"
							class="py-3 rounded-sm border border-cyan-500/25 bg-gray-950/60 text-cyan-300 font-bold uppercase tracking-[0.15em] text-sm hover:bg-cyan-500/10 hover:border-cyan-400/50 hover:shadow-[0_0_20px_#00ffff44] transition-all duration-300"
						>
							Apple
						</button>
					</div>

					<!-- Sign up link -->
					<p class="mt-8 text-center text-sm text-gray-500">
						{t.auth.noAccount}
						<a href="#" class="text-fuchsia-400 hover:text-fuchsia-300 font-bold ml-1 transition-all duration-300 hover:drop-shadow-[0_0_8px_#ff00ff66]">
							{t.auth.signUp}
						</a>
					</p>
				</div>

				<!-- Bottom glow bar -->
				<div class="h-0.5 bg-gradient-to-r from-fuchsia-500 via-cyan-400 to-fuchsia-500 shadow-[0_0_10px_#ff00ff]"></div>
			</div>
		</section>
	</main>
</div>

<style>
	@keyframes retro-pulse {
		0%, 100% { opacity: 1; box-shadow: 0 0 20px #ff00ff; }
		50% { opacity: 0.7; box-shadow: 0 0 10px #ff00ff; }
	}
	.retro-pulse {
		animation: retro-pulse 3s ease-in-out infinite;
	}
</style>
