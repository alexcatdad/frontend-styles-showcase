---
const { lang, style, nav, cats, t } = Astro.props;
---

<div class="min-h-screen bg-gray-950 text-white font-mono relative overflow-hidden">
	<!-- Perspective grid background -->
	<div class="fixed inset-0 z-0 pointer-events-none" aria-hidden="true">
		<div class="absolute inset-0 bg-[linear-gradient(rgba(255,0,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,0,255,0.03)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
		<div class="absolute bottom-0 left-0 right-0 h-[40vh] bg-[linear-gradient(rgba(0,255,255,0.07)_1px,transparent_1px),linear-gradient(90deg,rgba(0,255,255,0.07)_1px,transparent_1px)] bg-[size:40px_40px] [transform:perspective(400px)_rotateX(60deg)] origin-bottom"></div>
		<div class="absolute inset-0 bg-gradient-to-b from-gray-950 via-transparent to-gray-950"></div>
	</div>

	<!-- Scanline overlay -->
	<div class="fixed inset-0 z-[1] pointer-events-none bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,rgba(0,0,0,0.08)_2px,rgba(0,0,0,0.08)_4px)]" aria-hidden="true"></div>

	<!-- Nav -->
	<nav class="relative z-50 sticky top-0">
		<div class="mx-4 mt-3 rounded-lg border border-fuchsia-500/40 bg-gray-950/95 backdrop-blur-md shadow-[0_0_20px_#ff00ff33,inset_0_0_20px_#ff00ff11]">
			<div class="max-w-6xl mx-auto px-4 py-3 flex flex-wrap gap-1 items-center justify-center sm:justify-start">
				{nav.map((item: any) => (
					<a
						href={item.href}
						class="px-4 py-2 text-sm font-bold uppercase tracking-[0.2em] text-fuchsia-300 hover:text-white rounded transition-all duration-300 hover:bg-fuchsia-500/20 hover:shadow-[0_0_15px_#ff00ff55] relative after:absolute after:bottom-0 after:left-2 after:right-2 after:h-px after:bg-fuchsia-500 after:opacity-0 hover:after:opacity-100 after:shadow-[0_0_8px_#ff00ff] after:transition-opacity"
					>
						{item.label}
					</a>
				))}
			</div>
		</div>
	</nav>

	<main class="relative z-10 max-w-6xl mx-auto px-4 py-16">
		<!-- Header — "CHARACTER SELECT" screen -->
		<div class="text-center mb-16">
			<p class="text-xs uppercase tracking-[0.4em] text-fuchsia-500/70 mb-3 font-bold">// select your companion //</p>
			<h1 class="text-5xl sm:text-7xl lg:text-8xl font-black uppercase tracking-tight leading-none">
				<span class="bg-gradient-to-r from-fuchsia-400 via-cyan-300 to-fuchsia-400 bg-clip-text text-transparent drop-shadow-[0_0_40px_#ff00ff]">
					{t.cats.title}
				</span>
			</h1>
			<div class="h-1 w-40 mx-auto mt-6 mb-5 bg-gradient-to-r from-transparent via-fuchsia-500 to-transparent shadow-[0_0_25px_#ff00ff,0_0_50px_#ff00ff44] retro-pulse"></div>
			<p class="text-lg text-cyan-300/80 tracking-[0.15em] font-light">{t.cats.subtitle}</p>
		</div>

		<!-- Cat Grid — character select cards -->
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
			{cats.map((cat: any) => (
				<a
					href={`/${lang}/${style}/cats/${cat.id}`}
					class="group block rounded-sm border border-fuchsia-500/25 bg-gray-900/50 overflow-hidden shadow-[0_0_10px_#ff00ff22] hover:shadow-[0_0_30px_#ff00ff66,0_0_60px_#ff00ff22] transition-all duration-500 hover:border-fuchsia-400/70 hover:-translate-y-1 relative"
				>
					<!-- Top glow bar -->
					<div class="h-0.5 bg-gradient-to-r from-fuchsia-500 via-cyan-400 to-fuchsia-500 opacity-50 group-hover:opacity-100 transition-opacity duration-500"></div>

					<!-- Corner brackets -->
					<div class="absolute top-2 left-2 w-3 h-3 border-t border-l border-cyan-400/40 group-hover:border-cyan-400 transition-colors"></div>
					<div class="absolute top-2 right-2 w-3 h-3 border-t border-r border-cyan-400/40 group-hover:border-cyan-400 transition-colors"></div>
					<div class="absolute bottom-2 left-2 w-3 h-3 border-b border-l border-cyan-400/40 group-hover:border-cyan-400 transition-colors"></div>
					<div class="absolute bottom-2 right-2 w-3 h-3 border-b border-r border-cyan-400/40 group-hover:border-cyan-400 transition-colors"></div>

					<div class="p-6">
						<div class="flex items-start justify-between mb-3 gap-2">
							<h2 class="text-2xl font-black uppercase tracking-wide text-cyan-300 group-hover:text-cyan-200 group-hover:drop-shadow-[0_0_10px_#00ffff66] transition-all">
								{cat.name}
							</h2>
							<span class="shrink-0 text-[10px] font-black uppercase tracking-[0.2em] px-3 py-1 rounded-sm border border-cyan-400/50 text-cyan-400 bg-cyan-400/10 shadow-[0_0_8px_#00ffff33] group-hover:shadow-[0_0_15px_#00ffff55] transition-shadow">
								{cat.status}
							</span>
						</div>
						<p class="text-sm text-fuchsia-300/70 font-semibold tracking-[0.1em] mb-4 uppercase">
							{cat.breed} &middot; {cat.age} &middot; {cat.gender}
						</p>
						<p class="text-gray-400 text-sm leading-relaxed mb-5 font-light">
							{cat.description.slice(0, 100)}...
						</p>
						<div class="flex flex-wrap gap-2">
							{cat.personality.map((trait: string) => (
								<span class="text-[10px] px-3 py-1 rounded-sm bg-fuchsia-500/10 border border-fuchsia-500/30 text-fuchsia-300 font-bold tracking-[0.15em] uppercase group-hover:border-fuchsia-400/50 group-hover:shadow-[0_0_8px_#ff00ff33] transition-all">
									{trait}
								</span>
							))}
						</div>
					</div>

					<!-- Bottom neon glow line -->
					<div class="h-0.5 bg-gradient-to-r from-fuchsia-500 via-cyan-400 to-fuchsia-500 opacity-30 group-hover:opacity-100 transition-opacity duration-500"></div>
				</a>
			))}
		</div>
	</main>
</div>

<style>
	@keyframes retro-pulse {
		0%, 100% { opacity: 1; box-shadow: 0 0 25px #ff00ff, 0 0 50px #ff00ff44; }
		50% { opacity: 0.7; box-shadow: 0 0 12px #ff00ff, 0 0 25px #ff00ff22; }
	}
	.retro-pulse {
		animation: retro-pulse 3s ease-in-out infinite;
	}
</style>
