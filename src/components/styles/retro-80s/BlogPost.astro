---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
---

<div class="min-h-screen bg-gray-950 text-white font-sans">
	<!-- Nav -->
	<nav class="border-b border-fuchsia-500/30 bg-gray-950/90 backdrop-blur-sm sticky top-0 z-50">
		<div class="max-w-6xl mx-auto px-4 py-4 flex flex-wrap gap-2 items-center justify-center sm:justify-start">
			{nav.map((item: any) => (
				<a
					href={item.href}
					class="px-4 py-2 text-sm font-bold uppercase tracking-widest text-fuchsia-300 hover:text-white hover:bg-fuchsia-500/20 rounded transition-all duration-300 hover:shadow-[0_0_15px_#ff00ff55]"
				>
					{item.label}
				</a>
			))}
		</div>
	</nav>

	<main class="max-w-3xl mx-auto px-4 py-12">
		<!-- Back link -->
		<a
			href={`/${lang}/${style}/blog`}
			class="inline-flex items-center gap-2 text-fuchsia-400 hover:text-fuchsia-300 font-bold uppercase tracking-widest text-sm transition-colors mb-10 group"
		>
			<span class="group-hover:-translate-x-1 transition-transform">&larr;</span>
			{t.blog.backToBlog}
		</a>

		<article class="rounded-lg border border-fuchsia-500/40 bg-gray-900/60 overflow-hidden shadow-[0_0_20px_#ff00ff33]">
			<!-- Header glow bar -->
			<div class="h-1 bg-gradient-to-r from-cyan-400 via-fuchsia-500 to-cyan-400 shadow-[0_0_15px_#ff00ff]"></div>

			<header class="p-6 sm:p-10 pb-0 sm:pb-0">
				<time
					datetime={post.date}
					class="text-xs font-bold uppercase tracking-widest text-cyan-400/70"
				>
					{post.date}
				</time>
				<h1 class="text-3xl sm:text-5xl font-black uppercase tracking-tight bg-gradient-to-r from-fuchsia-400 via-cyan-300 to-fuchsia-400 bg-clip-text text-transparent mt-3 mb-4">
					{post.title}
				</h1>
				<span class="text-sm text-fuchsia-300/70 font-semibold tracking-wide">
					{t.blog.by} {post.author}
				</span>
				<div class="flex flex-wrap gap-2 mt-4">
					{post.tags.map((tag: string) => (
						<span class="text-xs px-3 py-1 rounded-full bg-fuchsia-500/15 border border-fuchsia-500/30 text-fuchsia-300 font-semibold tracking-wide">
							{tag}
						</span>
					))}
				</div>
			</header>

			<!-- Neon divider -->
			<div class="mx-6 sm:mx-10 my-8 h-px bg-gradient-to-r from-transparent via-cyan-400 to-transparent shadow-[0_0_8px_#00ffff]"></div>

			<!-- Content -->
			<div class="px-6 sm:px-10 pb-10 space-y-6">
				{post.content.map((paragraph: string) => (
					<p class="text-gray-300 text-lg leading-relaxed">
						{paragraph}
					</p>
				))}
			</div>
		</article>

		<!-- More Stories -->
		<section class="mt-20">
			<h2 class="text-2xl sm:text-3xl font-black uppercase tracking-wider text-center text-cyan-300 mb-2">
				{t.blog.moreStories}
			</h2>
			<div class="h-0.5 w-24 mx-auto mb-10 bg-fuchsia-500 shadow-[0_0_10px_#ff00ff]"></div>
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
				{otherPosts.map((p: any) => (
					<a
						href={`/${lang}/${style}/blog/${p.slug}`}
						class="group block p-6 rounded-lg border border-fuchsia-500/30 bg-gray-900/60 shadow-[0_0_10px_#ff00ff22] hover:shadow-[0_0_20px_#ff00ff55] hover:border-fuchsia-400/50 transition-all duration-300 hover:-translate-y-1"
					>
						<h3 class="text-lg font-black uppercase text-cyan-300 group-hover:text-cyan-200 tracking-wide mb-2">
							{p.title}
						</h3>
						<p class="text-sm text-gray-400 leading-relaxed">
							{p.excerpt}
						</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
