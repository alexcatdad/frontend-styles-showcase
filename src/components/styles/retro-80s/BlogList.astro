---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-gray-950 text-white font-sans">
	<!-- Nav -->
	<nav class="border-b border-fuchsia-500/30 bg-gray-950/90 backdrop-blur-sm sticky top-0 z-50">
		<div class="max-w-6xl mx-auto px-4 py-4 flex flex-wrap gap-2 items-center justify-center sm:justify-start">
			{nav.map((item: any) => (
				<a
					href={item.href}
					class="px-4 py-2 text-sm font-bold uppercase tracking-widest text-fuchsia-300 hover:text-white hover:bg-fuchsia-500/20 rounded transition-all duration-300 hover:shadow-[0_0_15px_#ff00ff55]"
				>
					{item.label}
				</a>
			))}
		</div>
	</nav>

	<main class="max-w-4xl mx-auto px-4 py-16">
		<!-- Header -->
		<div class="text-center mb-16">
			<h1 class="text-4xl sm:text-6xl font-black uppercase tracking-tight bg-gradient-to-r from-fuchsia-400 via-cyan-300 to-fuchsia-400 bg-clip-text text-transparent">
				{t.blog.title}
			</h1>
			<div class="h-1 w-32 mx-auto my-6 bg-gradient-to-r from-transparent via-cyan-400 to-transparent shadow-[0_0_20px_#00ffff]"></div>
			<p class="text-lg text-fuchsia-300/80 tracking-wide">{t.blog.subtitle}</p>
		</div>

		<!-- Posts -->
		<div class="space-y-8">
			{posts.map((post: any) => (
				<a
					href={`/${lang}/${style}/blog/${post.slug}`}
					class="group block rounded-lg border border-fuchsia-500/30 bg-gray-900/60 overflow-hidden shadow-[0_0_10px_#ff00ff22] hover:shadow-[0_0_25px_#ff00ff55,0_0_50px_#ff00ff22] transition-all duration-500 hover:border-fuchsia-400/50"
				>
					<article class="p-6 sm:p-8">
						<time
							datetime={post.date}
							class="text-xs font-bold uppercase tracking-widest text-cyan-400/70"
						>
							{post.date}
						</time>
						<h2 class="text-2xl sm:text-3xl font-black uppercase tracking-wide text-cyan-200 group-hover:text-cyan-100 mt-2 mb-3 transition-colors">
							{post.title}
						</h2>
						<p class="text-gray-400 leading-relaxed mb-4">
							{post.excerpt}
						</p>
						<div class="flex flex-wrap items-center gap-3">
							{post.tags.map((tag: string) => (
								<span class="text-xs px-3 py-1 rounded-full bg-fuchsia-500/15 border border-fuchsia-500/30 text-fuchsia-300 font-semibold tracking-wide">
									{tag}
								</span>
							))}
							<span class="ml-auto text-sm text-fuchsia-400/70 font-semibold tracking-wide">
								{t.blog.by} {post.author}
							</span>
						</div>
					</article>
					<!-- Bottom neon line -->
					<div class="h-0.5 bg-gradient-to-r from-fuchsia-500 via-cyan-400 to-fuchsia-500 opacity-30 group-hover:opacity-100 transition-opacity duration-500"></div>
				</a>
			))}
		</div>
	</main>
</div>
