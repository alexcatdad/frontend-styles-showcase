---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-gray-950 text-white font-mono relative overflow-hidden">
	<!-- Perspective grid background -->
	<div class="fixed inset-0 z-0 pointer-events-none" aria-hidden="true">
		<div class="absolute inset-0 bg-[linear-gradient(rgba(255,0,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,0,255,0.03)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
		<div class="absolute bottom-0 left-0 right-0 h-[40vh] bg-[linear-gradient(rgba(0,255,255,0.07)_1px,transparent_1px),linear-gradient(90deg,rgba(0,255,255,0.07)_1px,transparent_1px)] bg-[size:40px_40px] [transform:perspective(400px)_rotateX(60deg)] origin-bottom"></div>
		<div class="absolute inset-0 bg-gradient-to-b from-gray-950 via-transparent to-gray-950"></div>
	</div>

	<!-- Scanline overlay -->
	<div class="fixed inset-0 z-[1] pointer-events-none bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,rgba(0,0,0,0.08)_2px,rgba(0,0,0,0.08)_4px)]" aria-hidden="true"></div>

	<!-- Nav -->
	<nav class="relative z-50 sticky top-0">
		<div class="mx-4 mt-3 rounded-lg border border-fuchsia-500/40 bg-gray-950/95 backdrop-blur-md shadow-[0_0_20px_#ff00ff33,inset_0_0_20px_#ff00ff11]">
			<div class="max-w-6xl mx-auto px-4 py-3 flex flex-wrap gap-1 items-center justify-center sm:justify-start">
				{nav.map((item: any) => (
					<a
						href={item.href}
						class="px-4 py-2 text-sm font-bold uppercase tracking-[0.2em] text-fuchsia-300 hover:text-white rounded transition-all duration-300 hover:bg-fuchsia-500/20 hover:shadow-[0_0_15px_#ff00ff55] relative after:absolute after:bottom-0 after:left-2 after:right-2 after:h-px after:bg-fuchsia-500 after:opacity-0 hover:after:opacity-100 after:shadow-[0_0_8px_#ff00ff] after:transition-opacity"
					>
						{item.label}
					</a>
				))}
			</div>
		</div>
	</nav>

	<main class="relative z-10 max-w-4xl mx-auto px-4 py-16">
		<!-- Header — data transmission log -->
		<div class="text-center mb-16">
			<p class="text-xs uppercase tracking-[0.4em] text-cyan-500/60 mb-3 font-bold">// data transmission log //</p>
			<h1 class="text-5xl sm:text-7xl lg:text-8xl font-black uppercase tracking-tight leading-none">
				<span class="bg-gradient-to-r from-fuchsia-400 via-cyan-300 to-fuchsia-400 bg-clip-text text-transparent drop-shadow-[0_0_40px_#ff00ff]">
					{t.blog.title}
				</span>
			</h1>
			<div class="h-1 w-40 mx-auto mt-6 mb-5 bg-gradient-to-r from-transparent via-cyan-400 to-transparent shadow-[0_0_25px_#00ffff,0_0_50px_#00ffff44] retro-pulse-cyan"></div>
			<p class="text-lg text-fuchsia-300/70 tracking-[0.15em] font-light">{t.blog.subtitle}</p>
		</div>

		<!-- Posts — CRT screen panels -->
		<div class="space-y-8">
			{posts.map((post: any, i: number) => (
				<a
					href={`/${lang}/${style}/blog/${post.slug}`}
					class="group block rounded-sm border border-fuchsia-500/25 bg-gray-900/50 overflow-hidden shadow-[0_0_10px_#ff00ff22] hover:shadow-[0_0_30px_#ff00ff55,0_0_60px_#ff00ff22] transition-all duration-500 hover:border-fuchsia-400/60 relative"
				>
					<!-- Top accent bar -->
					<div class="h-0.5 bg-gradient-to-r from-cyan-400 via-fuchsia-500 to-cyan-400 opacity-40 group-hover:opacity-100 transition-opacity duration-500"></div>

					<article class="p-6 sm:p-8 relative">
						<img src={post.image} alt={post.title} class="w-full h-40 md:h-48 object-cover rounded-sm mb-5 border border-fuchsia-500/30 shadow-[0_0_10px_#ff00ff22]" />
						<!-- Corner brackets -->
						<div class="absolute top-3 left-3 w-3 h-3 border-t border-l border-cyan-400/30 group-hover:border-cyan-400/70 transition-colors"></div>
						<div class="absolute top-3 right-3 w-3 h-3 border-t border-r border-cyan-400/30 group-hover:border-cyan-400/70 transition-colors"></div>

						<!-- Entry index -->
						<div class="flex items-center gap-3 mb-3">
							<span class="text-[10px] font-black tracking-[0.3em] text-fuchsia-500/50 uppercase">
								entry_{String(i + 1).padStart(3, '0')}
							</span>
							<div class="h-px flex-1 bg-fuchsia-500/15"></div>
							<time
								datetime={post.date}
								class="text-xs font-bold uppercase tracking-[0.2em] text-cyan-400/60"
							>
								{post.date}
							</time>
						</div>

						<h2 class="text-2xl sm:text-3xl font-black uppercase tracking-wide text-cyan-200 group-hover:text-cyan-100 group-hover:drop-shadow-[0_0_15px_#00ffff66] mb-3 transition-all">
							{post.title}
						</h2>
						<p class="text-gray-400 leading-relaxed mb-5 font-light">
							{post.excerpt}
						</p>
						<div class="flex flex-wrap items-center gap-3">
							{post.tags.map((tag: string) => (
								<span class="text-[10px] px-3 py-1 rounded-sm bg-fuchsia-500/10 border border-fuchsia-500/30 text-fuchsia-300 font-bold tracking-[0.15em] uppercase group-hover:border-fuchsia-400/50 group-hover:shadow-[0_0_6px_#ff00ff33] transition-all">
									{tag}
								</span>
							))}
							<span class="ml-auto text-sm text-fuchsia-400/50 font-semibold tracking-[0.1em]">
								{t.blog.by} {post.author}
							</span>
						</div>
					</article>

					<!-- Bottom neon line -->
					<div class="h-0.5 bg-gradient-to-r from-fuchsia-500 via-cyan-400 to-fuchsia-500 opacity-20 group-hover:opacity-100 transition-opacity duration-500"></div>
				</a>
			))}
		</div>
	</main>
</div>

<style>
	@keyframes retro-pulse-cyan {
		0%, 100% { opacity: 1; box-shadow: 0 0 25px #00ffff, 0 0 50px #00ffff44; }
		50% { opacity: 0.7; box-shadow: 0 0 12px #00ffff, 0 0 25px #00ffff22; }
	}
	.retro-pulse-cyan {
		animation: retro-pulse-cyan 3s ease-in-out infinite;
	}
</style>
