---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-gray-950 text-white font-mono relative overflow-hidden">
	<!-- Perspective grid background -->
	<div class="fixed inset-0 z-0 pointer-events-none" aria-hidden="true">
		<div class="absolute inset-0 bg-[linear-gradient(rgba(255,0,255,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(255,0,255,0.03)_1px,transparent_1px)] bg-[size:60px_60px]"></div>
		<div class="absolute bottom-0 left-0 right-0 h-[40vh] bg-[linear-gradient(rgba(0,255,255,0.07)_1px,transparent_1px),linear-gradient(90deg,rgba(0,255,255,0.07)_1px,transparent_1px)] bg-[size:40px_40px] [transform:perspective(400px)_rotateX(60deg)] origin-bottom"></div>
		<div class="absolute inset-0 bg-gradient-to-b from-gray-950 via-transparent to-gray-950"></div>
	</div>

	<!-- Scanline overlay -->
	<div class="fixed inset-0 z-[1] pointer-events-none bg-[repeating-linear-gradient(0deg,transparent,transparent_2px,rgba(0,0,0,0.08)_2px,rgba(0,0,0,0.08)_4px)]" aria-hidden="true"></div>

	<!-- Nav — floating neon strip -->
	<nav class="relative z-50 sticky top-0">
		<div class="mx-4 mt-3 rounded-lg border border-fuchsia-500/40 bg-gray-950/95 backdrop-blur-md shadow-[0_0_20px_#ff00ff33,inset_0_0_20px_#ff00ff11]">
			<div class="max-w-6xl mx-auto px-4 py-3 flex flex-wrap gap-1 items-center justify-center sm:justify-start">
				{nav.map((item: any) => (
					<a
						href={item.href}
						class="px-4 py-2 text-sm font-bold uppercase tracking-[0.2em] text-fuchsia-300 hover:text-white rounded transition-all duration-300 hover:bg-fuchsia-500/20 hover:shadow-[0_0_15px_#ff00ff55] relative after:absolute after:bottom-0 after:left-2 after:right-2 after:h-px after:bg-fuchsia-500 after:opacity-0 hover:after:opacity-100 after:shadow-[0_0_8px_#ff00ff] after:transition-opacity"
					>
						{item.label}
					</a>
				))}
			</div>
		</div>
	</nav>

	<main class="relative z-10">
		<!-- Hero — massive glowing text -->
		<section class="relative py-28 sm:py-40 lg:py-48 px-4 text-center overflow-hidden">
			<!-- Radial glow behind title -->
			<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-fuchsia-600/10 rounded-full blur-[100px]" aria-hidden="true"></div>
			<div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[200px] bg-cyan-500/10 rounded-full blur-[80px]" aria-hidden="true"></div>

			<div class="relative z-10 max-w-5xl mx-auto">
				<h1 class="text-6xl sm:text-8xl lg:text-9xl font-black uppercase tracking-tight leading-none retro-title">
					<span class="bg-gradient-to-r from-fuchsia-400 via-cyan-300 to-fuchsia-400 bg-clip-text text-transparent drop-shadow-[0_0_40px_#ff00ff]">
						{sanctuary.name}
					</span>
				</h1>
				<!-- Neon underline bar -->
				<div class="h-1 w-64 mx-auto mt-8 mb-6 bg-gradient-to-r from-transparent via-fuchsia-500 to-transparent shadow-[0_0_30px_#ff00ff,0_0_60px_#ff00ff44] retro-pulse"></div>
				<p class="text-xl sm:text-2xl lg:text-3xl text-cyan-300 font-light tracking-[0.15em] max-w-3xl mx-auto drop-shadow-[0_0_15px_#00ffff66]">
					{sanctuary.tagline}
				</p>
				<div class="mt-12 flex flex-col sm:flex-row gap-5 justify-center">
					<a
						href={`/${lang}/${style}/cats`}
						class="group px-10 py-4 bg-fuchsia-600/90 text-white font-black uppercase tracking-[0.2em] rounded-sm border border-fuchsia-400 shadow-[0_0_25px_#ff00ff,0_0_50px_#ff00ff44] hover:shadow-[0_0_40px_#ff00ff,0_0_80px_#ff00ff66] hover:bg-fuchsia-500 transition-all duration-500 relative overflow-hidden"
					>
						<span class="relative z-10">{t.home.meetCats}</span>
						<span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></span>
					</a>
					<a
						href={`/${lang}/${style}/donate`}
						class="group px-10 py-4 bg-transparent text-cyan-300 font-black uppercase tracking-[0.2em] rounded-sm border border-cyan-400/70 shadow-[0_0_20px_#00ffff44] hover:shadow-[0_0_35px_#00ffff,0_0_70px_#00ffff44] hover:bg-cyan-500/10 transition-all duration-500 relative overflow-hidden"
					>
						<span class="relative z-10">{t.home.donate}</span>
						<span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></span>
					</a>
				</div>
			</div>
		</section>

		<!-- Neon divider with glow -->
		<div class="relative h-px mx-8">
			<div class="absolute inset-0 bg-gradient-to-r from-transparent via-fuchsia-500 to-transparent shadow-[0_0_15px_#ff00ff]"></div>
			<div class="absolute inset-0 bg-gradient-to-r from-transparent via-fuchsia-500 to-transparent blur-sm"></div>
		</div>

		<!-- Mission — CRT monitor panel -->
		<section class="max-w-4xl mx-auto px-4 py-20 sm:py-24">
			<div class="border border-fuchsia-500/30 rounded-sm bg-gray-900/40 p-8 sm:p-12 shadow-[0_0_30px_#ff00ff22,inset_0_0_30px_#00000066] relative">
				<!-- Corner decorations -->
				<div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-fuchsia-400 shadow-[0_0_8px_#ff00ff]"></div>
				<div class="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-fuchsia-400 shadow-[0_0_8px_#ff00ff]"></div>
				<div class="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-fuchsia-400 shadow-[0_0_8px_#ff00ff]"></div>
				<div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-fuchsia-400 shadow-[0_0_8px_#ff00ff]"></div>

				<h2 class="text-3xl sm:text-4xl font-black uppercase tracking-[0.15em] text-center text-fuchsia-400 mb-3 drop-shadow-[0_0_20px_#ff00ff66]">
					{t.home.mission}
				</h2>
				<div class="h-0.5 w-24 mx-auto mb-8 bg-cyan-400 shadow-[0_0_12px_#00ffff]"></div>
				<p class="text-lg text-gray-300 leading-relaxed max-w-3xl mx-auto text-center font-light">
					{sanctuary.mission}
				</p>
			</div>
		</section>

		<!-- Neon divider -->
		<div class="relative h-px mx-8">
			<div class="absolute inset-0 bg-gradient-to-r from-transparent via-cyan-400 to-transparent shadow-[0_0_15px_#00ffff]"></div>
			<div class="absolute inset-0 bg-gradient-to-r from-transparent via-cyan-400 to-transparent blur-sm"></div>
		</div>

		<!-- Stats — arcade scoreboard display -->
		<section class="max-w-5xl mx-auto px-4 py-20 sm:py-24">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-5">
				{sanctuary.stats.map((stat: any, i: number) => (
					<div class="group text-center p-6 sm:p-8 rounded-sm border border-fuchsia-500/30 bg-gray-900/50 shadow-[0_0_15px_#ff00ff22] hover:shadow-[0_0_30px_#ff00ff55,0_0_60px_#ff00ff22] transition-all duration-500 hover:border-fuchsia-400/60 relative overflow-hidden">
						<!-- Top accent bar -->
						<div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-fuchsia-500 via-cyan-400 to-fuchsia-500 opacity-60 group-hover:opacity-100 transition-opacity"></div>
						<span class="block text-5xl sm:text-6xl font-black tracking-tight bg-gradient-to-b from-cyan-200 to-cyan-500 bg-clip-text text-transparent drop-shadow-[0_0_20px_#00ffff66] retro-flicker" style={`animation-delay: ${i * 0.2}s`}>
							{stat.value}
						</span>
						<span class="block mt-3 text-xs sm:text-sm uppercase tracking-[0.2em] text-fuchsia-300 font-bold">
							{stat.label}
						</span>
					</div>
				))}
			</div>
		</section>

		<!-- Neon divider -->
		<div class="relative h-px mx-8">
			<div class="absolute inset-0 bg-gradient-to-r from-transparent via-fuchsia-500 to-transparent shadow-[0_0_15px_#ff00ff]"></div>
			<div class="absolute inset-0 bg-gradient-to-r from-transparent via-fuchsia-500 to-transparent blur-sm"></div>
		</div>

		<!-- About — bordered CRT panels -->
		<section class="max-w-4xl mx-auto px-4 py-20 sm:py-24">
			<h2 class="text-3xl sm:text-4xl font-black uppercase tracking-[0.15em] text-center text-cyan-300 mb-3 drop-shadow-[0_0_20px_#00ffff66]">
				{t.home.aboutUs}
			</h2>
			<div class="h-0.5 w-24 mx-auto mb-12 bg-fuchsia-500 shadow-[0_0_12px_#ff00ff]"></div>
			<div class="space-y-6">
				{sanctuary.about.map((paragraph: string) => (
					<div class="border-l-2 border-fuchsia-500/60 pl-6 py-2 hover:border-fuchsia-400 hover:shadow-[-2px_0_15px_#ff00ff44] transition-all duration-300">
						<p class="text-gray-300 leading-relaxed text-lg font-light">
							{paragraph}
						</p>
					</div>
				))}
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="relative z-10 border-t border-fuchsia-500/20 mt-12">
		<div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-fuchsia-500 to-transparent shadow-[0_0_10px_#ff00ff]"></div>
		<div class="max-w-6xl mx-auto px-4 py-10 text-center">
			<p class="text-sm text-gray-500 tracking-[0.15em] uppercase">
				&copy; 2026 {sanctuary.name} &bull; {t.footer.style}: <span class="text-fuchsia-400 drop-shadow-[0_0_8px_#ff00ff]">{meta.name}</span>
			</p>
		</div>
	</footer>
</div>

<style>
	@keyframes retro-pulse {
		0%, 100% { opacity: 1; box-shadow: 0 0 30px #ff00ff, 0 0 60px #ff00ff44; }
		50% { opacity: 0.7; box-shadow: 0 0 15px #ff00ff, 0 0 30px #ff00ff22; }
	}
	.retro-pulse {
		animation: retro-pulse 3s ease-in-out infinite;
	}
	@keyframes retro-flicker {
		0%, 100% { opacity: 1; }
		92% { opacity: 1; }
		93% { opacity: 0.7; }
		94% { opacity: 1; }
		96% { opacity: 0.8; }
		97% { opacity: 1; }
	}
	.retro-flicker {
		animation: retro-flicker 4s ease-in-out infinite;
	}
</style>
