---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-gray-950 text-white font-sans">
	<!-- Nav -->
	<nav class="border-b border-fuchsia-500/30 bg-gray-950/90 backdrop-blur-sm sticky top-0 z-50">
		<div class="max-w-6xl mx-auto px-4 py-4 flex flex-wrap gap-2 items-center justify-center sm:justify-start">
			{nav.map((item: any) => (
				<a
					href={item.href}
					class="px-4 py-2 text-sm font-bold uppercase tracking-widest text-fuchsia-300 hover:text-white hover:bg-fuchsia-500/20 rounded transition-all duration-300 hover:shadow-[0_0_15px_#ff00ff55]"
				>
					{item.label}
				</a>
			))}
		</div>
	</nav>

	<main>
		<!-- Hero -->
		<section class="relative overflow-hidden py-24 sm:py-36 px-4 text-center">
			<div class="absolute inset-0 bg-gradient-to-b from-fuchsia-900/20 via-transparent to-cyan-900/20"></div>
			<div class="absolute inset-0 bg-[linear-gradient(transparent_49%,rgba(255,0,255,0.03)_50%,transparent_51%)] bg-[length:100%_4px]"></div>
			<div class="relative z-10 max-w-4xl mx-auto">
				<h1 class="text-5xl sm:text-7xl lg:text-8xl font-black uppercase tracking-tight bg-gradient-to-r from-fuchsia-400 via-cyan-300 to-fuchsia-400 bg-clip-text text-transparent drop-shadow-lg">
					{sanctuary.name}
				</h1>
				<div class="h-1 w-48 mx-auto my-6 bg-gradient-to-r from-transparent via-fuchsia-500 to-transparent shadow-[0_0_20px_#ff00ff]"></div>
				<p class="text-xl sm:text-2xl text-cyan-300 font-light tracking-wide max-w-2xl mx-auto">
					{sanctuary.tagline}
				</p>
				<div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
					<a
						href={`/${lang}/${style}/cats`}
						class="px-8 py-4 bg-fuchsia-600 text-white font-bold uppercase tracking-widest rounded border border-fuchsia-400 shadow-[0_0_20px_#ff00ff,0_0_40px_#ff00ff44] hover:shadow-[0_0_30px_#ff00ff,0_0_60px_#ff00ff66] hover:bg-fuchsia-500 transition-all duration-300"
					>
						{t.home.meetCats}
					</a>
					<a
						href={`/${lang}/${style}/donate`}
						class="px-8 py-4 bg-transparent text-cyan-300 font-bold uppercase tracking-widest rounded border border-cyan-400 shadow-[0_0_15px_#00ffff44] hover:shadow-[0_0_25px_#00ffff,0_0_50px_#00ffff44] hover:bg-cyan-500/10 transition-all duration-300"
					>
						{t.home.donate}
					</a>
				</div>
			</div>
		</section>

		<!-- Neon divider -->
		<div class="h-px bg-gradient-to-r from-transparent via-fuchsia-500 to-transparent shadow-[0_0_10px_#ff00ff]"></div>

		<!-- Mission -->
		<section class="max-w-4xl mx-auto px-4 py-20 text-center">
			<h2 class="text-3xl sm:text-4xl font-black uppercase tracking-wider text-fuchsia-400 mb-2 shadow-fuchsia-500">
				{t.home.mission}
			</h2>
			<div class="h-0.5 w-24 mx-auto mb-8 bg-cyan-400 shadow-[0_0_10px_#00ffff]"></div>
			<p class="text-lg text-gray-300 leading-relaxed max-w-3xl mx-auto">
				{sanctuary.mission}
			</p>
		</section>

		<!-- Neon divider -->
		<div class="h-px bg-gradient-to-r from-transparent via-cyan-400 to-transparent shadow-[0_0_10px_#00ffff]"></div>

		<!-- Stats -->
		<section class="max-w-5xl mx-auto px-4 py-20">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-6">
				{sanctuary.stats.map((stat: any) => (
					<div class="text-center p-6 rounded-lg border border-fuchsia-500/40 bg-gray-900/60 shadow-[0_0_15px_#ff00ff33] hover:shadow-[0_0_25px_#ff00ff66] transition-all duration-300">
						<span class="block text-4xl sm:text-5xl font-black bg-gradient-to-b from-cyan-300 to-cyan-500 bg-clip-text text-transparent">
							{stat.value}
						</span>
						<span class="block mt-2 text-sm uppercase tracking-widest text-fuchsia-300 font-semibold">
							{stat.label}
						</span>
					</div>
				))}
			</div>
		</section>

		<!-- Neon divider -->
		<div class="h-px bg-gradient-to-r from-transparent via-fuchsia-500 to-transparent shadow-[0_0_10px_#ff00ff]"></div>

		<!-- About -->
		<section class="max-w-4xl mx-auto px-4 py-20">
			<h2 class="text-3xl sm:text-4xl font-black uppercase tracking-wider text-center text-cyan-300 mb-2">
				{t.home.aboutUs}
			</h2>
			<div class="h-0.5 w-24 mx-auto mb-10 bg-fuchsia-500 shadow-[0_0_10px_#ff00ff]"></div>
			<div class="space-y-6">
				{sanctuary.about.map((paragraph: string) => (
					<p class="text-gray-300 leading-relaxed text-lg border-l-2 border-fuchsia-500/50 pl-6">
						{paragraph}
					</p>
				))}
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="border-t border-fuchsia-500/30 mt-12">
		<div class="max-w-6xl mx-auto px-4 py-8 text-center">
			<p class="text-sm text-gray-500 tracking-wide">
				&copy; 2026 {sanctuary.name}. {t.footer.style}: <span class="text-fuchsia-400">{meta.name}</span>.
			</p>
		</div>
	</footer>
</div>
