---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-lime-400 font-mono overflow-x-hidden">
	<nav class="flex flex-wrap items-center gap-2 px-4 py-3 bg-fuchsia-600 border-b-8 border-yellow-300 rotate-0.5">
		{nav.map((item: any, i: number) => (
			<a
				href={item.href}
				class:list={[
					"px-3 py-1 font-bold no-underline transition-transform hover:scale-110",
					i % 3 === 0 && "bg-cyan-400 text-black font-serif text-lg -rotate-2",
					i % 3 === 1 && "bg-orange-500 text-white font-mono text-xs rotate-1 uppercase tracking-widest",
					i % 3 === 2 && "bg-lime-300 text-fuchsia-800 font-sans text-base -rotate-1 border-2 border-black",
				]}
			>
				{item.label}
			</a>
		))}
	</nav>

	<main>
		<section class="relative px-6 py-16 md:py-24 bg-black text-lime-400 border-b-12 border-fuchsia-500 overflow-hidden">
			<div class="absolute top-4 right-4 w-32 h-32 bg-orange-500 rounded-full opacity-30 -rotate-12"></div>
			<div class="absolute bottom-8 left-8 w-20 h-20 bg-cyan-400 opacity-40 rotate-6"></div>
			<h1 class="relative text-5xl md:text-8xl lg:text-9xl font-black font-serif tracking-tighter -rotate-2 mb-4 text-fuchsia-400 leading-none">
				{sanctuary.name}
			</h1>
			<p class="relative text-xl md:text-3xl font-mono text-cyan-300 rotate-1 ml-4 md:ml-12 mb-10 max-w-2xl">
				{sanctuary.tagline}
			</p>
			<div class="relative flex flex-wrap gap-4 ml-2">
				<a
					href={`/${lang}/${style}/cats`}
					class="inline-block px-8 py-4 bg-lime-400 text-black font-black text-xl md:text-2xl font-sans border-4 border-white rotate-2 hover:-rotate-1 transition-transform no-underline"
				>
					{t.home.meetCats}
				</a>
				<a
					href={`/${lang}/${style}/donate`}
					class="inline-block px-8 py-4 bg-fuchsia-500 text-yellow-300 font-black text-xl md:text-2xl font-serif border-4 border-cyan-400 -rotate-3 hover:rotate-1 transition-transform no-underline"
				>
					{t.home.donate}
				</a>
			</div>
		</section>

		<section class="px-6 py-12 bg-cyan-400 text-black border-b-8 border-orange-500 -rotate-0.5">
			<h2 class="text-4xl md:text-6xl font-black font-sans rotate-3 mb-6 text-fuchsia-700 underline decoration-yellow-400 decoration-8 underline-offset-4">
				{t.home.mission}
			</h2>
			<p class="text-lg md:text-2xl font-serif max-w-3xl -rotate-1 ml-4 md:ml-16 bg-white/60 p-4 border-l-8 border-fuchsia-600">
				{sanctuary.mission}
			</p>
		</section>

		<section class="px-6 py-12 bg-orange-500 border-b-8 border-lime-400">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
				{sanctuary.stats.map((stat: any, i: number) => (
					<div
						class:list={[
							"p-4 md:p-6 text-center border-4",
							i % 4 === 0 && "bg-black text-lime-400 border-fuchsia-500 rotate-3 font-mono",
							i % 4 === 1 && "bg-fuchsia-600 text-yellow-300 border-cyan-400 -rotate-2 font-serif",
							i % 4 === 2 && "bg-cyan-400 text-black border-orange-600 rotate-1 font-sans",
							i % 4 === 3 && "bg-lime-400 text-fuchsia-700 border-black -rotate-3 font-mono",
						]}
					>
						<span class="block text-4xl md:text-6xl font-black">{stat.value}</span>
						<span class="block text-sm md:text-base mt-2 uppercase tracking-widest font-bold">{stat.label}</span>
					</div>
				))}
			</div>
		</section>

		<section class="px-6 py-12 bg-fuchsia-700 text-white border-b-8 border-cyan-400 rotate-0.5">
			<h2 class="text-4xl md:text-5xl font-black font-mono -rotate-2 mb-8 text-yellow-300 line-through decoration-lime-400">
				{t.home.aboutUs}
			</h2>
			<div class="space-y-6 max-w-4xl">
				{sanctuary.about.map((paragraph: string, i: number) => (
					<p
						class:list={[
							"text-base md:text-lg p-4",
							i % 3 === 0 && "font-serif bg-black/30 rotate-1 border-l-4 border-lime-400 ml-0",
							i % 3 === 1 && "font-sans bg-cyan-600/40 -rotate-1 border-r-4 border-orange-400 ml-8 md:ml-24",
							i % 3 === 2 && "font-mono bg-fuchsia-900/50 rotate-0.5 border-l-4 border-yellow-400 ml-4 md:ml-12",
						]}
					>
						{paragraph}
					</p>
				))}
			</div>
		</section>
	</main>

	<footer class="px-6 py-8 bg-yellow-300 text-black border-t-8 border-fuchsia-600 -rotate-0.5">
		<p class="text-center font-black font-serif text-lg md:text-xl rotate-2">
			&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.
		</p>
	</footer>
</div>
