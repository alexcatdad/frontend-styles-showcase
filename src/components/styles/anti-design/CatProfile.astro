---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-cyan-400 overflow-x-hidden">
	<!-- NAV: diagonal strip across the top-left corner -->
	<nav class="relative z-30 -rotate-3 origin-top-left bg-fuchsia-600 border-b-4 border-lime-400 p-2 md:p-3 -ml-4 pl-8 pr-12 md:pr-20 inline-flex flex-wrap gap-2 items-center shadow-[0_8px_0_theme(colors.black)]">
		{nav.map((item: any, i: number) => (
			<a
				href={item.href}
				class:list={[
					"px-2 py-1 font-bold no-underline hover:scale-110 transition-transform whitespace-nowrap",
					i % 3 === 0 && "bg-black text-lime-400 font-mono text-xs rotate-3",
					i % 3 === 1 && "bg-yellow-300 text-fuchsia-700 font-serif text-sm -rotate-1",
					i % 3 === 2 && "text-white font-sans text-xs rotate-2 underline decoration-orange-500 decoration-2",
				]}
			>
				{item.label}
			</a>
		))}
	</nav>

	<main class="px-3 md:px-6 pt-4 pb-12">
		<!-- Back button: absurdly positioned -->
		<div class="text-right mb-4 md:mb-0 md:absolute md:right-6 md:top-20 z-20">
			<a
				href={`/${lang}/${style}/cats`}
				class="inline-block px-3 py-1 md:px-6 md:py-3 bg-black text-lime-400 font-black text-sm md:text-base font-mono no-underline rotate-6 border-4 border-orange-500 hover:-rotate-3 transition-transform shadow-[4px_4px_0_theme(colors.fuchsia.500)]"
			>
				&larr; {t.cats.backToAll}
			</a>
		</div>

		<article class="relative mt-4 md:mt-8">
			<!-- Cat name: MASSIVE, overlapping everything -->
			<h1 class="text-[4rem] md:text-[10rem] lg:text-[14rem] font-black font-serif text-fuchsia-600 leading-none -rotate-3 relative z-10 drop-shadow-[6px_6px_0_theme(colors.lime.400)] mb-[-1rem] md:mb-[-3rem]">
				{cat.name}
			</h1>

			<!-- Status badge: floating top-right, rotated wildly -->
			<div class="absolute top-0 right-2 md:right-8 bg-lime-400 text-black px-4 py-2 md:px-6 md:py-3 font-black text-sm md:text-xl uppercase rotate-12 border-4 border-fuchsia-600 z-20 font-mono shadow-[4px_4px_0_black]">
				{cat.status}
			</div>

			<!-- Details: scattered grid, not aligned -->
			<div class="relative z-0 bg-black p-4 md:p-8 border-8 border-lime-400 rotate-1 mb-8">
				<dl class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
					<div class="bg-fuchsia-700 p-2 md:p-4 -rotate-3 border-l-8 border-orange-500 md:col-span-1">
						<dt class="text-[8px] md:text-[10px] uppercase tracking-[0.4em] font-mono text-lime-400 font-bold">{t.cats.breed}</dt>
						<dd class="text-lg md:text-3xl font-black font-serif text-white mt-1">{cat.breed}</dd>
					</div>
					<div class="bg-orange-600 p-2 md:p-4 rotate-2 border-t-8 border-cyan-400 translate-y-2 md:translate-y-4">
						<dt class="text-[8px] md:text-[10px] uppercase tracking-[0.4em] font-sans text-black font-bold">{t.cats.age}</dt>
						<dd class="text-2xl md:text-4xl font-black font-mono text-white mt-1">{cat.age}</dd>
					</div>
					<div class="bg-lime-500 p-2 md:p-4 -rotate-1 border-r-8 border-fuchsia-600 -translate-y-1 md:-translate-y-2">
						<dt class="text-[8px] md:text-[10px] uppercase tracking-[0.4em] font-mono text-fuchsia-800 font-bold">{t.cats.gender}</dt>
						<dd class="text-lg md:text-2xl font-black font-serif text-black mt-1">{cat.gender}</dd>
					</div>
					<div class="bg-cyan-800 p-2 md:p-4 rotate-3 border-b-8 border-yellow-300 col-span-2 md:col-span-1">
						<dt class="text-[8px] md:text-[10px] uppercase tracking-[0.4em] font-serif text-orange-400 font-bold">{t.cats.color}</dt>
						<dd class="text-xl md:text-3xl font-black font-sans text-white mt-1">{cat.color}</dd>
					</div>
					<div class="bg-yellow-400 p-2 md:p-4 -rotate-2 border-4 border-dashed border-fuchsia-600">
						<dt class="text-[8px] md:text-[10px] uppercase tracking-[0.4em] font-mono text-fuchsia-700 font-bold">{t.cats.arrived}</dt>
						<dd class="text-base md:text-xl font-black font-serif text-black mt-1">{cat.arrivalDate}</dd>
					</div>
					<div class="bg-fuchsia-400 p-2 md:p-4 rotate-1 border-l-8 border-r-8 border-black">
						<dt class="text-[8px] md:text-[10px] uppercase tracking-[0.4em] font-sans text-black font-bold">{t.cats.status}</dt>
						<dd class="text-base md:text-xl font-black font-mono text-white mt-1">{cat.status}</dd>
					</div>
				</dl>
			</div>

			<!-- Personality: scattered like confetti -->
			<div class="flex flex-wrap gap-2 md:gap-4 mb-8 justify-center md:justify-start -rotate-1 px-2">
				{cat.personality.map((trait: string, i: number) => (
					<span
						class:list={[
							"font-black uppercase border-2 inline-block",
							i % 5 === 0 && "bg-lime-400 text-black border-fuchsia-600 px-6 py-3 text-lg md:text-2xl rotate-6 font-serif shadow-[4px_4px_0_black]",
							i % 5 === 1 && "bg-fuchsia-500 text-yellow-300 border-cyan-400 px-2 py-1 text-[10px] -rotate-12 font-mono tracking-[0.5em]",
							i % 5 === 2 && "bg-black text-orange-500 border-lime-400 px-4 py-2 text-sm rotate-3 font-sans",
							i % 5 === 3 && "bg-orange-500 text-white border-black px-3 py-4 text-xs -rotate-6 font-serif writing-mode-vertical",
							i % 5 === 4 && "bg-cyan-400 text-fuchsia-700 border-orange-500 px-5 py-1 text-base rotate-1 font-mono",
						]}
					>
						{trait}
					</span>
				))}
			</div>

			<!-- Description: quote-style, offset -->
			<div class="md:ml-[15%] md:mr-[5%] mb-12">
				<p class="text-base md:text-xl font-serif leading-loose bg-fuchsia-900 text-lime-100 p-6 md:p-10 -rotate-0.5 border-t-[12px] border-lime-400 border-b-[12px] border-b-orange-500 shadow-[12px_12px_0_theme(colors.black)]">
					{cat.description}
				</p>
			</div>

			<!-- Adopt CTA: centered but tilted, impossible to ignore -->
			<div class="text-center mb-16">
				<a
					href={`/${lang}/${style}/auth`}
					class="inline-block px-8 py-6 md:px-16 md:py-8 bg-yellow-300 text-fuchsia-700 font-black text-xl md:text-4xl font-sans border-8 border-black -rotate-3 hover:rotate-2 transition-transform no-underline uppercase shadow-[8px_8px_0_theme(colors.lime.400)] hover:shadow-[-8px_-8px_0_theme(colors.fuchsia.500)]"
				>
					{t.cats.adopt} {cat.name}
				</a>
			</div>
		</article>

		<!-- Other cats: horizontal scroll strip -->
		<section class="bg-black p-4 md:p-8 border-4 border-orange-500 -rotate-1">
			<h2 class="text-2xl md:text-5xl font-black font-mono text-cyan-400 rotate-3 mb-6 underline decoration-fuchsia-500 decoration-wavy decoration-4">
				{t.cats.otherCats}
			</h2>
			<div class="flex gap-4 md:gap-6 overflow-x-auto pb-4 -rotate-0.5">
				{otherCats.map((c: any, i: number) => (
					<a
						href={`/${lang}/${style}/cats/${c.id}`}
						class:list={[
							"block p-4 md:p-6 no-underline border-4 transition-transform hover:scale-110 shrink-0 w-48 md:w-64",
							i % 3 === 0 && "bg-lime-400 text-black border-fuchsia-600 rotate-2 shadow-[4px_4px_0_theme(colors.cyan.400)]",
							i % 3 === 1 && "bg-fuchsia-600 text-yellow-300 border-lime-400 -rotate-3 shadow-[-4px_4px_0_theme(colors.orange.500)]",
							i % 3 === 2 && "bg-orange-500 text-white border-cyan-400 rotate-1 shadow-[4px_-4px_0_theme(colors.lime.400)]",
						]}
					>
						<h3 class="text-xl md:text-3xl font-black font-serif mb-1">{c.name}</h3>
						<p class="text-xs md:text-sm font-mono font-bold">{c.breed} / {c.age}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
