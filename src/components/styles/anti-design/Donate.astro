---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-black overflow-x-hidden">
	<!-- NAV: bottom-right corner, vertical, reversed -->
	<nav class="fixed bottom-4 right-2 md:right-4 z-50 flex flex-col-reverse gap-1 max-w-[120px] md:max-w-[180px]">
		{nav.map((item: any, i: number) => (
			<a
				href={item.href}
				class:list={[
					"px-2 py-1 font-bold no-underline transition-all hover:-translate-x-2 hover:scale-110 block text-right text-[10px] md:text-xs truncate",
					i % 4 === 0 && "bg-fuchsia-600 text-yellow-300 font-serif rotate-2 border-r-4 border-lime-400",
					i % 4 === 1 && "bg-transparent text-cyan-400 font-mono -rotate-1 border border-cyan-400",
					i % 4 === 2 && "bg-lime-400 text-black font-sans rotate-3 border-l-4 border-fuchsia-600",
					i % 4 === 3 && "bg-orange-500 text-white font-mono -rotate-2 border-b-4 border-black",
				]}
			>
				{item.label}
			</a>
		))}
	</nav>

	<main class="px-3 md:px-8 py-8 md:py-16 mr-16 md:mr-24">
		<!-- Title: stacked vertically, each word different -->
		<div class="mb-12 md:mb-20 ml-2 md:ml-6">
			<h1 class="text-6xl md:text-[10rem] font-black font-serif text-fuchsia-500 -rotate-6 leading-[0.8] drop-shadow-[8px_8px_0_theme(colors.lime.400)] mb-4">
				{t.donate.title}
			</h1>
			<p class="text-sm md:text-xl font-mono text-cyan-400 rotate-3 ml-[15%] md:ml-[30%] bg-fuchsia-900/70 inline-block px-4 py-2 md:px-8 md:py-4 border-4 border-orange-500 border-dashed">
				{t.donate.subtitle}
			</p>
		</div>

		<!-- MONTHLY: overlapping card pile -->
		<section class="relative mb-20 md:mb-32">
			<h2 class="text-3xl md:text-7xl font-black font-mono text-lime-400 rotate-3 mb-8 md:mb-12 underline decoration-fuchsia-500 decoration-8 underline-offset-8 inline-block bg-black/80 px-4">
				{t.donate.monthly}
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-4">
				{monthlyTiers.map((tier: any, i: number) => (
					<div
						class:list={[
							"relative p-4 md:p-8 border-4 transition-all hover:z-20 hover:scale-105",
							tier.highlighted
								? "bg-yellow-300 text-black border-fuchsia-600 -rotate-2 scale-105 z-10 shadow-[12px_12px_0_theme(colors.fuchsia.600),24px_24px_0_theme(colors.black)] border-8"
								: i % 3 === 0
									? "bg-fuchsia-800 text-lime-400 border-cyan-400 rotate-3 shadow-[8px_8px_0_theme(colors.lime.400)]"
									: i % 3 === 1
										? "bg-cyan-400 text-black border-orange-500 -rotate-1 shadow-[-6px_6px_0_theme(colors.fuchsia.500)]"
										: "bg-orange-600 text-white border-lime-400 rotate-2 shadow-[6px_-6px_0_theme(colors.cyan.400)]",
						]}
					>
						{tier.highlighted && (
							<span class="absolute -top-6 -right-4 md:-top-8 md:-right-6 bg-fuchsia-600 text-lime-400 px-3 py-1 md:px-4 md:py-2 font-black text-xs md:text-sm uppercase rotate-12 border-4 border-yellow-300 font-mono shadow-[4px_4px_0_black]">
								{t.donate.mostPopular}
							</span>
						)}

						<h3 class:list={[
							"font-black mb-2",
							tier.highlighted ? "text-3xl md:text-4xl font-serif -rotate-2" : i % 2 === 0 ? "text-xl md:text-2xl font-mono rotate-1 uppercase tracking-wide" : "text-2xl md:text-3xl font-sans -rotate-1",
						]}>{tier.name}</h3>

						<p class="mb-4">
							<span class:list={[
								"font-black font-mono",
								tier.highlighted ? "text-5xl md:text-7xl text-fuchsia-700" : "text-3xl md:text-5xl",
							]}>${tier.amount}</span>
							<span class:list={[
								"font-sans",
								tier.highlighted ? "text-sm text-fuchsia-600" : "text-xs",
							]}>{t.donate.perMonth}</span>
						</p>

						<p class:list={[
							"text-sm mb-4 font-sans leading-relaxed",
							tier.highlighted ? "text-fuchsia-800 font-bold" : "opacity-90",
						]}>
							{tier.description}
						</p>

						<ul class="space-y-2 mb-6">
							{tier.perks.map((perk: string, j: number) => (
								<li
									class:list={[
										"text-xs md:text-sm font-bold pl-3 md:pl-4",
										j % 3 === 0 ? "border-l-4 border-fuchsia-500 font-mono rotate-0.5" : j % 3 === 1 ? "border-l-4 border-lime-400 font-serif -rotate-0.5" : "border-l-4 border-orange-500 font-sans rotate-1",
									]}
								>
									{perk}
								</li>
							))}
						</ul>

						<button
							type="button"
							class:list={[
								"w-full py-3 md:py-4 px-4 font-black text-base md:text-lg uppercase border-4 transition-all cursor-pointer",
								tier.highlighted
									? "bg-fuchsia-600 text-yellow-300 border-black hover:-rotate-3 hover:scale-110 rotate-1 shadow-[4px_4px_0_theme(colors.lime.400)]"
									: "bg-lime-400 text-black border-fuchsia-600 hover:rotate-3 hover:scale-105 -rotate-1",
							]}
						>
							{t.donate.choose} {tier.name}
						</button>
					</div>
				))}
			</div>
		</section>

		<!-- ONE-TIME: horizontal scroll instead of grid -->
		<section class="relative bg-fuchsia-900 p-4 md:p-10 border-t-[16px] border-b-[16px] border-t-lime-400 border-b-orange-500 -rotate-1">
			<h2 class="text-3xl md:text-6xl font-black font-serif text-orange-400 -rotate-3 mb-8 md:mb-10 line-through decoration-cyan-400 decoration-8">
				{t.donate.oneTime}
			</h2>
			<div class="flex gap-4 md:gap-8 overflow-x-auto pb-6 snap-x">
				{oneTimeTiers.map((tier: any, i: number) => (
					<div
						class:list={[
							"relative p-4 md:p-8 border-4 transition-all hover:z-20 hover:scale-105 shrink-0 w-72 md:w-96 snap-center",
							tier.highlighted
								? "bg-lime-400 text-fuchsia-800 border-fuchsia-600 rotate-2 shadow-[10px_10px_0_theme(colors.black),20px_20px_0_theme(colors.cyan.400)] border-8"
								: i % 3 === 0
									? "bg-black text-cyan-400 border-yellow-300 -rotate-2 shadow-[6px_6px_0_theme(colors.fuchsia.500)]"
									: i % 3 === 1
										? "bg-yellow-300 text-fuchsia-700 border-black rotate-3 shadow-[-4px_8px_0_theme(colors.lime.400)]"
										: "bg-cyan-800 text-lime-400 border-orange-500 -rotate-1 shadow-[8px_-4px_0_theme(colors.orange.500)]",
						]}
					>
						{tier.highlighted && (
							<span class="absolute -top-6 -left-4 md:-top-8 md:-left-6 bg-orange-500 text-white px-3 py-1 md:px-4 md:py-2 font-black text-xs md:text-sm uppercase -rotate-12 border-4 border-black font-serif shadow-[4px_4px_0_theme(colors.lime.400)]">
								{t.donate.greatestImpact}
							</span>
						)}

						<h3 class:list={[
							"font-black mb-2",
							tier.highlighted ? "text-2xl md:text-4xl font-mono -rotate-1" : "text-xl md:text-2xl font-serif rotate-1",
						]}>{tier.name}</h3>

						<p class="mb-4">
							<span class:list={[
								"font-black font-serif",
								tier.highlighted ? "text-5xl md:text-7xl" : "text-3xl md:text-5xl",
							]}>${tier.amount}</span>
						</p>

						<p class:list={[
							"text-sm mb-4 font-sans leading-relaxed",
							tier.highlighted ? "text-fuchsia-700 font-bold" : "opacity-90",
						]}>
							{tier.description}
						</p>

						<ul class="space-y-2 mb-6">
							{tier.perks.map((perk: string, j: number) => (
								<li
									class:list={[
										"text-xs md:text-sm font-bold pl-3 md:pl-4",
										j % 2 === 0 ? "border-l-4 border-orange-500 font-mono" : "border-l-4 border-cyan-400 font-serif",
									]}
								>
									{perk}
								</li>
							))}
						</ul>

						<button
							type="button"
							class:list={[
								"w-full py-3 md:py-4 px-4 font-black text-base md:text-lg uppercase border-4 transition-all cursor-pointer",
								tier.highlighted
									? "bg-fuchsia-600 text-lime-400 border-black hover:rotate-3 hover:scale-110 -rotate-1 shadow-[4px_4px_0_theme(colors.orange.500)]"
									: "bg-orange-500 text-white border-fuchsia-600 hover:-rotate-3 hover:scale-105 rotate-1",
							]}
						>
							{t.donate.give} ${tier.amount}
						</button>
					</div>
				))}
			</div>
		</section>
	</main>
</div>
