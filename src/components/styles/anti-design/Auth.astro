---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-[radial-gradient(circle_at_20%_80%,#a21caf_0%,#000_50%,#164e63_100%)] overflow-x-hidden">
	<!-- NAV: diagonal waterfall down the right side -->
	<nav class="absolute top-0 right-0 z-30 flex flex-col gap-0 w-[100px] md:w-[160px]">
		{nav.map((item: any, i: number) => (
			<a
				href={item.href}
				class:list={[
					"px-2 py-1 md:px-3 md:py-2 font-bold no-underline transition-all hover:scale-110 block text-[10px] md:text-xs",
					i % 4 === 0 && "bg-lime-400 text-black font-serif rotate-1 border-b-2 border-fuchsia-600 ml-0",
					i % 4 === 1 && "bg-fuchsia-600 text-yellow-300 font-mono -rotate-2 border-l-4 border-lime-400 ml-2 md:ml-4",
					i % 4 === 2 && "bg-black text-cyan-400 font-sans rotate-3 border-b-2 border-orange-500 ml-4 md:ml-8",
					i % 4 === 3 && "bg-orange-500 text-white font-serif -rotate-1 border-l-4 border-cyan-400 ml-6 md:ml-12",
				]}
			>
				{item.label}
			</a>
		))}
	</nav>

	<main class="flex items-center justify-center min-h-screen px-4 py-12">
		<div class="relative w-full max-w-lg md:max-w-xl">
			<!-- Background chaos shapes -->
			<div class="absolute -top-16 -left-16 w-48 h-48 bg-lime-400 opacity-15 rotate-45 -z-10 blur-sm"></div>
			<div class="absolute -bottom-12 -right-12 w-64 h-32 bg-fuchsia-500 opacity-20 -rotate-12 -z-10 blur-sm"></div>
			<div class="absolute top-1/2 -left-20 w-16 h-80 bg-orange-500 opacity-15 rotate-12 -z-10"></div>

			<!-- Title: HUGE and offset, overlapping the form -->
			<h1 class="text-6xl md:text-[8rem] font-black font-serif text-fuchsia-500 -rotate-6 leading-[0.8] mb-[-1rem] md:mb-[-3rem] relative z-10 drop-shadow-[4px_4px_0_theme(colors.lime.400)]">
				{t.auth.title}
			</h1>
			<p class="text-base md:text-xl font-mono text-cyan-400 rotate-2 ml-[20%] mb-4 md:mb-6 relative z-10">
				{t.auth.subtitle}
			</p>

			<!-- Form: the container itself is chaotic -->
			<form class="relative bg-black/90 backdrop-blur-sm p-6 md:p-10 border-8 border-lime-400 border-r-fuchsia-600 border-b-orange-500 rotate-1 z-0">
				<!-- Email: tilted left -->
				<div class="-rotate-2 mb-6 md:mb-8">
					<label for="email" class="block text-[10px] md:text-xs font-black uppercase tracking-[0.4em] text-lime-400 mb-2 font-mono border-b-2 border-fuchsia-600 pb-1 inline-block">
						{t.auth.email}
					</label>
					<input
						type="email"
						id="email"
						name="email"
						placeholder="you@example.com"
						class="w-full px-4 py-3 md:py-4 bg-fuchsia-950 text-yellow-300 border-4 border-fuchsia-500 border-l-8 border-l-lime-400 font-mono text-sm md:text-lg placeholder-fuchsia-700 focus:border-cyan-400 focus:outline-none shadow-[4px_4px_0_theme(colors.orange.500)]"
					/>
				</div>

				<!-- Password: tilted right, different style -->
				<div class="rotate-1 mb-6 md:mb-8 ml-4 md:ml-8">
					<label for="password" class="block text-[10px] md:text-xs font-black uppercase tracking-[0.4em] text-orange-400 mb-2 font-serif border-b-2 border-cyan-400 pb-1 inline-block">
						{t.auth.password}
					</label>
					<input
						type="password"
						id="password"
						name="password"
						placeholder="••••••••"
						class="w-full px-4 py-3 md:py-4 bg-cyan-950 text-lime-300 border-4 border-cyan-500 border-r-8 border-r-orange-500 font-mono text-sm md:text-lg placeholder-cyan-800 focus:border-fuchsia-400 focus:outline-none shadow-[-4px_4px_0_theme(colors.fuchsia.500)]"
					/>
				</div>

				<!-- Remember + forgot: fighting each other -->
				<div class="flex flex-wrap items-center justify-between gap-3 mb-6 md:mb-8 -rotate-1">
					<label class="flex items-center gap-2 cursor-pointer rotate-2">
						<input
							type="checkbox"
							name="remember"
							class="w-5 h-5 md:w-6 md:h-6 accent-lime-400"
						/>
						<span class="text-xs md:text-sm font-black font-sans text-yellow-300">{t.auth.rememberMe}</span>
					</label>
					<a href="#" class="text-[10px] md:text-xs font-black font-mono text-fuchsia-400 hover:text-lime-400 transition-colors no-underline underline decoration-fuchsia-600 decoration-2 hover:decoration-lime-400 -rotate-3 bg-black/50 px-2 py-1">
						{t.auth.forgotPassword}
					</a>
				</div>

				<!-- Submit: enormous -->
				<button
					type="submit"
					class="w-full py-4 md:py-6 px-6 bg-lime-400 text-black font-black text-lg md:text-2xl uppercase border-4 border-fuchsia-600 -rotate-2 hover:rotate-2 transition-all cursor-pointer font-sans shadow-[8px_8px_0_theme(colors.fuchsia.600)] hover:shadow-[-4px_-4px_0_theme(colors.cyan.400)] tracking-wider"
				>
					{t.auth.signIn}
				</button>
			</form>

			<!-- Social login: below, off-axis -->
			<div class="relative mt-6 md:mt-10 -rotate-1">
				<p class="text-center text-xs md:text-sm font-black font-mono text-fuchsia-400 mb-4 rotate-2">
					{t.auth.continueWith}
				</p>
				<div class="flex gap-3 md:gap-6 justify-center">
					<button
						type="button"
						class="px-6 py-3 md:px-10 md:py-4 bg-fuchsia-600 text-yellow-300 font-black text-sm md:text-xl border-4 border-cyan-400 rotate-6 hover:-rotate-2 transition-transform cursor-pointer font-serif uppercase shadow-[4px_4px_0_theme(colors.lime.400)]"
					>
						Google
					</button>
					<button
						type="button"
						class="px-6 py-3 md:px-10 md:py-4 bg-cyan-400 text-black font-black text-sm md:text-xl border-4 border-orange-500 -rotate-6 hover:rotate-2 transition-transform cursor-pointer font-mono uppercase shadow-[-4px_4px_0_theme(colors.fuchsia.500)]"
					>
						Apple
					</button>
				</div>
			</div>

			<!-- Sign up link: tiny, rotated, almost hidden -->
			<p class="mt-6 md:mt-10 text-right text-xs md:text-sm font-sans text-lime-300 rotate-3 pr-4">
				{t.auth.noAccount}{" "}
				<a href="#" class="font-black text-yellow-300 hover:text-fuchsia-400 transition-colors no-underline underline decoration-yellow-300 decoration-4 hover:decoration-fuchsia-400">
					{t.auth.signUp}
				</a>
			</p>
		</div>
	</main>
</div>
