---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-yellow-300 font-mono overflow-x-hidden">
	<nav class="flex flex-wrap items-center gap-2 px-4 py-3 bg-lime-400 border-b-8 border-fuchsia-600">
		{nav.map((item: any, i: number) => (
			<a
				href={item.href}
				class:list={[
					"px-3 py-1 font-bold no-underline transition-transform hover:scale-110",
					i % 3 === 0 && "bg-fuchsia-600 text-yellow-300 font-serif text-lg rotate-2",
					i % 3 === 1 && "bg-black text-lime-400 font-mono text-xs -rotate-1 uppercase tracking-widest",
					i % 3 === 2 && "bg-orange-500 text-white font-sans text-base rotate-1 border-2 border-cyan-400",
				]}
			>
				{item.label}
			</a>
		))}
	</nav>

	<main class="px-4 md:px-8 py-8">
		<div class="mb-12">
			<h1 class="text-6xl md:text-9xl font-black font-serif text-fuchsia-600 rotate-2 mb-2 drop-shadow-[6px_6px_0_black]">
				{t.blog.title}
			</h1>
			<p class="text-xl md:text-2xl font-sans text-black -rotate-1 ml-8 md:ml-20 bg-cyan-400/70 inline-block px-6 py-3 border-4 border-fuchsia-600">
				{t.blog.subtitle}
			</p>
		</div>

		<div class="space-y-8">
			{posts.map((post: any, i: number) => (
				<a
					href={`/${lang}/${style}/blog/${post.slug}`}
					class:list={[
						"block p-6 md:p-8 border-4 no-underline transition-transform hover:scale-[1.02]",
						i % 4 === 0 && "bg-black text-lime-400 border-fuchsia-500 rotate-1 font-mono hover:-rotate-1",
						i % 4 === 1 && "bg-fuchsia-600 text-yellow-300 border-cyan-400 -rotate-1 font-serif hover:rotate-1",
						i % 4 === 2 && "bg-cyan-400 text-black border-orange-500 rotate-2 font-sans hover:-rotate-2",
						i % 4 === 3 && "bg-orange-500 text-white border-lime-400 -rotate-2 font-mono hover:rotate-2",
					]}
				>
					<article>
						<time
							datetime={post.date}
							class:list={[
								"inline-block text-xs font-black uppercase tracking-widest mb-2 px-2 py-1",
								i % 2 === 0 ? "bg-yellow-300 text-black -rotate-2" : "bg-lime-400 text-fuchsia-700 rotate-1",
							]}
						>
							{post.date}
						</time>
						<h2 class="text-3xl md:text-5xl font-black mb-3 underline decoration-4">{post.title}</h2>
						<p class:list={[
							"text-base md:text-lg mb-4 leading-relaxed",
							i % 2 === 0 ? "font-serif" : "font-sans",
						]}>
							{post.excerpt}
						</p>
						<div class="flex flex-wrap gap-2 mb-3">
							{post.tags.map((tag: string, j: number) => (
								<span
									class:list={[
										"px-2 py-1 text-xs font-black uppercase border-2",
										j % 3 === 0 && "bg-fuchsia-500 text-white border-lime-400 rotate-2",
										j % 3 === 1 && "bg-lime-400 text-black border-fuchsia-600 -rotate-1",
										j % 3 === 2 && "bg-cyan-300 text-black border-orange-500 rotate-1",
									]}
								>
									{tag}
								</span>
							))}
						</div>
						<span class:list={[
							"inline-block text-sm font-bold",
							i % 2 === 0 ? "font-mono rotate-1" : "font-serif -rotate-1",
						]}>
							{t.blog.by} {post.author}
						</span>
					</article>
				</a>
			))}
		</div>
	</main>
</div>
