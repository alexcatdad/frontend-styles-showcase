---
const { lang, style, nav, cats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-amber-50 text-stone-700 font-serif antialiased">
	<!-- Navigation -->
	<nav class="py-5 px-6 lg:px-12 border-b border-amber-200">
		<div class="max-w-4xl mx-auto flex items-center justify-between">
			<a href={`${_base}/${lang}/${style}/`} class="text-lg text-green-800 tracking-wide hover:text-green-700 transition-colors">{t.cats.title}</a>
			<div class="flex items-center gap-5 md:gap-8">
				{nav.map((item: any) => (
					<a href={item.href} class="text-sm text-stone-500 hover:text-green-700 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main>
		<!-- Header -->
		<section class="pt-16 md:pt-24 pb-10 md:pb-14 px-6 lg:px-12">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-3xl md:text-5xl italic text-green-800 leading-tight">{t.cats.title}</h1>
				<p class="mt-4 text-base md:text-lg text-amber-700 max-w-md mx-auto leading-relaxed">{t.cats.subtitle}</p>
			</div>
		</section>

		<!-- Divider -->
		<div class="flex items-center justify-center pb-8">
			<span class="h-px flex-1 max-w-20 bg-amber-200"></span>
			<span class="mx-3 text-green-700/40 text-sm">&starf;</span>
			<span class="h-px flex-1 max-w-20 bg-amber-200"></span>
		</div>

		<!-- Cat cards -->
		<section class="pb-20 md:pb-32 px-6 lg:px-12">
			<div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
				{cats.map((cat: any) => (
					<a href={`${_base}/${lang}/${style}/cats/${cat.id}`} class="group block bg-white rounded-2xl border border-amber-200 shadow-sm overflow-hidden hover:shadow-md transition-shadow">
						<img src={cat.thumbnail} alt={cat.name} class="w-full h-48 md:h-56 object-cover" />
						<div class="p-6">
							<h2 class="text-xl text-green-800 group-hover:text-green-700 transition-colors">{cat.name}</h2>
							<p class="mt-1 text-sm text-amber-700">{cat.breed} &mdash; {cat.age}</p>
							<p class="mt-3 text-sm text-stone-500 leading-relaxed">{cat.description.slice(0, 120)}...</p>
						</div>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
