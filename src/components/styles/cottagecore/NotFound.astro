---
const { lang, style, nav, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-amber-50 text-stone-700 font-serif antialiased">
	<!-- Navigation -->
	<nav class="py-5 px-6 lg:px-12 border-b border-amber-200">
		<div class="max-w-4xl mx-auto flex items-center justify-between">
			<a href={`${_base}/${lang}/${style}/`} class="text-lg text-green-800 tracking-wide hover:text-green-700 transition-colors">404</a>
			<div class="flex items-center gap-5 md:gap-8">
				{nav.map((item: any) => (
					<a href={item.href} class="text-sm text-stone-500 hover:text-green-700 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="px-6 lg:px-12">
		<div class="max-w-3xl mx-auto pt-24 md:pt-40 pb-20 md:pb-32 text-center">
			<p class="text-[8rem] md:text-[12rem] font-bold leading-none text-green-200">{t.notFound.title}</p>
			<h2 class="mt-4 md:mt-6 text-2xl md:text-4xl italic text-green-800">{t.notFound.heading}</h2>
			<p class="mt-4 md:mt-6 text-base text-stone-500 leading-relaxed max-w-md mx-auto">{t.notFound.description}</p>

			<!-- Decorative divider -->
			<div class="flex items-center justify-center my-10">
				<span class="h-px flex-1 max-w-16 bg-amber-200"></span>
				<span class="mx-3 text-amber-600/50 text-sm">&starf;</span>
				<span class="h-px flex-1 max-w-16 bg-amber-200"></span>
			</div>

			<div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
				<a href={`${_base}/${lang}/${style}/`} class="px-8 py-3 bg-green-700 text-white rounded-full text-sm hover:bg-green-800 transition-colors">{t.notFound.backHome}</a>
				<a href={`${_base}/${lang}/${style}/cats`} class="px-8 py-3 border border-amber-700 text-amber-700 rounded-full text-sm hover:bg-amber-100 transition-colors">{t.notFound.meetCats}</a>
			</div>
		</div>
	</main>
</div>
