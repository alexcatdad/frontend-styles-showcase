---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-amber-50 text-stone-700 font-serif antialiased">
	<!-- Navigation -->
	<nav class="py-5 px-6 lg:px-12 border-b border-amber-200">
		<div class="max-w-4xl mx-auto flex items-center justify-between">
			<a href={`${_base}/${lang}/${style}/`} class="text-lg text-green-800 tracking-wide hover:text-green-700 transition-colors">{sanctuary.name}</a>
			<div class="flex items-center gap-5 md:gap-8">
				{nav.map((item: any) => (
					<a href={item.href} class="text-sm text-stone-500 hover:text-green-700 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main>
		<!-- Decorative divider -->
		<div class="flex items-center justify-center py-4">
			<span class="h-px flex-1 max-w-16 bg-amber-300"></span>
			<span class="mx-3 text-green-700/50 text-sm">&check;</span>
			<span class="h-px flex-1 max-w-16 bg-amber-300"></span>
		</div>

		<!-- Hero -->
		<section class="pt-12 md:pt-20 pb-16 md:pb-24 px-6 lg:px-12">
			<div class="max-w-4xl mx-auto text-center">
				<img src={sanctuary.heroImage} alt={sanctuary.name} class="w-full max-w-2xl mx-auto h-64 md:h-80 object-cover rounded-2xl mb-10 md:mb-14" />
				<h1 class="text-4xl md:text-5xl lg:text-6xl italic text-green-800 leading-tight">{sanctuary.name}</h1>
				<p class="mt-4 md:mt-6 text-lg md:text-xl text-amber-700 max-w-xl mx-auto leading-relaxed">{sanctuary.tagline}</p>
				<div class="mt-10 md:mt-14 flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
					<a href={`${_base}/${lang}/${style}/cats`} class="px-8 py-3 bg-green-700 text-white rounded-full text-sm hover:bg-green-800 transition-colors">{t.home.meetCats}</a>
					<a href={`${_base}/${lang}/${style}/donate`} class="px-8 py-3 border border-amber-700 text-amber-700 rounded-full text-sm hover:bg-amber-100 transition-colors">{t.home.donate}</a>
				</div>
			</div>
		</section>

		<!-- Flower divider -->
		<div class="flex items-center justify-center py-2">
			<span class="h-px flex-1 max-w-24 bg-amber-200"></span>
			<span class="mx-4 text-amber-600/60 text-lg">&starf;</span>
			<span class="h-px flex-1 max-w-24 bg-amber-200"></span>
		</div>

		<!-- Mission -->
		<section class="py-16 md:py-24 px-6 lg:px-12">
			<div class="max-w-3xl mx-auto">
				<div class="bg-white rounded-2xl shadow-sm border border-amber-200 p-8 md:p-12">
					<p class="text-sm uppercase tracking-wider text-amber-700 mb-6">{t.home.mission}</p>
					<p class="text-xl md:text-2xl text-green-800 leading-relaxed italic">{sanctuary.mission}</p>
				</div>
			</div>
		</section>

		<!-- Stats -->
		<section class="py-12 md:py-16 px-6 lg:px-12">
			<div class="max-w-3xl mx-auto">
				<div class="bg-white rounded-2xl shadow-sm border border-amber-200 p-8 md:p-12">
					<div class="flex flex-wrap justify-center gap-x-12 md:gap-x-20 gap-y-8">
						{sanctuary.stats.map((stat: any) => (
							<div class="text-center">
								<span class="block text-3xl md:text-4xl text-green-700 font-semibold">{stat.value}</span>
								<span class="text-sm text-stone-500 mt-1 block">{stat.label}</span>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Flower divider -->
		<div class="flex items-center justify-center py-2">
			<span class="h-px flex-1 max-w-24 bg-amber-200"></span>
			<span class="mx-4 text-green-700/40 text-lg">&starf;</span>
			<span class="h-px flex-1 max-w-24 bg-amber-200"></span>
		</div>

		<!-- About -->
		<section class="py-16 md:py-24 px-6 lg:px-12">
			<div class="max-w-3xl mx-auto">
				<p class="text-sm uppercase tracking-wider text-amber-700 mb-8">{t.home.aboutUs}</p>
				<div class="space-y-6">
					{sanctuary.about.map((paragraph: string) => (
						<p class="text-base md:text-lg text-stone-600 leading-loose">{paragraph}</p>
					))}
				</div>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="py-10 md:py-14 px-6 lg:px-12 border-t border-amber-200">
		<div class="max-w-4xl mx-auto text-center">
			<p class="text-sm text-stone-400">&starf; {sanctuary.name} &mdash; {t.footer.style}: {meta.name} &starf;</p>
		</div>
	</footer>
</div>
