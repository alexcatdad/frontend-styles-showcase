---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-amber-50 text-stone-700 font-serif antialiased">
	<!-- Navigation -->
	<nav class="py-5 px-6 lg:px-12 border-b border-amber-200">
		<div class="max-w-4xl mx-auto flex items-center justify-between">
			<a href={`${_base}/${lang}/${style}/`} class="text-lg text-green-800 tracking-wide hover:text-green-700 transition-colors">{cat.name}</a>
			<div class="flex items-center gap-5 md:gap-8">
				{nav.map((item: any) => (
					<a href={item.href} class="text-sm text-stone-500 hover:text-green-700 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main>
		<!-- Back link -->
		<section class="pt-8 md:pt-12 px-6 lg:px-12">
			<div class="max-w-3xl mx-auto">
				<a href={`${_base}/${lang}/${style}/cats`} class="text-sm text-green-700 hover:text-green-800 transition-colors">&larr; {t.cats.backToAll}</a>
			</div>
		</section>

		<!-- Cat profile -->
		<article class="pt-10 md:pt-16 pb-20 md:pb-32 px-6 lg:px-12">
			<div class="max-w-3xl mx-auto">
				<img src={cat.image} alt={cat.name} class="w-full aspect-[3/2] object-cover rounded-2xl border-2 border-amber-200 mb-10 md:mb-14" />

				<h1 class="text-3xl md:text-5xl italic text-green-800 leading-tight">{cat.name}</h1>

				<!-- Metadata -->
				<div class="mt-10 md:mt-14 bg-white rounded-2xl border border-amber-200 shadow-sm p-6 md:p-8 space-y-4">
					<div class="flex justify-between items-baseline border-b border-amber-100 pb-4">
						<span class="text-sm text-amber-700">{t.cats.breed}</span>
						<span class="text-sm text-stone-700">{cat.breed}</span>
					</div>
					<div class="flex justify-between items-baseline border-b border-amber-100 pb-4">
						<span class="text-sm text-amber-700">{t.cats.age}</span>
						<span class="text-sm text-stone-700">{cat.age}</span>
					</div>
					<div class="flex justify-between items-baseline border-b border-amber-100 pb-4">
						<span class="text-sm text-amber-700">{t.cats.gender}</span>
						<span class="text-sm text-stone-700">{cat.gender}</span>
					</div>
					<div class="flex justify-between items-baseline border-b border-amber-100 pb-4">
						<span class="text-sm text-amber-700">{t.cats.color}</span>
						<span class="text-sm text-stone-700">{cat.color}</span>
					</div>
					<div class="flex justify-between items-baseline border-b border-amber-100 pb-4">
						<span class="text-sm text-amber-700">{t.cats.arrived}</span>
						<span class="text-sm text-stone-700">{cat.arrivalDate}</span>
					</div>
					<div class="flex justify-between items-baseline">
						<span class="text-sm text-amber-700">{t.cats.status}</span>
						<span class="text-sm text-stone-700">{cat.status}</span>
					</div>
				</div>

				<!-- Personality -->
				<div class="mt-8 flex flex-wrap gap-2">
					{cat.personality.map((trait: string) => (
						<span class="px-4 py-1.5 bg-green-100 text-green-800 text-sm rounded-full">{trait}</span>
					))}
				</div>

				<!-- Description -->
				<p class="mt-10 md:mt-14 text-base md:text-lg text-stone-600 leading-loose">{cat.description}</p>

				<!-- Adopt button -->
				<div class="mt-10 md:mt-14">
					<a href={`${_base}/${lang}/${style}/auth`} class="inline-block px-10 py-3 bg-green-700 text-white rounded-full text-sm hover:bg-green-800 transition-colors">{t.cats.adopt} {cat.name}</a>
				</div>
			</div>
		</article>

		<!-- Divider -->
		<div class="flex items-center justify-center py-2">
			<span class="h-px flex-1 max-w-24 bg-amber-200"></span>
			<span class="mx-4 text-amber-600/50 text-lg">&starf;</span>
			<span class="h-px flex-1 max-w-24 bg-amber-200"></span>
		</div>

		<!-- Other cats -->
		<section class="py-16 md:py-24 px-6 lg:px-12">
			<div class="max-w-3xl mx-auto">
				<p class="text-sm uppercase tracking-wider text-amber-700 mb-10">{t.cats.otherCats}</p>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
					{otherCats.map((c: any) => (
						<a href={`${_base}/${lang}/${style}/cats/${c.id}`} class="group block bg-white rounded-2xl border border-amber-200 p-5 hover:shadow-sm transition-shadow">
							<h3 class="text-lg text-green-800 group-hover:text-green-700 transition-colors">{c.name}</h3>
							<p class="mt-1 text-sm text-amber-700">{c.breed} &mdash; {c.age}</p>
						</a>
					))}
				</div>
			</div>
		</section>
	</main>
</div>
