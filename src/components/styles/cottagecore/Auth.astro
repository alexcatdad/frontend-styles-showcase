---
const { lang, style, nav, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-amber-50 text-stone-700 font-serif antialiased">
	<!-- Navigation -->
	<nav class="py-5 px-6 lg:px-12 border-b border-amber-200">
		<div class="max-w-4xl mx-auto flex items-center justify-between">
			<a href={`${_base}/${lang}/${style}/`} class="text-lg text-green-800 tracking-wide hover:text-green-700 transition-colors">{t.auth.title}</a>
			<div class="flex items-center gap-5 md:gap-8">
				{nav.map((item: any) => (
					<a href={item.href} class="text-sm text-stone-500 hover:text-green-700 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main class="px-6 lg:px-12">
		<div class="max-w-md mx-auto pt-20 md:pt-32 pb-20 md:pb-32">
			<!-- Auth card -->
			<div class="bg-white rounded-2xl border border-amber-200 shadow-sm p-8 md:p-10">
				<div class="text-center mb-8">
					<h1 class="text-2xl md:text-3xl italic text-green-800">{t.auth.title}</h1>
					<p class="mt-2 text-sm text-stone-500 leading-relaxed">{t.auth.subtitle}</p>
				</div>

				<form class="space-y-6">
					<div>
						<label for="email" class="block text-sm text-amber-700 mb-2">{t.auth.email}</label>
						<input type="email" id="email" name="email" placeholder="you@example.com" class="w-full px-4 py-3 bg-amber-50/50 border border-amber-300 rounded-xl text-sm text-stone-700 focus:border-green-500 focus:outline-none transition-colors" />
					</div>
					<div>
						<label for="password" class="block text-sm text-amber-700 mb-2">{t.auth.password}</label>
						<input type="password" id="password" name="password" placeholder="--------" class="w-full px-4 py-3 bg-amber-50/50 border border-amber-300 rounded-xl text-sm text-stone-700 focus:border-green-500 focus:outline-none transition-colors" />
					</div>
					<div class="flex items-center justify-between">
						<label class="flex items-center gap-2 cursor-pointer">
							<input type="checkbox" name="remember" class="w-4 h-4 rounded accent-green-700" />
							<span class="text-sm text-stone-500">{t.auth.rememberMe}</span>
						</label>
						<a href="#" class="text-sm text-green-700 hover:text-green-800 transition-colors">{t.auth.forgotPassword}</a>
					</div>
					<button type="submit" class="w-full py-3 bg-green-700 text-white rounded-full text-sm hover:bg-green-800 transition-colors">{t.auth.signIn}</button>
				</form>

				<!-- Divider -->
				<div class="flex items-center my-8">
					<span class="h-px flex-1 bg-amber-200"></span>
					<span class="mx-4 text-xs text-stone-400">{t.auth.continueWith}</span>
					<span class="h-px flex-1 bg-amber-200"></span>
				</div>

				<!-- Social auth -->
				<div class="flex gap-4">
					<button type="button" class="flex-1 py-2.5 border border-amber-300 text-stone-600 rounded-full text-sm hover:bg-amber-100 transition-colors">Google</button>
					<button type="button" class="flex-1 py-2.5 border border-amber-300 text-stone-600 rounded-full text-sm hover:bg-amber-100 transition-colors">Apple</button>
				</div>
			</div>

			<!-- Sign up link -->
			<p class="mt-8 text-center text-sm text-stone-500">
				{t.auth.noAccount} <a href="#" class="text-green-700 hover:text-green-800 transition-colors">{t.auth.signUp}</a>
			</p>
		</div>
	</main>
</div>
