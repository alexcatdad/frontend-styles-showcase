---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-amber-50 text-stone-700 font-serif antialiased">
	<!-- Navigation -->
	<nav class="py-5 px-6 lg:px-12 border-b border-amber-200">
		<div class="max-w-4xl mx-auto flex items-center justify-between">
			<a href={`${_base}/${lang}/${style}/`} class="text-lg text-green-800 tracking-wide hover:text-green-700 transition-colors">{post.title}</a>
			<div class="flex items-center gap-5 md:gap-8">
				{nav.map((item: any) => (
					<a href={item.href} class="text-sm text-stone-500 hover:text-green-700 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main>
		<!-- Back link -->
		<section class="pt-8 md:pt-12 px-6 lg:px-12">
			<div class="max-w-3xl mx-auto">
				<a href={`${_base}/${lang}/${style}/blog`} class="text-sm text-green-700 hover:text-green-800 transition-colors">&larr; {t.blog.backToBlog}</a>
			</div>
		</section>

		<!-- Article -->
		<article class="pt-10 md:pt-16 pb-20 md:pb-32 px-6 lg:px-12">
			<div class="max-w-3xl mx-auto">
				<header class="mb-12 md:mb-16">
					<img src={post.image} alt={post.title} class="w-full h-56 md:h-72 object-cover rounded-2xl border border-amber-200 mb-8" />
					<time datetime={post.date} class="text-sm text-amber-700 block">{post.date}</time>
					<h1 class="mt-3 text-3xl md:text-4xl lg:text-5xl italic text-green-800 leading-tight">{post.title}</h1>
					<p class="mt-4 text-sm text-stone-500">{t.blog.by} {post.author}</p>
				</header>

				<!-- Content -->
				<div class="space-y-6">
					{post.content.map((paragraph: string) => (
						<p class="text-base md:text-lg text-stone-600 leading-loose">{paragraph}</p>
					))}
				</div>

				<!-- Tags -->
				<div class="mt-12 flex flex-wrap gap-2">
					{post.tags.map((tag: string) => (
						<span class="px-4 py-1.5 bg-amber-100 text-amber-800 text-sm rounded-full">{tag}</span>
					))}
				</div>
			</div>
		</article>

		<!-- Divider -->
		<div class="flex items-center justify-center py-2">
			<span class="h-px flex-1 max-w-24 bg-amber-200"></span>
			<span class="mx-4 text-green-700/40 text-lg">&starf;</span>
			<span class="h-px flex-1 max-w-24 bg-amber-200"></span>
		</div>

		<!-- More stories -->
		<section class="py-16 md:py-24 px-6 lg:px-12">
			<div class="max-w-3xl mx-auto">
				<p class="text-sm uppercase tracking-wider text-amber-700 mb-10">{t.blog.moreStories}</p>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
					{otherPosts.map((p: any) => (
						<a href={`${_base}/${lang}/${style}/blog/${p.slug}`} class="group block bg-white rounded-2xl border border-amber-200 p-6 hover:shadow-sm transition-shadow">
							<time datetime={p.date} class="text-xs text-amber-700 block">{p.date}</time>
							<h3 class="mt-2 text-lg text-green-800 leading-snug group-hover:text-green-700 transition-colors">{p.title}</h3>
							<p class="mt-2 text-sm text-stone-500 leading-relaxed">{p.excerpt}</p>
						</a>
					))}
				</div>
			</div>
		</section>
	</main>
</div>
