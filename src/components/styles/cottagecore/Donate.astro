---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-amber-50 text-stone-700 font-serif antialiased">
	<!-- Navigation -->
	<nav class="py-5 px-6 lg:px-12 border-b border-amber-200">
		<div class="max-w-4xl mx-auto flex items-center justify-between">
			<a href={`${_base}/${lang}/${style}/`} class="text-lg text-green-800 tracking-wide hover:text-green-700 transition-colors">{t.donate.title}</a>
			<div class="flex items-center gap-5 md:gap-8">
				{nav.map((item: any) => (
					<a href={item.href} class="text-sm text-stone-500 hover:text-green-700 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<main>
		<!-- Header -->
		<section class="pt-16 md:pt-24 pb-10 md:pb-14 px-6 lg:px-12">
			<div class="max-w-4xl mx-auto text-center">
				<h1 class="text-3xl md:text-5xl italic text-green-800 leading-tight">{t.donate.title}</h1>
				<p class="mt-4 text-base md:text-lg text-amber-700 max-w-md mx-auto leading-relaxed">{t.donate.subtitle}</p>
			</div>
		</section>

		<!-- Divider -->
		<div class="flex items-center justify-center pb-8">
			<span class="h-px flex-1 max-w-20 bg-amber-200"></span>
			<span class="mx-3 text-green-700/40 text-sm">&starf;</span>
			<span class="h-px flex-1 max-w-20 bg-amber-200"></span>
		</div>

		<!-- Monthly tiers -->
		<section class="pb-16 md:pb-24 px-6 lg:px-12">
			<div class="max-w-4xl mx-auto">
				<p class="text-sm uppercase tracking-wider text-amber-700 mb-8 text-center">{t.donate.monthly}</p>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					{monthlyTiers.map((tier: any) => (
						<div class={`rounded-2xl border shadow-sm p-6 md:p-8 flex flex-col ${tier.highlighted ? 'bg-green-50 border-green-300' : 'bg-white border-amber-200'}`}>
							<span class="text-3xl md:text-4xl text-green-700 font-semibold">${tier.amount}</span>
							<span class="text-xs text-stone-500 mt-1">{t.donate.perMonth}</span>
							<h3 class="mt-4 text-lg text-green-800">{tier.name}</h3>
							{tier.highlighted && (
								<span class="mt-2 inline-block text-xs text-green-700 font-medium">{t.donate.mostPopular}</span>
							)}
							<p class="mt-3 text-sm text-stone-500 leading-relaxed flex-1">{tier.description}</p>
							<div class="mt-4 space-y-1.5">
								{tier.perks.map((perk: string) => (
									<p class="text-sm text-stone-600">&starf; {perk}</p>
								))}
							</div>
							<a href="#" class={`mt-6 inline-block text-center px-6 py-2.5 rounded-full text-sm transition-colors ${tier.highlighted ? 'bg-green-700 text-white hover:bg-green-800' : 'border border-amber-700 text-amber-700 hover:bg-amber-100'}`}>{t.donate.choose} {tier.name}</a>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- Divider -->
		<div class="flex items-center justify-center py-2">
			<span class="h-px flex-1 max-w-24 bg-amber-200"></span>
			<span class="mx-4 text-amber-600/50 text-lg">&starf;</span>
			<span class="h-px flex-1 max-w-24 bg-amber-200"></span>
		</div>

		<!-- One-time tiers -->
		<section class="py-16 md:py-24 px-6 lg:px-12">
			<div class="max-w-4xl mx-auto">
				<p class="text-sm uppercase tracking-wider text-amber-700 mb-8 text-center">{t.donate.oneTime}</p>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					{oneTimeTiers.map((tier: any) => (
						<div class={`rounded-2xl border shadow-sm p-6 md:p-8 flex flex-col ${tier.highlighted ? 'bg-green-50 border-green-300' : 'bg-white border-amber-200'}`}>
							<span class="text-3xl md:text-4xl text-green-700 font-semibold">${tier.amount}</span>
							<h3 class="mt-4 text-lg text-green-800">{tier.name}</h3>
							{tier.highlighted && (
								<span class="mt-2 inline-block text-xs text-green-700 font-medium">{t.donate.greatestImpact}</span>
							)}
							<p class="mt-3 text-sm text-stone-500 leading-relaxed flex-1">{tier.description}</p>
							<div class="mt-4 space-y-1.5">
								{tier.perks.map((perk: string) => (
									<p class="text-sm text-stone-600">&starf; {perk}</p>
								))}
							</div>
							<a href="#" class={`mt-6 inline-block text-center px-6 py-2.5 rounded-full text-sm transition-colors ${tier.highlighted ? 'bg-green-700 text-white hover:bg-green-800' : 'border border-amber-700 text-amber-700 hover:bg-amber-100'}`}>{t.donate.give} ${tier.amount}</a>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>
</div>
