---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-stone-50 text-stone-800 flex flex-col">
	<!-- Masthead nav -->
	<header class="max-w-6xl mx-auto w-full px-6 pt-6">
		<hr class="border-t-2 border-stone-900 mb-1" />
		<hr class="border-t border-stone-400" />
		<nav class="flex items-center justify-center gap-6 md:gap-10 py-3 border-b border-stone-300">
			{nav.map((item: any) => (
				<a href={item.href} class="font-serif text-xs md:text-sm tracking-[0.25em] uppercase text-stone-500 hover:text-stone-900 transition-colors">{item.label}</a>
			))}
		</nav>
	</header>

	<main class="flex-1 flex items-center justify-center px-6">
		<section class="max-w-3xl w-full py-20">
			<!-- Newspaper-style 404 layout -->
			<div class="md:grid md:grid-cols-5 md:gap-12 items-center">
				<!-- Big number in feature column -->
				<div class="md:col-span-2 text-center md:text-right md:border-r md:border-stone-300 md:pr-12 mb-8 md:mb-0">
					<span class="font-serif text-9xl md:text-[10rem] font-light text-stone-200 leading-none">{t.notFound.title}</span>
				</div>

				<!-- Text content -->
				<div class="md:col-span-3">
					<p class="text-xs tracking-[0.3em] uppercase text-amber-700 mb-4">Page Not Found</p>
					<h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-light text-stone-900 leading-tight mb-4">{t.notFound.heading}</h2>
					<hr class="w-12 border-t border-stone-300 mb-6" />
					<p class="text-stone-500 leading-relaxed mb-10 max-w-md">{t.notFound.description}</p>
					<div class="flex flex-col sm:flex-row gap-4">
						<a href={`/${lang}/${style}/`} class="px-8 py-3 bg-stone-800 text-stone-50 font-serif text-xs tracking-[0.3em] uppercase hover:bg-stone-900 transition-colors text-center">{t.notFound.backHome}</a>
						<a href={`/${lang}/${style}/cats`} class="px-8 py-3 border border-stone-400 text-stone-700 font-serif text-xs tracking-[0.3em] uppercase hover:border-stone-800 hover:text-stone-900 transition-colors text-center">{t.notFound.meetCats}</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</div>
