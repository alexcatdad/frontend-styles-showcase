---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
---

<div class="min-h-screen bg-stone-50 text-stone-800">
	<nav class="max-w-5xl mx-auto px-6 py-6 flex items-center justify-center gap-8 border-b border-stone-300">
		{nav.map((item: any) => (
			<a href={item.href} class="font-serif text-sm tracking-widest uppercase text-stone-500 hover:text-stone-900 transition-colors">{item.label}</a>
		))}
	</nav>

	<main class="max-w-4xl mx-auto px-6">
		<div class="pt-8 pb-4">
			<a href={`/${lang}/${style}/blog`} class="text-sm tracking-widest uppercase text-stone-400 hover:text-stone-700 transition-colors">&larr; {t.blog.backToBlog}</a>
		</div>

		<article class="pb-16">
			<header class="text-center pt-8 pb-12 border-b border-stone-200 mb-12">
				<div class="flex flex-wrap justify-center gap-3 mb-6">
					{post.tags.map((tag: string) => (
						<span class="text-xs tracking-widest uppercase text-amber-700">{tag}</span>
					))}
				</div>
				<h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-stone-900 leading-tight mb-6 max-w-3xl mx-auto">{post.title}</h1>
				<hr class="w-16 mx-auto border-t border-stone-300 mb-6" />
				<div class="flex items-center justify-center gap-4 text-sm text-stone-400">
					<span class="font-serif italic">{t.blog.by} {post.author}</span>
					<span class="text-stone-300">|</span>
					<time datetime={post.date} class="tracking-widest uppercase text-xs">{post.date}</time>
				</div>
			</header>

			<div class="max-w-2xl mx-auto">
				{post.content.map((paragraph: string, i: number) => (
					<p class:list={[
						"text-lg leading-loose text-stone-600 mb-8",
						i === 0 && "first-letter:text-6xl first-letter:font-serif first-letter:font-light first-letter:float-left first-letter:mr-3 first-letter:mt-1 first-letter:leading-none first-letter:text-stone-900",
						i === Math.floor(post.content.length / 2) && "font-serif text-2xl italic text-stone-700 border-l-2 border-amber-700 pl-8 my-12 leading-relaxed"
					]}>{paragraph}</p>
				))}
			</div>
		</article>

		<section class="border-t border-stone-300 py-16">
			<h2 class="font-serif text-3xl font-light text-stone-900 text-center mb-3">{t.blog.moreStories}</h2>
			<hr class="w-12 mx-auto border-t border-amber-700 mb-10" />
			<div class="grid grid-cols-1 md:grid-cols-3 gap-10">
				{otherPosts.map((p: any) => (
					<a href={`/${lang}/${style}/blog/${p.slug}`} class="group block">
						<time datetime={p.date} class="text-xs tracking-widest uppercase text-stone-400 mb-2 block">{p.date}</time>
						<h3 class="font-serif text-xl font-light text-stone-800 mb-2 group-hover:text-amber-800 transition-colors leading-snug">{p.title}</h3>
						<p class="text-sm text-stone-500 leading-relaxed">{p.excerpt}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
