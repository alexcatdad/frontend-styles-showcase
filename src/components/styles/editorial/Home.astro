---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-stone-50 text-stone-800">
	<!-- Masthead -->
	<header class="max-w-6xl mx-auto px-6 pt-8 pb-0">
		<div class="text-center mb-4">
			<p class="text-xs tracking-[0.35em] uppercase text-stone-400 mb-2">{sanctuary.tagline}</p>
			<h1 class="font-serif text-6xl md:text-8xl lg:text-9xl font-light text-stone-900 leading-none tracking-tight">{sanctuary.name}</h1>
		</div>
		<hr class="border-t-2 border-stone-900 mb-1" />
		<hr class="border-t border-stone-400 mb-0" />
		<nav class="flex items-center justify-center gap-6 md:gap-10 py-3 border-b border-stone-300">
			{nav.map((item: any) => (
				<a href={item.href} class="font-serif text-xs md:text-sm tracking-[0.25em] uppercase text-stone-500 hover:text-stone-900 transition-colors">{item.label}</a>
			))}
		</nav>
	</header>

	<main>
		<!-- Lead section: asymmetric 2-column -->
		<section class="max-w-6xl mx-auto px-6 py-14 md:py-20">
			<div class="md:grid md:grid-cols-5 md:gap-12 items-start">
				<!-- Feature column (wide) -->
				<div class="md:col-span-3 md:border-r md:border-stone-300 md:pr-12">
					<img src={sanctuary.heroImage} alt={sanctuary.name} class="w-full h-64 md:h-80 lg:h-96 object-cover mb-8" />
					<p class="text-xs tracking-[0.3em] uppercase text-amber-700 mb-4">{t.home.mission}</p>
					<p class="font-serif text-2xl md:text-3xl lg:text-4xl leading-snug text-stone-700 italic mb-8">{sanctuary.mission}</p>
					<hr class="w-20 border-t border-stone-300 mb-8" />
					<div class="flex flex-col sm:flex-row gap-4">
						<a href={`/${lang}/${style}/cats`} class="px-8 py-3 bg-stone-800 text-stone-50 font-serif text-xs tracking-[0.3em] uppercase hover:bg-stone-900 transition-colors text-center">{t.home.meetCats}</a>
						<a href={`/${lang}/${style}/donate`} class="px-8 py-3 border border-stone-400 text-stone-700 font-serif text-xs tracking-[0.3em] uppercase hover:border-stone-800 hover:text-stone-900 transition-colors text-center">{t.home.donate}</a>
					</div>
				</div>

				<!-- Sidebar column (narrow) — stats woven into prose style -->
				<aside class="md:col-span-2 mt-10 md:mt-0">
					<p class="text-xs tracking-[0.3em] uppercase text-stone-400 mb-6">By the Numbers</p>
					<div class="space-y-6">
						{sanctuary.stats.map((stat: any, i: number) => (
							<div>
								<span class="font-serif text-5xl md:text-6xl font-light text-stone-900 leading-none">{stat.value}</span>
								<p class="text-sm text-stone-500 mt-1 tracking-wide leading-relaxed">{stat.label}</p>
								{i < sanctuary.stats.length - 1 && <hr class="border-t border-stone-200 mt-6" />}
							</div>
						))}
					</div>
				</aside>
			</div>
		</section>

		<!-- Thin double rule divider -->
		<div class="max-w-6xl mx-auto px-6">
			<hr class="border-t border-stone-300" />
		</div>

		<!-- About section: multi-column flowing text with pull quote -->
		<section class="max-w-6xl mx-auto px-6 py-16">
			<div class="md:grid md:grid-cols-6 md:gap-10 items-start">
				<!-- Section label (narrow left gutter) -->
				<div class="md:col-span-1 mb-6 md:mb-0">
					<h2 class="font-serif text-xs tracking-[0.3em] uppercase text-stone-400 md:sticky md:top-8">{t.home.aboutUs}</h2>
					<hr class="w-8 border-t border-amber-700 mt-3 hidden md:block" />
				</div>

				<!-- Main text body (multi-column) -->
				<div class="md:col-span-5">
					<div class="lg:columns-2 gap-10 text-stone-600 leading-loose text-base">
						{sanctuary.about.map((paragraph: string, i: number) => (
							<p class:list={[
								"mb-6 break-inside-avoid",
								i === 0 && "first-letter:text-6xl first-letter:font-serif first-letter:font-light first-letter:float-left first-letter:mr-3 first-letter:leading-[0.8] first-letter:text-stone-900 first-letter:mt-1"
							]}>{paragraph}</p>
						))}
					</div>

					{sanctuary.about.length > 1 && (
						<aside class="border-l-2 border-amber-700 pl-8 my-10 max-w-xl">
							<p class="font-serif text-2xl italic text-stone-700 leading-relaxed">{sanctuary.mission}</p>
						</aside>
					)}
				</div>
			</div>
		</section>

		<!-- Contact dateline -->
		<div class="max-w-6xl mx-auto px-6 pb-6">
			<hr class="border-t border-stone-300 mb-6" />
			<div class="md:flex md:justify-between md:items-baseline">
				<p class="text-xs tracking-[0.3em] uppercase text-stone-400">{sanctuary.contact.email}</p>
				<p class="text-xs tracking-[0.3em] uppercase text-stone-400 mt-2 md:mt-0">{sanctuary.contact.phone}</p>
				<p class="text-xs tracking-[0.3em] uppercase text-stone-400 mt-2 md:mt-0">{sanctuary.contact.address}</p>
			</div>
		</div>
	</main>

	<footer class="max-w-6xl mx-auto px-6 py-6 border-t border-stone-900">
		<hr class="border-t border-stone-400 -mt-[5px] mb-4" />
		<p class="text-xs tracking-[0.25em] uppercase text-stone-400 text-center">&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.</p>
	</footer>
</div>
