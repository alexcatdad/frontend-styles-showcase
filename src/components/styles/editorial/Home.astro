---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-stone-50 text-stone-800">
	<nav class="max-w-5xl mx-auto px-6 py-6 flex items-center justify-center gap-8 border-b border-stone-300">
		{nav.map((item: any) => (
			<a href={item.href} class="font-serif text-sm tracking-widest uppercase text-stone-500 hover:text-stone-900 transition-colors">{item.label}</a>
		))}
	</nav>

	<main>
		<section class="max-w-5xl mx-auto px-6 pt-20 pb-16 text-center">
			<p class="font-serif text-sm tracking-widest uppercase text-stone-400 mb-4">{sanctuary.tagline}</p>
			<h1 class="font-serif text-5xl md:text-7xl lg:text-8xl font-light text-stone-900 leading-tight mb-8">{sanctuary.name}</h1>
			<hr class="w-16 mx-auto border-t border-stone-400 mb-8" />
			<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
				<a href={`/${lang}/${style}/cats`} class="px-8 py-3 bg-stone-800 text-stone-50 font-serif text-sm tracking-widest uppercase hover:bg-stone-900 transition-colors">{t.home.meetCats}</a>
				<a href={`/${lang}/${style}/donate`} class="px-8 py-3 border border-stone-400 text-stone-700 font-serif text-sm tracking-widest uppercase hover:border-stone-800 hover:text-stone-900 transition-colors">{t.home.donate}</a>
			</div>
		</section>

		<section class="max-w-3xl mx-auto px-6 py-16">
			<h2 class="font-serif text-3xl md:text-4xl font-light text-stone-900 text-center mb-3">{t.home.mission}</h2>
			<hr class="w-12 mx-auto border-t border-amber-700 mb-8" />
			<p class="font-serif text-xl md:text-2xl leading-relaxed text-stone-600 text-center italic">{sanctuary.mission}</p>
		</section>

		<section class="max-w-4xl mx-auto px-6 py-12">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-8 border-y border-stone-300 py-10">
				{sanctuary.stats.map((stat: any) => (
					<div class="text-center">
						<span class="block font-serif text-4xl md:text-5xl font-light text-stone-900">{stat.value}</span>
						<span class="block mt-2 text-xs tracking-widest uppercase text-stone-500">{stat.label}</span>
					</div>
				))}
			</div>
		</section>

		<section class="max-w-3xl mx-auto px-6 py-16">
			<h2 class="font-serif text-3xl md:text-4xl font-light text-stone-900 text-center mb-3">{t.home.aboutUs}</h2>
			<hr class="w-12 mx-auto border-t border-amber-700 mb-10" />
			<div class="md:columns-2 gap-10 text-stone-600 leading-relaxed">
				{sanctuary.about.map((paragraph: string, i: number) => (
					<p class:list={["mb-6", i === 0 && "first-letter:text-5xl first-letter:font-serif first-letter:font-light first-letter:float-left first-letter:mr-2 first-letter:leading-none first-letter:text-stone-900"]}>{paragraph}</p>
				))}
			</div>
		</section>
	</main>

	<footer class="max-w-5xl mx-auto px-6 py-8 border-t border-stone-300 text-center">
		<p class="text-xs tracking-widest uppercase text-stone-400">&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.</p>
	</footer>
</div>
