---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-stone-50 text-stone-800">
	<nav class="max-w-5xl mx-auto px-6 py-6 flex items-center justify-center gap-8 border-b border-stone-300">
		{nav.map((item: any) => (
			<a href={item.href} class="font-serif text-sm tracking-widest uppercase text-stone-500 hover:text-stone-900 transition-colors">{item.label}</a>
		))}
	</nav>

	<main class="max-w-5xl mx-auto px-6">
		<div class="pt-16 pb-10 text-center">
			<h1 class="font-serif text-5xl md:text-6xl font-light text-stone-900 mb-3">{t.donate.title}</h1>
			<hr class="w-12 mx-auto border-t border-amber-700 mb-4" />
			<p class="text-stone-500 text-lg max-w-xl mx-auto">{t.donate.subtitle}</p>
		</div>

		<section class="py-12">
			<h2 class="font-serif text-3xl font-light text-stone-900 text-center mb-10">{t.donate.monthly}</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-stone-200">
				{monthlyTiers.map((tier: any) => (
					<div class:list={[
						"bg-stone-50 p-8 flex flex-col",
						tier.highlighted && "bg-white ring-1 ring-amber-700 relative"
					]}>
						{tier.highlighted && <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-amber-700 text-white text-xs tracking-widest uppercase px-4 py-1">{t.donate.mostPopular}</span>}
						<h3 class="font-serif text-2xl font-light text-stone-900 mb-2">{tier.name}</h3>
						<p class="mb-4">
							<span class="font-serif text-4xl font-light text-stone-900">${tier.amount}</span>
							<span class="text-sm text-stone-400 tracking-wide">{t.donate.perMonth}</span>
						</p>
						<hr class="w-8 border-t border-stone-300 mb-4" />
						<p class="text-stone-500 text-sm leading-relaxed mb-6">{tier.description}</p>
						<ul class="space-y-2 mb-8 flex-1">
							{tier.perks.map((perk: string) => (
								<li class="text-sm text-stone-600 pl-4 border-l border-stone-200">{perk}</li>
							))}
						</ul>
						<button type="button" class:list={[
							"w-full py-3 font-serif text-sm tracking-widest uppercase transition-colors",
							tier.highlighted
								? "bg-amber-700 text-white hover:bg-amber-800"
								: "bg-stone-800 text-stone-50 hover:bg-stone-900"
						]}>{t.donate.choose} {tier.name}</button>
					</div>
				))}
			</div>
		</section>

		<section class="py-12 pb-20">
			<h2 class="font-serif text-3xl font-light text-stone-900 text-center mb-10">{t.donate.oneTime}</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-stone-200">
				{oneTimeTiers.map((tier: any) => (
					<div class:list={[
						"bg-stone-50 p-8 flex flex-col",
						tier.highlighted && "bg-white ring-1 ring-amber-700 relative"
					]}>
						{tier.highlighted && <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-amber-700 text-white text-xs tracking-widest uppercase px-4 py-1">{t.donate.greatestImpact}</span>}
						<h3 class="font-serif text-2xl font-light text-stone-900 mb-2">{tier.name}</h3>
						<p class="mb-4">
							<span class="font-serif text-4xl font-light text-stone-900">${tier.amount}</span>
						</p>
						<hr class="w-8 border-t border-stone-300 mb-4" />
						<p class="text-stone-500 text-sm leading-relaxed mb-6">{tier.description}</p>
						<ul class="space-y-2 mb-8 flex-1">
							{tier.perks.map((perk: string) => (
								<li class="text-sm text-stone-600 pl-4 border-l border-stone-200">{perk}</li>
							))}
						</ul>
						<button type="button" class:list={[
							"w-full py-3 font-serif text-sm tracking-widest uppercase transition-colors",
							tier.highlighted
								? "bg-amber-700 text-white hover:bg-amber-800"
								: "bg-stone-800 text-stone-50 hover:bg-stone-900"
						]}>{t.donate.give} ${tier.amount}</button>
					</div>
				))}
			</div>
		</section>
	</main>
</div>
