---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-stone-50 text-stone-800">
	<!-- Masthead nav -->
	<header class="max-w-6xl mx-auto px-6 pt-6">
		<hr class="border-t-2 border-stone-900 mb-1" />
		<hr class="border-t border-stone-400" />
		<nav class="flex items-center justify-center gap-6 md:gap-10 py-3 border-b border-stone-300">
			{nav.map((item: any) => (
				<a href={item.href} class="font-serif text-xs md:text-sm tracking-[0.25em] uppercase text-stone-500 hover:text-stone-900 transition-colors">{item.label}</a>
			))}
		</nav>
	</header>

	<main class="max-w-6xl mx-auto px-6">
		<!-- Massive headline -->
		<div class="pt-14 pb-4">
			<h1 class="font-serif text-6xl md:text-7xl lg:text-8xl font-light text-stone-900 leading-none tracking-tight">{t.donate.title}</h1>
		</div>
		<div class="pb-8 border-b border-stone-300">
			<p class="text-stone-500 text-lg max-w-lg">{t.donate.subtitle}</p>
		</div>

		<!-- Monthly tiers: editorial spread layout -->
		<section class="py-12">
			<div class="md:grid md:grid-cols-6 md:gap-10 items-start">
				<!-- Section label in gutter -->
				<div class="md:col-span-1 mb-6 md:mb-0">
					<h2 class="text-xs tracking-[0.3em] uppercase text-stone-400 md:sticky md:top-8">{t.donate.monthly}</h2>
					<hr class="w-8 border-t border-amber-700 mt-3 hidden md:block" />
				</div>

				<!-- Tiers grid -->
				<div class="md:col-span-5">
					<div class="grid grid-cols-1 md:grid-cols-3 gap-0 border-t border-stone-300">
						{monthlyTiers.map((tier: any, i: number) => (
							<div class:list={[
								"p-8 flex flex-col border-b border-stone-200",
								i < monthlyTiers.length - 1 && "md:border-r md:border-stone-200",
								tier.highlighted && "bg-white"
							]}>
								{tier.highlighted && (
									<span class="text-xs tracking-[0.3em] uppercase text-amber-700 mb-4 block">{t.donate.mostPopular}</span>
								)}
								<h3 class="font-serif text-2xl font-light text-stone-900 mb-2">{tier.name}</h3>
								<p class="mb-4">
									<span class="font-serif text-5xl font-light text-stone-900">${tier.amount}</span>
									<span class="text-xs text-stone-400 tracking-[0.2em] uppercase ml-1">{t.donate.perMonth}</span>
								</p>
								<hr class="w-10 border-t border-stone-300 mb-4" />
								<p class="text-stone-500 text-sm leading-relaxed mb-6">{tier.description}</p>
								<ul class="space-y-3 mb-8 flex-1">
									{tier.perks.map((perk: string) => (
										<li class="text-sm text-stone-600 pl-4 border-l border-stone-200 leading-relaxed">{perk}</li>
									))}
								</ul>
								<button type="button" class:list={[
									"w-full py-3 font-serif text-xs tracking-[0.25em] uppercase transition-colors",
									tier.highlighted
										? "bg-amber-700 text-white hover:bg-amber-800"
										: "bg-stone-800 text-stone-50 hover:bg-stone-900"
								]}>{t.donate.choose} {tier.name}</button>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Divider -->
		<div class="max-w-6xl mx-auto">
			<hr class="border-t border-stone-300" />
		</div>

		<!-- One-time tiers: same editorial treatment -->
		<section class="py-12 pb-20">
			<div class="md:grid md:grid-cols-6 md:gap-10 items-start">
				<!-- Section label in gutter -->
				<div class="md:col-span-1 mb-6 md:mb-0">
					<h2 class="text-xs tracking-[0.3em] uppercase text-stone-400 md:sticky md:top-8">{t.donate.oneTime}</h2>
					<hr class="w-8 border-t border-amber-700 mt-3 hidden md:block" />
				</div>

				<!-- Tiers grid -->
				<div class="md:col-span-5">
					<div class="grid grid-cols-1 md:grid-cols-3 gap-0 border-t border-stone-300">
						{oneTimeTiers.map((tier: any, i: number) => (
							<div class:list={[
								"p-8 flex flex-col border-b border-stone-200",
								i < oneTimeTiers.length - 1 && "md:border-r md:border-stone-200",
								tier.highlighted && "bg-white"
							]}>
								{tier.highlighted && (
									<span class="text-xs tracking-[0.3em] uppercase text-amber-700 mb-4 block">{t.donate.greatestImpact}</span>
								)}
								<h3 class="font-serif text-2xl font-light text-stone-900 mb-2">{tier.name}</h3>
								<p class="mb-4">
									<span class="font-serif text-5xl font-light text-stone-900">${tier.amount}</span>
								</p>
								<hr class="w-10 border-t border-stone-300 mb-4" />
								<p class="text-stone-500 text-sm leading-relaxed mb-6">{tier.description}</p>
								<ul class="space-y-3 mb-8 flex-1">
									{tier.perks.map((perk: string) => (
										<li class="text-sm text-stone-600 pl-4 border-l border-stone-200 leading-relaxed">{perk}</li>
									))}
								</ul>
								<button type="button" class:list={[
									"w-full py-3 font-serif text-xs tracking-[0.25em] uppercase transition-colors",
									tier.highlighted
										? "bg-amber-700 text-white hover:bg-amber-800"
										: "bg-stone-800 text-stone-50 hover:bg-stone-900"
								]}>{t.donate.give} ${tier.amount}</button>
							</div>
						))}
					</div>
				</div>
			</div>
		</section>
	</main>
</div>
