---
const { lang, style, nav, cats, t } = Astro.props;
---

<div class="min-h-screen bg-stone-50 text-stone-800">
	<nav class="max-w-5xl mx-auto px-6 py-6 flex items-center justify-center gap-8 border-b border-stone-300">
		{nav.map((item: any) => (
			<a href={item.href} class="font-serif text-sm tracking-widest uppercase text-stone-500 hover:text-stone-900 transition-colors">{item.label}</a>
		))}
	</nav>

	<main class="max-w-5xl mx-auto px-6">
		<div class="pt-16 pb-10 text-center">
			<h1 class="font-serif text-5xl md:text-6xl font-light text-stone-900 mb-3">{t.cats.title}</h1>
			<hr class="w-12 mx-auto border-t border-amber-700 mb-4" />
			<p class="text-stone-500 text-lg max-w-xl mx-auto">{t.cats.subtitle}</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-stone-200">
			{cats.map((cat: any) => (
				<a href={`/${lang}/${style}/cats/${cat.id}`} class="group bg-stone-50 p-8 hover:bg-white transition-colors block">
					<div>
						<span class="text-xs tracking-widest uppercase text-amber-700 mb-3 block">{cat.status}</span>
						<h2 class="font-serif text-2xl md:text-3xl font-light text-stone-900 mb-2 group-hover:text-amber-800 transition-colors">{cat.name}</h2>
						<p class="text-sm text-stone-400 mb-4 tracking-wide">{cat.breed} · {cat.age} · {cat.gender}</p>
						<hr class="w-8 border-t border-stone-300 mb-4" />
						<p class="text-stone-600 leading-relaxed text-sm mb-5">{cat.description.slice(0, 100)}...</p>
						<div class="flex flex-wrap gap-2">
							{cat.personality.map((trait: string) => (
								<span class="text-xs tracking-wider uppercase text-stone-400 border border-stone-200 px-2 py-1">{trait}</span>
							))}
						</div>
					</div>
				</a>
			))}
		</div>
	</main>
</div>
