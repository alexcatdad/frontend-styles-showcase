---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-stone-50 text-stone-800">
	<nav class="max-w-5xl mx-auto px-6 py-6 flex items-center justify-center gap-8 border-b border-stone-300">
		{nav.map((item: any) => (
			<a href={item.href} class="font-serif text-sm tracking-widest uppercase text-stone-500 hover:text-stone-900 transition-colors">{item.label}</a>
		))}
	</nav>

	<main class="max-w-4xl mx-auto px-6">
		<div class="pt-16 pb-10 text-center">
			<h1 class="font-serif text-5xl md:text-6xl font-light text-stone-900 mb-3">{t.blog.title}</h1>
			<hr class="w-12 mx-auto border-t border-amber-700 mb-4" />
			<p class="text-stone-500 text-lg max-w-xl mx-auto">{t.blog.subtitle}</p>
		</div>

		<div class="divide-y divide-stone-200">
			{posts.map((post: any, i: number) => (
				<a href={`/${lang}/${style}/blog/${post.slug}`} class="group block py-10">
					<article class={i === 0 ? "max-w-2xl mx-auto text-center" : "md:grid md:grid-cols-4 md:gap-8 items-start"}>
						{i === 0 ? (
							<>
								<time datetime={post.date} class="text-xs tracking-widest uppercase text-stone-400 mb-4 block">{post.date}</time>
								<h2 class="font-serif text-3xl md:text-4xl font-light text-stone-900 mb-4 group-hover:text-amber-800 transition-colors leading-snug">{post.title}</h2>
								<p class="text-stone-500 leading-relaxed mb-5 text-lg">{post.excerpt}</p>
								<div class="flex flex-wrap justify-center gap-3 mb-3">
									{post.tags.map((tag: string) => (
										<span class="text-xs tracking-widest uppercase text-stone-400">{tag}</span>
									))}
								</div>
								<span class="text-sm italic text-stone-400 font-serif">{t.blog.by} {post.author}</span>
							</>
						) : (
							<>
								<div class="md:col-span-1 mb-2 md:mb-0">
									<time datetime={post.date} class="text-xs tracking-widest uppercase text-stone-400 block">{post.date}</time>
									<span class="text-sm italic text-stone-400 font-serif">{t.blog.by} {post.author}</span>
								</div>
								<div class="md:col-span-3">
									<h2 class="font-serif text-2xl font-light text-stone-900 mb-2 group-hover:text-amber-800 transition-colors leading-snug">{post.title}</h2>
									<p class="text-stone-500 leading-relaxed mb-3">{post.excerpt}</p>
									<div class="flex flex-wrap gap-3">
										{post.tags.map((tag: string) => (
											<span class="text-xs tracking-widest uppercase text-stone-400">{tag}</span>
										))}
									</div>
								</div>
							</>
						)}
					</article>
				</a>
			))}
		</div>
	</main>
</div>
