---
const { lang, style, nav, posts, t } = Astro.props;
const leadPost = posts[0];
const remainingPosts = posts.slice(1);
---

<div class="min-h-screen bg-stone-50 text-stone-800">
	<!-- Masthead nav -->
	<header class="max-w-6xl mx-auto px-6 pt-6">
		<hr class="border-t-2 border-stone-900 mb-1" />
		<hr class="border-t border-stone-400" />
		<nav class="flex items-center justify-center gap-6 md:gap-10 py-3 border-b border-stone-300">
			{nav.map((item: any) => (
				<a href={item.href} class="font-serif text-xs md:text-sm tracking-[0.25em] uppercase text-stone-500 hover:text-stone-900 transition-colors">{item.label}</a>
			))}
		</nav>
	</header>

	<main class="max-w-6xl mx-auto px-6">
		<!-- Section header -->
		<div class="pt-14 pb-4">
			<h1 class="font-serif text-6xl md:text-7xl lg:text-8xl font-light text-stone-900 leading-none tracking-tight">{t.blog.title}</h1>
		</div>
		<div class="md:flex md:items-baseline md:justify-between pb-8 border-b border-stone-300">
			<p class="text-stone-500 text-lg max-w-md">{t.blog.subtitle}</p>
		</div>

		<!-- Lead story: hero treatment -->
		{leadPost && (
			<section class="py-10 border-b border-stone-300">
				<a href={`/${lang}/${style}/blog/${leadPost.slug}`} class="group block md:grid md:grid-cols-5 md:gap-12 items-start">
					<div class="md:col-span-3">
						<img src={leadPost.image} alt={leadPost.title} class="w-full h-64 object-cover mb-6" />
						<div class="flex flex-wrap gap-3 mb-4">
							{leadPost.tags.map((tag: string) => (
								<span class="text-xs tracking-[0.3em] uppercase text-amber-700">{tag}</span>
							))}
						</div>
						<h2 class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-stone-900 mb-5 group-hover:text-amber-800 transition-colors leading-tight">{leadPost.title}</h2>
						<p class="text-stone-600 leading-relaxed text-lg max-w-prose mb-6">{leadPost.excerpt}</p>
					</div>
					<aside class="md:col-span-2 md:border-l md:border-stone-300 md:pl-10 mt-6 md:mt-0 md:pt-2">
						<p class="font-serif italic text-stone-500 text-base mb-4">{t.blog.by} {leadPost.author}</p>
						<time datetime={leadPost.date} class="text-xs tracking-[0.3em] uppercase text-stone-400 block mb-6">{leadPost.date}</time>
						<hr class="w-8 border-t border-stone-300 mb-6" />
						<p class="font-serif text-xl italic text-stone-600 leading-relaxed">{leadPost.excerpt.slice(0, 80)}...</p>
					</aside>
				</a>
			</section>
		)}

		<!-- Remaining posts: compact newspaper listing with columns -->
		{remainingPosts.length > 0 && (
			<section class="py-8">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-0">
					{remainingPosts.map((post: any, i: number) => (
						<a href={`/${lang}/${style}/blog/${post.slug}`} class:list={[
							"group block py-6 px-5",
							"border-b border-stone-200",
							i % 3 !== 2 && "lg:border-r lg:border-stone-200",
							i % 2 !== 1 && "md:border-r md:border-stone-200 lg:border-r-0",
							i % 3 !== 2 && "lg:border-r lg:border-stone-200"
						]}>
							<img src={post.image} alt={post.title} class="w-full h-40 object-cover mb-4" />
								<div class="flex items-baseline gap-3 mb-3">
								<time datetime={post.date} class="text-xs tracking-[0.25em] uppercase text-stone-400 shrink-0">{post.date}</time>
								<span class="text-stone-300">&middot;</span>
								<span class="text-xs font-serif italic text-stone-400 truncate">{t.blog.by} {post.author}</span>
							</div>
							<h3 class="font-serif text-xl md:text-2xl font-light text-stone-900 mb-2 group-hover:text-amber-800 transition-colors leading-snug">{post.title}</h3>
							<p class="text-stone-500 leading-relaxed text-sm mb-4">{post.excerpt.slice(0, 100)}...</p>
							<div class="flex flex-wrap gap-2">
								{post.tags.map((tag: string) => (
									<span class="text-xs tracking-[0.2em] uppercase text-stone-400">{tag}</span>
								))}
							</div>
						</a>
					))}
				</div>
			</section>
		)}
	</main>
</div>
