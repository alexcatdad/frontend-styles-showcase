---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-stone-50 text-stone-800">
	<!-- Masthead nav -->
	<header class="max-w-6xl mx-auto px-6 pt-6">
		<hr class="border-t-2 border-stone-900 mb-1" />
		<hr class="border-t border-stone-400" />
		<nav class="flex items-center justify-center gap-6 md:gap-10 py-3 border-b border-stone-300">
			{nav.map((item: any) => (
				<a href={item.href} class="font-serif text-xs md:text-sm tracking-[0.25em] uppercase text-stone-500 hover:text-stone-900 transition-colors">{item.label}</a>
			))}
		</nav>
	</header>

	<main class="max-w-6xl mx-auto px-6">
		<!-- Breadcrumb dateline -->
		<div class="pt-8 pb-2 flex items-baseline justify-between">
			<a href={`/${lang}/${style}/cats`} class="text-xs tracking-[0.3em] uppercase text-stone-400 hover:text-stone-700 transition-colors">&larr; {t.cats.backToAll}</a>
			<span class="text-xs tracking-[0.3em] uppercase text-amber-700">{cat.status}</span>
		</div>
		<hr class="border-t border-stone-300" />

		<article>
			<!-- Magazine spread headline -->
			<header class="pt-10 pb-8">
				<h1 class="font-serif text-6xl md:text-8xl lg:text-9xl font-light text-stone-900 leading-none tracking-tight mb-4">{cat.name}</h1>
				<div class="flex flex-wrap items-baseline gap-4 text-sm text-stone-400">
					<span class="tracking-wide">{cat.breed}</span>
					<span class="text-stone-300">|</span>
					<span class="tracking-wide">{cat.age}</span>
					<span class="text-stone-300">|</span>
					<span class="tracking-wide">{cat.gender}</span>
					<span class="text-stone-300">|</span>
					<span class="tracking-wide">{cat.color}</span>
				</div>
			</header>

			<!-- Asymmetric layout: wide text + narrow details sidebar -->
			<div class="md:grid md:grid-cols-6 md:gap-12 border-t border-stone-300 pt-10 pb-16">
				<!-- Main story column -->
				<div class="md:col-span-4">
					<p class="text-lg md:text-xl leading-loose text-stone-600 first-letter:text-7xl first-letter:font-serif first-letter:font-light first-letter:float-left first-letter:mr-4 first-letter:leading-[0.8] first-letter:text-stone-900 first-letter:mt-1">{cat.description}</p>

					<!-- Pull quote -->
					<aside class="border-t border-b border-stone-300 py-8 my-10">
						<p class="font-serif text-2xl md:text-3xl italic text-stone-700 leading-relaxed text-center max-w-lg mx-auto">
							{cat.personality.join(', ')}
						</p>
					</aside>

					<!-- CTA -->
					<div class="pt-4">
						<a href={`/${lang}/${style}/auth`} class="inline-block px-10 py-4 bg-stone-800 text-stone-50 font-serif text-xs tracking-[0.3em] uppercase hover:bg-stone-900 transition-colors">{t.cats.adopt} {cat.name}</a>
					</div>
				</div>

				<!-- Sidebar: stats as dateline items -->
				<aside class="md:col-span-2 md:border-l md:border-stone-300 md:pl-8 mt-12 md:mt-0">
					<p class="text-xs tracking-[0.3em] uppercase text-stone-400 mb-6">Profile</p>

					<dl class="space-y-5">
						<div>
							<dt class="text-xs tracking-[0.25em] uppercase text-stone-400 mb-1">{t.cats.breed}</dt>
							<dd class="font-serif text-lg text-stone-800">{cat.breed}</dd>
						</div>
						<hr class="border-t border-stone-200" />
						<div>
							<dt class="text-xs tracking-[0.25em] uppercase text-stone-400 mb-1">{t.cats.age}</dt>
							<dd class="font-serif text-lg text-stone-800">{cat.age}</dd>
						</div>
						<hr class="border-t border-stone-200" />
						<div>
							<dt class="text-xs tracking-[0.25em] uppercase text-stone-400 mb-1">{t.cats.gender}</dt>
							<dd class="font-serif text-lg text-stone-800">{cat.gender}</dd>
						</div>
						<hr class="border-t border-stone-200" />
						<div>
							<dt class="text-xs tracking-[0.25em] uppercase text-stone-400 mb-1">{t.cats.color}</dt>
							<dd class="font-serif text-lg text-stone-800">{cat.color}</dd>
						</div>
						<hr class="border-t border-stone-200" />
						<div>
							<dt class="text-xs tracking-[0.25em] uppercase text-stone-400 mb-1">{t.cats.arrived}</dt>
							<dd class="font-serif text-lg text-stone-800">{cat.arrivalDate}</dd>
						</div>
						<hr class="border-t border-stone-200" />
						<div>
							<dt class="text-xs tracking-[0.25em] uppercase text-stone-400 mb-1">{t.cats.status}</dt>
							<dd class="font-serif text-lg text-amber-700">{cat.status}</dd>
						</div>
					</dl>

					<hr class="border-t border-stone-300 mt-8 mb-6" />
					<p class="text-xs tracking-[0.25em] uppercase text-stone-400 mb-3">Temperament</p>
					<div class="flex flex-wrap gap-2">
						{cat.personality.map((trait: string) => (
							<span class="font-serif italic text-stone-600 text-sm">{trait}</span>
						))}
					</div>
				</aside>
			</div>
		</article>

		<!-- Other cats: compact newspaper listing -->
		<section class="border-t-2 border-stone-900 pt-1">
			<hr class="border-t border-stone-400 mb-8" />
			<h2 class="font-serif text-3xl md:text-4xl font-light text-stone-900 mb-8">{t.cats.otherCats}</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-0 border-t border-stone-300">
				{otherCats.map((c: any, i: number) => (
					<a href={`/${lang}/${style}/cats/${c.id}`} class:list={[
						"group block py-6 px-4",
						i < otherCats.length - 1 && "md:border-r md:border-stone-200",
						"border-b border-stone-200"
					]}>
						<span class="text-xs tracking-[0.25em] uppercase text-amber-700 block mb-1">{c.status}</span>
						<h3 class="font-serif text-xl font-light text-stone-800 group-hover:text-amber-800 transition-colors mb-1">{c.name}</h3>
						<p class="text-xs text-stone-400 tracking-wide">{c.breed} &middot; {c.age}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
