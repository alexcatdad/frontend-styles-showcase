---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-stone-50 text-stone-800">
	<nav class="max-w-5xl mx-auto px-6 py-6 flex items-center justify-center gap-8 border-b border-stone-300">
		{nav.map((item: any) => (
			<a href={item.href} class="font-serif text-sm tracking-widest uppercase text-stone-500 hover:text-stone-900 transition-colors">{item.label}</a>
		))}
	</nav>

	<main class="max-w-4xl mx-auto px-6">
		<div class="pt-8 pb-4">
			<a href={`/${lang}/${style}/cats`} class="text-sm tracking-widest uppercase text-stone-400 hover:text-stone-700 transition-colors">&larr; {t.cats.backToAll}</a>
		</div>

		<article class="pb-16">
			<header class="text-center pt-8 pb-10">
				<span class="text-xs tracking-widest uppercase text-amber-700 mb-4 block">{cat.status}</span>
				<h1 class="font-serif text-5xl md:text-7xl font-light text-stone-900 mb-4">{cat.name}</h1>
				<hr class="w-16 mx-auto border-t border-stone-300 mb-6" />
				<div class="flex flex-wrap justify-center gap-3">
					{cat.personality.map((trait: string) => (
						<span class="font-serif italic text-stone-500 text-lg">{trait}</span>
					))}
				</div>
			</header>

			<div class="grid grid-cols-2 md:grid-cols-3 gap-6 border-y border-stone-300 py-8 mb-12">
				<div class="text-center">
					<dt class="text-xs tracking-widest uppercase text-stone-400 mb-1">{t.cats.breed}</dt>
					<dd class="font-serif text-lg text-stone-800">{cat.breed}</dd>
				</div>
				<div class="text-center">
					<dt class="text-xs tracking-widest uppercase text-stone-400 mb-1">{t.cats.age}</dt>
					<dd class="font-serif text-lg text-stone-800">{cat.age}</dd>
				</div>
				<div class="text-center">
					<dt class="text-xs tracking-widest uppercase text-stone-400 mb-1">{t.cats.gender}</dt>
					<dd class="font-serif text-lg text-stone-800">{cat.gender}</dd>
				</div>
				<div class="text-center">
					<dt class="text-xs tracking-widest uppercase text-stone-400 mb-1">{t.cats.color}</dt>
					<dd class="font-serif text-lg text-stone-800">{cat.color}</dd>
				</div>
				<div class="text-center">
					<dt class="text-xs tracking-widest uppercase text-stone-400 mb-1">{t.cats.arrived}</dt>
					<dd class="font-serif text-lg text-stone-800">{cat.arrivalDate}</dd>
				</div>
				<div class="text-center">
					<dt class="text-xs tracking-widest uppercase text-stone-400 mb-1">{t.cats.status}</dt>
					<dd class="font-serif text-lg text-amber-700">{cat.status}</dd>
				</div>
			</div>

			<div class="max-w-2xl mx-auto mb-14">
				<p class="text-lg leading-loose text-stone-600 first-letter:text-5xl first-letter:font-serif first-letter:font-light first-letter:float-left first-letter:mr-3 first-letter:leading-none first-letter:text-stone-900">{cat.description}</p>
			</div>

			<div class="text-center">
				<a href={`/${lang}/${style}/auth`} class="inline-block px-10 py-4 bg-stone-800 text-stone-50 font-serif text-sm tracking-widest uppercase hover:bg-stone-900 transition-colors">{t.cats.adopt} {cat.name}</a>
			</div>
		</article>

		<section class="border-t border-stone-300 py-16">
			<h2 class="font-serif text-3xl font-light text-stone-900 text-center mb-3">{t.cats.otherCats}</h2>
			<hr class="w-12 mx-auto border-t border-amber-700 mb-10" />
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				{otherCats.map((c: any) => (
					<a href={`/${lang}/${style}/cats/${c.id}`} class="group text-center block">
						<h3 class="font-serif text-2xl font-light text-stone-800 group-hover:text-amber-800 transition-colors mb-1">{c.name}</h3>
						<p class="text-sm text-stone-400 tracking-wide">{c.breed} · {c.age}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
