---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-black text-white font-sans">
	<!-- Nav -->
	<nav class="bg-black text-white flex flex-wrap items-center justify-between px-6 py-4 border-b-4 border-red-600">
		<div class="flex items-center gap-2">
			<div class="w-4 h-4 rounded-full bg-yellow-400"></div>
			<div class="w-4 h-4 bg-red-600"></div>
			<div class="w-0 h-0 border-l-[8px] border-l-transparent border-r-[8px] border-r-transparent border-b-[14px] border-b-blue-600"></div>
		</div>
		<div class="flex flex-wrap gap-6">
			{nav.map((item: any) => (
				<a href={item.href} class="uppercase text-sm font-bold tracking-widest hover:text-yellow-400 transition-colors">{item.label}</a>
			))}
		</div>
	</nav>

	<main class="flex items-center justify-center min-h-[calc(100vh-64px)] px-8 py-16 relative overflow-hidden">
		<!-- Background geometric composition -->
		<div class="absolute inset-0 flex items-center justify-center">
			<div class="w-80 h-80 md:w-[500px] md:h-[500px] rounded-full border-4 border-red-600 opacity-15"></div>
		</div>
		<div class="absolute top-16 left-16 w-24 h-24 bg-blue-600 opacity-20 hidden md:block"></div>
		<div class="absolute bottom-20 right-20 w-32 h-32 bg-yellow-400 opacity-15 hidden md:block"></div>
		<div class="absolute top-1/3 right-16 w-16 h-16 rounded-full bg-red-600 opacity-20 hidden md:block"></div>

		<section class="text-center relative z-10 max-w-2xl">
			<!-- Giant 404 -->
			<h1 class="text-[10rem] md:text-[16rem] font-black leading-none tracking-tighter">
				<span class="text-red-600">4</span><span class="text-yellow-400">0</span><span class="text-blue-600">4</span>
			</h1>

			<h2 class="text-3xl md:text-5xl font-black uppercase tracking-tight mb-4">
				{t.notFound.heading}
			</h2>
			<div class="w-16 h-1 bg-yellow-400 mx-auto mb-6"></div>
			<p class="text-lg font-light text-neutral-400 mb-10 max-w-md mx-auto">
				{t.notFound.description}
			</p>

			<div class="flex flex-wrap justify-center gap-4">
				<a href={`/${lang}/${style}/`} class="inline-block bg-yellow-400 text-black font-black uppercase tracking-widest px-8 py-4 text-sm border-2 border-yellow-400 hover:bg-white hover:border-white transition-colors">
					{t.notFound.backHome}
				</a>
				<a href={`/${lang}/${style}/cats`} class="inline-block bg-transparent text-white font-black uppercase tracking-widest px-8 py-4 text-sm border-2 border-white hover:bg-red-600 hover:border-red-600 transition-colors">
					{t.notFound.meetCats}
				</a>
			</div>
		</section>
	</main>
</div>
