---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-black text-white font-sans">
	<!-- Nav — geometric composition strip -->
	<nav class="relative z-50 flex flex-wrap items-stretch">
		<div class="bg-red-600 w-16 md:w-24 shrink-0"></div>
		<div class="flex-1 bg-black text-white flex flex-wrap items-center justify-between px-6 py-4">
			<div class="flex items-center gap-3">
				<div class="w-5 h-5 rounded-full bg-yellow-400"></div>
				<div class="w-5 h-5 bg-red-600 rotate-45"></div>
				<div class="w-0 h-0 border-l-[10px] border-l-transparent border-r-[10px] border-r-transparent border-b-[18px] border-b-blue-600"></div>
			</div>
			<div class="flex flex-wrap gap-6">
				{nav.map((item: any) => (
					<a href={item.href} class="uppercase text-xs font-black tracking-[0.25em] hover:text-yellow-400 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
		<div class="bg-blue-600 w-10 md:w-16 shrink-0"></div>
	</nav>

	<main class="relative min-h-[calc(100vh-56px)] overflow-hidden">
		<!-- Full geometric poster composition as background -->
		<!-- Large red circle -->
		<div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[30rem] h-[30rem] md:w-[50rem] md:h-[50rem] rounded-full border-8 border-red-600 opacity-10"></div>
		<!-- Blue rectangle -->
		<div class="absolute -left-8 top-1/4 w-48 h-48 md:w-72 md:h-72 bg-blue-600 opacity-10 rotate-12 hidden md:block"></div>
		<!-- Yellow triangle -->
		<div class="absolute right-12 top-16 w-0 h-0 border-l-[60px] border-l-transparent border-r-[60px] border-r-transparent border-b-[104px] border-b-yellow-400 opacity-15 hidden md:block"></div>
		<!-- Small red square -->
		<div class="absolute bottom-20 left-20 w-16 h-16 bg-red-600 opacity-20 hidden md:block"></div>
		<!-- Circle ring -->
		<div class="absolute top-16 right-1/3 w-20 h-20 rounded-full border-4 border-yellow-400 opacity-15 hidden md:block"></div>

		<!-- Content -->
		<div class="relative z-10 flex flex-col items-center justify-center min-h-[calc(100vh-56px)] px-8 py-16 text-center">
			<!-- 404 as giant poster typography with color per digit -->
			<div class="relative mb-8">
				<!-- Background shapes behind the numbers -->
				<div class="absolute left-0 top-1/2 -translate-y-1/2 w-32 h-32 md:w-48 md:h-48 rounded-full bg-red-600 opacity-20"></div>
				<div class="absolute left-1/2 -translate-x-1/2 top-1/2 -translate-y-1/2 w-28 h-28 md:w-44 md:h-44 bg-yellow-400 opacity-15 rotate-45"></div>
				<div class="absolute right-0 top-1/2 -translate-y-1/2 w-32 h-32 md:w-48 md:h-48 rounded-full bg-blue-600 opacity-20"></div>

				<h1 class="text-[8rem] md:text-[14rem] lg:text-[18rem] font-black leading-none tracking-tighter relative z-10">
					<span class="text-red-600">4</span><span class="text-yellow-400">0</span><span class="text-blue-600">4</span>
				</h1>
			</div>

			<!-- Geometric separator -->
			<div class="flex items-center gap-4 mb-8">
				<div class="w-6 h-6 rounded-full bg-red-600"></div>
				<div class="w-20 h-1 bg-white"></div>
				<div class="w-6 h-6 bg-yellow-400 rotate-45"></div>
				<div class="w-20 h-1 bg-white"></div>
				<div class="w-0 h-0 border-l-[10px] border-l-transparent border-r-[10px] border-r-transparent border-b-[18px] border-b-blue-600"></div>
			</div>

			<h2 class="text-3xl md:text-5xl lg:text-6xl font-black uppercase tracking-tighter mb-6">
				{t.notFound.heading}
			</h2>
			<p class="text-base md:text-lg font-light text-neutral-400 mb-12 max-w-lg tracking-wide">
				{t.notFound.description}
			</p>

			<div class="flex flex-wrap justify-center gap-0">
				<a href={`/${lang}/${style}/`} class="bg-yellow-400 text-black font-black uppercase tracking-[0.25em] px-10 py-5 text-sm border-4 border-yellow-400 hover:bg-white hover:border-white transition-colors">
					{t.notFound.backHome}
				</a>
				<a href={`/${lang}/${style}/cats`} class="bg-transparent text-white font-black uppercase tracking-[0.25em] px-10 py-5 text-sm border-4 border-white hover:bg-red-600 hover:border-red-600 transition-colors">
					{t.notFound.meetCats}
				</a>
			</div>
		</div>

		<!-- Bottom geometric bar -->
		<div class="absolute bottom-0 left-0 w-full flex">
			<div class="h-3 flex-1 bg-red-600"></div>
			<div class="h-3 flex-1 bg-yellow-400"></div>
			<div class="h-3 flex-1 bg-blue-600"></div>
		</div>
	</main>
</div>
