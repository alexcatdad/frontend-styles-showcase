---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-white text-black font-sans">
	<!-- Nav — geometric composition strip -->
	<nav class="relative z-50 flex flex-wrap items-stretch">
		<div class="bg-red-600 w-16 md:w-24 shrink-0"></div>
		<div class="flex-1 bg-black text-white flex flex-wrap items-center justify-between px-6 py-4">
			<div class="flex items-center gap-3">
				<div class="w-5 h-5 rounded-full bg-yellow-400"></div>
				<div class="w-5 h-5 bg-red-600 rotate-45"></div>
				<div class="w-0 h-0 border-l-[10px] border-l-transparent border-r-[10px] border-r-transparent border-b-[18px] border-b-blue-600"></div>
			</div>
			<div class="flex flex-wrap gap-6">
				{nav.map((item: any) => (
					<a href={item.href} class="uppercase text-xs font-black tracking-[0.25em] hover:text-yellow-400 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
		<div class="bg-blue-600 w-10 md:w-16 shrink-0"></div>
	</nav>

	<main>
		<!-- Back link bar -->
		<div class="bg-yellow-400 text-black px-8 py-3 flex items-center gap-3">
			<div class="w-0 h-0 border-t-[6px] border-t-transparent border-b-[6px] border-b-transparent border-r-[10px] border-r-black"></div>
			<a href={`${_base}/${lang}/${style}/blog`} class="text-xs uppercase tracking-[0.25em] font-black hover:text-red-600 transition-colors">
				{t.blog.backToBlog}
			</a>
		</div>

		<article>
			<!-- Header — bold poster-style asymmetric composition -->
			<header class="relative overflow-hidden">
				<div class="grid grid-cols-1 md:grid-cols-12 min-h-[45vh]">
					<!-- Meta column -->
					<div class="md:col-span-4 bg-blue-600 text-white p-8 md:p-12 flex flex-col justify-center relative overflow-hidden">
						<!-- Geometric accents -->
						<div class="absolute -bottom-12 -right-12 w-40 h-40 rounded-full border-4 border-white opacity-15"></div>
						<div class="absolute top-6 right-6 w-8 h-8 bg-yellow-400 rotate-45"></div>

						<time datetime={post.date} class="text-xs uppercase tracking-[0.3em] font-black mb-6 relative z-10">{post.date}</time>
						<div class="w-12 h-1 bg-yellow-400 mb-6 relative z-10"></div>
						<span class="text-sm uppercase tracking-[0.2em] font-black opacity-80 relative z-10">{t.blog.by}</span>
						<span class="text-xl md:text-2xl font-black uppercase tracking-tight relative z-10">{post.author}</span>

						<!-- Tags -->
						<div class="flex flex-wrap gap-2 mt-8 relative z-10">
							{post.tags.map((tag: string) => (
								<span class="text-[0.6rem] uppercase tracking-[0.25em] font-black border-2 border-white px-3 py-1">
									{tag}
								</span>
							))}
						</div>
					</div>

					<!-- Title -->
					<div class="md:col-span-8 bg-black text-white p-8 md:p-12 lg:p-16 flex flex-col justify-center relative overflow-hidden">
						<!-- Large circle decoration -->
						<div class="absolute -right-20 top-1/2 -translate-y-1/2 w-64 h-64 rounded-full border-4 border-red-600 opacity-15"></div>

						<img src={post.image} alt={post.title} class="w-full h-48 md:h-64 object-cover mb-8 border-4 border-red-600 relative z-10" />
						<h1 class="text-4xl md:text-6xl lg:text-7xl font-black uppercase tracking-tighter leading-[0.85] mb-8 relative z-10">
							{post.title}
						</h1>
						<div class="flex items-center gap-4 relative z-10">
							<div class="w-8 h-8 rounded-full bg-red-600"></div>
							<div class="w-8 h-8 bg-yellow-400"></div>
							<div class="w-0 h-0 border-l-[14px] border-l-transparent border-r-[14px] border-r-transparent border-b-[24px] border-b-blue-600"></div>
						</div>
					</div>
				</div>
				<!-- Bottom accent strip -->
				<div class="h-2 bg-red-600"></div>
			</header>

			<!-- Content — clean reading area with geometric left rail -->
			<div class="grid grid-cols-1 md:grid-cols-12">
				<!-- Geometric rail -->
				<div class="hidden md:flex md:col-span-1 flex-col">
					<div class="flex-1 bg-yellow-400"></div>
					<div class="flex-1 bg-white border-r-4 border-black"></div>
					<div class="flex-1 bg-blue-600"></div>
				</div>

				<!-- Text content -->
				<div class="md:col-span-11 py-12 md:py-20 px-8 md:px-16 lg:px-24">
					<div class="max-w-3xl">
						{post.content.map((paragraph: string, i: number) => (
							<div class="mb-8 flex gap-6">
								{i === 0 && (
									<div class="hidden md:block w-12 h-12 rounded-full bg-red-600 shrink-0 mt-1"></div>
								)}
								<p class:list={[
									"leading-relaxed font-light",
									i === 0 ? "text-lg md:text-xl" : "text-base md:text-lg"
								]}>{paragraph}</p>
							</div>
						))}
					</div>
				</div>
			</div>
		</article>

		<!-- More stories — black block with constructivist cards -->
		<section class="bg-black text-white">
			<div class="p-8 md:p-16">
				<div class="flex items-center gap-6 mb-10">
					<div class="w-8 h-8 rounded-full bg-yellow-400"></div>
					<h2 class="text-3xl md:text-5xl font-black uppercase tracking-tighter">{t.blog.moreStories}</h2>
					<div class="flex-1 h-1 bg-white hidden md:block"></div>
				</div>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3">
				{otherPosts.map((p: any, i: number) => (
					<a href={`${_base}/${lang}/${style}/blog/${p.slug}`}
						class:list={[
							"group block p-8 md:p-10 border-t-4 transition-colors relative overflow-hidden",
							i % 3 === 0 && "border-red-600 hover:bg-red-600",
							i % 3 === 1 && "border-blue-600 hover:bg-blue-600",
							i % 3 === 2 && "border-yellow-400 hover:bg-yellow-400 hover:text-black"
						]}>
						<div class:list={[
							"absolute -right-4 -bottom-4 opacity-10 group-hover:opacity-20 transition-opacity",
							i % 3 === 0 && "w-20 h-20 rounded-full bg-red-600",
							i % 3 === 1 && "w-16 h-16 bg-blue-600 rotate-45",
							i % 3 === 2 && "w-20 h-20 bg-yellow-400"
						]}></div>
						<h3 class="text-xl md:text-2xl font-black uppercase tracking-tighter leading-tight mb-4 group-hover:text-current relative z-10">{p.title}</h3>
						<p class="text-sm font-light text-neutral-400 group-hover:text-current leading-relaxed relative z-10">{p.excerpt}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
