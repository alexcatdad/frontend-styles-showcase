---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-sans">
	<!-- Nav -->
	<nav class="bg-black text-white flex flex-wrap items-center justify-between px-6 py-4 border-b-4 border-red-600">
		<div class="flex items-center gap-2">
			<div class="w-4 h-4 rounded-full bg-yellow-400"></div>
			<div class="w-4 h-4 bg-red-600"></div>
			<div class="w-0 h-0 border-l-[8px] border-l-transparent border-r-[8px] border-r-transparent border-b-[14px] border-b-blue-600"></div>
		</div>
		<div class="flex flex-wrap gap-6">
			{nav.map((item: any) => (
				<a href={item.href} class="uppercase text-sm font-bold tracking-widest hover:text-yellow-400 transition-colors">{item.label}</a>
			))}
		</div>
	</nav>

	<main>
		<!-- Back link -->
		<div class="bg-black text-white px-8 py-3">
			<a href={`/${lang}/${style}/blog`} class="text-sm uppercase tracking-widest font-bold hover:text-yellow-400 transition-colors">
				&larr; {t.blog.backToBlog}
			</a>
		</div>

		<article>
			<!-- Header — bold asymmetric composition -->
			<header class="grid grid-cols-1 md:grid-cols-12 border-b-4 border-black">
				<!-- Date & meta in color block -->
				<div class="md:col-span-3 bg-blue-600 text-white p-8 md:p-12 flex flex-col justify-center relative overflow-hidden">
					<time datetime={post.date} class="text-sm uppercase tracking-widest font-bold mb-4">{post.date}</time>
					<span class="text-sm uppercase tracking-widest font-bold opacity-75">{t.blog.by} {post.author}</span>
					<div class="absolute -bottom-6 -right-6 w-24 h-24 rounded-full border-2 border-white opacity-20"></div>
				</div>

				<!-- Title and tags -->
				<div class="md:col-span-9 p-8 md:p-12 flex flex-col justify-center">
					<h1 class="text-4xl md:text-6xl font-black uppercase tracking-tight leading-none mb-6">
						{post.title}
					</h1>
					<div class="w-16 h-1 bg-red-600 mb-6"></div>
					<div class="flex flex-wrap gap-2">
						{post.tags.map((tag: string) => (
							<span class="text-xs uppercase tracking-widest font-bold bg-black text-white px-3 py-1">
								{tag}
							</span>
						))}
					</div>
				</div>
			</header>

			<!-- Content — clean reading area with geometric accents -->
			<div class="py-12 md:py-20 px-8 md:px-16">
				<div class="max-w-3xl mx-auto relative">
					<div class="absolute -left-8 top-0 w-1 h-full bg-yellow-400 hidden md:block"></div>
					{post.content.map((paragraph: string) => (
						<p class="text-base md:text-lg leading-relaxed font-light mb-6">{paragraph}</p>
					))}
				</div>
			</div>
		</article>

		<!-- More stories -->
		<section class="bg-black text-white py-12 md:py-20 px-8 md:px-16">
			<div class="max-w-6xl mx-auto">
				<h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight mb-2">{t.blog.moreStories}</h2>
				<div class="w-16 h-1 bg-yellow-400 mb-10"></div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-0">
					{otherPosts.map((p: any, i: number) => (
						<a href={`/${lang}/${style}/blog/${p.slug}`} class="group block border-2 border-white hover:border-yellow-400 transition-colors p-6 md:p-8">
							<div class:list={[
								"w-6 h-6 mb-4",
								i % 3 === 0 && "bg-red-600",
								i % 3 === 1 && "rounded-full bg-blue-600",
								i % 3 === 2 && "bg-yellow-400"
							]}></div>
							<h3 class="text-xl font-black uppercase tracking-tight group-hover:text-yellow-400 transition-colors mb-3">{p.title}</h3>
							<p class="text-sm font-light text-neutral-400 leading-relaxed">{p.excerpt}</p>
						</a>
					))}
				</div>
			</div>
		</section>
	</main>
</div>
