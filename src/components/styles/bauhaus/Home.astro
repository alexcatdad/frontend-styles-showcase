---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-black text-white font-sans overflow-hidden">
	<!-- Nav — geometric composition strip -->
	<nav class="relative z-50 flex flex-wrap items-stretch">
		<div class="bg-red-600 w-16 md:w-24 shrink-0"></div>
		<div class="flex-1 bg-black flex flex-wrap items-center justify-between px-6 py-4">
			<div class="flex items-center gap-3">
				<div class="w-5 h-5 rounded-full bg-yellow-400"></div>
				<div class="w-5 h-5 bg-red-600 rotate-45"></div>
				<div class="w-0 h-0 border-l-[10px] border-l-transparent border-r-[10px] border-r-transparent border-b-[18px] border-b-blue-600"></div>
			</div>
			<div class="flex flex-wrap gap-6">
				{nav.map((item: any) => (
					<a href={item.href} class="uppercase text-xs font-black tracking-[0.25em] hover:text-yellow-400 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
		<div class="bg-blue-600 w-10 md:w-16 shrink-0"></div>
	</nav>

	<main>
		<!-- HERO — full poster composition -->
		<section class="relative min-h-[90vh] grid grid-cols-12 grid-rows-6">
			<!-- Giant red circle, shifted left -->
			<div class="absolute -left-24 top-1/2 -translate-y-1/2 w-[28rem] h-[28rem] md:w-[44rem] md:h-[44rem] rounded-full bg-red-600 opacity-90"></div>

			<!-- Blue vertical bar -->
			<div class="absolute right-0 top-0 w-20 md:w-32 h-full bg-blue-600"></div>

			<!-- Yellow horizontal bar -->
			<div class="absolute left-0 bottom-0 h-16 md:h-24 w-2/3 bg-yellow-400"></div>

			<!-- Main title block -->
			<div class="col-span-12 md:col-start-3 md:col-span-8 row-start-2 row-span-3 relative z-10 px-8 md:px-0">
				<h1 class="text-6xl md:text-[8rem] lg:text-[10rem] font-black uppercase tracking-tighter leading-[0.85] mb-8">
					{sanctuary.name}
				</h1>
				<div class="flex items-center gap-4 mb-8">
					<div class="w-12 h-12 rounded-full bg-yellow-400"></div>
					<div class="w-24 h-1 bg-white"></div>
				</div>
				<p class="text-xl md:text-3xl font-light max-w-2xl leading-relaxed tracking-wide">
					{sanctuary.tagline}
				</p>
				<img src={sanctuary.heroImage} alt={sanctuary.name} class="mt-10 w-full max-w-2xl h-56 md:h-72 object-cover border-4 border-white" />
			</div>

			<!-- CTA block — anchored to grid -->
			<div class="col-span-12 md:col-start-3 md:col-span-6 row-start-5 relative z-10 px-8 md:px-0 flex flex-wrap gap-0">
				<a href={`/${lang}/${style}/cats`} class="bg-yellow-400 text-black font-black uppercase tracking-[0.25em] px-10 py-5 text-sm hover:bg-white transition-colors border-4 border-yellow-400 hover:border-white">
					{t.home.meetCats}
				</a>
				<a href={`/${lang}/${style}/donate`} class="bg-transparent text-white font-black uppercase tracking-[0.25em] px-10 py-5 text-sm border-4 border-white hover:bg-blue-600 hover:border-blue-600 transition-colors">
					{t.home.donate}
				</a>
			</div>

			<!-- Small geometric accents -->
			<div class="absolute top-12 right-40 md:right-48 w-8 h-8 border-4 border-white rotate-45 hidden md:block"></div>
			<div class="absolute bottom-32 right-40 w-0 h-0 border-l-[20px] border-l-transparent border-r-[20px] border-r-transparent border-b-[36px] border-b-yellow-400 hidden md:block"></div>
		</section>

		<!-- MISSION — red full-bleed poster block -->
		<section class="relative bg-red-600 text-white overflow-hidden">
			<div class="grid grid-cols-1 md:grid-cols-12 min-h-[50vh]">
				<!-- Geometric composition column -->
				<div class="hidden md:flex md:col-span-4 items-center justify-center relative">
					<div class="w-48 h-48 rounded-full border-8 border-white"></div>
					<div class="absolute top-0 left-0 w-full h-full flex items-center justify-center">
						<div class="w-32 h-32 bg-black rotate-45"></div>
					</div>
					<div class="absolute bottom-0 left-0 w-full h-20 bg-yellow-400"></div>
				</div>

				<!-- Text block -->
				<div class="md:col-span-8 flex flex-col justify-center p-8 md:p-20">
					<span class="text-xs uppercase tracking-[0.5em] font-bold mb-6 opacity-75">///</span>
					<h2 class="text-4xl md:text-6xl lg:text-7xl font-black uppercase tracking-tighter leading-[0.9] mb-8">
						{t.home.mission}
					</h2>
					<div class="w-20 h-2 bg-black mb-8"></div>
					<p class="text-lg md:text-2xl leading-relaxed font-light max-w-2xl">
						{sanctuary.mission}
					</p>
				</div>
			</div>
		</section>

		<!-- STATS — large numbers inside geometric shapes -->
		<section class="bg-white text-black py-0">
			<div class="grid grid-cols-2 md:grid-cols-4">
				{sanctuary.stats.map((stat: any, i: number) => (
					<div class:list={[
						"relative flex flex-col items-center justify-center py-16 md:py-24 border-r-4 border-b-4 border-black last:border-r-0",
						i === 0 && "bg-blue-600 text-white",
						i === 1 && "bg-black text-white",
						i === 2 && "bg-yellow-400 text-black",
						i === 3 && "bg-red-600 text-white"
					]}>
						<!-- Geometric shape behind number -->
						<div class:list={[
							"absolute opacity-15",
							i === 0 && "w-32 h-32 md:w-40 md:h-40 rounded-full border-8 border-white",
							i === 1 && "w-28 h-28 md:w-36 md:h-36 bg-yellow-400 rotate-45",
							i === 2 && "w-32 h-32 md:w-40 md:h-40 rounded-full bg-red-600",
							i === 3 && "w-28 h-28 md:w-36 md:h-36 border-8 border-white"
						]}></div>
						<span class="text-5xl md:text-7xl lg:text-8xl font-black leading-none relative z-10">{stat.value}</span>
						<span class="text-[0.65rem] md:text-xs uppercase tracking-[0.3em] font-black mt-4 relative z-10">{stat.label}</span>
					</div>
				))}
			</div>
		</section>

		<!-- ABOUT — asymmetric constructivist composition -->
		<section class="bg-black text-white relative">
			<div class="grid grid-cols-1 md:grid-cols-12 min-h-[60vh]">
				<!-- Vertical title column -->
				<div class="md:col-span-3 bg-yellow-400 text-black p-8 md:p-12 flex flex-col justify-between">
					<h2 class="text-4xl md:text-5xl font-black uppercase tracking-tighter leading-[0.85]">
						{t.home.aboutUs}
					</h2>
					<div class="hidden md:flex flex-col gap-4 mt-12">
						<div class="w-16 h-16 rounded-full bg-black"></div>
						<div class="w-16 h-16 bg-red-600"></div>
						<div class="w-0 h-0 border-l-[32px] border-l-transparent border-r-[32px] border-r-transparent border-b-[56px] border-b-blue-600"></div>
					</div>
				</div>

				<!-- Content columns -->
				<div class="md:col-span-9 p-8 md:p-16 lg:p-20 flex flex-col gap-8">
					{sanctuary.about.map((paragraph: string, i: number) => (
						<div class="flex gap-6 items-start">
							<div class:list={[
								"w-4 h-4 shrink-0 mt-2",
								i % 3 === 0 && "rounded-full bg-red-600",
								i % 3 === 1 && "bg-blue-600",
								i % 3 === 2 && "bg-yellow-400 rotate-45"
							]}></div>
							<p class="text-base md:text-lg leading-relaxed font-light">{paragraph}</p>
						</div>
					))}
				</div>
			</div>

			<!-- Blue strip accent at bottom -->
			<div class="h-4 bg-blue-600"></div>
		</section>
	</main>

	<!-- Footer — geometric strip -->
	<footer class="bg-black text-white border-t-4 border-white">
		<div class="flex flex-wrap items-stretch">
			<div class="bg-red-600 px-4 py-4 flex items-center">
				<div class="w-4 h-4 rounded-full bg-white"></div>
			</div>
			<div class="bg-blue-600 px-4 py-4 flex items-center">
				<div class="w-4 h-4 bg-white rotate-45"></div>
			</div>
			<div class="bg-yellow-400 px-4 py-4 flex items-center">
				<div class="w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-b-[10px] border-b-black"></div>
			</div>
			<div class="flex-1 flex items-center justify-end px-6 py-4">
				<p class="text-[0.65rem] uppercase tracking-[0.3em] font-black">
					&copy; 2026 {sanctuary.name} &mdash; {t.footer.style}: {meta.name}
				</p>
			</div>
		</div>
	</footer>
</div>
