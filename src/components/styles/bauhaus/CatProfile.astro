---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-sans">
	<!-- Nav -->
	<nav class="bg-black text-white flex flex-wrap items-center justify-between px-6 py-4 border-b-4 border-red-600">
		<div class="flex items-center gap-2">
			<div class="w-4 h-4 rounded-full bg-yellow-400"></div>
			<div class="w-4 h-4 bg-red-600"></div>
			<div class="w-0 h-0 border-l-[8px] border-l-transparent border-r-[8px] border-r-transparent border-b-[14px] border-b-blue-600"></div>
		</div>
		<div class="flex flex-wrap gap-6">
			{nav.map((item: any) => (
				<a href={item.href} class="uppercase text-sm font-bold tracking-widest hover:text-yellow-400 transition-colors">{item.label}</a>
			))}
		</div>
	</nav>

	<main>
		<!-- Back link -->
		<div class="bg-black text-white px-8 py-3">
			<a href={`/${lang}/${style}/cats`} class="text-sm uppercase tracking-widest font-bold hover:text-yellow-400 transition-colors">
				&larr; {t.cats.backToAll}
			</a>
		</div>

		<!-- Cat profile hero -->
		<article>
			<section class="grid grid-cols-1 md:grid-cols-12">
				<!-- Left: Name and geometric composition -->
				<div class="md:col-span-5 bg-red-600 text-white p-8 md:p-16 flex flex-col justify-center relative overflow-hidden">
					<h1 class="text-5xl md:text-7xl font-black uppercase tracking-tight leading-none mb-6 relative z-10">
						{cat.name}
					</h1>
					<div class="w-16 h-1 bg-yellow-400 mb-6 relative z-10"></div>
					<!-- Personality tags -->
					<div class="flex flex-wrap gap-2 relative z-10">
						{cat.personality.map((trait: string) => (
							<span class="text-xs uppercase tracking-widest font-bold border-2 border-white px-3 py-1">
								{trait}
							</span>
						))}
					</div>
					<!-- Decorative shapes -->
					<div class="absolute -bottom-8 -right-8 w-40 h-40 rounded-full border-4 border-white opacity-20"></div>
					<div class="absolute top-6 right-6 w-10 h-10 bg-yellow-400"></div>
				</div>

				<!-- Right: Details grid -->
				<div class="md:col-span-7 bg-white p-8 md:p-16">
					<dl class="grid grid-cols-2 gap-0">
						<div class="border-2 border-black p-4 md:p-6 bg-blue-600 text-white">
							<dt class="text-xs uppercase tracking-widest font-bold mb-1 opacity-75">{t.cats.breed}</dt>
							<dd class="text-lg md:text-xl font-black uppercase">{cat.breed}</dd>
						</div>
						<div class="border-2 border-black p-4 md:p-6 bg-yellow-400 text-black">
							<dt class="text-xs uppercase tracking-widest font-bold mb-1 opacity-75">{t.cats.age}</dt>
							<dd class="text-lg md:text-xl font-black uppercase">{cat.age}</dd>
						</div>
						<div class="border-2 border-black p-4 md:p-6 bg-black text-white">
							<dt class="text-xs uppercase tracking-widest font-bold mb-1 opacity-75">{t.cats.gender}</dt>
							<dd class="text-lg md:text-xl font-black uppercase">{cat.gender}</dd>
						</div>
						<div class="border-2 border-black p-4 md:p-6 bg-white text-black">
							<dt class="text-xs uppercase tracking-widest font-bold mb-1 opacity-75">{t.cats.color}</dt>
							<dd class="text-lg md:text-xl font-black uppercase">{cat.color}</dd>
						</div>
						<div class="border-2 border-black p-4 md:p-6 bg-red-600 text-white">
							<dt class="text-xs uppercase tracking-widest font-bold mb-1 opacity-75">{t.cats.arrived}</dt>
							<dd class="text-lg md:text-xl font-black uppercase">{cat.arrivalDate}</dd>
						</div>
						<div class="border-2 border-black p-4 md:p-6 bg-blue-600 text-white">
							<dt class="text-xs uppercase tracking-widest font-bold mb-1 opacity-75">{t.cats.status}</dt>
							<dd class="text-lg md:text-xl font-black uppercase">{cat.status}</dd>
						</div>
					</dl>
				</div>
			</section>

			<!-- Description -->
			<section class="bg-white py-12 md:py-20 px-8 md:px-16">
				<div class="max-w-3xl mx-auto border-l-4 border-black pl-8">
					<p class="text-lg md:text-xl leading-relaxed font-light">{cat.description}</p>
				</div>
				<div class="max-w-3xl mx-auto mt-10">
					<a href={`/${lang}/${style}/auth`} class="inline-block bg-yellow-400 text-black font-black uppercase tracking-widest px-10 py-4 text-sm border-2 border-black hover:bg-red-600 hover:text-white hover:border-red-600 transition-colors">
						{t.cats.adopt} {cat.name}
					</a>
				</div>
			</section>
		</article>

		<!-- Other cats -->
		<section class="bg-black text-white py-12 md:py-20 px-8 md:px-16">
			<div class="max-w-6xl mx-auto">
				<h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight mb-2">{t.cats.otherCats}</h2>
				<div class="w-16 h-1 bg-red-600 mb-10"></div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-0">
					{otherCats.map((c: any, i: number) => (
						<a href={`/${lang}/${style}/cats/${c.id}`} class="group block border-2 border-white hover:border-yellow-400 transition-colors p-6 md:p-8">
							<div class:list={[
								"w-6 h-6 mb-4",
								i % 3 === 0 && "rounded-full bg-red-600",
								i % 3 === 1 && "bg-blue-600",
								i % 3 === 2 && "bg-yellow-400"
							]}></div>
							<h3 class="text-xl font-black uppercase tracking-tight group-hover:text-yellow-400 transition-colors mb-2">{c.name}</h3>
							<p class="text-sm uppercase tracking-widest font-bold text-neutral-400">{c.breed} · {c.age}</p>
						</a>
					))}
				</div>
			</div>
		</section>
	</main>
</div>
