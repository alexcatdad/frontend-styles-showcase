---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-sans">
	<!-- Nav — geometric composition strip -->
	<nav class="relative z-50 flex flex-wrap items-stretch">
		<div class="bg-red-600 w-16 md:w-24 shrink-0"></div>
		<div class="flex-1 bg-black text-white flex flex-wrap items-center justify-between px-6 py-4">
			<div class="flex items-center gap-3">
				<div class="w-5 h-5 rounded-full bg-yellow-400"></div>
				<div class="w-5 h-5 bg-red-600 rotate-45"></div>
				<div class="w-0 h-0 border-l-[10px] border-l-transparent border-r-[10px] border-r-transparent border-b-[18px] border-b-blue-600"></div>
			</div>
			<div class="flex flex-wrap gap-6">
				{nav.map((item: any) => (
					<a href={item.href} class="uppercase text-xs font-black tracking-[0.25em] hover:text-yellow-400 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
		<div class="bg-blue-600 w-10 md:w-16 shrink-0"></div>
	</nav>

	<main>
		<!-- Back link bar -->
		<div class="bg-yellow-400 text-black px-8 py-3 flex items-center gap-3">
			<div class="w-0 h-0 border-t-[6px] border-t-transparent border-b-[6px] border-b-transparent border-r-[10px] border-r-black"></div>
			<a href={`/${lang}/${style}/cats`} class="text-xs uppercase tracking-[0.25em] font-black hover:text-red-600 transition-colors">
				{t.cats.backToAll}
			</a>
		</div>

		<article>
			<!-- Hero — poster-style name composition -->
			<section class="relative overflow-hidden">
				<div class="grid grid-cols-1 md:grid-cols-12 min-h-[50vh]">
					<!-- Left: Giant name on red -->
					<div class="md:col-span-7 bg-red-600 text-white p-8 md:p-16 lg:p-20 flex flex-col justify-center relative overflow-hidden">
						<!-- Background circle -->
						<div class="absolute -right-24 -bottom-24 w-72 h-72 rounded-full border-8 border-white opacity-15"></div>
						<div class="absolute top-8 right-8 w-12 h-12 bg-yellow-400 rotate-45"></div>

						<img src={cat.image} alt={cat.name} class="w-48 h-48 md:w-64 md:h-64 object-cover rounded-full border-4 border-white mb-8 relative z-10" />
						<h1 class="text-6xl md:text-[8rem] lg:text-[10rem] font-black uppercase tracking-tighter leading-[0.8] mb-8 relative z-10">
							{cat.name}
						</h1>
						<div class="flex items-center gap-4 mb-6 relative z-10">
							<div class="w-12 h-12 rounded-full border-4 border-white"></div>
							<div class="w-16 h-1 bg-yellow-400"></div>
						</div>
						<!-- Personality tags -->
						<div class="flex flex-wrap gap-2 relative z-10">
							{cat.personality.map((trait: string) => (
								<span class="text-[0.65rem] uppercase tracking-[0.3em] font-black border-2 border-white px-4 py-1.5">
									{trait}
								</span>
							))}
						</div>
					</div>

					<!-- Right: Details grid — color-blocked cells -->
					<div class="md:col-span-5 grid grid-cols-2 grid-rows-3">
						<div class="bg-blue-600 text-white p-4 md:p-6 border-b-4 border-r-4 border-black flex flex-col justify-center">
							<dt class="text-[0.6rem] uppercase tracking-[0.3em] font-black opacity-70 mb-1">{t.cats.breed}</dt>
							<dd class="text-base md:text-lg font-black uppercase tracking-tight">{cat.breed}</dd>
						</div>
						<div class="bg-yellow-400 text-black p-4 md:p-6 border-b-4 border-black flex flex-col justify-center">
							<dt class="text-[0.6rem] uppercase tracking-[0.3em] font-black opacity-70 mb-1">{t.cats.age}</dt>
							<dd class="text-base md:text-lg font-black uppercase tracking-tight">{cat.age}</dd>
						</div>
						<div class="bg-black text-white p-4 md:p-6 border-b-4 border-r-4 border-white flex flex-col justify-center">
							<dt class="text-[0.6rem] uppercase tracking-[0.3em] font-black opacity-70 mb-1">{t.cats.gender}</dt>
							<dd class="text-base md:text-lg font-black uppercase tracking-tight">{cat.gender}</dd>
						</div>
						<div class="bg-white text-black p-4 md:p-6 border-b-4 border-l-4 border-black flex flex-col justify-center">
							<dt class="text-[0.6rem] uppercase tracking-[0.3em] font-black opacity-50 mb-1">{t.cats.color}</dt>
							<dd class="text-base md:text-lg font-black uppercase tracking-tight">{cat.color}</dd>
						</div>
						<div class="bg-red-600 text-white p-4 md:p-6 border-r-4 border-black flex flex-col justify-center">
							<dt class="text-[0.6rem] uppercase tracking-[0.3em] font-black opacity-70 mb-1">{t.cats.arrived}</dt>
							<dd class="text-base md:text-lg font-black uppercase tracking-tight">{cat.arrivalDate}</dd>
						</div>
						<div class="bg-blue-600 text-white p-4 md:p-6 flex flex-col justify-center">
							<dt class="text-[0.6rem] uppercase tracking-[0.3em] font-black opacity-70 mb-1">{t.cats.status}</dt>
							<dd class="text-base md:text-lg font-black uppercase tracking-tight">{cat.status}</dd>
						</div>
					</div>
				</div>
			</section>

			<!-- Description — black bar + white content -->
			<section class="bg-white relative">
				<div class="grid grid-cols-1 md:grid-cols-12">
					<!-- Left geometric accent -->
					<div class="hidden md:flex md:col-span-2 bg-black items-center justify-center relative overflow-hidden">
						<div class="w-20 h-20 rounded-full border-4 border-yellow-400"></div>
						<div class="absolute bottom-0 left-0 w-full h-1/3 bg-blue-600"></div>
					</div>
					<!-- Text content -->
					<div class="md:col-span-10 p-8 md:p-16 lg:p-20">
						<p class="text-lg md:text-xl leading-relaxed font-light max-w-2xl">{cat.description}</p>
						<div class="mt-10">
							<a href={`/${lang}/${style}/auth`} class="inline-flex items-center gap-4 bg-black text-white font-black uppercase tracking-[0.25em] px-10 py-5 text-sm border-4 border-black hover:bg-red-600 hover:border-red-600 transition-colors">
								<div class="w-4 h-4 rounded-full bg-yellow-400"></div>
								{t.cats.adopt} {cat.name}
							</a>
						</div>
					</div>
				</div>
			</section>
		</article>

		<!-- Other cats — constructivist grid on black -->
		<section class="bg-black text-white">
			<div class="p-8 md:p-16">
				<div class="flex items-center gap-6 mb-10">
					<div class="w-8 h-8 bg-red-600 rotate-45"></div>
					<h2 class="text-3xl md:text-5xl font-black uppercase tracking-tighter">{t.cats.otherCats}</h2>
					<div class="flex-1 h-1 bg-white hidden md:block"></div>
				</div>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3">
				{otherCats.map((c: any, i: number) => (
					<a href={`/${lang}/${style}/cats/${c.id}`}
						class:list={[
							"group block p-8 md:p-10 border-t-4 transition-colors relative overflow-hidden",
							i % 3 === 0 && "border-red-600 hover:bg-red-600",
							i % 3 === 1 && "border-blue-600 hover:bg-blue-600",
							i % 3 === 2 && "border-yellow-400 hover:bg-yellow-400 hover:text-black"
						]}>
						<!-- Background shape -->
						<div class:list={[
							"absolute -right-4 -bottom-4 opacity-10 group-hover:opacity-20 transition-opacity",
							i % 3 === 0 && "w-24 h-24 rounded-full bg-red-600",
							i % 3 === 1 && "w-20 h-20 bg-blue-600",
							i % 3 === 2 && "w-24 h-24 bg-yellow-400 rotate-45"
						]}></div>
						<h3 class="text-2xl md:text-3xl font-black uppercase tracking-tighter mb-3 relative z-10">{c.name}</h3>
						<p class="text-xs uppercase tracking-[0.25em] font-bold text-neutral-400 group-hover:text-current relative z-10">{c.breed} / {c.age}</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
