---
const { lang, style, nav, cats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-white text-black font-sans">
	<!-- Nav — geometric composition strip -->
	<nav class="relative z-50 flex flex-wrap items-stretch">
		<div class="bg-red-600 w-16 md:w-24 shrink-0"></div>
		<div class="flex-1 bg-black text-white flex flex-wrap items-center justify-between px-6 py-4">
			<div class="flex items-center gap-3">
				<div class="w-5 h-5 rounded-full bg-yellow-400"></div>
				<div class="w-5 h-5 bg-red-600 rotate-45"></div>
				<div class="w-0 h-0 border-l-[10px] border-l-transparent border-r-[10px] border-r-transparent border-b-[18px] border-b-blue-600"></div>
			</div>
			<div class="flex flex-wrap gap-6">
				{nav.map((item: any) => (
					<a href={item.href} class="uppercase text-xs font-black tracking-[0.25em] hover:text-yellow-400 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
		<div class="bg-blue-600 w-10 md:w-16 shrink-0"></div>
	</nav>

	<main>
		<!-- Header — dramatic diagonal composition -->
		<section class="relative bg-blue-600 text-white overflow-hidden min-h-[40vh] flex items-center">
			<!-- Large yellow circle -->
			<div class="absolute -right-20 -top-20 w-64 h-64 md:w-96 md:h-96 rounded-full bg-yellow-400 opacity-20"></div>
			<!-- Black triangle -->
			<div class="absolute right-8 bottom-0 w-0 h-0 border-l-[60px] border-l-transparent border-r-[60px] border-r-transparent border-b-[100px] border-b-black opacity-30 hidden md:block"></div>
			<!-- Red bar -->
			<div class="absolute left-0 bottom-0 h-3 w-1/2 bg-red-600"></div>

			<div class="relative z-10 px-8 md:px-16 py-16 md:py-24 max-w-6xl">
				<div class="flex items-center gap-6 mb-6">
					<div class="w-16 h-16 rounded-full border-4 border-white"></div>
					<div class="w-16 h-1 bg-yellow-400"></div>
				</div>
				<h1 class="text-5xl md:text-7xl lg:text-[8rem] font-black uppercase tracking-tighter leading-[0.85] mb-6">
					{t.cats.title}
				</h1>
				<p class="text-lg md:text-2xl font-light max-w-xl tracking-wide">{t.cats.subtitle}</p>
			</div>
		</section>

		<!-- Cat cards — constructivist asymmetric grid -->
		<section class="bg-white">
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
				{cats.map((cat: any, i: number) => (
					<a href={`${_base}/${lang}/${style}/cats/${cat.id}`}
						class:list={[
							"group block relative overflow-hidden border-b-4 border-r-4 border-black transition-colors",
							i % 6 === 0 && "lg:col-span-2",
						]}>
						<!-- Top color strip with geometric shape -->
						<div class:list={[
							"h-3",
							i % 3 === 0 && "bg-red-600",
							i % 3 === 1 && "bg-yellow-400",
							i % 3 === 2 && "bg-blue-600"
						]}></div>

						<div class="p-6 md:p-8 relative">
							<!-- Geometric accent — different per card -->
							<div class:list={[
								"absolute top-4 right-4 opacity-10 group-hover:opacity-30 transition-opacity",
								i % 3 === 0 && "w-24 h-24 rounded-full bg-red-600",
								i % 3 === 1 && "w-20 h-20 bg-yellow-400 rotate-45",
								i % 3 === 2 && "w-0 h-0 border-l-[40px] border-l-transparent border-r-[40px] border-r-transparent border-b-[70px] border-b-blue-600"
							]}></div>

							<!-- Cat thumbnail -->
							<img src={cat.thumbnail} alt={cat.name} class="w-full h-40 object-cover mb-4 relative z-10" />

							<!-- Name -->
							<div class="flex items-start gap-4 mb-4 relative z-10">
								<div class:list={[
									"w-6 h-6 shrink-0 mt-1",
									i % 3 === 0 && "rounded-full bg-red-600",
									i % 3 === 1 && "bg-blue-600",
									i % 3 === 2 && "bg-yellow-400 rotate-45"
								]}></div>
								<h2 class="text-3xl md:text-4xl font-black uppercase tracking-tighter leading-none group-hover:text-red-600 transition-colors">
									{cat.name}
								</h2>
							</div>

							<!-- Details strip -->
							<div class="bg-black text-white px-4 py-2 mb-4 inline-block">
								<span class="text-xs uppercase tracking-[0.2em] font-black">
									{cat.breed} / {cat.age} / {cat.gender}
								</span>
							</div>

							<!-- Description -->
							<p class="text-sm leading-relaxed font-light mb-6 max-w-md relative z-10">
								{cat.description.slice(0, 100)}...
							</p>

							<!-- Personality as geometric tagged pills -->
							<div class="flex flex-wrap gap-1 mb-4">
								{cat.personality.map((trait: string, j: number) => (
									<span class:list={[
										"text-[0.65rem] uppercase tracking-[0.2em] font-black px-3 py-1 border-2",
										j % 3 === 0 && "border-red-600 text-red-600",
										j % 3 === 1 && "border-blue-600 text-blue-600",
										j % 3 === 2 && "border-black text-black"
									]}>
										{trait}
									</span>
								))}
							</div>

							<!-- Status badge -->
							<div class="pt-4 border-t-2 border-black">
								<span class:list={[
									"text-[0.65rem] uppercase tracking-[0.3em] font-black px-4 py-1.5 inline-block",
									cat.status === "available" && "bg-yellow-400 text-black",
									cat.status === "adopted" && "bg-blue-600 text-white",
									cat.status !== "available" && cat.status !== "adopted" && "bg-red-600 text-white"
								]}>
									{cat.status}
								</span>
							</div>
						</div>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
