---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-sans">
	<!-- Nav — geometric composition strip -->
	<nav class="relative z-50 flex flex-wrap items-stretch">
		<div class="bg-red-600 w-16 md:w-24 shrink-0"></div>
		<div class="flex-1 bg-black text-white flex flex-wrap items-center justify-between px-6 py-4">
			<div class="flex items-center gap-3">
				<div class="w-5 h-5 rounded-full bg-yellow-400"></div>
				<div class="w-5 h-5 bg-red-600 rotate-45"></div>
				<div class="w-0 h-0 border-l-[10px] border-l-transparent border-r-[10px] border-r-transparent border-b-[18px] border-b-blue-600"></div>
			</div>
			<div class="flex flex-wrap gap-6">
				{nav.map((item: any) => (
					<a href={item.href} class="uppercase text-xs font-black tracking-[0.25em] hover:text-yellow-400 transition-colors">{item.label}</a>
				))}
			</div>
		</div>
		<div class="bg-blue-600 w-10 md:w-16 shrink-0"></div>
	</nav>

	<main>
		<!-- Header — red poster block -->
		<section class="relative bg-red-600 text-white overflow-hidden min-h-[40vh] flex items-center">
			<!-- Geometric overlays -->
			<div class="absolute right-0 top-0 w-48 h-full bg-black opacity-10"></div>
			<div class="absolute -left-20 -bottom-20 w-72 h-72 rounded-full border-8 border-white opacity-15"></div>
			<div class="absolute right-20 top-12 w-16 h-16 bg-yellow-400 rotate-45 hidden md:block"></div>
			<div class="absolute left-1/2 bottom-4 w-0 h-0 border-l-[30px] border-l-transparent border-r-[30px] border-r-transparent border-b-[52px] border-b-blue-600 opacity-20 hidden md:block"></div>

			<div class="relative z-10 px-8 md:px-16 py-16 md:py-24 max-w-6xl">
				<div class="flex items-center gap-4 mb-6">
					<div class="w-12 h-12 rounded-full border-4 border-white"></div>
					<div class="w-16 h-1 bg-yellow-400"></div>
				</div>
				<h1 class="text-5xl md:text-7xl lg:text-[8rem] font-black uppercase tracking-tighter leading-[0.85] mb-6">
					{t.donate.title}
				</h1>
				<p class="text-lg md:text-2xl font-light max-w-xl tracking-wide">{t.donate.subtitle}</p>
			</div>
		</section>

		<!-- Monthly tiers -->
		<section class="bg-white relative">
			<!-- Section header -->
			<div class="border-b-4 border-black px-8 md:px-16 py-8 flex items-center gap-6">
				<div class="w-10 h-10 bg-blue-600"></div>
				<h2 class="text-3xl md:text-5xl font-black uppercase tracking-tighter">{t.donate.monthly}</h2>
				<div class="flex-1 h-1 bg-black hidden md:block"></div>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3">
				{monthlyTiers.map((tier: any, i: number) => (
					<div class:list={[
						"border-r-4 border-b-4 border-black flex flex-col relative overflow-hidden last:border-r-0",
						tier.highlighted ? "bg-black text-white" : "bg-white text-black"
					]}>
						{tier.highlighted && (
							<div class="bg-yellow-400 text-black text-[0.65rem] uppercase tracking-[0.3em] font-black text-center py-2">
								{t.donate.mostPopular}
							</div>
						)}

						{/* Color accent strip */}
						{!tier.highlighted && (
							<div class:list={[
								"h-3",
								i === 0 && "bg-red-600",
								i === 2 && "bg-blue-600"
							]}></div>
						)}

						<div class="p-8 md:p-10 flex flex-col flex-1">
							<!-- Geometric shape + tier name -->
							<div class="flex items-center gap-4 mb-6">
								<div class:list={[
									"w-8 h-8 shrink-0",
									i % 3 === 0 && "rounded-full bg-red-600",
									i % 3 === 1 && "bg-yellow-400 rotate-45",
									i % 3 === 2 && "bg-blue-600"
								]}></div>
								<h3 class="text-lg font-black uppercase tracking-[0.15em]">{tier.name}</h3>
							</div>

							<!-- Price — giant number inside geometric frame -->
							<div class="relative mb-6">
								<div class:list={[
									"absolute -left-2 -top-2 opacity-10",
									i % 3 === 0 && "w-24 h-24 rounded-full border-4 border-red-600",
									i % 3 === 1 && "w-20 h-20 bg-yellow-400",
									i % 3 === 2 && "w-24 h-24 rounded-full border-4 border-blue-600"
								]}></div>
								<span class="text-5xl md:text-6xl font-black relative z-10">${tier.amount}</span>
								<span class:list={[
									"text-[0.65rem] uppercase tracking-[0.3em] font-black ml-2",
									tier.highlighted ? "opacity-60" : "opacity-40"
								]}>{t.donate.perMonth}</span>
							</div>

							<p class:list={[
								"text-sm font-light leading-relaxed mb-8",
								tier.highlighted ? "text-neutral-400" : "text-neutral-500"
							]}>{tier.description}</p>

							<ul class="flex flex-col gap-3 mb-10 flex-1">
								{tier.perks.map((perk: string, j: number) => (
									<li class="flex items-start gap-3 text-sm">
										<div class:list={[
											"w-2 h-2 shrink-0 mt-1.5",
											tier.highlighted && "bg-yellow-400",
											!tier.highlighted && j % 2 === 0 && "bg-red-600",
											!tier.highlighted && j % 2 === 1 && "bg-blue-600"
										]}></div>
										{perk}
									</li>
								))}
							</ul>

							<button type="button" class:list={[
								"w-full uppercase tracking-[0.25em] font-black text-sm py-4 border-4 transition-colors",
								tier.highlighted
									? "bg-yellow-400 text-black border-yellow-400 hover:bg-red-600 hover:text-white hover:border-red-600"
									: "bg-black text-white border-black hover:bg-red-600 hover:border-red-600"
							]}>
								{t.donate.choose} {tier.name}
							</button>
						</div>
					</div>
				))}
			</div>
		</section>

		<!-- One-time tiers — inverted on black -->
		<section class="bg-black text-white relative">
			<!-- Section header -->
			<div class="border-b-4 border-white px-8 md:px-16 py-8 flex items-center gap-6">
				<div class="w-10 h-10 rounded-full bg-yellow-400"></div>
				<h2 class="text-3xl md:text-5xl font-black uppercase tracking-tighter">{t.donate.oneTime}</h2>
				<div class="flex-1 h-1 bg-white hidden md:block"></div>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3">
				{oneTimeTiers.map((tier: any, i: number) => (
					<div class:list={[
						"border-r-4 border-b-4 flex flex-col relative overflow-hidden last:border-r-0",
						tier.highlighted ? "border-yellow-400 bg-neutral-900" : "border-white"
					]}>
						{tier.highlighted && (
							<div class="bg-red-600 text-white text-[0.65rem] uppercase tracking-[0.3em] font-black text-center py-2">
								{t.donate.greatestImpact}
							</div>
						)}

						<div class="p-8 md:p-10 flex flex-col flex-1">
							<!-- Shape + name -->
							<div class="flex items-center gap-4 mb-6">
								<div class:list={[
									"w-8 h-8 shrink-0",
									i % 3 === 0 && "bg-red-600",
									i % 3 === 1 && "rounded-full bg-blue-600",
									i % 3 === 2 && "bg-yellow-400 rotate-45"
								]}></div>
								<h3 class="text-lg font-black uppercase tracking-[0.15em]">{tier.name}</h3>
							</div>

							<!-- Price -->
							<div class="relative mb-6">
								<div class:list={[
									"absolute -left-2 -top-2 opacity-10",
									i % 3 === 0 && "w-24 h-24 bg-red-600 rotate-45",
									i % 3 === 1 && "w-24 h-24 rounded-full border-4 border-blue-600",
									i % 3 === 2 && "w-20 h-20 bg-yellow-400"
								]}></div>
								<span class="text-5xl md:text-6xl font-black relative z-10">${tier.amount}</span>
							</div>

							<p class="text-sm font-light leading-relaxed mb-8 text-neutral-400">{tier.description}</p>

							<ul class="flex flex-col gap-3 mb-10 flex-1">
								{tier.perks.map((perk: string) => (
									<li class="flex items-start gap-3 text-sm">
										<div class="w-2 h-2 bg-yellow-400 shrink-0 mt-1.5"></div>
										{perk}
									</li>
								))}
							</ul>

							<button type="button" class:list={[
								"w-full uppercase tracking-[0.25em] font-black text-sm py-4 border-4 transition-colors",
								tier.highlighted
									? "bg-yellow-400 text-black border-yellow-400 hover:bg-red-600 hover:text-white hover:border-red-600"
									: "bg-white text-black border-white hover:bg-blue-600 hover:text-white hover:border-blue-600"
							]}>
								{t.donate.give} ${tier.amount}
							</button>
						</div>
					</div>
				))}
			</div>
		</section>
	</main>
</div>
