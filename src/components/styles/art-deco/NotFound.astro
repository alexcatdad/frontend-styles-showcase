---
const { lang, style, nav, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-neutral-900 font-serif text-stone-200 antialiased">
	<!-- Navigation -->
	<nav class="sticky top-0 z-50 border-b border-amber-500/30 bg-neutral-900/95 backdrop-blur-sm">
		<div class="mx-auto flex h-14 max-w-5xl items-center justify-between px-4 lg:px-6">
			<a href={`${_base}/${lang}/${style}/`} class="text-sm font-light uppercase tracking-[0.3em] text-amber-400 transition-colors hover:text-amber-300">404</a>
			<div class="hidden items-center gap-1 sm:flex">
				{nav.map((item: any) => (
					<a href={item.href} class="px-3 py-2 text-xs font-light uppercase tracking-[0.3em] text-amber-400/70 transition-colors hover:text-amber-300">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<!-- Mobile nav -->
	<div class="flex items-center gap-1 overflow-x-auto border-b border-amber-500/20 px-4 sm:hidden">
		{nav.map((item: any) => (
			<a href={item.href} class="shrink-0 px-3 py-2.5 text-xs font-light uppercase tracking-[0.3em] text-amber-400/70 transition-colors hover:text-amber-300">{item.label}</a>
		))}
	</div>

	<main class="flex min-h-[calc(100vh-57px)] items-center justify-center px-4">
		<section class="w-full max-w-lg text-center">
			<!-- Large 404 in gold outline style -->
			<div class="mb-6">
				<span class="text-[100px] font-bold leading-none tracking-[0.15em] text-amber-400/10 sm:text-[140px] lg:text-[180px]">404</span>
			</div>

			<!-- Decorative line -->
			<div class="mb-8 flex items-center justify-center">
				<span class="h-px w-16 bg-amber-500/40"></span>
				<span class="mx-3 text-amber-500/50">&#9670;</span>
				<span class="h-px w-16 bg-amber-500/40"></span>
			</div>

			<!-- Heading and description -->
			<h1 class="mb-4 text-2xl font-bold uppercase tracking-[0.15em] text-amber-400 sm:text-3xl">{t.notFound.heading}</h1>
			<p class="mx-auto mb-8 max-w-sm text-sm font-light leading-relaxed text-stone-400">{t.notFound.description}</p>

			<!-- Decorative line -->
			<div class="mb-8 flex items-center justify-center">
				<span class="h-px w-10 bg-amber-500/30"></span>
				<span class="mx-2 text-xs text-amber-500/40">&#9670;</span>
				<span class="h-px w-10 bg-amber-500/30"></span>
			</div>

			<!-- CTAs -->
			<div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
				<a href={`${_base}/${lang}/${style}/`} class="inline-block border-2 border-amber-400 bg-amber-400 px-8 py-3 text-xs font-bold uppercase tracking-[0.3em] text-neutral-900 transition-colors hover:bg-amber-300 hover:border-amber-300">{t.notFound.backHome}</a>
				<a href={`${_base}/${lang}/${style}/cats`} class="inline-block border-2 border-amber-500/40 px-8 py-3 text-xs font-bold uppercase tracking-[0.3em] text-amber-400 transition-colors hover:border-amber-400 hover:bg-amber-400/10">{t.notFound.meetCats}</a>
			</div>
		</section>
	</main>
</div>
