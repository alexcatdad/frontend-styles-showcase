---
const { lang, style, nav, posts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-neutral-900 font-serif text-stone-200 antialiased">
	<!-- Navigation -->
	<nav class="sticky top-0 z-50 border-b border-amber-500/30 bg-neutral-900/95 backdrop-blur-sm">
		<div class="mx-auto flex h-14 max-w-5xl items-center justify-between px-4 lg:px-6">
			<a href={`${_base}/${lang}/${style}/`} class="text-sm font-light uppercase tracking-[0.3em] text-amber-400 transition-colors hover:text-amber-300">{t.blog.title}</a>
			<div class="hidden items-center gap-1 sm:flex">
				{nav.map((item: any) => (
					<a href={item.href} class="px-3 py-2 text-xs font-light uppercase tracking-[0.3em] text-amber-400/70 transition-colors hover:text-amber-300">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<!-- Mobile nav -->
	<div class="flex items-center gap-1 overflow-x-auto border-b border-amber-500/20 px-4 sm:hidden">
		{nav.map((item: any) => (
			<a href={item.href} class="shrink-0 px-3 py-2.5 text-xs font-light uppercase tracking-[0.3em] text-amber-400/70 transition-colors hover:text-amber-300">{item.label}</a>
		))}
	</div>

	<main class="mx-auto max-w-3xl px-4 py-10 lg:py-14">
		<!-- Title with decorative lines -->
		<div class="mb-10 text-center">
			<div class="mb-4 flex items-center justify-center">
				<span class="h-px w-12 bg-amber-500/40"></span>
				<span class="mx-3 text-amber-500/50">&#9670;</span>
				<span class="h-px w-12 bg-amber-500/40"></span>
			</div>
			<h1 class="text-3xl font-bold uppercase tracking-[0.15em] text-amber-400 sm:text-4xl">{t.blog.title}</h1>
			<p class="mt-2 text-sm font-light tracking-wide text-stone-400">{t.blog.subtitle}</p>
			<div class="mt-4 flex items-center justify-center">
				<span class="h-px w-12 bg-amber-500/40"></span>
				<span class="mx-3 text-amber-500/50">&#9670;</span>
				<span class="h-px w-12 bg-amber-500/40"></span>
			</div>
		</div>

		<!-- Posts feed -->
		<div class="space-y-8">
			{posts.map((post: any) => (
				<a href={`${_base}/${lang}/${style}/blog/${post.slug}`} class="group block border border-amber-500/20 bg-neutral-800/40 transition-all duration-300 hover:border-amber-400/40">
					<article>
						<img src={post.image} alt={post.title} class="h-48 w-full border-b border-amber-500/20 object-cover sm:h-56" />
						<div class="p-6">
							<div class="mb-3 flex items-center gap-3 text-xs">
								<time datetime={post.date} class="font-light uppercase tracking-[0.2em] text-amber-400">{post.date}</time>
								<span class="text-amber-500/40">&#9670;</span>
								<span class="font-light text-stone-500">{post.author}</span>
							</div>
							<h2 class="mb-2 text-xl font-bold tracking-wide text-stone-100 transition-colors group-hover:text-amber-400">{post.title}</h2>
							<p class="mb-4 text-sm leading-relaxed text-stone-400">{post.excerpt}</p>
							<div class="flex flex-wrap gap-2">
								{post.tags.map((tag: string) => (
									<span class="border border-amber-500/20 px-2.5 py-0.5 text-xs font-light uppercase tracking-[0.15em] text-amber-400/60">{tag}</span>
								))}
							</div>
						</div>
					</article>
				</a>
			))}
		</div>
	</main>
</div>
