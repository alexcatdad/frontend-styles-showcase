---
const { lang, style, nav, cats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-neutral-900 font-serif text-stone-200 antialiased">
	<!-- Navigation -->
	<nav class="sticky top-0 z-50 border-b border-amber-500/30 bg-neutral-900/95 backdrop-blur-sm">
		<div class="mx-auto flex h-14 max-w-5xl items-center justify-between px-4 lg:px-6">
			<a href={`${_base}/${lang}/${style}/`} class="text-sm font-light uppercase tracking-[0.3em] text-amber-400 transition-colors hover:text-amber-300">{t.cats.title}</a>
			<div class="hidden items-center gap-1 sm:flex">
				{nav.map((item: any) => (
					<a href={item.href} class="px-3 py-2 text-xs font-light uppercase tracking-[0.3em] text-amber-400/70 transition-colors hover:text-amber-300">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<!-- Mobile nav -->
	<div class="flex items-center gap-1 overflow-x-auto border-b border-amber-500/20 px-4 sm:hidden">
		{nav.map((item: any) => (
			<a href={item.href} class="shrink-0 px-3 py-2.5 text-xs font-light uppercase tracking-[0.3em] text-amber-400/70 transition-colors hover:text-amber-300">{item.label}</a>
		))}
	</div>

	<main class="mx-auto max-w-5xl px-4 py-10 lg:px-6 lg:py-14">
		<!-- Title with decorative lines -->
		<div class="mb-10 text-center">
			<div class="mb-4 flex items-center justify-center">
				<span class="h-px w-12 bg-amber-500/40"></span>
				<span class="mx-3 text-amber-500/50">&#9670;</span>
				<span class="h-px w-12 bg-amber-500/40"></span>
			</div>
			<h1 class="text-3xl font-bold uppercase tracking-[0.15em] text-amber-400 sm:text-4xl">{t.cats.title}</h1>
			<p class="mt-2 text-sm font-light tracking-wide text-stone-400">{t.cats.subtitle}</p>
			<div class="mt-4 flex items-center justify-center">
				<span class="h-px w-12 bg-amber-500/40"></span>
				<span class="mx-3 text-amber-500/50">&#9670;</span>
				<span class="h-px w-12 bg-amber-500/40"></span>
			</div>
		</div>

		<!-- Cat cards grid -->
		<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{cats.map((cat: any) => (
				<a href={`${_base}/${lang}/${style}/cats/${cat.id}`} class="group block border border-amber-500/20 bg-neutral-800 transition-all duration-300 hover:border-amber-400/50 hover:bg-neutral-800/80">
					<div class="overflow-hidden">
						<img src={cat.thumbnail} alt={cat.name} class="h-52 w-full object-cover transition-transform duration-500 group-hover:scale-105" />
					</div>
					<div class="border-t border-amber-500/20 p-5">
						<h2 class="mb-1 text-xl font-bold tracking-wide text-stone-100">{cat.name}</h2>
						<div class="mb-3 flex items-center gap-2 text-xs">
							<span class="font-light uppercase tracking-[0.2em] text-amber-400">{cat.breed}</span>
							<span class="text-amber-500/40">&#9670;</span>
							<span class="font-light text-amber-400/70">{cat.age}</span>
						</div>
						<p class="line-clamp-2 text-sm leading-relaxed text-stone-400">{cat.description}</p>
					</div>
				</a>
			))}
		</div>
	</main>
</div>
