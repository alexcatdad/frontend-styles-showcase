---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-neutral-900 font-serif text-stone-200 antialiased">
	<!-- Navigation -->
	<nav class="sticky top-0 z-50 border-b border-amber-500/30 bg-neutral-900/95 backdrop-blur-sm">
		<div class="mx-auto flex h-14 max-w-5xl items-center justify-between px-4 lg:px-6">
			<a href={`${_base}/${lang}/${style}/`} class="text-sm font-light uppercase tracking-[0.3em] text-amber-400 transition-colors hover:text-amber-300">{t.blog.title}</a>
			<div class="hidden items-center gap-1 sm:flex">
				{nav.map((item: any) => (
					<a href={item.href} class="px-3 py-2 text-xs font-light uppercase tracking-[0.3em] text-amber-400/70 transition-colors hover:text-amber-300">{item.label}</a>
				))}
			</div>
		</div>
	</nav>

	<!-- Mobile nav -->
	<div class="flex items-center gap-1 overflow-x-auto border-b border-amber-500/20 px-4 sm:hidden">
		{nav.map((item: any) => (
			<a href={item.href} class="shrink-0 px-3 py-2.5 text-xs font-light uppercase tracking-[0.3em] text-amber-400/70 transition-colors hover:text-amber-300">{item.label}</a>
		))}
	</div>

	<main class="mx-auto max-w-3xl px-4 py-10 lg:py-14">
		<!-- Back link -->
		<a href={`${_base}/${lang}/${style}/blog`} class="mb-8 inline-flex items-center gap-2 text-sm text-amber-400/70 transition-colors hover:text-amber-300">
			<span class="text-amber-500">&larr;</span>
			{t.blog.backToBlog}
		</a>

		<article class="mb-16">
			<!-- Header -->
			<header class="mb-10">
				<!-- Decorative top line -->
				<div class="mb-6 flex items-center">
					<span class="h-px flex-1 bg-amber-500/30"></span>
					<span class="mx-3 text-amber-500/50">&#9670;</span>
					<span class="h-px flex-1 bg-amber-500/30"></span>
				</div>

				<!-- Image with border -->
				<div class="mb-6 border-2 border-amber-500/30 p-1.5">
					<img src={post.image} alt={post.title} class="w-full object-cover" />
				</div>

				<!-- Date and author -->
				<div class="mb-3 flex items-center gap-3 text-xs">
					<time datetime={post.date} class="font-light uppercase tracking-[0.2em] text-amber-400">{post.date}</time>
					<span class="text-amber-500/40">&#9670;</span>
					<span class="font-light text-stone-500">{t.blog.by} {post.author}</span>
				</div>

				<!-- Title -->
				<h1 class="mb-4 text-2xl font-bold uppercase tracking-[0.08em] text-amber-400 sm:text-3xl lg:text-4xl">{post.title}</h1>

				<!-- Tags -->
				<div class="flex flex-wrap gap-2">
					{post.tags.map((tag: string) => (
						<span class="border border-amber-500/30 px-3 py-1 text-xs font-light uppercase tracking-[0.2em] text-amber-400/70">{tag}</span>
					))}
				</div>

				<!-- Decorative bottom line -->
				<div class="mt-6 flex items-center">
					<span class="h-px flex-1 bg-amber-500/20"></span>
					<span class="mx-3 text-amber-500/40">&#9670;</span>
					<span class="h-px flex-1 bg-amber-500/20"></span>
				</div>
			</header>

			<!-- Content -->
			<div class="space-y-5">
				{post.content.map((paragraph: string) => (
					<p class="text-base leading-[1.8] text-stone-300">{paragraph}</p>
				))}
			</div>
		</article>

		<!-- More stories -->
		<section class="border-t-2 border-amber-500/30 pt-10">
			<div class="mb-6 text-center">
				<h2 class="text-xs font-bold uppercase tracking-[0.4em] text-amber-500/70">{t.blog.moreStories}</h2>
			</div>
			<div class="space-y-4">
				{otherPosts.map((p: any) => (
					<a href={`${_base}/${lang}/${style}/blog/${p.slug}`} class="group flex items-start justify-between gap-4 border border-amber-500/15 bg-neutral-800/30 px-5 py-4 transition-all duration-200 hover:border-amber-400/40 hover:bg-neutral-800/50">
						<div class="min-w-0">
							<h3 class="mb-1 text-base font-bold text-stone-200 transition-colors group-hover:text-amber-400">{p.title}</h3>
							<p class="text-sm leading-relaxed text-stone-500">{p.excerpt}</p>
						</div>
						<span class="mt-1 shrink-0 text-sm text-amber-500/40 transition-colors group-hover:text-amber-400">&rarr;</span>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
