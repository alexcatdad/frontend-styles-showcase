---
const { lang, style, nav, posts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<nav>
	{nav.map((item: any) => (
		<a href={item.href}>{item.label}</a>
	))}
</nav>

<main>
	<h1>{t.blog.title}</h1>
	<p>{t.blog.subtitle}</p>

	<div>
		{posts.map((post: any) => (
			<a href={`${_base}/${lang}/${style}/blog/${post.slug}`}>
				<article>
					<time datetime={post.date}>{post.date}</time>
					<h2>{post.title}</h2>
					<p>{post.excerpt}</p>
					<div>
						{post.tags.map((tag: string) => (
							<span>{tag}</span>
						))}
					</div>
					<span>{t.blog.by} {post.author}</span>
				</article>
			</a>
		))}
	</div>
</main>
