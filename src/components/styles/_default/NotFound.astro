---
const { lang, style, nav, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<nav>
	{nav.map((item: any) => (
		<a href={item.href}>{item.label}</a>
	))}
</nav>

<main>
	<section>
		<h1>{t.notFound.title}</h1>
		<h2>{t.notFound.heading}</h2>
		<p>{t.notFound.description}</p>
		<a href={`${_base}/${lang}/${style}/`}>{t.notFound.backHome}</a>
		<a href={`${_base}/${lang}/${style}/cats`}>{t.notFound.meetCats}</a>
	</section>
</main>
