---
const { lang, style, nav, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<main class="bg-gray-900 font-mono text-green-400 min-h-screen overflow-x-hidden relative">
	<!-- NAV: GAME MENU BAR -->
	<nav class="border-b-2 border-green-500 bg-gray-900 px-4 py-3 flex flex-wrap items-center gap-x-6 gap-y-2 relative z-10">
		{nav.map((item: any) => (
			<a href={item.href} class="text-green-400 uppercase text-xs md:text-sm tracking-widest hover:bg-green-500 hover:text-gray-900 px-2 py-1 border border-transparent hover:border-green-500 cursor-pointer">{item.label}</a>
		))}
	</nav>

	<!-- GIANT 404 BACKGROUND -->
	<div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none overflow-hidden">
		<span class="text-[10rem] md:text-[20rem] lg:text-[30rem] font-bold leading-none tracking-tighter text-green-500 opacity-10">404</span>
	</div>

	<!-- GAME OVER CONTENT -->
	<div class="relative z-10 flex flex-col items-center justify-center min-h-[80vh] px-4 py-12 text-center">
		<div class="border-2 border-green-500 bg-gray-800 p-8 md:p-12 lg:p-16 max-w-xl w-full">
			<h1 class="text-6xl md:text-8xl lg:text-9xl font-bold text-green-400 leading-none mb-4">404</h1>
			<h2 class="text-xl md:text-3xl lg:text-4xl font-bold uppercase text-red-500 tracking-widest mb-6 md:mb-8">{t.notFound.heading}</h2>
			<p class="text-sm md:text-base text-gray-400 leading-relaxed mb-8 md:mb-10">{t.notFound.description}</p>
			<div class="flex flex-col sm:flex-row gap-3 justify-center">
				<a href={`${_base}/${lang}/${style}/`} class="border-2 border-green-500 text-green-400 uppercase text-sm px-6 py-3 tracking-widest hover:bg-green-500 hover:text-gray-900 cursor-pointer text-center">{">>>"} {t.notFound.backHome}</a>
				<a href={`${_base}/${lang}/${style}/cats`} class="border-2 border-yellow-400 text-yellow-400 uppercase text-sm px-6 py-3 tracking-widest hover:bg-yellow-400 hover:text-gray-900 cursor-pointer text-center">{">>>"} {t.notFound.meetCats}</a>
			</div>
		</div>
	</div>

	<!-- FOOTER NAV -->
	<footer class="border-t-2 border-green-500 bg-gray-900 px-4 py-6 relative z-10">
		<div class="max-w-5xl mx-auto flex flex-wrap gap-x-6 gap-y-2">
			{nav.map((item: any) => (
				<a href={item.href} class="text-green-400 uppercase text-xs tracking-widest hover:text-yellow-400 cursor-pointer">{item.label}</a>
			))}
		</div>
	</footer>
</main>
