---
const { lang, style, nav, cats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<main class="bg-gray-900 font-mono text-green-400 overflow-x-hidden">
	<!-- NAV: GAME MENU BAR -->
	<nav class="border-b-2 border-green-500 bg-gray-900 px-4 py-3 flex flex-wrap items-center gap-x-6 gap-y-2">
		{nav.map((item: any) => (
			<a href={item.href} class="text-green-400 uppercase text-xs md:text-sm tracking-widest hover:bg-green-500 hover:text-gray-900 px-2 py-1 border border-transparent hover:border-green-500 cursor-pointer">{item.label}</a>
		))}
	</nav>

	<!-- HEADER -->
	<section class="px-4 pt-12 pb-8 md:pt-20 md:pb-12 border-b-2 border-green-500">
		<div class="max-w-6xl mx-auto">
			<div class="border-2 border-green-500 bg-gray-800 px-4 py-3 md:px-6 md:py-4 inline-block mb-4">
				<h1 class="text-3xl md:text-5xl lg:text-7xl font-bold uppercase tracking-tight text-green-400 leading-none">{t.cats.title}</h1>
			</div>
			<p class="text-sm md:text-lg text-yellow-400 uppercase tracking-widest">{t.cats.subtitle}</p>
		</div>
	</section>

	<!-- CAT GRID -->
	<section class="px-4 py-8 md:py-12">
		<div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
			{cats.map((cat: any) => (
				<a href={`${_base}/${lang}/${style}/cats/${cat.id}`} class="block border-2 border-green-500 bg-gray-800 hover:border-yellow-400 hover:bg-gray-700 cursor-pointer group">
					<img src={cat.thumbnail} alt={cat.name} class="w-full h-44 md:h-52 object-cover border-b-2 border-green-500 group-hover:border-yellow-400" />
					<div class="p-4 md:p-5">
						<div class="flex items-center justify-between gap-2 mb-2">
							<h2 class="text-lg md:text-xl font-bold uppercase text-yellow-400 tracking-wide leading-tight">{cat.name}</h2>
							<span class="text-xs uppercase tracking-widest text-red-500 border border-red-500 px-2 py-0.5 shrink-0">{cat.status}</span>
						</div>
						<p class="text-xs uppercase tracking-widest text-green-400 mb-3">{cat.breed} // {cat.age} // {cat.gender}</p>
						<p class="text-xs md:text-sm text-gray-400 leading-relaxed mb-3">{cat.description.slice(0, 100)}...</p>
						<div class="flex flex-wrap gap-1">
							{cat.personality.map((trait: string) => (
								<span class="text-xs uppercase tracking-wider text-green-400 border border-green-500 px-2 py-0.5">{trait}</span>
							))}
						</div>
						<p class="text-xs uppercase tracking-widest text-yellow-400 mt-4 group-hover:text-green-400">{">>>"}</p>
					</div>
				</a>
			))}
		</div>
	</section>

	<!-- FOOTER NAV -->
	<footer class="border-t-2 border-green-500 bg-gray-900 px-4 py-6">
		<div class="max-w-5xl mx-auto flex flex-wrap gap-x-6 gap-y-2">
			{nav.map((item: any) => (
				<a href={item.href} class="text-green-400 uppercase text-xs tracking-widest hover:text-yellow-400 cursor-pointer">{item.label}</a>
			))}
		</div>
	</footer>
</main>
