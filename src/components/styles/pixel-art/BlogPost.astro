---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<main class="bg-gray-900 font-mono text-green-400 overflow-x-hidden">
	<!-- NAV: GAME MENU BAR -->
	<nav class="border-b-2 border-green-500 bg-gray-900 px-4 py-3 flex flex-wrap items-center gap-x-6 gap-y-2">
		{nav.map((item: any) => (
			<a href={item.href} class="text-green-400 uppercase text-xs md:text-sm tracking-widest hover:bg-green-500 hover:text-gray-900 px-2 py-1 border border-transparent hover:border-green-500 cursor-pointer">{item.label}</a>
		))}
	</nav>

	<!-- BACK LINK -->
	<div class="px-4 py-4 bg-gray-800 border-b-2 border-green-500">
		<a href={`${_base}/${lang}/${style}/blog`} class="text-green-400 uppercase text-xs tracking-widest hover:text-yellow-400 cursor-pointer">{"<<<"} {t.blog.backToBlog}</a>
	</div>

	<!-- POST HEADER -->
	<header class="px-4 py-8 md:py-12">
		<div class="max-w-4xl mx-auto">
			<img src={post.image} alt={post.title} class="w-full h-56 md:h-72 lg:h-80 object-cover border-4 border-green-500 mb-6 md:mb-8" />
			<div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-4 mb-4">
				<time datetime={post.date} class="text-xs uppercase tracking-widest text-green-400 border border-green-500 px-2 py-1 self-start">{post.date}</time>
				<span class="text-xs uppercase tracking-widest text-gray-400">{t.blog.by} {post.author}</span>
			</div>
			<h1 class="text-3xl md:text-5xl lg:text-6xl font-bold uppercase text-yellow-400 tracking-tight leading-none">{post.title}</h1>
			<div class="flex flex-wrap gap-2 mt-4 md:mt-6">
				{post.tags.map((tag: string) => (
					<span class="text-xs uppercase tracking-widest text-blue-400 border-2 border-blue-500 px-3 py-1">{tag}</span>
				))}
			</div>
		</div>
	</header>

	<!-- CONTENT -->
	<article class="px-4 py-6 md:py-10 border-t-2 border-green-500">
		<div class="max-w-4xl mx-auto space-y-6">
			{post.content.map((paragraph: string, i: number) => (
				<p class={`text-sm md:text-base text-gray-300 leading-relaxed ${i === 0 ? 'text-base md:text-lg text-green-300 border-l-2 border-green-500 pl-4' : ''}`}>{paragraph}</p>
			))}
		</div>
	</article>

	<!-- MORE STORIES -->
	<section class="px-4 py-8 md:py-12 border-t-2 border-green-500 bg-gray-800">
		<div class="max-w-5xl mx-auto">
			<h2 class="text-xl md:text-3xl font-bold uppercase text-green-400 tracking-wide mb-6 md:mb-8">{t.blog.moreStories}</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
				{otherPosts.map((p: any) => (
					<a href={`${_base}/${lang}/${style}/blog/${p.slug}`} class="block border-2 border-green-500 bg-gray-900 p-4 md:p-5 hover:border-yellow-400 hover:bg-gray-700 cursor-pointer">
						<h3 class="text-base md:text-lg font-bold uppercase text-yellow-400 tracking-wide leading-tight">{p.title}</h3>
						<p class="text-xs md:text-sm text-gray-400 mt-2 leading-relaxed">{p.excerpt}</p>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- FOOTER NAV -->
	<footer class="border-t-2 border-green-500 bg-gray-900 px-4 py-6">
		<div class="max-w-5xl mx-auto flex flex-wrap gap-x-6 gap-y-2">
			{nav.map((item: any) => (
				<a href={item.href} class="text-green-400 uppercase text-xs tracking-widest hover:text-yellow-400 cursor-pointer">{item.label}</a>
			))}
		</div>
	</footer>
</main>
