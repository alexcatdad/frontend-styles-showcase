---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<main class="bg-gray-900 font-mono text-green-400 overflow-x-hidden">
	<!-- NAV: GAME MENU BAR -->
	<nav class="border-b-2 border-green-500 bg-gray-900 px-4 py-3 flex flex-wrap items-center gap-x-6 gap-y-2">
		{nav.map((item: any) => (
			<a href={item.href} class="text-green-400 uppercase text-xs md:text-sm tracking-widest hover:bg-green-500 hover:text-gray-900 px-2 py-1 border border-transparent hover:border-green-500 cursor-pointer">{item.label}</a>
		))}
	</nav>

	<!-- HEADER -->
	<section class="px-4 pt-12 pb-8 md:pt-20 md:pb-12 border-b-2 border-green-500">
		<div class="max-w-6xl mx-auto">
			<h1 class="text-3xl md:text-5xl lg:text-7xl font-bold uppercase tracking-tight text-green-400 leading-none">{t.donate.title}</h1>
			<p class="text-sm md:text-lg text-yellow-400 uppercase tracking-widest mt-2 md:mt-4">{t.donate.subtitle}</p>
		</div>
	</section>

	<!-- MONTHLY TIERS: GAME ITEM SELECTION -->
	<section class="px-4 py-8 md:py-12">
		<div class="max-w-6xl mx-auto">
			<h2 class="text-xl md:text-3xl font-bold uppercase text-blue-400 tracking-wide mb-6 md:mb-8 border-b-2 border-blue-500 pb-3 inline-block">{t.donate.monthly}</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
				{monthlyTiers.map((tier: any) => (
					<div class={`border-2 bg-gray-800 p-5 md:p-6 relative ${tier.highlighted ? 'border-yellow-400' : 'border-green-500'}`} data-highlighted={tier.highlighted}>
						{tier.highlighted && <span class="absolute -top-3 left-4 bg-yellow-400 text-gray-900 text-xs font-bold uppercase px-3 py-1 tracking-widest">{t.donate.mostPopular}</span>}
						<h3 class="text-lg md:text-xl font-bold uppercase tracking-wide text-green-400 mt-1">{tier.name}</h3>
						<p class="mt-3">
							<span class={`text-4xl md:text-5xl font-bold leading-none ${tier.highlighted ? 'text-yellow-400' : 'text-yellow-400'}`}>${tier.amount}</span>
							<span class="text-xs uppercase tracking-widest text-green-500 ml-1">{t.donate.perMonth}</span>
						</p>
						<p class="text-xs md:text-sm text-gray-400 mt-4 leading-relaxed border-l-2 border-green-500 pl-3">{tier.description}</p>
						<ul class="mt-4 space-y-2">
							{tier.perks.map((perk: string) => (
								<li class="text-xs uppercase tracking-wider text-green-400 pl-4 border-l-2 border-yellow-400">{perk}</li>
							))}
						</ul>
						<button type="button" class={`mt-6 w-full uppercase font-bold text-sm px-4 py-3 border-2 tracking-widest cursor-pointer ${tier.highlighted ? 'border-yellow-400 text-yellow-400 hover:bg-yellow-400 hover:text-gray-900' : 'border-green-500 text-green-400 hover:bg-green-500 hover:text-gray-900'}`}>{">>>"} {t.donate.choose} {tier.name}</button>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ONE-TIME TIERS -->
	<section class="px-4 py-8 md:py-12 border-t-2 border-green-500 bg-gray-800">
		<div class="max-w-6xl mx-auto">
			<h2 class="text-xl md:text-3xl font-bold uppercase text-red-500 tracking-wide mb-6 md:mb-8 border-b-2 border-red-500 pb-3 inline-block">{t.donate.oneTime}</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
				{oneTimeTiers.map((tier: any) => (
					<div class={`border-2 bg-gray-900 p-5 md:p-6 relative ${tier.highlighted ? 'border-yellow-400' : 'border-green-500'}`} data-highlighted={tier.highlighted}>
						{tier.highlighted && <span class="absolute -top-3 right-4 bg-yellow-400 text-gray-900 text-xs font-bold uppercase px-3 py-1 tracking-widest">{t.donate.greatestImpact}</span>}
						<h3 class="text-lg md:text-xl font-bold uppercase tracking-wide text-green-400 mt-1">{tier.name}</h3>
						<p class="mt-3">
							<span class="text-4xl md:text-6xl font-bold text-yellow-400 leading-none">${tier.amount}</span>
						</p>
						<p class="text-xs md:text-sm text-gray-400 mt-4 leading-relaxed border-l-2 border-red-500 pl-3">{tier.description}</p>
						<ul class="mt-4 space-y-2">
							{tier.perks.map((perk: string) => (
								<li class="text-xs uppercase tracking-wider text-green-400 pl-4 border-l-2 border-yellow-400">{perk}</li>
							))}
						</ul>
						<button type="button" class={`mt-6 w-full uppercase font-bold text-sm px-4 py-3 border-2 tracking-widest cursor-pointer ${tier.highlighted ? 'border-yellow-400 text-yellow-400 hover:bg-yellow-400 hover:text-gray-900' : 'border-green-500 text-green-400 hover:bg-green-500 hover:text-gray-900'}`}>{">>>"} {t.donate.give} ${tier.amount}</button>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- FOOTER NAV -->
	<footer class="border-t-2 border-green-500 bg-gray-900 px-4 py-6">
		<div class="max-w-5xl mx-auto flex flex-wrap gap-x-6 gap-y-2">
			{nav.map((item: any) => (
				<a href={item.href} class="text-green-400 uppercase text-xs tracking-widest hover:text-yellow-400 cursor-pointer">{item.label}</a>
			))}
		</div>
	</footer>
</main>
