---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-[#0a0015] text-pink-100 font-sans overflow-hidden">
	<!-- Sunset gradient sky -->
	<div class="fixed inset-0 bg-gradient-to-b from-[#1a0030] via-[#3d0066] via-40% to-[#ff6b9d]/20 pointer-events-none"></div>

	<!-- Perspective grid floor -->
	<div class="fixed bottom-0 left-0 right-0 h-[45vh] pointer-events-none opacity-30" style="background: linear-gradient(transparent 0%, rgba(255,107,157,0.06) 2%, transparent 2.5%, transparent 10%, rgba(255,107,157,0.06) 10.5%, transparent 11%, transparent 20%, rgba(255,107,157,0.06) 20.5%, transparent 21%, transparent 30%, rgba(255,107,157,0.06) 30.5%, transparent 31%, transparent 42%, rgba(255,107,157,0.06) 42.5%, transparent 43%, transparent 56%, rgba(255,107,157,0.06) 56.5%, transparent 57%, transparent 74%, rgba(255,107,157,0.06) 74.5%, transparent 75%), repeating-linear-gradient(90deg, transparent, transparent 8%, rgba(6,182,212,0.08) 8.2%, transparent 8.4%); perspective: 400px; transform: rotateX(55deg); transform-origin: top center;"></div>

	<!-- Floating ambient glyphs -->
	<div class="fixed top-[15%] left-[6%] text-pink-500/[0.05] text-6xl font-serif italic pointer-events-none select-none">&#9651;</div>
	<div class="fixed top-[55%] right-[8%] text-cyan-400/[0.04] text-5xl pointer-events-none select-none">&#9671;</div>

	<!-- Navigation -->
	<nav class="relative z-20 flex flex-wrap items-center justify-center gap-1 px-6 py-8 opacity-70 hover:opacity-100 transition-opacity duration-700">
		<span class="text-fuchsia-500/20 text-xs mr-3 tracking-[0.3em] hidden md:inline">&#9553;</span>
		{nav.map((item: any) => (
			<a href={item.href} class="px-5 py-2 text-[11px] tracking-[0.35em] uppercase text-cyan-300/60 hover:text-pink-300 transition-all duration-500 hover:drop-shadow-[0_0_12px_rgba(236,72,153,0.5)]">
				{item.label}
			</a>
		))}
		<span class="text-fuchsia-500/20 text-xs ml-3 tracking-[0.3em] hidden md:inline">&#9553;</span>
	</nav>

	<main class="relative z-10 max-w-4xl mx-auto px-6 py-12">
		<!-- Back link -->
		<a href={`/${lang}/${style}/cats`} class="inline-flex items-center gap-3 text-[11px] tracking-[0.35em] uppercase text-cyan-400/40 hover:text-pink-300/70 transition-colors duration-500 mb-14">
			<span class="text-lg leading-none">&larr;</span> {t.cats.backToAll}
		</a>

		<!-- Main profile panel: floating against the void -->
		<article class="border border-pink-500/[0.08] bg-purple-950/15 backdrop-blur-md shadow-[0_0_100px_rgba(139,92,246,0.04)] p-8 md:p-14">

			<!-- Name header with glitch -->
			<div class="text-center mb-14">
				<p class="text-[10px] tracking-[0.8em] uppercase text-fuchsia-400/15 mb-6 select-none">&#9553; &#9671; &#9553;</p>

				<h1 class="relative text-5xl md:text-7xl lg:text-8xl font-serif italic font-bold leading-none">
					<span class="absolute inset-0 text-cyan-400/20 translate-x-[4px] -translate-y-[2px] blur-[0.5px]" aria-hidden="true">{cat.name}</span>
					<span class="absolute inset-0 text-pink-500/15 -translate-x-[4px] translate-y-[2px] blur-[0.5px]" aria-hidden="true">{cat.name}</span>
					<span class="relative bg-gradient-to-r from-pink-300 via-fuchsia-200 to-cyan-300 bg-clip-text text-transparent">{cat.name}</span>
				</h1>

				<p class="mt-4 text-[10px] tracking-[0.6em] uppercase text-cyan-500/20 select-none">&#9651; &#9671; &#9651;</p>
			</div>

			<!-- Details grid: translucent panels -->
			<dl class="grid grid-cols-2 md:grid-cols-3 gap-5 mb-14">
				<div class="p-5 border border-pink-500/[0.06] bg-purple-950/20">
					<dt class="text-[9px] tracking-[0.4em] uppercase text-cyan-400/30 mb-2">{t.cats.breed}</dt>
					<dd class="text-sm text-pink-200/60 font-light tracking-wide">{cat.breed}</dd>
				</div>
				<div class="p-5 border border-pink-500/[0.06] bg-purple-950/20">
					<dt class="text-[9px] tracking-[0.4em] uppercase text-cyan-400/30 mb-2">{t.cats.age}</dt>
					<dd class="text-sm text-pink-200/60 font-light tracking-wide">{cat.age}</dd>
				</div>
				<div class="p-5 border border-pink-500/[0.06] bg-purple-950/20">
					<dt class="text-[9px] tracking-[0.4em] uppercase text-cyan-400/30 mb-2">{t.cats.gender}</dt>
					<dd class="text-sm text-pink-200/60 font-light tracking-wide">{cat.gender}</dd>
				</div>
				<div class="p-5 border border-pink-500/[0.06] bg-purple-950/20">
					<dt class="text-[9px] tracking-[0.4em] uppercase text-cyan-400/30 mb-2">{t.cats.color}</dt>
					<dd class="text-sm text-pink-200/60 font-light tracking-wide">{cat.color}</dd>
				</div>
				<div class="p-5 border border-pink-500/[0.06] bg-purple-950/20">
					<dt class="text-[9px] tracking-[0.4em] uppercase text-cyan-400/30 mb-2">{t.cats.arrived}</dt>
					<dd class="text-sm text-pink-200/60 font-light tracking-wide">{cat.arrivalDate}</dd>
				</div>
				<div class="p-5 border border-pink-500/[0.06] bg-purple-950/20">
					<dt class="text-[9px] tracking-[0.4em] uppercase text-cyan-400/30 mb-2">{t.cats.status}</dt>
					<dd class="text-sm text-pink-200/60 font-light tracking-wide">{cat.status}</dd>
				</div>
			</dl>

			<!-- Personality: scattered traits -->
			<div class="flex flex-wrap justify-center gap-3 mb-14">
				{cat.personality.map((trait: string) => (
					<span class="text-[9px] tracking-[0.35em] uppercase px-5 py-2.5 border border-fuchsia-500/10 text-fuchsia-300/45 bg-fuchsia-950/10 hover:border-cyan-400/20 hover:text-cyan-300/50 transition-all duration-500">
						{trait}
					</span>
				))}
			</div>

			<!-- Divider -->
			<div class="flex items-center justify-center gap-3 mb-14 select-none">
				<div class="w-20 h-px bg-gradient-to-r from-transparent to-pink-500/10"></div>
				<span class="text-pink-400/[0.08] text-[10px] tracking-[0.5em]">&#9553; &#9671; &#9553;</span>
				<div class="w-20 h-px bg-gradient-to-l from-transparent to-pink-500/10"></div>
			</div>

			<!-- Description -->
			<p class="text-pink-200/40 leading-loose font-light text-center max-w-2xl mx-auto mb-16 tracking-wide">
				{cat.description}
			</p>

			<!-- Adopt CTA -->
			<div class="text-center">
				<a href={`/${lang}/${style}/auth`} class="inline-block px-12 py-4 bg-gradient-to-r from-pink-600/80 to-fuchsia-600/80 text-white/90 tracking-[0.3em] uppercase text-xs hover:from-pink-500/90 hover:to-fuchsia-500/90 hover:shadow-[0_0_50px_rgba(236,72,153,0.2)] transition-all duration-500">
					{t.cats.adopt} {cat.name}
				</a>
			</div>
		</article>

		<!-- Other Cats -->
		<section class="mt-24">
			<div class="text-center mb-14">
				<h2 class="relative text-2xl md:text-4xl font-serif italic">
					<span class="absolute inset-0 text-pink-500/10 -translate-x-[2px] translate-y-[1px]" aria-hidden="true">{t.cats.otherCats}</span>
					<span class="relative text-cyan-300/80">{t.cats.otherCats}</span>
				</h2>
				<p class="mt-3 text-[10px] tracking-[0.6em] text-fuchsia-400/15 select-none">&#9553; ア エ ス &#9553;</p>
			</div>

			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-7">
				{otherCats.map((c: any) => (
					<a href={`/${lang}/${style}/cats/${c.id}`} class="group block p-7 border border-pink-500/[0.08] bg-purple-950/10 backdrop-blur-sm hover:border-cyan-400/20 hover:shadow-[0_0_50px_rgba(6,182,212,0.06)] transition-all duration-700">
						<h3 class="text-xl font-serif italic text-fuchsia-300/70 group-hover:text-cyan-300/80 transition-colors duration-500">
							{c.name}
						</h3>
						<p class="mt-3 text-[11px] text-pink-300/25 tracking-wider">
							{c.breed} &#9553; {c.age}
						</p>
					</a>
				))}
			</div>
		</section>
	</main>

	<footer class="relative z-10 border-t border-pink-500/[0.06] py-10 mt-20 text-center">
		<p class="text-[10px] text-cyan-500/10 tracking-[0.6em] select-none">&#9651; &#9671; &#9649;</p>
	</footer>
</div>
