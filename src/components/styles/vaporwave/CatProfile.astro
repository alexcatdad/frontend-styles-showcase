---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-purple-950 via-pink-900 to-cyan-950 text-pink-100 font-sans">
	<div class="fixed inset-0 pointer-events-none opacity-5 bg-[linear-gradient(rgba(255,255,255,.1)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.1)_1px,transparent_1px)] bg-[size:60px_60px]"></div>

	<nav class="relative z-10 flex flex-wrap items-center justify-center gap-2 px-6 py-5 border-b border-pink-500/20 backdrop-blur-sm bg-purple-950/30">
		{nav.map((item: any) => (
			<a href={item.href} class="px-4 py-2 text-sm tracking-widest uppercase text-cyan-300 hover:text-pink-300 transition-colors duration-300 hover:drop-shadow-[0_0_8px_rgba(236,72,153,0.6)]">
				{item.label}
			</a>
		))}
	</nav>

	<main class="relative z-10 max-w-4xl mx-auto px-6 py-12">
		<a href={`/${lang}/${style}/cats`} class="inline-flex items-center gap-2 text-sm tracking-widest uppercase text-cyan-400/70 hover:text-pink-300 transition-colors duration-300 mb-10">
			&larr; {t.cats.backToAll}
		</a>

		<article class="border border-pink-500/20 bg-purple-900/20 backdrop-blur-sm p-8 md:p-12">
			<div class="text-center mb-10">
				<p class="text-xs tracking-[0.5em] uppercase text-fuchsia-400/40 mb-3">&#9649; &#9671; &#9651;</p>
				<h1 class="text-5xl md:text-7xl font-serif italic font-bold bg-gradient-to-r from-pink-400 via-fuchsia-300 to-cyan-400 bg-clip-text text-transparent drop-shadow-[3px_3px_0px_rgba(6,182,212,0.3)]">
					{cat.name}
				</h1>
			</div>

			<dl class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-10">
				<div class="p-4 border border-pink-500/15 bg-purple-950/30">
					<dt class="text-[10px] tracking-widest uppercase text-cyan-400/50 mb-1">{t.cats.breed}</dt>
					<dd class="text-sm text-pink-200/80 font-light">{cat.breed}</dd>
				</div>
				<div class="p-4 border border-pink-500/15 bg-purple-950/30">
					<dt class="text-[10px] tracking-widest uppercase text-cyan-400/50 mb-1">{t.cats.age}</dt>
					<dd class="text-sm text-pink-200/80 font-light">{cat.age}</dd>
				</div>
				<div class="p-4 border border-pink-500/15 bg-purple-950/30">
					<dt class="text-[10px] tracking-widest uppercase text-cyan-400/50 mb-1">{t.cats.gender}</dt>
					<dd class="text-sm text-pink-200/80 font-light">{cat.gender}</dd>
				</div>
				<div class="p-4 border border-pink-500/15 bg-purple-950/30">
					<dt class="text-[10px] tracking-widest uppercase text-cyan-400/50 mb-1">{t.cats.color}</dt>
					<dd class="text-sm text-pink-200/80 font-light">{cat.color}</dd>
				</div>
				<div class="p-4 border border-pink-500/15 bg-purple-950/30">
					<dt class="text-[10px] tracking-widest uppercase text-cyan-400/50 mb-1">{t.cats.arrived}</dt>
					<dd class="text-sm text-pink-200/80 font-light">{cat.arrivalDate}</dd>
				</div>
				<div class="p-4 border border-pink-500/15 bg-purple-950/30">
					<dt class="text-[10px] tracking-widest uppercase text-cyan-400/50 mb-1">{t.cats.status}</dt>
					<dd class="text-sm text-pink-200/80 font-light">{cat.status}</dd>
				</div>
			</dl>

			<div class="flex flex-wrap justify-center gap-3 mb-10">
				{cat.personality.map((trait: string) => (
					<span class="text-[10px] tracking-[0.2em] uppercase px-4 py-2 border border-fuchsia-500/30 text-fuchsia-300/70 bg-fuchsia-950/20 hover:border-cyan-400/40 hover:text-cyan-300/70 transition-colors duration-300">
						{trait}
					</span>
				))}
			</div>

			<div class="w-48 h-px mx-auto bg-gradient-to-r from-transparent via-pink-500/40 to-transparent mb-10"></div>

			<p class="text-pink-200/60 leading-relaxed font-light text-center max-w-2xl mx-auto mb-12">
				{cat.description}
			</p>

			<div class="text-center">
				<a href={`/${lang}/${style}/auth`} class="inline-block px-10 py-4 bg-gradient-to-r from-pink-600 to-fuchsia-600 text-white tracking-widest uppercase text-sm hover:from-pink-500 hover:to-fuchsia-500 hover:shadow-[0_0_30px_rgba(236,72,153,0.4)] transition-all duration-300">
					{t.cats.adopt} {cat.name}
				</a>
			</div>
		</article>

		<!-- Other Cats -->
		<section class="mt-20">
			<div class="text-center mb-10">
				<h2 class="text-2xl md:text-3xl font-serif italic text-cyan-300">{t.cats.otherCats}</h2>
				<p class="mt-2 text-xs tracking-[0.4em] text-fuchsia-400/40">&#9651; &#9671; &#9651;</p>
			</div>
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
				{otherCats.map((c: any) => (
					<a href={`/${lang}/${style}/cats/${c.id}`} class="group block p-6 border border-pink-500/20 bg-purple-900/20 backdrop-blur-sm hover:border-cyan-400/40 hover:shadow-[0_0_20px_rgba(6,182,212,0.1)] transition-all duration-500">
						<h3 class="text-xl font-serif italic text-fuchsia-300 group-hover:text-cyan-300 transition-colors duration-300">
							{c.name}
						</h3>
						<p class="mt-2 text-sm text-pink-300/40 tracking-wide">
							{c.breed} &#183; {c.age}
						</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
