---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-[#0a0015] text-pink-100 font-sans overflow-hidden">
	<!-- Sunset gradient sky -->
	<div class="fixed inset-0 bg-gradient-to-b from-[#1a0030] via-[#3d0066] via-40% to-[#ff6b9d]/20 pointer-events-none"></div>

	<!-- Horizontal sun band -->
	<div class="fixed top-[40%] left-0 right-0 h-24 bg-gradient-to-b from-[#ff2d7b]/10 via-[#ff6b35]/8 to-transparent pointer-events-none blur-sm"></div>

	<!-- Perspective grid floor -->
	<div class="fixed bottom-0 left-0 right-0 h-[45vh] pointer-events-none opacity-30" style="background: linear-gradient(transparent 0%, rgba(255,107,157,0.06) 2%, transparent 2.5%, transparent 10%, rgba(255,107,157,0.06) 10.5%, transparent 11%, transparent 20%, rgba(255,107,157,0.06) 20.5%, transparent 21%, transparent 30%, rgba(255,107,157,0.06) 30.5%, transparent 31%, transparent 42%, rgba(255,107,157,0.06) 42.5%, transparent 43%, transparent 56%, rgba(255,107,157,0.06) 56.5%, transparent 57%, transparent 74%, rgba(255,107,157,0.06) 74.5%, transparent 75%), repeating-linear-gradient(90deg, transparent, transparent 8%, rgba(6,182,212,0.08) 8.2%, transparent 8.4%); perspective: 400px; transform: rotateX(55deg); transform-origin: top center;"></div>

	<!-- Floating ambient glyphs -->
	<div class="fixed top-[20%] left-[10%] text-fuchsia-500/[0.05] text-5xl font-serif italic pointer-events-none select-none">&#9651;</div>
	<div class="fixed bottom-[35%] right-[8%] text-cyan-400/[0.04] text-4xl pointer-events-none select-none">&#9671;</div>

	<!-- Navigation -->
	<nav class="relative z-20 flex flex-wrap items-center justify-center gap-1 px-6 py-8 opacity-70 hover:opacity-100 transition-opacity duration-700">
		<span class="text-fuchsia-500/20 text-xs mr-3 tracking-[0.3em] hidden md:inline">&#9553;</span>
		{nav.map((item: any) => (
			<a href={item.href} class="px-5 py-2 text-[11px] tracking-[0.35em] uppercase text-cyan-300/60 hover:text-pink-300 transition-all duration-500 hover:drop-shadow-[0_0_12px_rgba(236,72,153,0.5)]">
				{item.label}
			</a>
		))}
		<span class="text-fuchsia-500/20 text-xs ml-3 tracking-[0.3em] hidden md:inline">&#9553;</span>
	</nav>

	<main class="relative z-10 flex items-center justify-center px-6 py-16 md:py-24">
		<section class="w-full max-w-md">
			<!-- Header -->
			<div class="text-center mb-14">
				<p class="text-[10px] tracking-[0.8em] uppercase text-cyan-400/20 mb-8 select-none">&#9553; &#9671; &#9553;</p>

				<h1 class="relative text-4xl md:text-5xl lg:text-6xl font-serif italic font-bold leading-none">
					<span class="absolute inset-0 text-cyan-400/15 translate-x-[2px] -translate-y-[1px] blur-[0.5px]" aria-hidden="true">{t.auth.title}</span>
					<span class="absolute inset-0 text-pink-500/10 -translate-x-[2px] translate-y-[1px] blur-[0.5px]" aria-hidden="true">{t.auth.title}</span>
					<span class="relative bg-gradient-to-r from-pink-300 via-fuchsia-200 to-cyan-300 bg-clip-text text-transparent">{t.auth.title}</span>
				</h1>

				<p class="mt-5 text-pink-200/30 font-light italic tracking-wider text-sm">
					{t.auth.subtitle}
				</p>
			</div>

			<!-- Form panel: floating against the void -->
			<div class="border border-pink-500/[0.08] bg-purple-950/20 backdrop-blur-md p-8 md:p-10 shadow-[0_0_100px_rgba(139,92,246,0.04)]">
				<form class="space-y-7">
					<div>
						<label for="email" class="block text-[9px] tracking-[0.4em] uppercase text-cyan-400/30 mb-3">
							{t.auth.email}
						</label>
						<input type="email" id="email" name="email" placeholder="you@example.com" class="w-full px-5 py-3.5 bg-purple-950/40 border border-pink-500/[0.08] text-pink-100/70 placeholder-pink-300/10 focus:border-cyan-400/25 focus:outline-none focus:shadow-[0_0_30px_rgba(6,182,212,0.06)] transition-all duration-500 text-sm tracking-wider" />
					</div>
					<div>
						<label for="password" class="block text-[9px] tracking-[0.4em] uppercase text-cyan-400/30 mb-3">
							{t.auth.password}
						</label>
						<input type="password" id="password" name="password" placeholder="••••••••" class="w-full px-5 py-3.5 bg-purple-950/40 border border-pink-500/[0.08] text-pink-100/70 placeholder-pink-300/10 focus:border-cyan-400/25 focus:outline-none focus:shadow-[0_0_30px_rgba(6,182,212,0.06)] transition-all duration-500 text-sm tracking-wider" />
					</div>

					<!-- Remember + Forgot -->
					<div class="flex items-center justify-between">
						<label class="flex items-center gap-2.5 cursor-pointer">
							<input type="checkbox" name="remember" class="w-4 h-4 accent-fuchsia-500 bg-purple-950/40 border border-pink-500/15" />
							<span class="text-[11px] text-pink-200/30 tracking-wider">{t.auth.rememberMe}</span>
						</label>
						<a href="#" class="text-[11px] text-cyan-400/30 hover:text-pink-300/50 tracking-wider transition-colors duration-500">
							{t.auth.forgotPassword}
						</a>
					</div>

					<button type="submit" class="w-full py-4 bg-gradient-to-r from-pink-600/80 to-fuchsia-600/80 text-white/90 tracking-[0.3em] uppercase text-xs hover:from-pink-500/90 hover:to-fuchsia-500/90 hover:shadow-[0_0_50px_rgba(236,72,153,0.2)] transition-all duration-500">
						{t.auth.signIn}
					</button>
				</form>

				<!-- Divider: column style -->
				<div class="my-10">
					<div class="flex items-center gap-4">
						<div class="flex-1 h-px bg-gradient-to-r from-transparent to-pink-500/[0.08]"></div>
						<p class="text-[9px] tracking-[0.4em] uppercase text-pink-300/15">{t.auth.continueWith}</p>
						<div class="flex-1 h-px bg-gradient-to-l from-transparent to-pink-500/[0.08]"></div>
					</div>

					<div class="mt-7 grid grid-cols-2 gap-5">
						<button type="button" class="py-3.5 border border-pink-500/[0.08] text-pink-200/35 text-[11px] tracking-[0.3em] uppercase hover:border-cyan-400/15 hover:text-cyan-300/45 hover:shadow-[0_0_30px_rgba(6,182,212,0.04)] transition-all duration-500">
							Google
						</button>
						<button type="button" class="py-3.5 border border-pink-500/[0.08] text-pink-200/35 text-[11px] tracking-[0.3em] uppercase hover:border-cyan-400/15 hover:text-cyan-300/45 hover:shadow-[0_0_30px_rgba(6,182,212,0.04)] transition-all duration-500">
							Apple
						</button>
					</div>
				</div>

				<p class="text-center text-[11px] text-pink-200/25 tracking-wider">
					{t.auth.noAccount}{" "}
					<a href="#" class="text-fuchsia-300/45 hover:text-cyan-300/60 transition-colors duration-500 underline underline-offset-4 decoration-fuchsia-500/15">
						{t.auth.signUp}
					</a>
				</p>
			</div>

			<!-- Footer decoration -->
			<p class="mt-10 text-center text-[10px] text-fuchsia-500/10 tracking-[0.6em] select-none">&#9553; ア エ ス &#9553;</p>
		</section>
	</main>
</div>
