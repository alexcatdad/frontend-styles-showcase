---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-purple-950 via-pink-900 to-cyan-950 text-pink-100 font-sans">
	<div class="fixed inset-0 pointer-events-none opacity-5 bg-[linear-gradient(rgba(255,255,255,.1)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.1)_1px,transparent_1px)] bg-[size:60px_60px]"></div>

	<nav class="relative z-10 flex flex-wrap items-center justify-center gap-2 px-6 py-5 border-b border-pink-500/20 backdrop-blur-sm bg-purple-950/30">
		{nav.map((item: any) => (
			<a href={item.href} class="px-4 py-2 text-sm tracking-widest uppercase text-cyan-300 hover:text-pink-300 transition-colors duration-300 hover:drop-shadow-[0_0_8px_rgba(236,72,153,0.6)]">
				{item.label}
			</a>
		))}
	</nav>

	<main class="relative z-10 flex items-center justify-center px-6 py-16 md:py-24">
		<section class="w-full max-w-md">
			<div class="text-center mb-10">
				<p class="text-xs tracking-[0.5em] uppercase text-cyan-400/50 mb-4">&#9651; &#9671; &#9649;</p>
				<h1 class="text-4xl md:text-5xl font-serif italic font-bold bg-gradient-to-r from-pink-400 via-fuchsia-300 to-cyan-400 bg-clip-text text-transparent">
					{t.auth.title}
				</h1>
				<p class="mt-4 text-pink-200/60 font-light italic tracking-wide">
					{t.auth.subtitle}
				</p>
			</div>

			<div class="border border-pink-500/20 bg-purple-900/20 backdrop-blur-sm p-8">
				<form class="space-y-6">
					<div>
						<label for="email" class="block text-[10px] tracking-widest uppercase text-cyan-400/60 mb-2">
							{t.auth.email}
						</label>
						<input type="email" id="email" name="email" placeholder="you@example.com" class="w-full px-4 py-3 bg-purple-950/50 border border-pink-500/20 text-pink-100 placeholder-pink-300/20 focus:border-cyan-400/50 focus:outline-none focus:shadow-[0_0_15px_rgba(6,182,212,0.1)] transition-all duration-300 text-sm tracking-wide" />
					</div>
					<div>
						<label for="password" class="block text-[10px] tracking-widest uppercase text-cyan-400/60 mb-2">
							{t.auth.password}
						</label>
						<input type="password" id="password" name="password" placeholder="••••••••" class="w-full px-4 py-3 bg-purple-950/50 border border-pink-500/20 text-pink-100 placeholder-pink-300/20 focus:border-cyan-400/50 focus:outline-none focus:shadow-[0_0_15px_rgba(6,182,212,0.1)] transition-all duration-300 text-sm tracking-wide" />
					</div>
					<div class="flex items-center justify-between">
						<label class="flex items-center gap-2 cursor-pointer">
							<input type="checkbox" name="remember" class="w-4 h-4 accent-fuchsia-500 bg-purple-950/50 border border-pink-500/30" />
							<span class="text-xs text-pink-200/50 tracking-wide">{t.auth.rememberMe}</span>
						</label>
						<a href="#" class="text-xs text-cyan-400/50 hover:text-pink-300 tracking-wide transition-colors duration-300">
							{t.auth.forgotPassword}
						</a>
					</div>
					<button type="submit" class="w-full py-3 bg-gradient-to-r from-pink-600 to-fuchsia-600 text-white tracking-widest uppercase text-sm hover:from-pink-500 hover:to-fuchsia-500 hover:shadow-[0_0_25px_rgba(236,72,153,0.4)] transition-all duration-300">
						{t.auth.signIn}
					</button>
				</form>

				<div class="my-8">
					<div class="flex items-center gap-4">
						<div class="flex-1 h-px bg-gradient-to-r from-transparent to-pink-500/20"></div>
						<p class="text-[10px] tracking-widest uppercase text-pink-300/30">{t.auth.continueWith}</p>
						<div class="flex-1 h-px bg-gradient-to-l from-transparent to-pink-500/20"></div>
					</div>
					<div class="mt-6 grid grid-cols-2 gap-4">
						<button type="button" class="py-3 border border-pink-500/20 text-pink-200/60 text-sm tracking-widest uppercase hover:border-cyan-400/40 hover:text-cyan-300 hover:shadow-[0_0_15px_rgba(6,182,212,0.1)] transition-all duration-300">
							Google
						</button>
						<button type="button" class="py-3 border border-pink-500/20 text-pink-200/60 text-sm tracking-widest uppercase hover:border-cyan-400/40 hover:text-cyan-300 hover:shadow-[0_0_15px_rgba(6,182,212,0.1)] transition-all duration-300">
							Apple
						</button>
					</div>
				</div>

				<p class="text-center text-sm text-pink-200/40">
					{t.auth.noAccount} <a href="#" class="text-fuchsia-300/70 hover:text-cyan-300 transition-colors duration-300 underline underline-offset-4 decoration-fuchsia-500/30">{t.auth.signUp}</a>
				</p>
			</div>
		</section>
	</main>
</div>
