---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-purple-950 via-pink-900 to-cyan-950 text-pink-100 font-sans">
	<div class="fixed inset-0 pointer-events-none opacity-5 bg-[linear-gradient(rgba(255,255,255,.1)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.1)_1px,transparent_1px)] bg-[size:60px_60px]"></div>

	<nav class="relative z-10 flex flex-wrap items-center justify-center gap-2 px-6 py-5 border-b border-pink-500/20 backdrop-blur-sm bg-purple-950/30">
		{nav.map((item: any) => (
			<a href={item.href} class="px-4 py-2 text-sm tracking-widest uppercase text-cyan-300 hover:text-pink-300 transition-colors duration-300 hover:drop-shadow-[0_0_8px_rgba(236,72,153,0.6)]">
				{item.label}
			</a>
		))}
	</nav>

	<main class="relative z-10 max-w-4xl mx-auto px-6 py-16">
		<div class="text-center mb-16">
			<p class="text-xs tracking-[0.5em] uppercase text-cyan-400/50 mb-4">&#9649; &#9671; &#9649;</p>
			<h1 class="text-4xl md:text-6xl font-serif italic font-bold bg-gradient-to-r from-pink-400 via-fuchsia-300 to-cyan-400 bg-clip-text text-transparent">
				{t.blog.title}
			</h1>
			<p class="mt-4 text-lg text-pink-200/60 font-light italic tracking-wide">
				{t.blog.subtitle}
			</p>
			<div class="mt-6 w-48 h-px mx-auto bg-gradient-to-r from-transparent via-pink-500/50 to-transparent"></div>
		</div>

		<div class="flex flex-col gap-8">
			{posts.map((post: any) => (
				<a href={`/${lang}/${style}/blog/${post.slug}`} class="group block border border-pink-500/20 bg-purple-900/20 backdrop-blur-sm hover:border-cyan-400/40 hover:shadow-[0_0_30px_rgba(6,182,212,0.1)] transition-all duration-500">
					<article class="p-8">
						<time datetime={post.date} class="text-[10px] tracking-widest uppercase text-cyan-400/50">
							{post.date}
						</time>
						<h2 class="mt-3 text-2xl md:text-3xl font-serif italic text-fuchsia-300 group-hover:text-cyan-300 transition-colors duration-300">
							{post.title}
						</h2>
						<p class="mt-4 text-pink-200/50 leading-relaxed font-light">
							{post.excerpt}
						</p>
						<div class="mt-5 flex flex-wrap items-center gap-3">
							{post.tags.map((tag: string) => (
								<span class="text-[10px] tracking-widest uppercase px-3 py-1 border border-fuchsia-500/20 text-fuchsia-300/50 bg-fuchsia-950/20">
									{tag}
								</span>
							))}
						</div>
						<div class="mt-5 pt-4 border-t border-pink-500/10">
							<span class="text-xs tracking-wide text-pink-300/40 italic">
								{t.blog.by} {post.author}
							</span>
						</div>
					</article>
				</a>
			))}
		</div>
	</main>
</div>
