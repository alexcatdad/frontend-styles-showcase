---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-purple-950 via-pink-900 to-cyan-950 text-pink-100 font-sans">
	<div class="fixed inset-0 pointer-events-none opacity-5 bg-[linear-gradient(rgba(255,255,255,.1)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.1)_1px,transparent_1px)] bg-[size:60px_60px]"></div>

	<nav class="relative z-10 flex flex-wrap items-center justify-center gap-2 px-6 py-5 border-b border-pink-500/20 backdrop-blur-sm bg-purple-950/30">
		{nav.map((item: any) => (
			<a href={item.href} class="px-4 py-2 text-sm tracking-widest uppercase text-cyan-300 hover:text-pink-300 transition-colors duration-300 hover:drop-shadow-[0_0_8px_rgba(236,72,153,0.6)]">
				{item.label}
			</a>
		))}
	</nav>

	<main class="relative z-10 max-w-3xl mx-auto px-6 py-12">
		<a href={`/${lang}/${style}/blog`} class="inline-flex items-center gap-2 text-sm tracking-widest uppercase text-cyan-400/70 hover:text-pink-300 transition-colors duration-300 mb-10">
			&larr; {t.blog.backToBlog}
		</a>

		<article class="border border-pink-500/20 bg-purple-900/20 backdrop-blur-sm">
			<header class="p-8 md:p-12 text-center border-b border-pink-500/10">
				<time datetime={post.date} class="text-[10px] tracking-widest uppercase text-cyan-400/50">
					{post.date}
				</time>
				<h1 class="mt-4 text-4xl md:text-5xl font-serif italic font-bold bg-gradient-to-r from-pink-400 via-fuchsia-300 to-cyan-400 bg-clip-text text-transparent">
					{post.title}
				</h1>
				<p class="mt-4 text-sm text-pink-300/50 italic tracking-wide">
					{t.blog.by} {post.author}
				</p>
				<div class="mt-5 flex flex-wrap justify-center gap-2">
					{post.tags.map((tag: string) => (
						<span class="text-[10px] tracking-widest uppercase px-3 py-1 border border-fuchsia-500/20 text-fuchsia-300/50 bg-fuchsia-950/20">
							{tag}
						</span>
					))}
				</div>
			</header>

			<div class="p-8 md:p-12">
				{post.content.map((paragraph: string) => (
					<p class="text-pink-200/60 leading-relaxed font-light mb-6 last:mb-0">
						{paragraph}
					</p>
				))}
			</div>
		</article>

		<!-- Decorative divider -->
		<div class="flex justify-center py-12">
			<p class="text-xs tracking-[0.5em] text-fuchsia-500/30">&#9651; &#9671; &#9649; ア エ ス &#9649; &#9671; &#9651;</p>
		</div>

		<!-- More Stories -->
		<section>
			<h2 class="text-2xl md:text-3xl font-serif italic text-cyan-300 text-center mb-8">
				{t.blog.moreStories}
			</h2>
			<div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
				{otherPosts.map((p: any) => (
					<a href={`/${lang}/${style}/blog/${p.slug}`} class="group block p-6 border border-pink-500/20 bg-purple-900/20 backdrop-blur-sm hover:border-cyan-400/40 hover:shadow-[0_0_20px_rgba(6,182,212,0.1)] transition-all duration-500">
						<h3 class="text-lg font-serif italic text-fuchsia-300 group-hover:text-cyan-300 transition-colors duration-300">
							{p.title}
						</h3>
						<p class="mt-3 text-sm text-pink-200/40 leading-relaxed font-light">
							{p.excerpt}
						</p>
					</a>
				))}
			</div>
		</section>
	</main>
</div>
