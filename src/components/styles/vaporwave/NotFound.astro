---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-purple-950 via-pink-900 to-cyan-950 text-pink-100 font-sans">
	<div class="fixed inset-0 pointer-events-none opacity-5 bg-[linear-gradient(rgba(255,255,255,.1)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.1)_1px,transparent_1px)] bg-[size:60px_60px]"></div>

	<nav class="relative z-10 flex flex-wrap items-center justify-center gap-2 px-6 py-5 border-b border-pink-500/20 backdrop-blur-sm bg-purple-950/30">
		{nav.map((item: any) => (
			<a href={item.href} class="px-4 py-2 text-sm tracking-widest uppercase text-cyan-300 hover:text-pink-300 transition-colors duration-300 hover:drop-shadow-[0_0_8px_rgba(236,72,153,0.6)]">
				{item.label}
			</a>
		))}
	</nav>

	<main class="relative z-10 flex items-center justify-center px-6 py-24 md:py-40">
		<section class="text-center max-w-lg">
			<p class="text-xs tracking-[0.5em] uppercase text-cyan-400/40 mb-6">&#9649; &#9671; &#9651; ア エ ス テ ティック &#9651; &#9671; &#9649;</p>

			<h1 class="text-8xl md:text-9xl font-serif italic font-bold bg-gradient-to-b from-pink-400 to-cyan-400 bg-clip-text text-transparent drop-shadow-[4px_4px_0px_rgba(6,182,212,0.3)]">
				{t.notFound.title}
			</h1>

			<h2 class="mt-6 text-2xl md:text-3xl font-serif italic text-fuchsia-300">
				{t.notFound.heading}
			</h2>

			<div class="mt-4 w-32 h-px mx-auto bg-gradient-to-r from-transparent via-pink-500/50 to-transparent"></div>

			<p class="mt-6 text-pink-200/50 font-light leading-relaxed">
				{t.notFound.description}
			</p>

			<div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
				<a href={`/${lang}/${style}/`} class="px-8 py-3 bg-gradient-to-r from-pink-600 to-fuchsia-600 text-white tracking-widest uppercase text-sm hover:from-pink-500 hover:to-fuchsia-500 hover:shadow-[0_0_25px_rgba(236,72,153,0.4)] transition-all duration-300">
					{t.notFound.backHome}
				</a>
				<a href={`/${lang}/${style}/cats`} class="px-8 py-3 border border-cyan-400/40 text-cyan-300 tracking-widest uppercase text-sm hover:bg-cyan-400/10 hover:shadow-[0_0_20px_rgba(6,182,212,0.2)] transition-all duration-300">
					{t.notFound.meetCats}
				</a>
			</div>

			<p class="mt-16 text-xs text-fuchsia-500/30 tracking-[0.3em]">&#9651; &#9671; &#9649;</p>
		</section>
	</main>
</div>
