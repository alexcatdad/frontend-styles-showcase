---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-[#0a0015] text-pink-100 font-sans overflow-hidden">
	<!-- Sunset gradient sky -->
	<div class="fixed inset-0 bg-gradient-to-b from-[#1a0030] via-[#3d0066] via-40% to-[#ff6b9d]/20 pointer-events-none"></div>

	<!-- Horizontal sun band -->
	<div class="fixed top-[35%] left-0 right-0 h-32 bg-gradient-to-b from-[#ff2d7b]/15 via-[#ff6b35]/10 to-transparent pointer-events-none blur-sm"></div>

	<!-- Perspective grid floor -->
	<div class="fixed bottom-0 left-0 right-0 h-[45vh] pointer-events-none opacity-30" style="background: linear-gradient(transparent 0%, rgba(255,107,157,0.06) 2%, transparent 2.5%, transparent 10%, rgba(255,107,157,0.06) 10.5%, transparent 11%, transparent 20%, rgba(255,107,157,0.06) 20.5%, transparent 21%, transparent 30%, rgba(255,107,157,0.06) 30.5%, transparent 31%, transparent 42%, rgba(255,107,157,0.06) 42.5%, transparent 43%, transparent 56%, rgba(255,107,157,0.06) 56.5%, transparent 57%, transparent 74%, rgba(255,107,157,0.06) 74.5%, transparent 75%), repeating-linear-gradient(90deg, transparent, transparent 8%, rgba(6,182,212,0.08) 8.2%, transparent 8.4%); perspective: 400px; transform: rotateX(55deg); transform-origin: top center;"></div>

	<!-- Floating decorative glyphs -->
	<div class="fixed top-[18%] left-[8%] text-fuchsia-500/[0.07] text-6xl font-serif italic pointer-events-none select-none">&#9651;</div>
	<div class="fixed top-[60%] right-[6%] text-cyan-400/[0.06] text-5xl pointer-events-none select-none">&#9671;</div>
	<div class="fixed bottom-[30%] left-[12%] text-pink-400/[0.05] text-4xl pointer-events-none select-none">&#9649;</div>

	<!-- Navigation: fading in from transparency -->
	<nav class="relative z-20 flex flex-wrap items-center justify-center gap-1 px-6 py-8 opacity-70 hover:opacity-100 transition-opacity duration-700">
		<span class="text-fuchsia-500/20 text-xs mr-3 tracking-[0.3em] hidden md:inline">&#9553;</span>
		{nav.map((item: any) => (
			<a href={item.href} class="px-5 py-2 text-[11px] tracking-[0.35em] uppercase text-cyan-300/60 hover:text-pink-300 transition-all duration-500 hover:drop-shadow-[0_0_12px_rgba(236,72,153,0.5)]">
				{item.label}
			</a>
		))}
		<span class="text-fuchsia-500/20 text-xs ml-3 tracking-[0.3em] hidden md:inline">&#9553;</span>
	</nav>

	<main class="relative z-10">
		<!-- Hero Section: drifting, spacious -->
		<section class="flex flex-col items-center justify-center px-6 pt-16 pb-28 md:pt-24 md:pb-40 text-center">
			<p class="text-[10px] tracking-[0.8em] uppercase text-cyan-400/30 mb-10 select-none">
				&#9553; ア エ ス テ ティック &#9553;
			</p>

			<!-- Glitch heading with offset colored shadows -->
			<h1 class="relative text-5xl md:text-7xl lg:text-9xl font-serif italic font-bold leading-none">
				<span class="absolute inset-0 text-cyan-400/30 translate-x-[3px] -translate-y-[2px] blur-[0.5px]" aria-hidden="true">{sanctuary.name}</span>
				<span class="absolute inset-0 text-pink-500/25 -translate-x-[3px] translate-y-[2px] blur-[0.5px]" aria-hidden="true">{sanctuary.name}</span>
				<span class="relative bg-gradient-to-r from-pink-300 via-fuchsia-200 to-cyan-300 bg-clip-text text-transparent">{sanctuary.name}</span>
			</h1>

			<p class="mt-10 text-lg md:text-2xl text-pink-200/50 font-light tracking-wide max-w-2xl italic leading-relaxed">
				{sanctuary.tagline}
			</p>

			<div class="mt-14 flex flex-col sm:flex-row gap-5">
				<a href={`/${lang}/${style}/cats`} class="px-10 py-4 border border-cyan-400/30 text-cyan-300/70 tracking-[0.3em] uppercase text-xs hover:bg-cyan-400/[0.07] hover:border-cyan-400/50 hover:shadow-[0_0_40px_rgba(6,182,212,0.15)] transition-all duration-500">
					{t.home.meetCats}
				</a>
				<a href={`/${lang}/${style}/donate`} class="px-10 py-4 bg-gradient-to-r from-pink-600/80 to-fuchsia-600/80 text-white/90 tracking-[0.3em] uppercase text-xs hover:from-pink-500/90 hover:to-fuchsia-500/90 hover:shadow-[0_0_50px_rgba(236,72,153,0.25)] transition-all duration-500">
					{t.home.donate}
				</a>
			</div>
		</section>

		<!-- Column divider -->
		<div class="flex items-center justify-center gap-4 py-6 select-none">
			<div class="w-24 h-px bg-gradient-to-r from-transparent to-pink-500/20"></div>
			<span class="text-fuchsia-500/15 tracking-[0.5em] text-xs">&#9553; &#9671; &#9553;</span>
			<div class="w-24 h-px bg-gradient-to-l from-transparent to-pink-500/20"></div>
		</div>

		<!-- Mission: floating panel -->
		<section class="max-w-3xl mx-auto px-6 py-20 text-center">
			<h2 class="relative text-3xl md:text-5xl font-serif italic leading-tight">
				<span class="absolute inset-0 text-cyan-400/15 translate-x-[2px] -translate-y-[1px]" aria-hidden="true">{t.home.mission}</span>
				<span class="relative text-fuchsia-300/90">{t.home.mission}</span>
			</h2>
			<p class="mt-3 text-[10px] tracking-[0.6em] uppercase text-cyan-500/25 select-none">&#9651; &#9671; &#9651;</p>

			<div class="mt-12 border border-pink-500/10 bg-purple-950/20 backdrop-blur-md p-10 md:p-14 shadow-[0_0_80px_rgba(139,92,246,0.05)]">
				<p class="text-lg text-pink-200/50 leading-loose font-light tracking-wide">
					{sanctuary.mission}
				</p>
			</div>
		</section>

		<!-- Stats: scattered, letter-spaced, A E S T H E T I C treatment -->
		<section class="max-w-5xl mx-auto px-6 py-20">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-8">
				{sanctuary.stats.map((stat: any) => (
					<div class="group flex flex-col items-center p-8 border border-pink-500/[0.08] bg-purple-950/15 backdrop-blur-sm hover:border-cyan-400/20 hover:shadow-[0_0_60px_rgba(6,182,212,0.06)] transition-all duration-700">
						<span class="text-5xl md:text-6xl font-serif italic font-bold bg-gradient-to-b from-cyan-300/90 to-pink-400/90 bg-clip-text text-transparent">
							{stat.value}
						</span>
						<span class="mt-4 text-[9px] tracking-[0.5em] uppercase text-pink-300/35 group-hover:text-pink-300/55 transition-colors duration-700">
							{stat.label}
						</span>
					</div>
				))}
			</div>
		</section>

		<!-- Column divider -->
		<div class="flex items-center justify-center gap-4 py-6 select-none">
			<div class="w-16 h-px bg-gradient-to-r from-transparent to-cyan-500/15"></div>
			<span class="text-cyan-400/10 tracking-[0.5em] text-xs">&#9553; ア エ ス &#9553;</span>
			<div class="w-16 h-px bg-gradient-to-l from-transparent to-cyan-500/15"></div>
		</div>

		<!-- About Section: floating panel against void -->
		<section class="max-w-3xl mx-auto px-6 py-20 text-center">
			<h2 class="relative text-3xl md:text-5xl font-serif italic leading-tight">
				<span class="absolute inset-0 text-pink-500/15 -translate-x-[2px] translate-y-[1px]" aria-hidden="true">{t.home.aboutUs}</span>
				<span class="relative text-cyan-300/90">{t.home.aboutUs}</span>
			</h2>
			<p class="mt-3 text-[10px] tracking-[0.6em] uppercase text-fuchsia-500/20 select-none">&#9649; &#9671; &#9649;</p>

			<div class="mt-12 border border-cyan-500/[0.08] bg-purple-950/15 backdrop-blur-md p-10 md:p-14 shadow-[0_0_80px_rgba(6,182,212,0.03)]">
				{sanctuary.about.map((paragraph: string) => (
					<p class="text-pink-200/40 leading-loose mb-8 last:mb-0 font-light tracking-wide">{paragraph}</p>
				))}
			</div>
		</section>

		<!-- Contact: ambient drift -->
		<section class="max-w-xl mx-auto px-6 pt-10 pb-28 text-center">
			<p class="text-[10px] tracking-[0.6em] uppercase text-fuchsia-400/20 select-none mb-8">&#9553; &#9671; &#9553;</p>
			<p class="text-sm text-pink-200/30 font-light tracking-wider italic">{sanctuary.contact}</p>
		</section>
	</main>

	<footer class="relative z-10 border-t border-pink-500/[0.08] py-10 text-center">
		<p class="text-[10px] tracking-[0.4em] uppercase text-pink-300/20">
			&copy; 2026 {sanctuary.name} &#9553; {t.footer.style}: {meta.name}
		</p>
		<p class="mt-3 text-[10px] text-cyan-500/10 tracking-[0.6em] select-none">&#9651; &#9671; &#9649; ア エ ス テ ティック &#9649; &#9671; &#9651;</p>
	</footer>
</div>
