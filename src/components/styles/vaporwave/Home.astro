---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-purple-950 via-pink-900 to-cyan-950 text-pink-100 font-sans">
	<!-- Decorative grid overlay -->
	<div class="fixed inset-0 pointer-events-none opacity-5 bg-[linear-gradient(rgba(255,255,255,.1)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.1)_1px,transparent_1px)] bg-[size:60px_60px]"></div>

	<nav class="relative z-10 flex flex-wrap items-center justify-center gap-2 px-6 py-5 border-b border-pink-500/20 backdrop-blur-sm bg-purple-950/30">
		{nav.map((item: any) => (
			<a href={item.href} class="px-4 py-2 text-sm tracking-widest uppercase text-cyan-300 hover:text-pink-300 transition-colors duration-300 hover:drop-shadow-[0_0_8px_rgba(236,72,153,0.6)]">
				{item.label}
			</a>
		))}
	</nav>

	<main class="relative z-10">
		<!-- Hero Section -->
		<section class="flex flex-col items-center justify-center px-6 py-24 md:py-36 text-center">
			<p class="text-xs tracking-[0.5em] uppercase text-cyan-400/60 mb-6">&#9649; &#9671; &#9651; ア エ ス テ ティック &#9651; &#9671; &#9649;</p>
			<h1 class="text-5xl md:text-7xl lg:text-8xl font-serif italic font-bold bg-gradient-to-r from-pink-400 via-fuchsia-300 to-cyan-400 bg-clip-text text-transparent drop-shadow-[3px_3px_0px_rgba(6,182,212,0.4)]">
				{sanctuary.name}
			</h1>
			<p class="mt-6 text-lg md:text-2xl text-pink-200/80 font-light tracking-wide max-w-2xl italic">
				{sanctuary.tagline}
			</p>
			<div class="mt-10 flex flex-col sm:flex-row gap-4">
				<a href={`/${lang}/${style}/cats`} class="px-8 py-3 rounded-none border-2 border-cyan-400 text-cyan-300 tracking-widest uppercase text-sm hover:bg-cyan-400/10 hover:shadow-[0_0_20px_rgba(6,182,212,0.3)] transition-all duration-300">
					{t.home.meetCats}
				</a>
				<a href={`/${lang}/${style}/donate`} class="px-8 py-3 rounded-none bg-gradient-to-r from-pink-600 to-fuchsia-600 text-white tracking-widest uppercase text-sm hover:from-pink-500 hover:to-fuchsia-500 hover:shadow-[0_0_20px_rgba(236,72,153,0.4)] transition-all duration-300">
					{t.home.donate}
				</a>
			</div>
		</section>

		<!-- Decorative divider -->
		<div class="flex justify-center py-4">
			<div class="w-3/4 max-w-xl h-px bg-gradient-to-r from-transparent via-pink-500/50 to-transparent"></div>
		</div>

		<!-- Mission Section -->
		<section class="max-w-3xl mx-auto px-6 py-16 text-center">
			<h2 class="text-3xl md:text-4xl font-serif italic text-fuchsia-300 mb-2">
				{t.home.mission}
			</h2>
			<p class="text-xs tracking-[0.4em] uppercase text-cyan-500/50 mb-8">&#9651; &#9671; &#9651;</p>
			<p class="text-lg text-pink-200/70 leading-relaxed font-light">
				{sanctuary.mission}
			</p>
		</section>

		<!-- Stats Section -->
		<section class="max-w-5xl mx-auto px-6 py-16">
			<div class="grid grid-cols-2 md:grid-cols-4 gap-6">
				{sanctuary.stats.map((stat: any) => (
					<div class="flex flex-col items-center p-6 border border-pink-500/20 bg-purple-900/30 backdrop-blur-sm hover:border-cyan-400/40 hover:shadow-[0_0_30px_rgba(6,182,212,0.1)] transition-all duration-500">
						<span class="text-4xl md:text-5xl font-serif italic font-bold bg-gradient-to-b from-cyan-300 to-pink-400 bg-clip-text text-transparent">
							{stat.value}
						</span>
						<span class="mt-3 text-xs tracking-widest uppercase text-pink-300/60">
							{stat.label}
						</span>
					</div>
				))}
			</div>
		</section>

		<!-- Decorative divider -->
		<div class="flex justify-center py-4">
			<div class="w-3/4 max-w-xl h-px bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>
		</div>

		<!-- About Section -->
		<section class="max-w-3xl mx-auto px-6 py-16 text-center">
			<h2 class="text-3xl md:text-4xl font-serif italic text-cyan-300 mb-2">
				{t.home.aboutUs}
			</h2>
			<p class="text-xs tracking-[0.4em] uppercase text-fuchsia-500/50 mb-10">&#9649; ア エ ス &#9649;</p>
			{sanctuary.about.map((paragraph: string) => (
				<p class="text-pink-200/60 leading-relaxed mb-6 font-light">{paragraph}</p>
			))}
		</section>
	</main>

	<footer class="relative z-10 border-t border-pink-500/20 py-8 text-center">
		<p class="text-xs tracking-widest uppercase text-pink-300/40">
			&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.
		</p>
		<p class="mt-2 text-xs text-cyan-500/30 tracking-[0.3em]">&#9651; &#9671; &#9649;</p>
	</footer>
</div>
