---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-gray-300 font-mono text-center">

	<!-- Browser Chrome Title Bar -->
	<div class="bg-gradient-to-r from-blue-800 via-blue-600 to-blue-800 text-white px-3 py-1.5 flex items-center justify-between border-b-2 border-blue-900">
		<span class="text-xs font-bold tracking-wide">:// {post.title} - Netscape Navigator</span>
		<div class="flex gap-1">
			<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[10px] leading-4 font-bold">_</span>
			<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[10px] leading-4 font-bold">&square;</span>
			<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[10px] leading-4 font-bold">X</span>
		</div>
	</div>

	<!-- Navigation -->
	<nav class="bg-gray-400 border-t-2 border-l-2 border-gray-200 border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 p-2 flex flex-wrap items-center justify-center gap-1.5">
		{nav.map((item: any) => (
			<a href={item.href} class="bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-700 border-r-gray-700 px-4 py-1.5 text-xs font-bold text-blue-900 no-underline uppercase tracking-wider hover:bg-gray-200 active:border-t-gray-700 active:border-l-gray-700 active:border-b-white active:border-r-white">
				{item.label}
			</a>
		))}
	</nav>

	<div class="max-w-4xl mx-auto px-2 py-4">

		<!-- Back link -->
		<div class="text-left mb-3">
			<a href={`${_base}/${lang}/${style}/blog`} class="text-blue-700 font-bold underline text-xs hover:text-fuchsia-600">&lt;&lt; {t.blog.backToBlog} &lt;&lt;</a>
		</div>

		<!-- ===== POST HEADER: Full Win95 Window ===== -->
		<article>
			<header class="border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 bg-gray-300 mb-4">
				<!-- Title bar -->
				<div class="bg-gradient-to-r from-blue-800 to-blue-600 text-white px-3 py-1.5 flex items-center justify-between">
					<span class="text-xs font-bold truncate mr-2">{post.title}</span>
					<div class="flex gap-0.5 shrink-0">
						<span class="inline-block w-3.5 h-3.5 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[9px] leading-3.5 font-bold">_</span>
						<span class="inline-block w-3.5 h-3.5 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[9px] leading-3.5 font-bold">&square;</span>
						<span class="inline-block w-3.5 h-3.5 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[9px] leading-3.5 font-bold">X</span>
					</div>
				</div>

				<!-- Menu bar -->
				<div class="bg-gray-300 border-b border-gray-400 px-2 py-0.5 flex gap-3 text-[10px] font-bold text-gray-700">
					<span class="underline">F</span><span>ile</span>
					<span class="underline">E</span><span>dit</span>
					<span class="underline">V</span><span>iew</span>
					<span class="underline">H</span><span>elp</span>
				</div>

				<!-- Post title area -->
				<div class="bg-white m-1 border-t-2 border-l-2 border-gray-500 border-b-2 border-r-2 border-b-white border-r-white p-4">
					<img src={post.image} alt={post.title} class="w-full h-48 object-cover border-4 border-double border-fuchsia-400 mb-3" />
						<h1 class="text-2xl md:text-3xl font-bold text-fuchsia-700 mb-2 drop-shadow">{post.title}</h1>

					<!-- Meta info table -->
					<div class="border-2 border-gray-500 inline-block">
						<div class="grid grid-cols-[auto_auto]">
							<div class="bg-blue-700 text-white font-bold px-2 py-1 text-[10px] border border-blue-500">Date:</div>
							<div class="bg-yellow-50 px-2 py-1 text-[10px] font-bold border border-gray-400">
								<time datetime={post.date}>{post.date}</time>
							</div>
							<div class="bg-blue-700 text-white font-bold px-2 py-1 text-[10px] border border-blue-500">Author:</div>
							<div class="bg-white px-2 py-1 text-[10px] font-bold border border-gray-400">{post.author}</div>
						</div>
					</div>

					<!-- Tags -->
					<div class="flex flex-wrap gap-1 mt-3 justify-center">
						{post.tags.map((tag: string) => (
							<span class="bg-lime-300 text-black text-[10px] font-bold px-2 py-0.5 border border-lime-700">{tag}</span>
						))}
					</div>
				</div>
			</header>

			<!-- Sparkle divider -->
			<p class="text-xs text-fuchsia-500 my-3">*~*~*~*~*~*~*~*~*~*~*~*~*~*~*~*~*~*~*~*</p>

			<!-- ===== POST CONTENT: Inset frame ===== -->
			<div class="border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 bg-gray-300 mb-4">
				<div class="bg-gradient-to-r from-fuchsia-700 to-fuchsia-500 text-white px-3 py-1 text-xs font-bold">
					Article Content
				</div>
				<div class="bg-white m-1 border-t-2 border-l-2 border-gray-500 border-b-2 border-r-2 border-b-white border-r-white p-4 text-left">
					{post.content.map((paragraph: string, i: number) => (
						<>
							<p class="text-gray-800 mb-3 leading-relaxed text-sm">{paragraph}</p>
							{i < post.content.length - 1 && i % 2 === 1 && (
								<p class="text-center text-[10px] text-blue-500 my-2">- - - - -</p>
							)}
						</>
					))}
				</div>
			</div>
		</article>

		<hr class="border-t-4 border-double border-gray-500 my-4" />

		<!-- ===== MORE STORIES: Grid of framed links ===== -->
		<section class="mb-4">
			<div class="border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 bg-gray-300">
				<div class="bg-gradient-to-r from-blue-800 to-blue-600 text-yellow-300 px-3 py-1.5 text-sm font-bold flex items-center justify-between">
					<span>{t.blog.moreStories}</span>
					<div class="flex gap-0.5">
						<span class="inline-block w-3 h-3 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[8px] leading-3 font-bold">_</span>
						<span class="inline-block w-3 h-3 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[8px] leading-3 font-bold">X</span>
					</div>
				</div>
				<div class="p-2 bg-white m-0.5 border-t border-l border-gray-500 border-b border-r border-b-white border-r-white">
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
						{otherPosts.map((p: any, i: number) => (
							<a href={`${_base}/${lang}/${style}/blog/${p.slug}`} class="no-underline block group">
								<div class={`border-2 border-gray-500 p-2 text-left hover:bg-fuchsia-50 ${i % 2 === 0 ? 'bg-yellow-50' : 'bg-cyan-50'}`}>
									<h3 class="text-xs font-bold text-blue-800 group-hover:text-fuchsia-600 mb-1">{p.title}</h3>
									<p class="text-[10px] text-gray-600 line-clamp-2 mb-1">{p.excerpt}</p>
									<p class="text-[10px] text-blue-700 font-bold underline">Click Here to Read!! &gt;&gt;</p>
								</div>
							</a>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- Footer badges -->
		<div class="flex flex-wrap items-center justify-center gap-3 mb-3">
			<div class="bg-black text-lime-400 font-mono text-[10px] px-3 py-1 border border-gray-600">
				Article reads: 00247
			</div>
			<span class="bg-yellow-400 text-black font-bold text-[10px] px-2 py-1 border-2 border-yellow-700">Sign our Guestbook!</span>
		</div>
	</div>
</div>
