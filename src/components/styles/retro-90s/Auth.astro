---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gray-300 font-mono text-center">

	<!-- Browser Chrome Title Bar -->
	<div class="bg-gradient-to-r from-blue-800 via-blue-600 to-blue-800 text-white px-3 py-1.5 flex items-center justify-between border-b-2 border-blue-900">
		<span class="text-xs font-bold tracking-wide">:// {t.auth.title} - Netscape Navigator</span>
		<div class="flex gap-1">
			<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[10px] leading-4 font-bold">_</span>
			<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[10px] leading-4 font-bold">&square;</span>
			<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[10px] leading-4 font-bold">X</span>
		</div>
	</div>

	<!-- Navigation -->
	<nav class="bg-gray-400 border-t-2 border-l-2 border-gray-200 border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 p-2 flex flex-wrap items-center justify-center gap-1.5">
		{nav.map((item: any) => (
			<a href={item.href} class="bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-700 border-r-gray-700 px-4 py-1.5 text-xs font-bold text-blue-900 no-underline uppercase tracking-wider hover:bg-gray-200 active:border-t-gray-700 active:border-l-gray-700 active:border-b-white active:border-r-white">
				{item.label}
			</a>
		))}
	</nav>

	<main class="max-w-lg mx-auto px-2 py-8">

		<!-- ===== LOGIN DIALOG: Full Win95 Dialog Box ===== -->
		<section class="border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 bg-gray-300">
			<!-- Title bar with full chrome -->
			<div class="bg-gradient-to-r from-blue-800 to-blue-600 text-white px-3 py-1.5 flex items-center justify-between">
				<div class="flex items-center gap-2">
					<span class="text-xs font-bold">{t.auth.title}</span>
				</div>
				<div class="flex gap-1">
					<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[10px] leading-4 font-bold cursor-pointer hover:bg-gray-200">_</span>
					<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[10px] leading-4 font-bold cursor-pointer hover:bg-gray-200">X</span>
				</div>
			</div>

			<!-- Dialog body -->
			<div class="p-4">

				<!-- Warning / info banner at top -->
				<div class="flex items-start gap-3 mb-4 bg-white border-t-2 border-l-2 border-gray-500 border-b-2 border-r-2 border-b-white border-r-white p-3">
					<div class="w-8 h-8 bg-blue-700 rounded-full flex items-center justify-center border-2 border-blue-900 shrink-0">
						<span class="text-yellow-300 text-lg font-bold">i</span>
					</div>
					<p class="text-xs text-gray-700 font-bold text-left">{t.auth.subtitle}</p>
				</div>

				<hr class="border-t border-gray-400 mb-4" />

				<!-- Login form -->
				<form class="text-left">
					<!-- Email field with label table-layout -->
					<div class="grid grid-cols-[auto_1fr] gap-x-3 gap-y-2 items-center mb-3">
						<label for="email" class="text-xs font-bold text-gray-800 text-right">{t.auth.email}:</label>
						<input type="email" id="email" name="email" placeholder="you@example.com" class="w-full px-2 py-1 text-xs bg-white border-t-2 border-l-2 border-gray-500 border-b-2 border-r-2 border-b-white border-r-white font-mono focus:outline-none" />

						<label for="password" class="text-xs font-bold text-gray-800 text-right">{t.auth.password}:</label>
						<input type="password" id="password" name="password" placeholder="********" class="w-full px-2 py-1 text-xs bg-white border-t-2 border-l-2 border-gray-500 border-b-2 border-r-2 border-b-white border-r-white font-mono focus:outline-none" />
					</div>

					<!-- Remember me + forgot password row -->
					<div class="flex items-center justify-between mb-4">
						<label class="flex items-center gap-1.5 text-xs text-gray-700 cursor-pointer">
							<input type="checkbox" name="remember" class="accent-blue-700" />
							<span class="font-bold">{t.auth.rememberMe}</span>
						</label>
						<a href="#" class="text-blue-700 text-[10px] font-bold underline hover:text-fuchsia-600">{t.auth.forgotPassword}</a>
					</div>

					<!-- Decorative HR -->
					<div class="border-t-2 border-gray-400 border-b border-white mb-4"></div>

					<!-- Sign In button row: classic Win95 dialog buttons -->
					<div class="flex gap-2 justify-center mb-4">
						<button type="submit" class="bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-700 border-r-gray-700 px-8 py-1.5 font-bold text-xs text-black cursor-pointer hover:bg-gray-200 active:border-t-gray-700 active:border-l-gray-700 active:border-b-white active:border-r-white min-w-[100px]">
							{t.auth.signIn}
						</button>
						<button type="button" class="bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-700 border-r-gray-700 px-8 py-1.5 font-bold text-xs text-black cursor-pointer hover:bg-gray-200 active:border-t-gray-700 active:border-l-gray-700 active:border-b-white active:border-r-white min-w-[100px]">
							Cancel
						</button>
					</div>
				</form>

				<!-- Thick separator -->
				<div class="border-t-2 border-gray-400 border-b border-white mb-4"></div>

				<!-- Social login as a separate "group box" -->
				<div class="border-t border-l border-gray-500 border-b border-r border-white p-3 mb-4">
					<p class="text-[10px] font-bold text-gray-600 mb-3 uppercase tracking-wider">{t.auth.continueWith}</p>
					<div class="flex gap-2 justify-center">
						<button type="button" class="bg-white border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-700 border-r-gray-700 px-6 py-1.5 font-bold text-xs text-blue-800 cursor-pointer hover:bg-gray-100 active:border-t-gray-700 active:border-l-gray-700 active:border-b-white active:border-r-white">
							Google
						</button>
						<button type="button" class="bg-white border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-700 border-r-gray-700 px-6 py-1.5 font-bold text-xs text-blue-800 cursor-pointer hover:bg-gray-100 active:border-t-gray-700 active:border-l-gray-700 active:border-b-white active:border-r-white">
							Apple
						</button>
					</div>
				</div>

				<!-- Sign up link -->
				<p class="text-xs text-gray-700">
					{t.auth.noAccount} <a href="#" class="text-blue-700 font-bold underline hover:text-fuchsia-600">{t.auth.signUp}</a>
				</p>
			</div>
		</section>

		<!-- Security badge cluster -->
		<div class="flex flex-wrap items-center justify-center gap-2 mt-6">
			<span class="bg-yellow-400 text-black font-bold text-[10px] px-2 py-1 border-2 border-yellow-700">128-bit SSL Encryption!</span>
			<span class="bg-lime-400 text-black font-bold text-[10px] px-2 py-1 border-2 border-lime-700">VeriSign Secured</span>
		</div>

		<div class="mt-4">
			<div class="bg-black text-lime-400 font-mono text-[10px] px-3 py-1 border border-gray-600 inline-block">
				Login attempts today: 00042
			</div>
		</div>
	</main>
</div>
