---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-white font-sans">
	<!-- Navigation bar -->
	<nav class="bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-500 border-r-gray-500 p-1 flex flex-wrap items-center justify-center gap-1">
		{nav.map((item: any) => (
			<a href={item.href} class="bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 px-3 py-1 text-sm font-bold text-blue-800 no-underline hover:bg-gray-200 active:border-t-gray-600 active:border-l-gray-600 active:border-b-white active:border-r-white">
				{item.label}
			</a>
		))}
	</nav>

	<main class="max-w-md mx-auto px-2 py-8">
		<!-- Login window - dialog box style -->
		<section class="border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-500 border-r-gray-500 bg-gray-300">
			<!-- Title bar -->
			<div class="bg-blue-700 text-white px-3 py-2 flex items-center justify-between">
				<h1 class="text-lg font-bold">{t.auth.title}</h1>
				<div class="flex gap-1">
					<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-xs leading-4 font-bold">_</span>
					<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-xs leading-4 font-bold">X</span>
				</div>
			</div>

			<!-- Dialog body -->
			<div class="p-4">
				<p class="text-sm text-gray-700 mb-4 text-center font-bold">{t.auth.subtitle}</p>

				<!-- Login form -->
				<form class="space-y-3">
					<div>
						<label for="email" class="block text-sm font-bold text-gray-800 mb-1">{t.auth.email}</label>
						<input type="email" id="email" name="email" placeholder="you@example.com" class="w-full px-2 py-1 text-sm bg-white border-t-2 border-l-2 border-gray-500 border-b-2 border-r-2 border-b-white border-r-white focus:outline-none" />
					</div>

					<div>
						<label for="password" class="block text-sm font-bold text-gray-800 mb-1">{t.auth.password}</label>
						<input type="password" id="password" name="password" placeholder="********" class="w-full px-2 py-1 text-sm bg-white border-t-2 border-l-2 border-gray-500 border-b-2 border-r-2 border-b-white border-r-white focus:outline-none" />
					</div>

					<div class="flex items-center justify-between">
						<label class="flex items-center gap-1 text-sm text-gray-700 cursor-pointer">
							<input type="checkbox" name="remember" class="accent-blue-700" />
							<span class="font-bold">{t.auth.rememberMe}</span>
						</label>
						<a href="#" class="text-blue-700 text-xs font-bold underline hover:text-fuchsia-600">{t.auth.forgotPassword}</a>
					</div>

					<hr class="border-t border-gray-400" />

					<!-- Sign in button - Win95 style -->
					<button type="submit" class="w-full bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 px-4 py-2 font-bold text-sm text-black cursor-pointer hover:bg-gray-200 active:border-t-gray-600 active:border-l-gray-600 active:border-b-white active:border-r-white">
						{t.auth.signIn}
					</button>
				</form>

				<hr class="border-t border-gray-400 my-4" />

				<!-- Social login section -->
				<div class="text-center">
					<p class="text-xs font-bold text-gray-600 mb-3">{t.auth.continueWith}</p>
					<div class="flex gap-2 justify-center">
						<button type="button" class="bg-white border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 px-6 py-1 font-bold text-sm text-blue-800 cursor-pointer hover:bg-gray-100 active:border-t-gray-600 active:border-l-gray-600 active:border-b-white active:border-r-white">
							Google
						</button>
						<button type="button" class="bg-white border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 px-6 py-1 font-bold text-sm text-blue-800 cursor-pointer hover:bg-gray-100 active:border-t-gray-600 active:border-l-gray-600 active:border-b-white active:border-r-white">
							Apple
						</button>
					</div>
				</div>

				<hr class="border-t border-gray-400 my-4" />

				<!-- Sign up link -->
				<p class="text-center text-sm text-gray-700">
					{t.auth.noAccount} <a href="#" class="text-blue-700 font-bold underline hover:text-fuchsia-600">{t.auth.signUp}</a>
				</p>
			</div>
		</section>

		<!-- Under construction badge -->
		<div class="text-center mt-6">
			<span class="inline-block bg-yellow-300 text-black font-bold text-xs px-3 py-1 border-2 border-yellow-600">Secure Login - 128-bit encryption!</span>
		</div>
	</main>
</div>
