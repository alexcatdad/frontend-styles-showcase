---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-white font-sans">
	<!-- Navigation bar - beveled 3D look -->
	<nav class="bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-500 border-r-gray-500 p-1 flex flex-wrap items-center justify-center gap-1">
		{nav.map((item: any) => (
			<a href={item.href} class="bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 px-3 py-1 text-sm font-bold text-blue-800 no-underline hover:bg-gray-200 active:border-t-gray-600 active:border-l-gray-600 active:border-b-white active:border-r-white">
				{item.label}
			</a>
		))}
	</nav>

	<!-- Marquee-style welcome banner -->
	<div class="bg-blue-700 text-yellow-300 text-center py-2 font-bold text-lg tracking-widest overflow-hidden">
		<span class="inline-block">~ * ~ * ~ Welcome to {sanctuary.name}! ~ * ~ * ~</span>
	</div>

	<main class="max-w-3xl mx-auto px-2 py-4">
		<!-- Hero Section -->
		<section class="text-center mb-4">
			<div class="bg-fuchsia-600 text-white py-4 px-4 border-4 border-double border-yellow-300 mb-4">
				<h1 class="text-4xl md:text-5xl font-bold mb-2 tracking-tight">{sanctuary.name}</h1>
				<p class="text-xl text-yellow-200 font-bold">{sanctuary.tagline}</p>
			</div>

			<div class="flex flex-col sm:flex-row gap-3 justify-center mt-4">
				<a href={`/${lang}/${style}/cats`} class="bg-lime-400 border-t-2 border-l-2 border-lime-200 border-b-2 border-r-2 border-b-lime-700 border-r-lime-700 px-6 py-3 font-bold text-lg text-black no-underline text-center hover:bg-lime-300 active:border-t-lime-700 active:border-l-lime-700 active:border-b-lime-200 active:border-r-lime-200">
					{t.home.meetCats}
				</a>
				<a href={`/${lang}/${style}/donate`} class="bg-yellow-300 border-t-2 border-l-2 border-yellow-100 border-b-2 border-r-2 border-b-yellow-600 border-r-yellow-600 px-6 py-3 font-bold text-lg text-black no-underline text-center hover:bg-yellow-200 active:border-t-yellow-600 active:border-l-yellow-600 active:border-b-yellow-100 active:border-r-yellow-100">
					{t.home.donate}
				</a>
			</div>
		</section>

		<!-- Horizontal rule divider -->
		<hr class="border-t-2 border-gray-400 my-4" />

		<!-- Under construction badge area -->
		<div class="text-center mb-4">
			<span class="inline-block bg-red-600 text-white font-bold text-xs px-3 py-1 border-2 border-yellow-400 animate-pulse">*** NEW ***</span>
		</div>

		<!-- Mission Section -->
		<section class="border-4 border-blue-600 bg-blue-50 p-4 mb-4">
			<h2 class="text-2xl font-bold text-blue-800 text-center mb-2 underline decoration-wavy decoration-fuchsia-500">{t.home.mission}</h2>
			<p class="text-gray-800 text-lg text-center leading-relaxed">{sanctuary.mission}</p>
		</section>

		<hr class="border-t-2 border-gray-400 my-4" />

		<!-- Stats Section - table-like grid -->
		<section class="mb-4">
			<div class="grid grid-cols-2 md:grid-cols-4 border-2 border-gray-600">
				{sanctuary.stats.map((stat: any) => (
					<div class="border border-gray-400 bg-yellow-100 p-3 text-center">
						<span class="block text-3xl font-bold text-fuchsia-600">{stat.value}</span>
						<span class="block text-sm font-bold text-blue-800 uppercase">{stat.label}</span>
					</div>
				))}
			</div>
		</section>

		<hr class="border-t-2 border-gray-400 my-4" />

		<!-- About Section -->
		<section class="border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-500 border-r-gray-500 bg-gray-200 p-4 mb-4">
			<h2 class="text-2xl font-bold text-center text-fuchsia-700 mb-3">{t.home.aboutUs}</h2>
			{sanctuary.about.map((paragraph: string) => (
				<p class="text-gray-800 mb-3 leading-relaxed text-lg">{paragraph}</p>
			))}
		</section>

		<!-- Visitor counter area -->
		<div class="text-center my-4">
			<div class="inline-block bg-black text-lime-400 font-mono text-sm px-4 py-2 border-2 border-gray-500">
				You are visitor #00{sanctuary.stats.length}742 to this page!
			</div>
		</div>

		<hr class="border-t-2 border-gray-400 my-4" />
	</main>

	<footer class="bg-gray-300 border-t-2 border-gray-500 text-center py-3 px-4">
		<p class="text-sm text-gray-700 font-bold">&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.</p>
		<p class="text-xs text-blue-700 mt-1">Best viewed with Netscape Navigator 4.0 at 800x600</p>
	</footer>
</div>
