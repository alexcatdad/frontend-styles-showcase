---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-gray-300 font-mono text-center">

	<!-- ===== TOP FRAME: Win95 Desktop Title Bar ===== -->
	<div class="bg-gradient-to-r from-blue-800 via-blue-600 to-blue-800 text-white px-3 py-1.5 flex items-center justify-between border-b-2 border-blue-900">
		<div class="flex items-center gap-2">
			<span class="text-xs font-bold tracking-wide">:// {sanctuary.name} - Netscape Navigator</span>
		</div>
		<div class="flex gap-1">
			<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[10px] leading-4 font-bold">_</span>
			<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[10px] leading-4 font-bold">&square;</span>
			<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[10px] leading-4 font-bold">X</span>
		</div>
	</div>

	<!-- Address bar -->
	<div class="bg-gray-300 border-b-2 border-gray-400 px-2 py-1 flex items-center gap-2">
		<span class="text-xs font-bold text-gray-700">Location:</span>
		<div class="flex-1 bg-white border-t border-l border-gray-500 border-b border-r border-b-white border-r-white px-2 py-0.5">
			<span class="text-xs text-gray-600 font-mono">http://www.{sanctuary.name.toLowerCase().replace(/\s+/g, '')}.geocities.com/</span>
		</div>
	</div>

	<!-- ===== NAVIGATION FRAME: Image-Map Style Buttons ===== -->
	<nav class="bg-gray-400 border-t-2 border-l-2 border-gray-200 border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 p-2 flex flex-wrap items-center justify-center gap-1.5">
		{nav.map((item: any) => (
			<a href={item.href} class="bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-700 border-r-gray-700 px-4 py-1.5 text-xs font-bold text-blue-900 no-underline uppercase tracking-wider hover:bg-gray-200 active:border-t-gray-700 active:border-l-gray-700 active:border-b-white active:border-r-white">
				{item.label}
			</a>
		))}
	</nav>

	<!-- ===== MARQUEE BANNER ===== -->
	<div class="bg-black text-yellow-300 py-1.5 text-sm font-bold tracking-widest overflow-hidden border-y-2 border-yellow-500">
		<span class="inline-block animate-pulse">*+*+*+* Welcome to {sanctuary.name}! *+*+*+* Your #1 Cat Sanctuary on the World Wide Web! *+*+*+*</span>
	</div>

	<!-- ===== MAIN FRAMESET: Sidebar + Content ===== -->
	<div class="max-w-5xl mx-auto px-2 py-3">
		<div class="grid grid-cols-1 md:grid-cols-[180px_1fr] gap-0 border-2 border-gray-600">

			<!-- LEFT SIDEBAR FRAME -->
			<aside class="bg-blue-900 border-r-2 border-gray-600 p-2 hidden md:block">
				<div class="text-center mb-3">
					<p class="text-yellow-300 font-bold text-xs mb-1 underline">SITE MAP</p>
				</div>
				{nav.map((item: any) => (
					<a href={item.href} class="block text-lime-300 text-xs font-bold py-1.5 px-2 no-underline hover:bg-blue-800 hover:text-yellow-300 border-b border-blue-700">
						&gt; {item.label}
					</a>
				))}
				<hr class="border-blue-700 my-3" />
				<div class="text-center">
					<span class="inline-block bg-red-600 text-white text-[10px] font-bold px-2 py-0.5 border border-yellow-400 animate-pulse mb-2">NEW!</span>
					<p class="text-cyan-300 text-[10px] font-bold">Last Updated:<br />April 1, 2026</p>
				</div>
				<hr class="border-blue-700 my-3" />
				<div class="text-center">
					<div class="bg-black text-lime-400 text-[10px] font-mono px-1 py-1 border border-gray-500 mb-2">
						Visitors:<br />#00{sanctuary.stats.length}742
					</div>
				</div>
				<hr class="border-blue-700 my-3" />
				<p class="text-yellow-200 text-[10px] text-center font-bold">Sign Our<br /><span class="text-cyan-300 underline">Guestbook!</span></p>
			</aside>

			<!-- MAIN CONTENT FRAME -->
			<main class="bg-white p-3">

				<!-- *** HERO: Big Flashy Banner *** -->
				<div class="border-4 border-double border-fuchsia-500 bg-gradient-to-b from-fuchsia-700 via-fuchsia-600 to-fuchsia-700 text-white py-5 px-4 mb-3">
					<img src={sanctuary.heroImage} alt={sanctuary.name} class="w-full max-w-md mx-auto h-48 object-cover border-4 border-yellow-400 mb-3" />
					<h1 class="text-3xl md:text-5xl font-bold mb-2 tracking-tight drop-shadow-lg">{sanctuary.name}</h1>
					<p class="text-lg md:text-xl text-yellow-300 font-bold">{sanctuary.tagline}</p>
				</div>

				<!-- Under Construction + NEW badges row -->
				<div class="flex flex-wrap items-center justify-center gap-3 mb-3">
					<span class="inline-block bg-yellow-400 text-black font-bold text-[10px] px-2 py-1 border-2 border-yellow-700 animate-pulse">!! UNDER CONSTRUCTION !!</span>
					<span class="inline-block bg-red-600 text-white font-bold text-[10px] px-2 py-1 border-2 border-red-800 animate-pulse">*** HOT ***</span>
					<span class="inline-block bg-lime-400 text-black font-bold text-[10px] px-2 py-1 border-2 border-lime-700">~* NEW CATS WEEKLY *~</span>
				</div>

				<!-- Sparkle HR -->
				<p class="text-center text-xs text-fuchsia-500 my-2">*~*~*~*~*~*~*~*~*~*~*~*~*~*~*~*~*~*~*~*~*~*</p>

				<!-- CTA Buttons: beveled 3D -->
				<div class="flex flex-col sm:flex-row gap-2 justify-center mb-3">
					<a href={`/${lang}/${style}/cats`} class="bg-lime-400 border-t-3 border-l-3 border-lime-200 border-b-3 border-r-3 border-b-lime-800 border-r-lime-800 px-6 py-3 font-bold text-base text-black no-underline text-center hover:bg-lime-300 active:border-t-lime-800 active:border-l-lime-800 active:border-b-lime-200 active:border-r-lime-200 uppercase tracking-wider">
						&gt;&gt; {t.home.meetCats} &lt;&lt;
					</a>
					<a href={`/${lang}/${style}/donate`} class="bg-yellow-400 border-t-3 border-l-3 border-yellow-200 border-b-3 border-r-3 border-b-yellow-700 border-r-yellow-700 px-6 py-3 font-bold text-base text-black no-underline text-center hover:bg-yellow-300 active:border-t-yellow-700 active:border-l-yellow-700 active:border-b-yellow-200 active:border-r-yellow-200 uppercase tracking-wider">
						&gt;&gt; {t.home.donate} &lt;&lt;
					</a>
				</div>

				<hr class="border-t-4 border-double border-gray-400 my-4" />

				<!-- *** MISSION: Win95 Window *** -->
				<section class="border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 bg-gray-300 mb-4">
					<div class="bg-gradient-to-r from-blue-800 to-blue-600 text-white px-3 py-1.5 flex items-center justify-between">
						<span class="text-sm font-bold">{t.home.mission}</span>
						<div class="flex gap-1">
							<span class="inline-block w-3.5 h-3.5 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[9px] leading-3.5 font-bold">_</span>
							<span class="inline-block w-3.5 h-3.5 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[9px] leading-3.5 font-bold">X</span>
						</div>
					</div>
					<div class="p-4 bg-white border-t-2 border-l-2 border-gray-500 border-b-2 border-r-2 border-b-white border-r-white m-1">
						<p class="text-gray-800 text-base leading-relaxed">{sanctuary.mission}</p>
					</div>
				</section>

				<!-- Decorative HR -->
				<div class="text-center my-3">
					<span class="text-sm text-blue-600">- - - - - - - - - - - - - - - - -</span>
				</div>

				<!-- *** STATS: HTML Table with Visible Borders *** -->
				<section class="mb-4">
					<div class="bg-gradient-to-r from-blue-800 to-blue-600 text-yellow-300 text-center py-1 font-bold text-sm border-2 border-blue-900">
						Cat Sanctuary Statistics
					</div>
					<div class="border-2 border-gray-700 border-collapse">
						<div class="grid grid-cols-2 md:grid-cols-4">
							{sanctuary.stats.map((stat: any, i: number) => (
								<div class={`border-2 border-gray-500 p-3 text-center ${i % 2 === 0 ? 'bg-yellow-100' : 'bg-cyan-100'}`}>
									<span class="block text-3xl font-bold text-fuchsia-600 drop-shadow">{stat.value}</span>
									<span class="block text-xs font-bold text-blue-900 uppercase mt-1">{stat.label}</span>
								</div>
							))}
						</div>
					</div>
				</section>

				<hr class="border-t-4 border-double border-gray-400 my-4" />

				<!-- *** ABOUT: Framed Panel *** -->
				<section class="mb-4">
					<div class="border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 bg-gray-300">
						<div class="bg-gradient-to-r from-fuchsia-700 to-fuchsia-500 text-white px-3 py-1.5 flex items-center justify-between">
							<span class="text-sm font-bold">{t.home.aboutUs}</span>
							<div class="flex gap-1">
								<span class="inline-block w-3.5 h-3.5 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[9px] leading-3.5 font-bold">_</span>
								<span class="inline-block w-3.5 h-3.5 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[9px] leading-3.5 font-bold">X</span>
							</div>
						</div>
						<div class="p-4 bg-white border-t-2 border-l-2 border-gray-500 border-b-2 border-r-2 border-b-white border-r-white m-1">
							{sanctuary.about.map((paragraph: string) => (
								<p class="text-gray-800 mb-3 leading-relaxed text-base">{paragraph}</p>
							))}
						</div>
					</div>
				</section>

				<!-- Email / Contact Webring-style bar -->
				<div class="bg-blue-900 text-center py-2 px-3 border-2 border-blue-700 mb-4">
					<p class="text-yellow-300 text-xs font-bold mb-1">Contact the Webmaster!</p>
					<p class="text-cyan-300 text-xs font-bold underline">{sanctuary.contact.email}</p>
					<p class="text-lime-300 text-[10px] mt-1">{sanctuary.contact.phone} | {sanctuary.contact.address}</p>
				</div>

				<hr class="border-t-4 border-double border-gray-400 my-3" />

				<!-- Visitor counter + badges row -->
				<div class="flex flex-wrap items-center justify-center gap-3 mb-3">
					<div class="bg-black text-lime-400 font-mono text-xs px-3 py-1 border-2 border-gray-600">
						You are visitor #00{sanctuary.stats.length}742!
					</div>
					<span class="bg-fuchsia-600 text-white text-[10px] font-bold px-2 py-1 border border-fuchsia-800">Made with Notepad</span>
					<span class="bg-blue-700 text-white text-[10px] font-bold px-2 py-1 border border-blue-900">Internet Explorer FREE!</span>
				</div>

			</main>
		</div>
	</div>

	<!-- ===== FOOTER FRAME ===== -->
	<footer class="bg-gray-400 border-t-3 border-gray-600 text-center py-3 px-4">
		<div class="border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 bg-gray-300 max-w-xl mx-auto p-3">
			<p class="text-xs text-gray-800 font-bold">&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.</p>
			<hr class="border-gray-400 my-2" />
			<p class="text-[10px] text-blue-800 font-bold">Best viewed with Netscape Navigator 4.0 at 800x600 resolution.</p>
			<p class="text-[10px] text-gray-600 mt-1">This site is a member of the Cat Lovers WebRing</p>
			<p class="text-[10px] text-fuchsia-600 font-bold mt-1">[ &lt;&lt; Prev | Random | Next &gt;&gt; ]</p>
		</div>
	</footer>
</div>
