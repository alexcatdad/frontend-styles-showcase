---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-white font-sans">
	<!-- Navigation bar -->
	<nav class="bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-500 border-r-gray-500 p-1 flex flex-wrap items-center justify-center gap-1">
		{nav.map((item: any) => (
			<a href={item.href} class="bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 px-3 py-1 text-sm font-bold text-blue-800 no-underline hover:bg-gray-200 active:border-t-gray-600 active:border-l-gray-600 active:border-b-white active:border-r-white">
				{item.label}
			</a>
		))}
	</nav>

	<!-- Marquee banner -->
	<div class="bg-fuchsia-600 text-yellow-300 text-center py-2 font-bold text-lg tracking-widest">
		<span>~*~ Help Our Cats Today! ~*~</span>
	</div>

	<main class="max-w-4xl mx-auto px-2 py-4">
		<!-- Page header -->
		<div class="text-center mb-4">
			<h1 class="text-3xl md:text-4xl font-bold text-blue-800 mb-2">{t.donate.title}</h1>
			<p class="text-lg text-fuchsia-600 font-bold">{t.donate.subtitle}</p>
		</div>

		<hr class="border-t-2 border-gray-400 my-4" />

		<!-- Blinking new badge -->
		<div class="text-center mb-4">
			<span class="inline-block bg-red-600 text-white font-bold text-xs px-3 py-1 border-2 border-yellow-400 animate-pulse">*** DONATE NOW ***</span>
		</div>

		<!-- Monthly Tiers Section -->
		<section class="mb-6">
			<div class="bg-blue-700 text-white text-center py-2 px-3 border-t-2 border-l-2 border-blue-400 border-b-2 border-r-2 border-b-blue-900 border-r-blue-900 mb-3">
				<h2 class="text-xl font-bold">{t.donate.monthly}</h2>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-3">
				{monthlyTiers.map((tier: any) => (
					<div class={`border-t-2 border-l-2 border-b-2 border-r-2 p-0 ${tier.highlighted ? 'border-t-yellow-300 border-l-yellow-300 border-b-yellow-700 border-r-yellow-700 bg-yellow-50' : 'border-t-white border-l-white border-b-gray-500 border-r-gray-500 bg-gray-200'}`}>
						{tier.highlighted && (
							<div class="bg-red-600 text-white text-center text-xs font-bold py-1 animate-pulse">
								{t.donate.mostPopular}
							</div>
						)}

						<div class="p-3 text-center">
							<h3 class="text-lg font-bold text-blue-800 mb-1">{tier.name}</h3>
							<p class="mb-2">
								<span class="text-3xl font-bold text-fuchsia-600">${tier.amount}</span>
								<span class="text-sm text-gray-600 font-bold">{t.donate.perMonth}</span>
							</p>
							<p class="text-sm text-gray-700 mb-3">{tier.description}</p>

							<!-- Perks list -->
							<ul class="text-left mb-3">
								{tier.perks.map((perk: string) => (
									<li class="text-sm text-gray-700 mb-1 pl-4 relative before:content-['*'] before:absolute before:left-0 before:text-lime-600 before:font-bold">{perk}</li>
								))}
							</ul>

							<button type="button" class={`w-full font-bold py-2 px-4 text-sm border-t-2 border-l-2 border-b-2 border-r-2 cursor-pointer ${tier.highlighted ? 'bg-fuchsia-500 text-white border-t-fuchsia-300 border-l-fuchsia-300 border-b-fuchsia-800 border-r-fuchsia-800 hover:bg-fuchsia-400' : 'bg-lime-400 text-black border-t-lime-200 border-l-lime-200 border-b-lime-700 border-r-lime-700 hover:bg-lime-300'} active:border-t-gray-600 active:border-l-gray-600 active:border-b-white active:border-r-white`}>
								{t.donate.choose} {tier.name}
							</button>
						</div>
					</div>
				))}
			</div>
		</section>

		<hr class="border-t-4 border-double border-gray-400 my-6" />

		<!-- One Time Tiers Section -->
		<section class="mb-6">
			<div class="bg-fuchsia-700 text-white text-center py-2 px-3 border-t-2 border-l-2 border-fuchsia-400 border-b-2 border-r-2 border-b-fuchsia-900 border-r-fuchsia-900 mb-3">
				<h2 class="text-xl font-bold">{t.donate.oneTime}</h2>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-3">
				{oneTimeTiers.map((tier: any) => (
					<div class={`border-t-2 border-l-2 border-b-2 border-r-2 p-0 ${tier.highlighted ? 'border-t-yellow-300 border-l-yellow-300 border-b-yellow-700 border-r-yellow-700 bg-yellow-50' : 'border-t-white border-l-white border-b-gray-500 border-r-gray-500 bg-gray-200'}`}>
						{tier.highlighted && (
							<div class="bg-red-600 text-white text-center text-xs font-bold py-1 animate-pulse">
								{t.donate.greatestImpact}
							</div>
						)}

						<div class="p-3 text-center">
							<h3 class="text-lg font-bold text-fuchsia-700 mb-1">{tier.name}</h3>
							<p class="mb-2">
								<span class="text-3xl font-bold text-blue-700">${tier.amount}</span>
							</p>
							<p class="text-sm text-gray-700 mb-3">{tier.description}</p>

							<!-- Perks list -->
							<ul class="text-left mb-3">
								{tier.perks.map((perk: string) => (
									<li class="text-sm text-gray-700 mb-1 pl-4 relative before:content-['*'] before:absolute before:left-0 before:text-fuchsia-600 before:font-bold">{perk}</li>
								))}
							</ul>

							<button type="button" class={`w-full font-bold py-2 px-4 text-sm border-t-2 border-l-2 border-b-2 border-r-2 cursor-pointer ${tier.highlighted ? 'bg-yellow-400 text-black border-t-yellow-200 border-l-yellow-200 border-b-yellow-700 border-r-yellow-700 hover:bg-yellow-300' : 'bg-blue-600 text-white border-t-blue-400 border-l-blue-400 border-b-blue-900 border-r-blue-900 hover:bg-blue-500'} active:border-t-gray-600 active:border-l-gray-600 active:border-b-white active:border-r-white`}>
								{t.donate.give} ${tier.amount}
							</button>
						</div>
					</div>
				))}
			</div>
		</section>

		<hr class="border-t-2 border-gray-400 my-4" />

		<!-- Guestbook-style footer -->
		<div class="text-center mb-4">
			<div class="inline-block bg-black text-lime-400 font-mono text-xs px-3 py-1 border-2 border-gray-500">
				Thank you for supporting our cats!
			</div>
		</div>
	</main>
</div>
