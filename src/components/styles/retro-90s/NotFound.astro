---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gray-300 font-mono text-center">

	<!-- Browser Chrome Title Bar -->
	<div class="bg-gradient-to-r from-blue-800 via-blue-600 to-blue-800 text-white px-3 py-1.5 flex items-center justify-between border-b-2 border-blue-900">
		<span class="text-xs font-bold tracking-wide">:// Error - Netscape Navigator</span>
		<div class="flex gap-1">
			<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[10px] leading-4 font-bold">_</span>
			<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[10px] leading-4 font-bold">&square;</span>
			<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[10px] leading-4 font-bold">X</span>
		</div>
	</div>

	<!-- Navigation -->
	<nav class="bg-gray-400 border-t-2 border-l-2 border-gray-200 border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 p-2 flex flex-wrap items-center justify-center gap-1.5">
		{nav.map((item: any) => (
			<a href={item.href} class="bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-700 border-r-gray-700 px-4 py-1.5 text-xs font-bold text-blue-900 no-underline uppercase tracking-wider hover:bg-gray-200 active:border-t-gray-700 active:border-l-gray-700 active:border-b-white active:border-r-white">
				{item.label}
			</a>
		))}
	</nav>

	<main class="max-w-xl mx-auto px-2 py-8">

		<!-- ===== ERROR DIALOG: Classic Windows Error Box ===== -->
		<section class="border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 bg-gray-300">
			<!-- Title bar: red-ish error styling -->
			<div class="bg-gradient-to-r from-blue-800 to-blue-600 text-white px-3 py-1.5 flex items-center justify-between">
				<span class="text-xs font-bold">Error - 404 Not Found</span>
				<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-[10px] leading-4 font-bold cursor-pointer hover:bg-gray-200">X</span>
			</div>

			<!-- Dialog body -->
			<div class="p-6">

				<!-- Error icon + message row -->
				<div class="flex items-start gap-4 mb-4">
					<!-- Classic X-in-circle error icon -->
					<div class="shrink-0">
						<div class="w-14 h-14 bg-red-600 rounded-full flex items-center justify-center border-3 border-red-800 shadow-inner">
							<span class="text-white text-3xl font-bold drop-shadow">X</span>
						</div>
					</div>

					<div class="text-left">
						<h1 class="text-4xl font-bold text-red-600 mb-1 drop-shadow">{t.notFound.title}</h1>
						<h2 class="text-lg font-bold text-blue-800 mb-2">{t.notFound.heading}</h2>
						<p class="text-xs text-gray-700 font-bold">{t.notFound.description}</p>
					</div>
				</div>

				<!-- Error details box (inset frame) -->
				<div class="bg-white border-t-2 border-l-2 border-gray-500 border-b-2 border-r-2 border-b-white border-r-white p-3 mb-4 text-left">
					<p class="text-[10px] text-gray-600 font-mono leading-relaxed">
						The page you requested could not be found on this server.<br />
						Please check the URL and try again, or use the navigation<br />
						buttons below to return to a valid page.<br /><br />
						HTTP Error 404 - File or directory not found.<br />
						Internet Information Services
					</p>
				</div>

				<!-- Sparkle divider -->
				<p class="text-xs text-fuchsia-500 mb-4">~ * ~ * ~ * ~ * ~ * ~ * ~</p>

				<!-- Action buttons: Win95 dialog-style row -->
				<div class="flex flex-col sm:flex-row gap-2 justify-center mb-4">
					<a href={`/${lang}/${style}/`} class="inline-block bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-700 border-r-gray-700 px-8 py-2 font-bold text-xs text-black no-underline text-center hover:bg-gray-200 active:border-t-gray-700 active:border-l-gray-700 active:border-b-white active:border-r-white min-w-[120px]">
						{t.notFound.backHome}
					</a>
					<a href={`/${lang}/${style}/cats`} class="inline-block bg-lime-400 border-t-2 border-l-2 border-lime-200 border-b-2 border-r-2 border-b-lime-700 border-r-lime-700 px-8 py-2 font-bold text-xs text-black no-underline text-center hover:bg-lime-300 active:border-t-lime-700 active:border-l-lime-700 active:border-b-lime-200 active:border-r-lime-200 min-w-[120px]">
						{t.notFound.meetCats}
					</a>
				</div>
			</div>
		</section>

		<!-- Error console / status badges -->
		<div class="mt-6 space-y-3">
			<div class="bg-black text-lime-400 font-mono text-[10px] px-4 py-2 border-2 border-gray-600 inline-block">
				C:\WINDOWS\&gt; HTTP 404 - File Not Found_
			</div>

			<div class="flex flex-wrap items-center justify-center gap-2">
				<span class="bg-yellow-400 text-black font-bold text-[10px] px-2 py-1 border-2 border-yellow-700 animate-pulse">!! UNDER CONSTRUCTION !!</span>
				<span class="bg-red-600 text-white font-bold text-[10px] px-2 py-1 border-2 border-red-800">Page Not Found</span>
			</div>

			<p class="text-[10px] text-gray-600 font-bold mt-4">This error has been logged. The webmaster has been notified via email.</p>
		</div>
	</main>
</div>
