---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-white font-sans">
	<!-- Navigation bar -->
	<nav class="bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-500 border-r-gray-500 p-1 flex flex-wrap items-center justify-center gap-1">
		{nav.map((item: any) => (
			<a href={item.href} class="bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 px-3 py-1 text-sm font-bold text-blue-800 no-underline hover:bg-gray-200 active:border-t-gray-600 active:border-l-gray-600 active:border-b-white active:border-r-white">
				{item.label}
			</a>
		))}
	</nav>

	<main class="max-w-xl mx-auto px-2 py-8">
		<!-- Error dialog box - Windows style -->
		<section class="border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-500 border-r-gray-500 bg-gray-300">
			<!-- Title bar -->
			<div class="bg-blue-700 text-white px-3 py-2 flex items-center justify-between">
				<span class="text-sm font-bold">Error</span>
				<span class="inline-block w-4 h-4 bg-gray-300 border-t border-l border-white border-b border-r border-b-gray-600 border-r-gray-600 text-center text-xs leading-4 font-bold">X</span>
			</div>

			<!-- Dialog body -->
			<div class="p-6 text-center">
				<!-- Error icon area -->
				<div class="flex items-center justify-center gap-4 mb-4">
					<div class="w-12 h-12 bg-red-600 rounded-full flex items-center justify-center border-2 border-red-800 shrink-0">
						<span class="text-white text-2xl font-bold">X</span>
					</div>
					<div class="text-left">
						<h1 class="text-4xl font-bold text-red-600 mb-1">{t.notFound.title}</h1>
						<h2 class="text-xl font-bold text-blue-800">{t.notFound.heading}</h2>
					</div>
				</div>

				<hr class="border-t border-gray-400 my-4" />

				<p class="text-gray-700 text-lg mb-6 font-bold">{t.notFound.description}</p>

				<!-- Sparkle divider -->
				<p class="text-fuchsia-500 text-sm mb-4">~ * ~ * ~ * ~ * ~</p>

				<!-- Action buttons - Win95 style -->
				<div class="flex flex-col sm:flex-row gap-3 justify-center">
					<a href={`/${lang}/${style}/`} class="inline-block bg-gray-300 border-t-2 border-l-2 border-white border-b-2 border-r-2 border-b-gray-600 border-r-gray-600 px-6 py-2 font-bold text-sm text-black no-underline text-center hover:bg-gray-200 active:border-t-gray-600 active:border-l-gray-600 active:border-b-white active:border-r-white">
						{t.notFound.backHome}
					</a>
					<a href={`/${lang}/${style}/cats`} class="inline-block bg-lime-400 border-t-2 border-l-2 border-lime-200 border-b-2 border-r-2 border-b-lime-700 border-r-lime-700 px-6 py-2 font-bold text-sm text-black no-underline text-center hover:bg-lime-300 active:border-t-lime-700 active:border-l-lime-700 active:border-b-lime-200 active:border-r-lime-200">
						{t.notFound.meetCats}
					</a>
				</div>
			</div>
		</section>

		<!-- Under construction -->
		<div class="text-center mt-8">
			<div class="inline-block bg-black text-lime-400 font-mono text-xs px-4 py-2 border-2 border-gray-500">
				HTTP 404 - File Not Found
			</div>
		</div>

		<div class="text-center mt-4">
			<span class="inline-block bg-yellow-300 text-black font-bold text-xs px-3 py-1 border-2 border-yellow-600">This page is under construction!</span>
		</div>
	</main>
</div>
