---
const { lang, style, nav, meta, post, otherPosts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-gray-100 font-sans">
	<!-- App Bar -->
	<nav class="bg-indigo-600 px-4 py-3 shadow-md sm:px-8">
		<div class="mx-auto flex max-w-6xl items-center justify-between">
			<span class="text-lg font-medium tracking-wide text-white">{meta.name}</span>
			<div class="flex flex-wrap items-center gap-1">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-lg px-4 py-2 text-sm font-medium text-white/90 transition-colors hover:bg-white/10 hover:text-white">
						{item.label}
					</a>
				))}
			</div>
		</div>
	</nav>

	<main class="px-4 py-10 sm:px-8">
		<div class="mx-auto max-w-3xl">
			<!-- Back Link -->
			<a href={`${_base}/${lang}/${style}/blog`} class="mb-6 inline-flex items-center gap-2 text-sm font-medium text-indigo-600 hover:text-indigo-800">
				&larr; {t.blog.backToBlog}
			</a>

			<!-- Post Header Card -->
			<div class="mb-8 overflow-hidden rounded-xl bg-white shadow-md">
				<img src={post.image} alt={post.title} class="h-56 w-full object-cover md:h-72" />
				<div class="p-6 sm:p-8">
					<div class="mb-3 flex flex-wrap items-center gap-3">
						<time datetime={post.date} class="rounded-full bg-indigo-100 px-3 py-1 text-xs font-medium text-indigo-700">{post.date}</time>
						<span class="text-sm text-gray-500">{t.blog.by} {post.author}</span>
					</div>
					<h1 class="text-2xl font-bold text-gray-800 sm:text-3xl md:text-4xl">{post.title}</h1>
				</div>
			</div>

			<!-- Content Paragraphs -->
			<div class="mb-8 rounded-xl bg-white p-6 shadow-sm sm:p-8">
				<article class="space-y-6">
					{post.content.map((paragraph: string) => (
						<p class="text-base leading-relaxed text-gray-700">{paragraph}</p>
					))}
				</article>
			</div>

			<!-- Tags as Material Chips -->
			<div class="mb-12 flex flex-wrap gap-2">
				{post.tags.map((tag: string) => (
					<span class="rounded-full bg-indigo-100 px-4 py-1.5 text-sm font-medium text-indigo-800">
						{tag}
					</span>
				))}
			</div>

			<!-- More Stories -->
			<section>
				<h2 class="mb-6 text-2xl font-bold text-gray-800">{t.blog.moreStories}</h2>
				<div class="grid gap-4 sm:grid-cols-2">
					{otherPosts.map((p: any) => (
						<a href={`${_base}/${lang}/${style}/blog/${p.slug}`} class="group rounded-xl bg-white p-5 shadow-sm transition-shadow hover:shadow-md">
							<h3 class="mb-2 text-lg font-bold text-gray-800 group-hover:text-indigo-600">{p.title}</h3>
							<p class="text-sm leading-relaxed text-gray-500">{p.excerpt}</p>
						</a>
					))}
				</div>
			</section>
		</div>
	</main>
</div>
