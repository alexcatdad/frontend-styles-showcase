---
const { lang, style, nav, meta, cats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-gray-100 font-sans">
	<!-- App Bar -->
	<nav class="bg-indigo-600 px-4 py-3 shadow-md sm:px-8">
		<div class="mx-auto flex max-w-6xl items-center justify-between">
			<span class="text-lg font-medium tracking-wide text-white">{meta.name}</span>
			<div class="flex flex-wrap items-center gap-1">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-lg px-4 py-2 text-sm font-medium text-white/90 transition-colors hover:bg-white/10 hover:text-white">
						{item.label}
					</a>
				))}
			</div>
		</div>
	</nav>

	<!-- Page Header -->
	<section class="bg-indigo-600 px-4 pb-12 pt-10 sm:px-8">
		<div class="mx-auto max-w-6xl text-center">
			<h1 class="mb-3 text-3xl font-bold text-white sm:text-4xl md:text-5xl">{t.cats.title}</h1>
			<p class="text-lg text-indigo-100">{t.cats.subtitle}</p>
		</div>
	</section>

	<!-- Cat Cards Grid -->
	<main class="px-4 py-10 sm:px-8">
		<div class="mx-auto max-w-6xl">
			<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{cats.map((cat: any) => (
					<a href={`${_base}/${lang}/${style}/cats/${cat.id}`} class="group block overflow-hidden rounded-xl bg-white shadow-md transition-shadow hover:shadow-lg">
						<img src={cat.thumbnail} alt={cat.name} class="h-48 w-full object-cover" />
						<div class="p-5">
							<div class="mb-2 flex items-center justify-between">
								<h2 class="text-xl font-bold text-gray-800 group-hover:text-indigo-600">{cat.name}</h2>
								<span class={`rounded-full px-3 py-0.5 text-xs font-medium uppercase tracking-wide ${
									cat.status === 'available'
										? 'bg-green-100 text-green-700'
										: cat.status === 'adopted'
											? 'bg-gray-100 text-gray-600'
											: 'bg-amber-100 text-amber-700'
								}`}>
									{cat.status}
								</span>
							</div>
							<p class="mb-3 text-sm text-gray-500">{cat.breed} &middot; {cat.age} &middot; {cat.gender}</p>
							<p class="text-sm leading-relaxed text-gray-600">
								{cat.description.slice(0, 100)}...
							</p>
						</div>
					</a>
				))}
			</div>
		</div>
	</main>
</div>
