---
const { lang, style, nav, meta, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-gray-100 font-sans">
	<!-- App Bar -->
	<nav class="bg-indigo-600 px-4 py-3 shadow-md sm:px-8">
		<div class="mx-auto flex max-w-6xl items-center justify-between">
			<span class="text-lg font-medium tracking-wide text-white">{meta.name}</span>
			<div class="flex flex-wrap items-center gap-1">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-lg px-4 py-2 text-sm font-medium text-white/90 transition-colors hover:bg-white/10 hover:text-white">
						{item.label}
					</a>
				))}
			</div>
		</div>
	</nav>

	<main class="flex items-center justify-center px-4 py-24 sm:px-8">
		<section class="mx-auto max-w-lg text-center">
			<p class="mb-6 text-9xl font-bold text-indigo-100">404</p>
			<h1 class="mb-4 text-3xl font-bold text-gray-800 sm:text-4xl">{t.notFound.heading}</h1>
			<p class="mb-10 text-base text-gray-500">{t.notFound.description}</p>
			<div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
				<a href={`${_base}/${lang}/${style}/`} class="rounded-lg bg-indigo-600 px-8 py-3 text-base font-medium text-white shadow-md transition-all hover:bg-indigo-700 hover:shadow-lg">
					{t.notFound.backHome}
				</a>
				<a href={`${_base}/${lang}/${style}/cats`} class="rounded-lg border-2 border-indigo-600 px-8 py-3 text-base font-medium text-indigo-600 transition-colors hover:bg-indigo-50">
					{t.notFound.meetCats}
				</a>
			</div>
		</section>
	</main>
</div>
