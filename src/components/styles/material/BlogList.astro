---
const { lang, style, nav, meta, posts, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-gray-100 font-sans">
	<!-- App Bar -->
	<nav class="bg-indigo-600 px-4 py-3 shadow-md sm:px-8">
		<div class="mx-auto flex max-w-6xl items-center justify-between">
			<span class="text-lg font-medium tracking-wide text-white">{meta.name}</span>
			<div class="flex flex-wrap items-center gap-1">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-lg px-4 py-2 text-sm font-medium text-white/90 transition-colors hover:bg-white/10 hover:text-white">
						{item.label}
					</a>
				))}
			</div>
		</div>
	</nav>

	<!-- Page Header -->
	<section class="bg-indigo-600 px-4 pb-12 pt-10 sm:px-8">
		<div class="mx-auto max-w-6xl text-center">
			<h1 class="mb-3 text-3xl font-bold text-white sm:text-4xl md:text-5xl">{t.blog.title}</h1>
			<p class="text-lg text-indigo-100">{t.blog.subtitle}</p>
		</div>
	</section>

	<!-- Blog Cards -->
	<main class="px-4 py-10 sm:px-8">
		<div class="mx-auto max-w-4xl space-y-6">
			{posts.map((post: any) => (
				<a href={`${_base}/${lang}/${style}/blog/${post.slug}`} class="group flex flex-col overflow-hidden rounded-xl bg-white shadow-md transition-shadow hover:shadow-lg sm:flex-row">
					<img src={post.image} alt={post.title} class="h-48 w-full shrink-0 object-cover sm:h-auto sm:w-48" />
					<div class="flex flex-1 flex-col p-6">
						<div class="mb-2 flex flex-wrap items-center gap-3">
							<time datetime={post.date} class="text-xs font-medium text-gray-400">{post.date}</time>
							<span class="text-xs text-gray-400">{t.blog.by} {post.author}</span>
						</div>
						<h2 class="mb-2 text-xl font-bold text-gray-800 group-hover:text-indigo-600">{post.title}</h2>
						<p class="mb-4 text-sm leading-relaxed text-gray-600">{post.excerpt}</p>
						<div class="mt-auto flex flex-wrap gap-2">
							{post.tags.map((tag: string) => (
								<span class="rounded-full bg-indigo-50 px-3 py-0.5 text-xs font-medium text-indigo-600">
									{tag}
								</span>
							))}
						</div>
					</div>
				</a>
			))}
		</div>
	</main>
</div>
