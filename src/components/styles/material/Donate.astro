---
const { lang, style, nav, meta, monthlyTiers, oneTimeTiers, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<div class="min-h-screen bg-gray-100 font-sans">
	<!-- App Bar -->
	<nav class="bg-indigo-600 px-4 py-3 shadow-md sm:px-8">
		<div class="mx-auto flex max-w-6xl items-center justify-between">
			<span class="text-lg font-medium tracking-wide text-white">{meta.name}</span>
			<div class="flex flex-wrap items-center gap-1">
				{nav.map((item: any) => (
					<a href={item.href} class="rounded-lg px-4 py-2 text-sm font-medium text-white/90 transition-colors hover:bg-white/10 hover:text-white">
						{item.label}
					</a>
				))}
			</div>
		</div>
	</nav>

	<!-- Page Header -->
	<section class="bg-indigo-600 px-4 pb-12 pt-10 sm:px-8">
		<div class="mx-auto max-w-6xl text-center">
			<h1 class="mb-3 text-3xl font-bold text-white sm:text-4xl md:text-5xl">{t.donate.title}</h1>
			<p class="text-lg text-indigo-100">{t.donate.subtitle}</p>
		</div>
	</section>

	<main class="px-4 py-10 sm:px-8">
		<div class="mx-auto max-w-6xl">
			<!-- Monthly Tiers -->
			<div class="mb-6">
				<div class="mb-2 flex items-center gap-3">
					<div class="h-1 w-8 rounded-full bg-indigo-600"></div>
					<span class="text-sm font-medium tracking-wide text-indigo-600 uppercase">{t.donate.monthly}</span>
				</div>
			</div>
			<div class="mb-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{monthlyTiers.map((tier: any) => (
					<div class={`relative rounded-xl p-6 shadow-md transition-shadow hover:shadow-lg sm:p-8 ${
						tier.highlighted
							? 'bg-indigo-600 text-white'
							: 'bg-white'
					}`}>
						{tier.highlighted && (
							<span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-pink-500 px-4 py-1 text-xs font-medium text-white shadow-sm">
								{t.donate.mostPopular}
							</span>
						)}
						<p class={`mb-1 text-3xl font-bold ${tier.highlighted ? 'text-white' : 'text-indigo-600'}`}>
							${tier.amount}
						</p>
						<p class={`mb-1 text-xs font-medium uppercase tracking-wide ${tier.highlighted ? 'text-indigo-200' : 'text-gray-400'}`}>
							{t.donate.perMonth}
						</p>
						<h3 class={`mb-2 text-lg font-bold ${tier.highlighted ? 'text-white' : 'text-gray-800'}`}>
							{tier.name}
						</h3>
						<p class={`mb-5 text-sm ${tier.highlighted ? 'text-indigo-200' : 'text-gray-500'}`}>
							{tier.description}
						</p>
						<ul class="mb-6 space-y-2">
							{tier.perks.map((perk: string) => (
								<li class={`flex items-start gap-2 text-sm ${tier.highlighted ? 'text-indigo-100' : 'text-gray-600'}`}>
									<span class={`mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full text-xs ${
										tier.highlighted
											? 'bg-white/20 text-white'
											: 'bg-indigo-100 text-indigo-600'
									}`}>&#10003;</span>
									{perk}
								</li>
							))}
						</ul>
						<button type="button" class={`w-full rounded-lg px-6 py-3 text-sm font-medium transition-colors ${
							tier.highlighted
								? 'bg-white text-indigo-600 hover:bg-indigo-50'
								: 'bg-indigo-600 text-white hover:bg-indigo-700'
						}`}>
							{t.donate.choose} {tier.name}
						</button>
					</div>
				))}
			</div>

			<!-- One-Time Tiers -->
			<div class="mb-6">
				<div class="mb-2 flex items-center gap-3">
					<div class="h-1 w-8 rounded-full bg-pink-500"></div>
					<span class="text-sm font-medium tracking-wide text-pink-500 uppercase">{t.donate.oneTime}</span>
				</div>
			</div>
			<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{oneTimeTiers.map((tier: any) => (
					<div class={`relative rounded-xl p-6 shadow-md transition-shadow hover:shadow-lg sm:p-8 ${
						tier.highlighted
							? 'bg-pink-500 text-white'
							: 'bg-white'
					}`}>
						{tier.highlighted && (
							<span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-indigo-600 px-4 py-1 text-xs font-medium text-white shadow-sm">
								{t.donate.greatestImpact}
							</span>
						)}
						<p class={`mb-1 text-3xl font-bold ${tier.highlighted ? 'text-white' : 'text-pink-500'}`}>
							${tier.amount}
						</p>
						<h3 class={`mb-2 text-lg font-bold ${tier.highlighted ? 'text-white' : 'text-gray-800'}`}>
							{tier.name}
						</h3>
						<p class={`mb-5 text-sm ${tier.highlighted ? 'text-pink-100' : 'text-gray-500'}`}>
							{tier.description}
						</p>
						<ul class="mb-6 space-y-2">
							{tier.perks.map((perk: string) => (
								<li class={`flex items-start gap-2 text-sm ${tier.highlighted ? 'text-pink-100' : 'text-gray-600'}`}>
									<span class={`mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full text-xs ${
										tier.highlighted
											? 'bg-white/20 text-white'
											: 'bg-pink-100 text-pink-500'
									}`}>&#10003;</span>
									{perk}
								</li>
							))}
						</ul>
						<button type="button" class={`w-full rounded-lg px-6 py-3 text-sm font-medium transition-colors ${
							tier.highlighted
								? 'bg-white text-pink-500 hover:bg-pink-50'
								: 'bg-pink-500 text-white hover:bg-pink-600'
						}`}>
							{t.donate.give} ${tier.amount}
						</button>
					</div>
				))}
			</div>
		</div>
	</main>
</div>
