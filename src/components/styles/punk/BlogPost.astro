---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-mono selection:bg-pink-500 selection:text-white overflow-x-hidden">

	<!-- NAV: scattered scraps -->
	<nav class="relative bg-black px-3 py-4 md:py-5 border-b-[6px] border-yellow-400 overflow-visible">
		<div class="flex flex-wrap items-start gap-x-2 gap-y-3 md:gap-x-4">
			{nav.map((item: any, i: number) => (
				<a
					href={item.href}
					class:list={[
						"inline-block uppercase font-black no-underline hover:scale-110 transition-transform relative",
						i % 5 === 0 ? "text-yellow-300 text-xs tracking-[0.3em] -rotate-3 bg-pink-600/30 px-2 py-1" :
						i % 5 === 1 ? "text-pink-400 text-lg tracking-widest rotate-2 border-b-2 border-pink-400 px-1" :
						i % 5 === 2 ? "text-orange-400 text-[10px] -rotate-1 bg-yellow-400/20 px-3 py-2 border border-orange-400" :
						i % 5 === 3 ? "text-white text-sm rotate-3 underline decoration-yellow-400 decoration-wavy px-1" :
						"text-yellow-400 text-base -rotate-2 border-2 border-yellow-400 px-2 py-0.5",
						i === 0 ? "mt-2" : i === 2 ? "mt-4" : i === 3 ? "-mt-1" : "",
					]}
				>
					{i % 4 === 0 ? "★ " : i % 4 === 1 ? "✕ " : i % 4 === 2 ? "→ " : "‼ "}{item.label}
				</a>
			))}
		</div>
		<div class="absolute -bottom-2 left-8 w-24 h-3 bg-pink-500/70 rotate-2"></div>
		<div class="absolute -bottom-1 right-12 w-16 h-2 bg-yellow-400/60 -rotate-3"></div>
	</nav>

	<main class="px-3 py-8 md:py-12">
		<div class="max-w-3xl mx-auto">
			<!-- Back link -->
			<a
				href={`/${lang}/${style}/blog`}
				class="inline-block bg-black text-yellow-400 font-black uppercase text-[10px] md:text-xs px-3 py-1.5 border-2 border-yellow-400 rotate-1 hover:rotate-0 transition-transform no-underline mb-10 shadow-[2px_2px_0_rgba(234,179,8,0.4)]"
			>
				← {t.blog.backToBlog}
			</a>

			<article>
				<!-- Header: assembled from separate pieces -->
				<header class="mb-12 relative">
					<!-- date: rubber stamp -->
					<time
						datetime={post.date}
						class="inline-block bg-orange-500 text-white text-[10px] md:text-xs font-black uppercase px-3 py-1.5 -rotate-3 mb-5 border-2 border-black shadow-[2px_2px_0_black]"
					>
						{post.date}
					</time>

					<!-- title: poster-scale -->
					<h1 class="text-4xl md:text-7xl lg:text-8xl font-black uppercase leading-[0.85] -rotate-1 mb-5 relative">
						<span class="bg-yellow-400 text-black px-4 py-2 border-[6px] border-black inline-block shadow-[6px_6px_0_black]">{post.title}</span>
						<div class="absolute -top-2 left-12 w-16 h-3 bg-pink-500/50 rotate-6"></div>
					</h1>

					<!-- author: credited on a separate slip -->
					<div class="inline-block rotate-2 ml-4">
						<span class="bg-pink-500 text-white font-black uppercase text-xs md:text-sm px-4 py-1.5 border-2 border-black shadow-[2px_2px_0_black] inline-block">
							★ {t.blog.by} {post.author}
						</span>
					</div>

					<!-- tags: scattered stickers -->
					<div class="flex flex-wrap gap-2 mt-6">
						{post.tags.map((tag: string, i: number) => (
							<span
								class:list={[
									"text-[10px] md:text-xs font-black uppercase px-2 py-1 border-2 border-black shadow-[1px_1px_0_black]",
									i % 4 === 0 ? "bg-yellow-400 -rotate-2" :
									i % 4 === 1 ? "bg-pink-500 text-white rotate-3" :
									i % 4 === 2 ? "bg-orange-500 text-white -rotate-1" :
									"bg-black text-white rotate-2",
								]}
							>
								{tag}
							</span>
						))}
					</div>
				</header>

				<!-- Header image: pasted in, taped down -->
				<div class="relative -rotate-1 mb-10">
					<img src={post.image} alt={post.title} class="w-full h-48 md:h-72 object-cover border-[6px] border-black shadow-[6px_6px_0_black]" />
					<div class="absolute -top-2 left-10 w-16 h-3 bg-yellow-400/50 rotate-6"></div>
					<div class="absolute -bottom-1.5 right-8 w-14 h-2.5 bg-pink-500/40 -rotate-3"></div>
				</div>

				<!-- Content: paragraphs as pasted clippings, each at slightly different angles -->
				<div class="space-y-5 md:space-y-6">
					{post.content.map((paragraph: string, i: number) => (
						<div
							class:list={[
								"relative p-4 md:p-5 border-2 border-black",
								i % 6 === 0 ? "bg-gray-100 -rotate-[0.7deg] shadow-[3px_3px_0_black] md:mr-8" :
								i % 6 === 1 ? "bg-yellow-50 rotate-[0.5deg] shadow-[-2px_3px_0_black] md:ml-6 border-l-4 border-l-yellow-400" :
								i % 6 === 2 ? "bg-pink-50 -rotate-[0.3deg] shadow-[2px_4px_0_black] md:mr-12 border-r-4 border-r-pink-500" :
								i % 6 === 3 ? "bg-white rotate-[0.8deg] shadow-[4px_2px_0_black] md:ml-10 border-4" :
								i % 6 === 4 ? "bg-orange-50 -rotate-[0.5deg] shadow-[-3px_3px_0_black] md:mr-4 border-b-4 border-b-orange-500" :
								"bg-gray-50 rotate-[0.4deg] shadow-[3px_3px_0_black] md:ml-4 border-t-4 border-t-black",
							]}
						>
							<p class="text-sm md:text-base leading-relaxed font-medium">{paragraph}</p>
							{i % 4 === 0 && (
								<div class="absolute -top-1.5 left-8 w-12 h-2 bg-yellow-400/50 -rotate-6"></div>
							)}
							{i % 4 === 2 && (
								<div class="absolute -bottom-1 right-6 w-10 h-1.5 bg-pink-500/40 rotate-3"></div>
							)}
						</div>
					))}
				</div>
			</article>

			<!-- More stories: pasted scraps at the bottom -->
			<section class="mt-20 pt-8 border-t-[6px] border-black relative">
				<div class="absolute top-0 left-16 w-20 h-3 bg-yellow-400/40 rotate-2"></div>
				<h2 class="text-xl md:text-4xl font-black uppercase -rotate-1 inline-block bg-black text-pink-400 px-4 py-2 mb-10 border-2 border-pink-500 shadow-[3px_3px_0_rgba(236,72,153,0.4)]">
					→ {t.blog.moreStories} ★
				</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-5">
					{otherPosts.map((p: any, i: number) => (
						<a
							href={`/${lang}/${style}/blog/${p.slug}`}
							class:list={[
								"relative block border-4 border-black p-4 no-underline text-black hover:scale-105 transition-transform shadow-[3px_3px_0_black]",
								i % 4 === 0 ? "rotate-1 bg-yellow-200 hover:bg-yellow-300" :
								i % 4 === 1 ? "-rotate-2 bg-pink-200 hover:bg-pink-300 mt-3" :
								i % 4 === 2 ? "rotate-2 bg-orange-200 hover:bg-orange-300 -mt-1" :
								"-rotate-1 bg-white hover:bg-gray-100 mt-2",
							]}
						>
							<h3 class="text-base md:text-xl font-black uppercase mb-2">{i % 2 === 0 ? "✕ " : "→ "}{p.title}</h3>
							<p class="text-xs leading-relaxed">{p.excerpt}</p>
							{i % 2 === 0 && (
								<div class="absolute -top-1 left-6 w-10 h-1.5 bg-orange-500/40 rotate-3"></div>
							)}
						</a>
					))}
				</div>
			</section>
		</div>
	</main>
</div>
