---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-mono selection:bg-pink-500 selection:text-white overflow-x-hidden">

	<!-- NAV: scattered scraps -->
	<nav class="relative bg-black px-3 py-4 md:py-5 border-b-[6px] border-yellow-400 overflow-visible">
		<div class="flex flex-wrap items-start gap-x-2 gap-y-3 md:gap-x-4">
			{nav.map((item: any, i: number) => (
				<a
					href={item.href}
					class:list={[
						"inline-block uppercase font-black no-underline hover:scale-110 transition-transform relative",
						i % 5 === 0 ? "text-yellow-300 text-xs tracking-[0.3em] -rotate-3 bg-pink-600/30 px-2 py-1" :
						i % 5 === 1 ? "text-pink-400 text-lg tracking-widest rotate-2 border-b-2 border-pink-400 px-1" :
						i % 5 === 2 ? "text-orange-400 text-[10px] -rotate-1 bg-yellow-400/20 px-3 py-2 border border-orange-400" :
						i % 5 === 3 ? "text-white text-sm rotate-3 underline decoration-yellow-400 decoration-wavy px-1" :
						"text-yellow-400 text-base -rotate-2 border-2 border-yellow-400 px-2 py-0.5",
						i === 0 ? "mt-2" : i === 2 ? "mt-4" : i === 3 ? "-mt-1" : "",
					]}
				>
					{i % 4 === 0 ? "★ " : i % 4 === 1 ? "✕ " : i % 4 === 2 ? "→ " : "‼ "}{item.label}
				</a>
			))}
		</div>
		<div class="absolute -bottom-2 left-8 w-24 h-3 bg-pink-500/70 rotate-2"></div>
		<div class="absolute -bottom-1 right-12 w-16 h-2 bg-yellow-400/60 -rotate-3"></div>
	</nav>

	<main class="px-3 py-8 md:py-12">
		<div class="max-w-6xl mx-auto">
			<!-- Header: hand-scrawled collection jar label -->
			<div class="mb-12 md:mb-16 relative">
				<h1 class="text-4xl md:text-7xl lg:text-8xl font-black uppercase -rotate-2 inline-block bg-pink-500 text-white px-5 py-3 border-[6px] border-black shadow-[8px_8px_0_black]">
					‼ {t.donate.title} ‼
				</h1>
				<div class="absolute -top-2 left-20 w-16 h-3 bg-yellow-400/60 rotate-6 hidden md:block"></div>
				<p class="text-base md:text-2xl font-black mt-6 rotate-1 bg-yellow-400 text-black inline-block px-4 py-2 border-4 border-black ml-4 md:ml-12 shadow-[3px_3px_0_black]">
					★ {t.donate.subtitle}
				</p>
			</div>

			<!-- MONTHLY: collection jar section -->
			<section class="mb-20 relative">
				<!-- section label: taped on -->
				<div class="relative inline-block mb-10">
					<h2 class="text-xl md:text-4xl font-black uppercase rotate-2 bg-black text-yellow-400 px-4 py-2 border-2 border-yellow-400 shadow-[4px_4px_0_rgba(234,179,8,0.4)]">
						★ {t.donate.monthly} ★
					</h2>
					<div class="absolute -top-1.5 right-6 w-12 h-2.5 bg-pink-500/50 -rotate-6"></div>
				</div>

				<!-- jar outline: the tiers sit inside a rough container -->
				<div class="relative border-4 border-dashed border-black/30 p-4 md:p-6 -rotate-[0.3deg]">
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
						{monthlyTiers.map((tier: any, i: number) => (
							<div
								class:list={[
									"relative border-4 border-black p-4 md:p-6",
									tier.highlighted
										? "bg-pink-500 text-white -rotate-1 scale-105 z-10 border-[6px] border-yellow-400 shadow-[6px_6px_0_black]"
										: i % 3 === 0
											? "bg-yellow-100 rotate-2 shadow-[4px_4px_0_black]"
											: i % 3 === 1
												? "bg-gray-100 -rotate-1 mt-3 shadow-[-3px_3px_0_black]"
												: "bg-orange-50 rotate-1 -mt-2 shadow-[3px_5px_0_black]",
								]}
							>
								{/* tape strips */}
								{tier.highlighted ? (
									<>
										<div class="absolute -top-2 left-8 w-16 h-3 bg-yellow-400/70 -rotate-6"></div>
										<div class="absolute -top-1.5 right-6 w-12 h-2.5 bg-orange-500/50 rotate-3"></div>
									</>
								) : i % 2 === 0 ? (
									<div class="absolute -top-1.5 left-6 w-12 h-2 bg-pink-500/40 rotate-3"></div>
								) : (
									<div class="absolute -top-1 right-4 w-10 h-1.5 bg-yellow-400/50 -rotate-3"></div>
								)}

								{tier.highlighted && (
									<span class="absolute -top-5 -right-3 bg-yellow-400 text-black font-black uppercase text-[10px] px-3 py-1.5 border-2 border-black rotate-6 shadow-[2px_2px_0_black]">
										★ {t.donate.mostPopular} ★
									</span>
								)}

								<!-- tier name: hand-scrawled label -->
								<h3 class:list={[
									"font-black uppercase mb-2",
									tier.highlighted ? "text-2xl md:text-3xl" : "text-xl md:text-2xl",
								]}>{tier.name}</h3>

								<!-- amount: stamped number -->
								<p class="mb-3">
									<span class:list={[
										"font-black leading-none",
										tier.highlighted ? "text-5xl md:text-7xl" : "text-4xl md:text-5xl",
									]}>${tier.amount}</span>
									<span class="text-[10px] font-black uppercase tracking-wider ml-1">{t.donate.perMonth}</span>
								</p>

								<p class="text-xs md:text-sm font-bold mb-4 border-b-2 border-current pb-3">{tier.description}</p>

								<ul class="space-y-1.5 mb-6">
									{tier.perks.map((perk: string, j: number) => (
										<li class:list={[
											"text-xs font-bold",
											j % 2 === 0 ? "" : "ml-2",
										]}>{j % 2 === 0 ? "✕" : "★"} {perk}</li>
									))}
								</ul>

								<button
									type="button"
									class:list={[
										"w-full font-black uppercase text-xs md:text-sm px-4 py-3 border-4 border-black cursor-pointer hover:scale-105 transition-transform shadow-[3px_3px_0_black] hover:shadow-[1px_1px_0_black] hover:translate-x-0.5 hover:translate-y-0.5",
										tier.highlighted
											? "bg-yellow-400 text-black"
											: "bg-black text-white",
									]}
								>
									→ {t.donate.choose} {tier.name}
								</button>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- ONE-TIME: separate collection, different vibe -->
			<section class="relative">
				<div class="relative inline-block mb-10">
					<h2 class="text-xl md:text-4xl font-black uppercase -rotate-1 bg-orange-500 text-white px-4 py-2 border-4 border-black shadow-[4px_4px_0_black]">
						→ {t.donate.oneTime} ‼
					</h2>
					<div class="absolute -top-1.5 left-10 w-14 h-2.5 bg-yellow-400/50 rotate-6"></div>
				</div>

				<div class="relative border-4 border-dashed border-black/30 p-4 md:p-6 rotate-[0.3deg]">
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
						{oneTimeTiers.map((tier: any, i: number) => (
							<div
								class:list={[
									"relative border-4 border-black p-4 md:p-6",
									tier.highlighted
										? "bg-orange-500 text-white rotate-1 scale-105 z-10 border-[6px] border-yellow-400 shadow-[6px_6px_0_black]"
										: i % 3 === 0
											? "bg-pink-100 -rotate-2 shadow-[-3px_4px_0_black]"
											: i % 3 === 1
												? "bg-yellow-100 rotate-2 mt-4 shadow-[4px_3px_0_black]"
												: "bg-white -rotate-1 -mt-1 shadow-[3px_4px_0_black]",
								]}
							>
								{tier.highlighted ? (
									<>
										<div class="absolute -top-2 right-8 w-14 h-3 bg-pink-500/60 rotate-6"></div>
										<div class="absolute -bottom-1.5 left-6 w-12 h-2 bg-yellow-400/50 -rotate-3"></div>
									</>
								) : i % 2 === 0 ? (
									<div class="absolute -top-1 left-8 w-10 h-1.5 bg-orange-500/40 -rotate-3"></div>
								) : (
									<div class="absolute -top-1.5 right-6 w-12 h-2 bg-pink-500/40 rotate-6"></div>
								)}

								{tier.highlighted && (
									<span class="absolute -top-5 -left-3 bg-yellow-400 text-black font-black uppercase text-[10px] px-3 py-1.5 border-2 border-black -rotate-6 shadow-[2px_2px_0_black]">
										‼ {t.donate.greatestImpact} ‼
									</span>
								)}

								<h3 class:list={[
									"font-black uppercase mb-2",
									tier.highlighted ? "text-2xl md:text-3xl" : "text-xl md:text-2xl",
								]}>{tier.name}</h3>

								<p class="mb-3">
									<span class:list={[
										"font-black leading-none",
										tier.highlighted ? "text-5xl md:text-7xl" : "text-4xl md:text-5xl",
									]}>${tier.amount}</span>
								</p>

								<p class="text-xs md:text-sm font-bold mb-4 border-b-2 border-current pb-3">{tier.description}</p>

								<ul class="space-y-1.5 mb-6">
									{tier.perks.map((perk: string, j: number) => (
										<li class:list={[
											"text-xs font-bold",
											j % 2 === 0 ? "" : "ml-2",
										]}>{j % 2 === 0 ? "★" : "✕"} {perk}</li>
									))}
								</ul>

								<button
									type="button"
									class:list={[
										"w-full font-black uppercase text-xs md:text-sm px-4 py-3 border-4 border-black cursor-pointer hover:scale-105 transition-transform shadow-[3px_3px_0_black] hover:shadow-[1px_1px_0_black] hover:translate-x-0.5 hover:translate-y-0.5",
										tier.highlighted
											? "bg-yellow-400 text-black"
											: "bg-black text-white",
									]}
								>
									→ {t.donate.give} ${tier.amount}
								</button>
							</div>
						))}
					</div>
				</div>
			</section>
		</div>
	</main>
</div>
