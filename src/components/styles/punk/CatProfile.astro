---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-white text-black font-mono selection:bg-pink-500 selection:text-white overflow-x-hidden">

	<!-- NAV: scattered scraps -->
	<nav class="relative bg-black px-3 py-4 md:py-5 border-b-[6px] border-yellow-400 overflow-visible">
		<div class="flex flex-wrap items-start gap-x-2 gap-y-3 md:gap-x-4">
			{nav.map((item: any, i: number) => (
				<a
					href={item.href}
					class:list={[
						"inline-block uppercase font-black no-underline hover:scale-110 transition-transform relative",
						i % 5 === 0 ? "text-yellow-300 text-xs tracking-[0.3em] -rotate-3 bg-pink-600/30 px-2 py-1" :
						i % 5 === 1 ? "text-pink-400 text-lg tracking-widest rotate-2 border-b-2 border-pink-400 px-1" :
						i % 5 === 2 ? "text-orange-400 text-[10px] -rotate-1 bg-yellow-400/20 px-3 py-2 border border-orange-400" :
						i % 5 === 3 ? "text-white text-sm rotate-3 underline decoration-yellow-400 decoration-wavy px-1" :
						"text-yellow-400 text-base -rotate-2 border-2 border-yellow-400 px-2 py-0.5",
						i === 0 ? "mt-2" : i === 2 ? "mt-4" : i === 3 ? "-mt-1" : "",
					]}
				>
					{i % 4 === 0 ? "★ " : i % 4 === 1 ? "✕ " : i % 4 === 2 ? "→ " : "‼ "}{item.label}
				</a>
			))}
		</div>
		<div class="absolute -bottom-2 left-8 w-24 h-3 bg-pink-500/70 rotate-2"></div>
		<div class="absolute -bottom-1 right-12 w-16 h-2 bg-yellow-400/60 -rotate-3"></div>
	</nav>

	<main class="px-3 py-8 md:py-12">
		<div class="max-w-4xl mx-auto">
			<!-- Back link: small torn scrap -->
			<a
				href={`${_base}/${lang}/${style}/cats`}
				class="inline-block bg-black text-yellow-400 font-black uppercase text-[10px] md:text-xs px-3 py-1.5 border-2 border-yellow-400 -rotate-2 hover:rotate-0 transition-transform no-underline mb-10 shadow-[2px_2px_0_rgba(234,179,8,0.4)]"
			>
				← {t.cats.backToAll}
			</a>

			<article class="relative">
				<!-- Cat name: MASSIVE, like a gig poster headline -->
				<div class="relative mb-10">
					<h1 class="text-5xl md:text-8xl lg:text-[10rem] font-black uppercase leading-[0.8] -rotate-3 inline-block">
						<span class="bg-pink-500 text-white px-4 md:px-6 py-2 border-[6px] border-black shadow-[8px_8px_0_black] inline-block">{cat.name}</span>
					</h1>
					<!-- tape on name -->
					<div class="absolute -top-2 left-16 w-20 h-3 bg-yellow-400/60 rotate-6"></div>
					<!-- decorative marks -->
					<div class="absolute -bottom-4 right-0 md:right-20 text-4xl md:text-6xl font-black text-black/10 select-none rotate-12">★★</div>
				</div>

				<!-- Cat photo: photocopied polaroid, taped on crooked -->
				<div class="relative -rotate-2 mb-10 inline-block">
					<div class="border-[6px] border-black bg-yellow-100 p-3 shadow-[8px_8px_0_black]">
						<img src={cat.image} alt={cat.name} class="w-56 h-56 md:w-80 md:h-80 object-cover grayscale-[10%]" />
					</div>
					<div class="absolute -top-2 left-10 w-16 h-3 bg-pink-500/50 rotate-6"></div>
					<div class="absolute -bottom-1.5 right-6 w-12 h-2.5 bg-yellow-400/60 -rotate-3"></div>
				</div>

				<!-- Details: scattered info cards, each a different scrap -->
				<dl class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4 mb-10">
					<div class="relative border-4 border-black bg-yellow-400 p-3 md:p-4 -rotate-2 shadow-[3px_3px_0_black]">
						<dt class="text-[9px] md:text-[10px] font-black uppercase tracking-[0.3em] opacity-70">{t.cats.breed}</dt>
						<dd class="text-base md:text-xl font-black mt-0.5">{cat.breed}</dd>
						<div class="absolute -top-1 right-4 w-8 h-1.5 bg-pink-500/50 rotate-6"></div>
					</div>
					<div class="border-[6px] border-pink-500 bg-pink-500 text-white p-3 md:p-4 rotate-3 mt-3 shadow-[-2px_4px_0_rgba(0,0,0,0.4)]">
						<dt class="text-[9px] md:text-[10px] font-black uppercase tracking-[0.3em] opacity-70">{t.cats.age}</dt>
						<dd class="text-2xl md:text-3xl font-black mt-0.5">{cat.age}</dd>
					</div>
					<div class="relative border-4 border-black bg-orange-500 text-white p-3 md:p-4 -rotate-1 -mt-1 shadow-[4px_2px_0_black]">
						<dt class="text-[9px] md:text-[10px] font-black uppercase tracking-[0.3em] opacity-70">{t.cats.gender}</dt>
						<dd class="text-base md:text-xl font-black mt-0.5">{cat.gender}</dd>
						<div class="absolute -bottom-1 left-6 w-10 h-1.5 bg-yellow-400/50 -rotate-3"></div>
					</div>
					<div class="border-4 border-black bg-white p-3 md:p-4 rotate-2 mt-2 shadow-[3px_3px_0_black]">
						<dt class="text-[9px] md:text-[10px] font-black uppercase tracking-[0.3em] opacity-50">{t.cats.color}</dt>
						<dd class="text-base md:text-xl font-black mt-0.5">{cat.color}</dd>
					</div>
					<div class="relative border-4 border-yellow-400 bg-gray-100 p-3 md:p-4 -rotate-3 shadow-[-3px_3px_0_black]">
						<dt class="text-[9px] md:text-[10px] font-black uppercase tracking-[0.3em] opacity-50">{t.cats.arrived}</dt>
						<dd class="text-base md:text-lg font-black mt-0.5">{cat.arrivalDate}</dd>
					</div>
					<div class="border-4 border-black bg-yellow-300 p-3 md:p-4 rotate-1 mt-4 shadow-[2px_4px_0_black]">
						<dt class="text-[9px] md:text-[10px] font-black uppercase tracking-[0.3em] opacity-50">{t.cats.status}</dt>
						<dd class="text-lg md:text-2xl font-black mt-0.5 uppercase">{cat.status}</dd>
					</div>
				</dl>

				<!-- Personality: sticker explosion -->
				<div class="flex flex-wrap gap-2 md:gap-3 mb-10">
					{cat.personality.map((trait: string, i: number) => (
						<span
							class:list={[
								"font-black uppercase px-3 py-1.5 border-4 border-black shadow-[2px_2px_0_black]",
								i % 5 === 0 ? "bg-yellow-400 -rotate-3 text-sm" :
								i % 5 === 1 ? "bg-pink-500 text-white rotate-2 text-base" :
								i % 5 === 2 ? "bg-orange-500 text-white -rotate-1 text-xs" :
								i % 5 === 3 ? "bg-black text-yellow-400 rotate-3 text-sm" :
								"bg-white -rotate-2 text-base border-pink-500",
							]}
						>
							{i % 3 === 0 ? "★ " : i % 3 === 1 ? "✕ " : "→ "}{trait}
						</span>
					))}
				</div>

				<!-- Description: photocopied page, slightly crooked -->
				<div class="relative rotate-1 mb-12 md:ml-4 md:mr-8">
					<div class="border-4 border-black bg-gray-100 p-5 md:p-8 shadow-[6px_6px_0_black]">
						<p class="text-sm md:text-lg leading-relaxed font-bold">{cat.description}</p>
					</div>
					<!-- tape holding it down -->
					<div class="absolute -top-2 left-10 w-16 h-3 bg-yellow-400/60 -rotate-6"></div>
					<div class="absolute -top-1.5 right-8 w-12 h-2.5 bg-pink-500/50 rotate-3"></div>
					<div class="absolute -bottom-1.5 left-1/3 w-14 h-2 bg-orange-500/40 rotate-1"></div>
				</div>

				<!-- ADOPT CTA: huge, unmissable, like a show flyer -->
				<div class="relative inline-block -rotate-2 hover:rotate-0 transition-transform">
					<a
						href={`${_base}/${lang}/${style}/auth`}
						class="inline-block bg-pink-500 text-white font-black uppercase text-xl md:text-3xl px-8 md:px-12 py-4 md:py-6 border-[6px] border-black shadow-[8px_8px_0_black] no-underline hover:shadow-[4px_4px_0_black] hover:translate-x-1 hover:translate-y-1 transition-all"
					>
						‼ {t.cats.adopt} {cat.name} ‼
					</a>
					<div class="absolute -top-2 right-8 w-14 h-3 bg-yellow-400/70 rotate-6"></div>
				</div>
			</article>

			<!-- OTHER CATS: small pasted clippings -->
			<section class="mt-20 pt-8 border-t-[6px] border-black relative">
				<div class="absolute top-0 left-20 w-20 h-3 bg-pink-500/40 -rotate-2"></div>
				<h2 class="text-xl md:text-4xl font-black uppercase rotate-2 inline-block bg-black text-yellow-400 px-4 py-2 mb-10 border-2 border-yellow-400 shadow-[3px_3px_0_rgba(234,179,8,0.4)]">
					→ {t.cats.otherCats} ★
				</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-5">
					{otherCats.map((c: any, i: number) => (
						<a
							href={`${_base}/${lang}/${style}/cats/${c.id}`}
							class:list={[
								"relative block border-4 border-black p-4 no-underline text-black hover:scale-105 transition-transform shadow-[3px_3px_0_black]",
								i % 4 === 0 ? "-rotate-2 bg-yellow-200 hover:bg-yellow-300" :
								i % 4 === 1 ? "rotate-3 bg-pink-200 hover:bg-pink-300 mt-3" :
								i % 4 === 2 ? "-rotate-1 bg-orange-200 hover:bg-orange-300 -mt-1" :
								"rotate-2 bg-white hover:bg-gray-100 mt-2",
							]}
						>
							<h3 class="text-lg md:text-xl font-black uppercase">{c.name}</h3>
							<p class="text-[10px] font-black uppercase tracking-wider mt-1">{c.breed} ✕ {c.age}</p>
							{i % 2 === 0 && (
								<div class="absolute -top-1 left-4 w-10 h-1.5 bg-pink-500/50 rotate-3"></div>
							)}
						</a>
					))}
				</div>
			</section>
		</div>
	</main>
</div>
