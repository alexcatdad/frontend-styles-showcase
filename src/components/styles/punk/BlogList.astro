---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-mono selection:bg-pink-500 selection:text-white overflow-x-hidden">

	<!-- NAV: scattered scraps -->
	<nav class="relative bg-black px-3 py-4 md:py-5 border-b-[6px] border-yellow-400 overflow-visible">
		<div class="flex flex-wrap items-start gap-x-2 gap-y-3 md:gap-x-4">
			{nav.map((item: any, i: number) => (
				<a
					href={item.href}
					class:list={[
						"inline-block uppercase font-black no-underline hover:scale-110 transition-transform relative",
						i % 5 === 0 ? "text-yellow-300 text-xs tracking-[0.3em] -rotate-3 bg-pink-600/30 px-2 py-1" :
						i % 5 === 1 ? "text-pink-400 text-lg tracking-widest rotate-2 border-b-2 border-pink-400 px-1" :
						i % 5 === 2 ? "text-orange-400 text-[10px] -rotate-1 bg-yellow-400/20 px-3 py-2 border border-orange-400" :
						i % 5 === 3 ? "text-white text-sm rotate-3 underline decoration-yellow-400 decoration-wavy px-1" :
						"text-yellow-400 text-base -rotate-2 border-2 border-yellow-400 px-2 py-0.5",
						i === 0 ? "mt-2" : i === 2 ? "mt-4" : i === 3 ? "-mt-1" : "",
					]}
				>
					{i % 4 === 0 ? "★ " : i % 4 === 1 ? "✕ " : i % 4 === 2 ? "→ " : "‼ "}{item.label}
				</a>
			))}
		</div>
		<div class="absolute -bottom-2 left-8 w-24 h-3 bg-pink-500/70 rotate-2"></div>
		<div class="absolute -bottom-1 right-12 w-16 h-2 bg-yellow-400/60 -rotate-3"></div>
	</nav>

	<main class="px-3 py-8 md:py-12">
		<div class="max-w-5xl mx-auto">
			<!-- Header: pasted on at an angle -->
			<div class="mb-12 md:mb-16 relative">
				<h1 class="text-4xl md:text-7xl lg:text-8xl font-black uppercase rotate-1 inline-block bg-yellow-400 text-black px-5 py-3 border-4 border-black shadow-[6px_6px_0_black]">
					✕ {t.blog.title}
				</h1>
				<p class="text-base md:text-2xl font-black mt-5 -rotate-2 bg-black text-pink-400 inline-block px-4 py-2 border-2 border-pink-500 ml-2 md:ml-8 shadow-[3px_3px_0_rgba(236,72,153,0.5)]">
					★ {t.blog.subtitle}
				</p>
				<div class="absolute -top-2 right-16 w-14 h-3 bg-orange-500/40 -rotate-6 hidden md:block"></div>
			</div>

			<!-- Blog entries: pasted-in newspaper clippings -->
			<div class="space-y-6 md:space-y-8">
				{posts.map((post: any, i: number) => (
					<a
						href={`/${lang}/${style}/blog/${post.slug}`}
						class:list={[
							"relative block border-4 border-black p-4 md:p-6 no-underline text-black hover:scale-[1.02] transition-transform group",
							i % 5 === 0 ? "-rotate-1 bg-yellow-100 hover:bg-yellow-200 shadow-[5px_5px_0_black] md:mr-12" :
							i % 5 === 1 ? "rotate-[1.5deg] bg-pink-100 hover:bg-pink-200 shadow-[-3px_4px_0_black] md:ml-16 border-pink-500" :
							i % 5 === 2 ? "-rotate-[0.5deg] bg-white hover:bg-gray-50 shadow-[4px_3px_0_black] md:mr-8 border-[6px]" :
							i % 5 === 3 ? "rotate-1 bg-orange-100 hover:bg-orange-200 shadow-[3px_5px_0_black] md:ml-8 border-orange-500" :
							"-rotate-2 bg-gray-100 hover:bg-gray-200 shadow-[-4px_4px_0_black] md:mr-16",
						]}
					>
						{/* tape strips */}
						{i % 3 === 0 && (
							<div class="absolute -top-1.5 left-8 w-16 h-2.5 bg-pink-500/50 -rotate-3"></div>
						)}
						{i % 3 === 1 && (
							<div class="absolute -top-1.5 right-6 w-14 h-2 bg-yellow-400/60 rotate-6"></div>
						)}
						{i % 3 === 2 && (
							<div class="absolute -top-1 left-1/3 w-12 h-2 bg-orange-500/40 -rotate-1"></div>
						)}

						<article>
							<!-- date stamp: like a rubber stamp -->
							<time
								datetime={post.date}
								class:list={[
									"inline-block text-[10px] md:text-xs font-black uppercase px-2 py-1 mb-3 border-2 border-black",
									i % 2 === 0 ? "bg-black text-white rotate-2" : "bg-orange-500 text-white -rotate-1",
								]}
							>
								{post.date}
							</time>

							<!-- post image: pasted clipping -->
							<img src={post.image} alt={post.title} class:list={[
								"w-full h-36 md:h-48 object-cover border-4 border-black mb-3",
								i % 3 === 0 ? "-rotate-1 shadow-[3px_3px_0_black]" :
								i % 3 === 1 ? "rotate-[1.5deg] shadow-[-2px_3px_0_rgba(236,72,153,0.5)]" :
								"rotate-0.5 shadow-[2px_2px_0_rgba(249,115,22,0.5)]",
							]} />

							<!-- title: ransom-note sizing -->
							<h2 class:list={[
								"font-black uppercase mb-2 group-hover:underline decoration-wavy decoration-pink-500",
								i % 3 === 0 ? "text-2xl md:text-5xl" : i % 3 === 1 ? "text-xl md:text-4xl" : "text-3xl md:text-4xl",
							]}>
								{i % 2 === 0 ? "→ " : "★ "}{post.title}
							</h2>

							<p class="text-xs md:text-sm leading-relaxed mb-3 font-medium max-w-prose">{post.excerpt}</p>

							<!-- tags: scattered stickers -->
							<div class="flex flex-wrap gap-1.5 mb-3">
								{post.tags.map((tag: string, j: number) => (
									<span
										class:list={[
											"text-[10px] font-black uppercase px-2 py-0.5 border-2 border-black",
											j % 4 === 0 ? "bg-yellow-400 -rotate-2" :
											j % 4 === 1 ? "bg-pink-500 text-white rotate-1" :
											j % 4 === 2 ? "bg-orange-500 text-white -rotate-1" :
											"bg-black text-white rotate-3",
										]}
									>
										{tag}
									</span>
								))}
							</div>

							<!-- author: small stamped credit -->
							<span class:list={[
								"inline-block text-[10px] font-black uppercase tracking-[0.2em] px-2 py-1 border-2 border-black",
								i % 2 === 0 ? "bg-white -rotate-1" : "bg-yellow-200 rotate-1",
							]}>
								✕ {t.blog.by} {post.author}
							</span>
						</article>
					</a>
				))}
			</div>
		</div>
	</main>
</div>
