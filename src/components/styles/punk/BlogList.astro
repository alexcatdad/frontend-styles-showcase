---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-mono selection:bg-pink-500 selection:text-white">

	<nav class="bg-black text-white px-4 py-3 flex flex-wrap items-center gap-x-5 gap-y-2 border-b-4 border-yellow-400">
		{nav.map((item: any, i: number) => (
			<a
				href={item.href}
				class:list={[
					"uppercase tracking-widest font-black no-underline hover:underline decoration-wavy decoration-pink-500",
					i % 3 === 0 ? "text-yellow-300 text-sm" : i % 3 === 1 ? "text-pink-400 text-base" : "text-orange-400 text-xs",
					i % 2 === 0 ? "-rotate-1" : "rotate-1",
				]}
			>
				{i % 2 === 0 ? "★ " : "✕ "}{item.label}
			</a>
		))}
	</nav>

	<main class="px-4 py-8 md:py-12">
		<div class="max-w-5xl mx-auto">
			<div class="mb-10 md:mb-14">
				<h1 class="text-4xl md:text-7xl font-black uppercase rotate-1 inline-block bg-yellow-400 text-black px-4 py-2 border-4 border-black">
					✕ {t.blog.title}
				</h1>
				<p class="text-lg md:text-2xl font-bold mt-4 -rotate-1 bg-black text-pink-400 inline-block px-3 py-1 border-2 border-pink-500">
					{t.blog.subtitle}
				</p>
			</div>

			<div class="space-y-6 md:space-y-8">
				{posts.map((post: any, i: number) => (
					<a
						href={`/${lang}/${style}/blog/${post.slug}`}
						class:list={[
							"block border-4 border-black p-4 md:p-6 no-underline text-black hover:scale-[1.02] transition-transform group",
							i % 3 === 0 ? "-rotate-1 bg-yellow-100 hover:bg-yellow-300" :
							i % 3 === 1 ? "rotate-1 bg-pink-100 hover:bg-pink-300" :
							"rotate-0 bg-orange-100 hover:bg-orange-300",
						]}
					>
						<article>
							<time
								datetime={post.date}
								class="inline-block bg-black text-white text-xs font-black uppercase px-2 py-1 rotate-2 mb-3"
							>
								{post.date}
							</time>
							<h2 class="text-2xl md:text-4xl font-black uppercase mb-2 group-hover:underline decoration-wavy decoration-pink-500">
								→ {post.title}
							</h2>
							<p class="text-sm md:text-base leading-relaxed mb-3">{post.excerpt}</p>
							<div class="flex flex-wrap gap-2 mb-3">
								{post.tags.map((tag: string, j: number) => (
									<span
										class:list={[
											"text-xs font-black uppercase px-2 py-1 border-2 border-black",
											j % 3 === 0 ? "bg-yellow-400 -rotate-1" :
											j % 3 === 1 ? "bg-pink-500 text-white rotate-1" :
											"bg-orange-500 text-white -rotate-2",
										]}
									>
										{tag}
									</span>
								))}
							</div>
							<span class="text-xs font-bold uppercase tracking-wider bg-white border-2 border-black px-2 py-1 -rotate-1 inline-block">
								★ {t.blog.by} {post.author}
							</span>
						</article>
					</a>
				))}
			</div>
		</div>
	</main>
</div>
