---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-black text-white font-mono selection:bg-yellow-400 selection:text-black">

	<nav class="bg-black text-white px-4 py-3 flex flex-wrap items-center gap-x-5 gap-y-2 border-b-4 border-yellow-400">
		{nav.map((item: any, i: number) => (
			<a
				href={item.href}
				class:list={[
					"uppercase tracking-widest font-black no-underline hover:underline decoration-wavy decoration-pink-500",
					i % 3 === 0 ? "text-yellow-300 text-sm" : i % 3 === 1 ? "text-pink-400 text-base" : "text-orange-400 text-xs",
					i % 2 === 0 ? "-rotate-1" : "rotate-1",
				]}
			>
				{i % 2 === 0 ? "★ " : "✕ "}{item.label}
			</a>
		))}
	</nav>

	<main class="px-4 py-12 md:py-20 flex items-center justify-center">
		<section class="w-full max-w-md">
			<h1 class="text-4xl md:text-6xl font-black uppercase -rotate-2 mb-2 inline-block bg-pink-500 text-white px-4 py-2 border-4 border-yellow-400">
				✕ {t.auth.title}
			</h1>
			<p class="text-sm md:text-base font-bold uppercase tracking-wider text-gray-400 rotate-1 mb-10 mt-3">
				{t.auth.subtitle}
			</p>

			<form class="bg-white text-black border-4 border-yellow-400 p-6 md:p-8 -rotate-1">
				<div class="mb-5">
					<label for="email" class="block text-xs font-black uppercase tracking-widest mb-2 bg-black text-yellow-400 inline-block px-2 py-1">
						{t.auth.email}
					</label>
					<input
						type="email"
						id="email"
						name="email"
						placeholder="you@example.com"
						class="w-full border-4 border-black px-3 py-2 font-mono font-bold text-sm bg-gray-100 placeholder:text-gray-400 focus:outline-none focus:border-pink-500 focus:bg-yellow-50"
					/>
				</div>
				<div class="mb-5">
					<label for="password" class="block text-xs font-black uppercase tracking-widest mb-2 bg-black text-pink-400 inline-block px-2 py-1">
						{t.auth.password}
					</label>
					<input
						type="password"
						id="password"
						name="password"
						placeholder="••••••••"
						class="w-full border-4 border-black px-3 py-2 font-mono font-bold text-sm bg-gray-100 placeholder:text-gray-400 focus:outline-none focus:border-pink-500 focus:bg-yellow-50"
					/>
				</div>
				<div class="flex items-center justify-between mb-6">
					<label class="flex items-center gap-2 text-xs font-bold uppercase cursor-pointer">
						<input type="checkbox" name="remember" class="w-4 h-4 accent-pink-500" />
						{t.auth.rememberMe}
					</label>
					<a href="#" class="text-xs font-black uppercase text-pink-500 hover:underline decoration-wavy no-underline">
						{t.auth.forgotPassword}
					</a>
				</div>
				<button
					type="submit"
					class="w-full bg-pink-500 text-white font-black uppercase text-lg px-4 py-3 border-4 border-black cursor-pointer hover:scale-105 hover:bg-yellow-400 hover:text-black transition-all"
				>
					→ {t.auth.signIn} ←
				</button>
			</form>

			<div class="mt-8 rotate-1">
				<p class="text-xs font-black uppercase tracking-widest text-gray-500 mb-4 text-center">{t.auth.continueWith}</p>
				<div class="flex gap-3">
					<button
						type="button"
						class="flex-1 bg-yellow-400 text-black font-black uppercase text-sm px-4 py-3 border-4 border-black cursor-pointer hover:scale-105 transition-transform -rotate-1"
					>
						★ Google
					</button>
					<button
						type="button"
						class="flex-1 bg-orange-500 text-white font-black uppercase text-sm px-4 py-3 border-4 border-black cursor-pointer hover:scale-105 transition-transform rotate-1"
					>
						★ Apple
					</button>
				</div>
			</div>

			<p class="text-sm font-bold text-center mt-8 -rotate-1 text-gray-400">
				{t.auth.noAccount}
				<a href="#" class="text-yellow-400 font-black uppercase hover:underline decoration-wavy no-underline">
					{t.auth.signUp} →
				</a>
			</p>
		</section>
	</main>
</div>
