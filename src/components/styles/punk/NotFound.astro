---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-black text-white font-mono selection:bg-yellow-400 selection:text-black overflow-x-hidden">

	<!-- NAV: scattered scraps -->
	<nav class="relative bg-black px-3 py-4 md:py-5 border-b-[6px] border-yellow-400 overflow-visible">
		<div class="flex flex-wrap items-start gap-x-2 gap-y-3 md:gap-x-4">
			{nav.map((item: any, i: number) => (
				<a
					href={item.href}
					class:list={[
						"inline-block uppercase font-black no-underline hover:scale-110 transition-transform relative",
						i % 5 === 0 ? "text-yellow-300 text-xs tracking-[0.3em] -rotate-3 bg-pink-600/30 px-2 py-1" :
						i % 5 === 1 ? "text-pink-400 text-lg tracking-widest rotate-2 border-b-2 border-pink-400 px-1" :
						i % 5 === 2 ? "text-orange-400 text-[10px] -rotate-1 bg-yellow-400/20 px-3 py-2 border border-orange-400" :
						i % 5 === 3 ? "text-white text-sm rotate-3 underline decoration-yellow-400 decoration-wavy px-1" :
						"text-yellow-400 text-base -rotate-2 border-2 border-yellow-400 px-2 py-0.5",
						i === 0 ? "mt-2" : i === 2 ? "mt-4" : i === 3 ? "-mt-1" : "",
					]}
				>
					{i % 4 === 0 ? "★ " : i % 4 === 1 ? "✕ " : i % 4 === 2 ? "→ " : "‼ "}{item.label}
				</a>
			))}
		</div>
		<div class="absolute -bottom-2 left-8 w-24 h-3 bg-pink-500/70 rotate-2"></div>
		<div class="absolute -bottom-1 right-12 w-16 h-2 bg-yellow-400/60 -rotate-3"></div>
	</nav>

	<main class="px-3 py-16 md:py-32 flex items-center justify-center text-center relative overflow-hidden">
		<!-- background noise: huge faded marks -->
		<div class="absolute top-8 left-4 text-[12rem] md:text-[20rem] font-black text-white/[0.03] select-none -rotate-12 leading-none">✕</div>
		<div class="absolute bottom-4 right-8 text-[10rem] md:text-[16rem] font-black text-white/[0.03] select-none rotate-6 leading-none">★</div>
		<div class="absolute top-1/3 right-1/4 w-40 h-4 bg-pink-500/10 rotate-45 hidden md:block"></div>
		<div class="absolute bottom-1/3 left-1/4 w-32 h-3 bg-yellow-400/10 -rotate-12 hidden md:block"></div>

		<section class="max-w-2xl mx-auto relative">
			<!-- 404: absolutely massive, like spray-painted on a wall -->
			<div class="relative mb-6 inline-block">
				<h1 class="text-[8rem] md:text-[14rem] lg:text-[18rem] font-black leading-none -rotate-3">
					<span class="bg-pink-500 text-white px-4 md:px-8 border-[8px] border-yellow-400 inline-block shadow-[10px_10px_0_rgba(0,0,0,0.5)]">{t.notFound.title}</span>
				</h1>
				<!-- tape on the 404 -->
				<div class="absolute -top-3 left-20 w-24 h-4 bg-yellow-400/50 rotate-6"></div>
				<div class="absolute -bottom-2 right-16 w-16 h-3 bg-orange-500/40 -rotate-3"></div>
			</div>

			<!-- heading: separate scrap, different angle -->
			<div class="relative mb-8 inline-block">
				<h2 class="text-2xl md:text-5xl font-black uppercase rotate-2 bg-yellow-400 text-black px-4 py-2 border-[6px] border-black shadow-[5px_5px_0_black] inline-block">
					✕ {t.notFound.heading} ✕
				</h2>
				<div class="absolute -top-1.5 right-8 w-12 h-2.5 bg-pink-500/50 -rotate-6"></div>
			</div>

			<!-- description: another pasted piece -->
			<div class="relative mb-12 inline-block">
				<p class="text-sm md:text-xl font-bold -rotate-1 bg-white text-black px-5 py-3 border-4 border-black shadow-[4px_4px_0_black] inline-block">
					{t.notFound.description}
				</p>
				<div class="absolute -bottom-1 left-10 w-14 h-2 bg-yellow-400/40 rotate-3"></div>
			</div>

			<!-- CTAs: two torn scraps, scattered -->
			<div class="flex flex-wrap justify-center gap-5 mt-4 items-start">
				<a
					href={`/${lang}/${style}/`}
					class="bg-yellow-400 text-black font-black uppercase text-base md:text-lg px-6 py-3 border-[6px] border-white -rotate-3 hover:rotate-0 transition-transform no-underline inline-block shadow-[4px_4px_0_white] hover:shadow-[2px_2px_0_white] hover:translate-x-0.5 hover:translate-y-0.5"
				>
					← {t.notFound.backHome}
				</a>
				<a
					href={`/${lang}/${style}/cats`}
					class="bg-pink-500 text-white font-black uppercase text-lg md:text-xl px-7 py-4 border-[6px] border-white rotate-2 hover:rotate-0 transition-transform no-underline inline-block mt-3 shadow-[-3px_4px_0_white] hover:shadow-[-1px_2px_0_white] hover:translate-x-0.5 hover:translate-y-0.5"
				>
					→ {t.notFound.meetCats} ★
				</a>
			</div>
		</section>
	</main>
</div>
