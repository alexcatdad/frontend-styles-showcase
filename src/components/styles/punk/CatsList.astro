---
const { lang, style, nav, cats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-white text-black font-mono selection:bg-pink-500 selection:text-white overflow-x-hidden">

	<!-- NAV: scattered scraps -->
	<nav class="relative bg-black px-3 py-4 md:py-5 border-b-[6px] border-yellow-400 overflow-visible">
		<div class="flex flex-wrap items-start gap-x-2 gap-y-3 md:gap-x-4">
			{nav.map((item: any, i: number) => (
				<a
					href={item.href}
					class:list={[
						"inline-block uppercase font-black no-underline hover:scale-110 transition-transform relative",
						i % 5 === 0 ? "text-yellow-300 text-xs tracking-[0.3em] -rotate-3 bg-pink-600/30 px-2 py-1" :
						i % 5 === 1 ? "text-pink-400 text-lg tracking-widest rotate-2 border-b-2 border-pink-400 px-1" :
						i % 5 === 2 ? "text-orange-400 text-[10px] -rotate-1 bg-yellow-400/20 px-3 py-2 border border-orange-400" :
						i % 5 === 3 ? "text-white text-sm rotate-3 underline decoration-yellow-400 decoration-wavy px-1" :
						"text-yellow-400 text-base -rotate-2 border-2 border-yellow-400 px-2 py-0.5",
						i === 0 ? "mt-2" : i === 2 ? "mt-4" : i === 3 ? "-mt-1" : "",
					]}
				>
					{i % 4 === 0 ? "★ " : i % 4 === 1 ? "✕ " : i % 4 === 2 ? "→ " : "‼ "}{item.label}
				</a>
			))}
		</div>
		<div class="absolute -bottom-2 left-8 w-24 h-3 bg-pink-500/70 rotate-2"></div>
		<div class="absolute -bottom-1 right-12 w-16 h-2 bg-yellow-400/60 -rotate-3"></div>
	</nav>

	<main class="px-3 py-8 md:py-12">
		<div class="max-w-6xl mx-auto">
			<!-- Page header: pasted-on title at an angle -->
			<div class="mb-12 md:mb-16 relative">
				<h1 class="text-4xl md:text-7xl lg:text-8xl font-black uppercase -rotate-2 inline-block bg-black text-yellow-400 px-5 py-3 border-4 border-yellow-400 shadow-[6px_6px_0_rgba(236,72,153,0.6)]">
					★ {t.cats.title}
				</h1>
				<p class="text-base md:text-2xl font-black mt-5 rotate-1 bg-pink-500 text-white inline-block px-4 py-2 border-2 border-black ml-6 md:ml-16 shadow-[3px_3px_0_black]">
					{t.cats.subtitle} ‼
				</p>
				<!-- tape -->
				<div class="absolute -top-2 left-20 w-16 h-3 bg-orange-500/50 rotate-6 hidden md:block"></div>
			</div>

			<!-- Cat cards: photocopied zine pages, scattered layout -->
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-7">
				{cats.map((cat: any, i: number) => (
					<a
						href={`${_base}/${lang}/${style}/cats/${cat.id}`}
						class:list={[
							"block relative border-4 border-black p-4 md:p-5 no-underline text-black hover:scale-105 transition-transform group",
							i % 6 === 0 ? "-rotate-2 bg-yellow-100 hover:bg-yellow-200 shadow-[5px_5px_0_black]" :
							i % 6 === 1 ? "rotate-3 bg-pink-100 hover:bg-pink-200 mt-4 shadow-[-3px_4px_0_black] border-pink-500" :
							i % 6 === 2 ? "-rotate-1 bg-white hover:bg-gray-100 -mt-2 shadow-[4px_3px_0_black] border-orange-500 border-[6px]" :
							i % 6 === 3 ? "rotate-1 bg-orange-100 hover:bg-orange-200 mt-6 shadow-[3px_5px_0_black]" :
							i % 6 === 4 ? "-rotate-3 bg-gray-100 hover:bg-gray-200 shadow-[-4px_4px_0_black] border-yellow-400" :
							"rotate-2 bg-pink-50 hover:bg-pink-100 -mt-3 shadow-[5px_3px_0_black] border-4",
						]}
					>
						{/* tape strips on cards */}
						{i % 3 === 0 && (
							<div class="absolute -top-1.5 left-6 w-14 h-2.5 bg-pink-500/50 -rotate-6"></div>
						)}
						{i % 3 === 1 && (
							<div class="absolute -top-1.5 right-4 w-12 h-2 bg-yellow-400/60 rotate-3"></div>
						)}
						{i % 3 === 2 && (
							<div class="absolute -top-1 left-1/2 -translate-x-1/2 w-16 h-2 bg-orange-500/40 rotate-1"></div>
						)}

						<div>
							<!-- cat photo: photocopied, rough -->
							<img src={cat.thumbnail} alt={cat.name} class:list={[
								"w-full h-32 md:h-40 object-cover border-4 border-black mb-3",
								i % 3 === 0 ? "-rotate-1 shadow-[3px_3px_0_black]" :
								i % 3 === 1 ? "rotate-2 shadow-[-2px_3px_0_rgba(236,72,153,0.5)]" :
								"-rotate-[0.5deg] shadow-[2px_2px_0_rgba(234,179,8,0.5)]",
							]} />

							<!-- cat name: ransom-note sized -->
							<h2 class:list={[
								"font-black uppercase mb-1 group-hover:underline decoration-wavy decoration-pink-500",
								i % 3 === 0 ? "text-3xl md:text-4xl" : i % 3 === 1 ? "text-2xl md:text-3xl" : "text-xl md:text-2xl",
							]}>
								{cat.name}
							</h2>
							<!-- info line: stamped look -->
							<p class="text-[10px] md:text-xs font-black uppercase tracking-[0.2em] text-gray-600 mb-3 border-b-2 border-black pb-2">
								{cat.breed} ✕ {cat.age} ✕ {cat.gender}
							</p>
							<p class="text-xs md:text-sm leading-snug mb-3 font-medium">{cat.description.slice(0, 100)}...</p>
							<!-- personality: individual sticker-tags -->
							<div class="flex flex-wrap gap-1.5 mb-3">
								{cat.personality.map((trait: string, j: number) => (
									<span
										class:list={[
											"text-[10px] font-black uppercase px-2 py-0.5 border-2 border-black",
											j % 4 === 0 ? "bg-yellow-400 -rotate-2" :
											j % 4 === 1 ? "bg-pink-500 text-white rotate-3" :
											j % 4 === 2 ? "bg-orange-500 text-white -rotate-1" :
											"bg-black text-white rotate-2",
										]}
									>
										{trait}
									</span>
								))}
							</div>
							<span class:list={[
								"inline-block bg-black text-white text-[10px] font-black uppercase px-3 py-1 border-2 border-current",
								i % 2 === 0 ? "rotate-1 border-yellow-400" : "-rotate-1 border-pink-500",
							]}>
								→ {cat.status}
							</span>
						</div>
					</a>
				))}
			</div>
		</div>
	</main>
</div>
