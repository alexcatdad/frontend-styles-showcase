---
const { lang, style, nav, cats, t } = Astro.props;
---

<div class="min-h-screen bg-white text-black font-mono selection:bg-pink-500 selection:text-white">

	<nav class="bg-black text-white px-4 py-3 flex flex-wrap items-center gap-x-5 gap-y-2 border-b-4 border-yellow-400">
		{nav.map((item: any, i: number) => (
			<a
				href={item.href}
				class:list={[
					"uppercase tracking-widest font-black no-underline hover:underline decoration-wavy decoration-pink-500",
					i % 3 === 0 ? "text-yellow-300 text-sm" : i % 3 === 1 ? "text-pink-400 text-base" : "text-orange-400 text-xs",
					i % 2 === 0 ? "-rotate-1" : "rotate-1",
				]}
			>
				{i % 2 === 0 ? "★ " : "✕ "}{item.label}
			</a>
		))}
	</nav>

	<main class="px-4 py-8 md:py-12">
		<div class="max-w-6xl mx-auto">
			<div class="mb-10 md:mb-14">
				<h1 class="text-4xl md:text-7xl font-black uppercase -rotate-1 inline-block bg-black text-yellow-400 px-4 py-2 border-4 border-yellow-400">
					★ {t.cats.title}
				</h1>
				<p class="text-lg md:text-2xl font-bold mt-4 rotate-1 bg-pink-500 text-white inline-block px-3 py-1 border-2 border-black">
					{t.cats.subtitle}
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
				{cats.map((cat: any, i: number) => (
					<a
						href={`/${lang}/${style}/cats/${cat.id}`}
						class:list={[
							"block border-4 border-black p-4 no-underline text-black hover:scale-105 transition-transform group",
							i % 4 === 0 ? "-rotate-1 bg-yellow-100 hover:bg-yellow-300" :
							i % 4 === 1 ? "rotate-2 bg-pink-100 hover:bg-pink-300" :
							i % 4 === 2 ? "-rotate-2 bg-orange-100 hover:bg-orange-300" :
							"rotate-1 bg-white hover:bg-gray-200",
						]}
					>
						<div>
							<h2 class="text-2xl md:text-3xl font-black uppercase mb-1 group-hover:underline decoration-wavy decoration-pink-500">
								{cat.name}
							</h2>
							<p class="text-sm font-bold uppercase tracking-wider text-gray-700 mb-3 border-b-2 border-black pb-2">
								{cat.breed} ✕ {cat.age} ✕ {cat.gender}
							</p>
							<p class="text-sm leading-snug mb-3">{cat.description.slice(0, 100)}...</p>
							<div class="flex flex-wrap gap-2 mb-3">
								{cat.personality.map((trait: string, j: number) => (
									<span
										class:list={[
											"text-xs font-black uppercase px-2 py-1 border-2 border-black",
											j % 3 === 0 ? "bg-yellow-400 -rotate-1" :
											j % 3 === 1 ? "bg-pink-500 text-white rotate-2" :
											"bg-orange-500 text-white -rotate-2",
										]}
									>
										{trait}
									</span>
								))}
							</div>
							<span class="inline-block bg-black text-white text-xs font-black uppercase px-3 py-1 rotate-1">
								→ {cat.status}
							</span>
						</div>
					</a>
				))}
			</div>
		</div>
	</main>
</div>
