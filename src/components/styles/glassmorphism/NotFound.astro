---
const { lang, style, nav, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-gradient-to-br from-indigo-950 via-purple-900 to-pink-900 text-white overflow-x-hidden">
	<!-- Decorative background orbs — dramatic for the error state -->
	<div class="fixed inset-0 overflow-hidden pointer-events-none">
		<div class="absolute top-1/3 left-1/3 w-[32rem] h-[32rem] bg-purple-600/25 rounded-full blur-[130px]"></div>
		<div class="absolute bottom-1/4 right-1/4 w-[28rem] h-[28rem] bg-pink-500/20 rounded-full blur-[110px]"></div>
		<div class="absolute top-0 right-0 w-80 h-80 bg-blue-500/15 rounded-full blur-[90px]"></div>
		<div class="absolute bottom-0 left-0 w-72 h-72 bg-fuchsia-400/10 rounded-full blur-[70px]"></div>
	</div>

	<div class="relative z-10">
		<!-- Floating frosted navigation -->
		<nav class="sticky top-4 z-50 mx-4 sm:mx-8 lg:mx-auto lg:max-w-5xl mt-4">
			<div class="backdrop-blur-2xl bg-white/[0.08] border border-white/[0.15] rounded-2xl shadow-lg shadow-black/10 px-5 sm:px-6 py-3 flex items-center justify-between">
				<span class="text-sm font-semibold px-3 py-1 rounded-full bg-white/10 border border-white/15 text-purple-200 tracking-wide">404</span>
				<div class="flex items-center gap-1 sm:gap-2">
					{nav.map((item: any) => (
						<a href={item.href} class="text-sm text-white/60 hover:text-white px-2.5 py-1.5 rounded-xl hover:bg-white/10 transition-all duration-200">{item.label}</a>
					))}
				</div>
			</div>
		</nav>

		<!-- 404 content — centered with layered floating glass panels creating depth -->
		<main class="flex items-center justify-center px-4 sm:px-8 pt-20 sm:pt-32 pb-24">
			<div class="relative w-full max-w-2xl">
				<!-- Background glass layers for depth -->
				<div class="absolute -top-10 -right-8 w-48 h-48 sm:w-64 sm:h-64 backdrop-blur-md bg-white/[0.04] border border-white/[0.07] rounded-3xl rotate-12 hidden sm:block"></div>
				<div class="absolute -bottom-8 -left-6 w-40 h-40 sm:w-52 sm:h-52 backdrop-blur-md bg-white/[0.03] border border-white/[0.05] rounded-2xl -rotate-6 hidden sm:block"></div>
				<div class="absolute top-1/2 -right-12 w-24 h-24 backdrop-blur-sm bg-white/[0.03] border border-white/[0.05] rounded-xl rotate-45 hidden lg:block"></div>

				<!-- Main 404 card -->
				<section class="relative z-10 backdrop-blur-2xl bg-white/[0.1] border border-white/[0.18] rounded-3xl p-10 sm:p-16 shadow-2xl shadow-purple-900/25 text-center">
					<!-- Massive 404 number -->
					<h1 class="text-8xl sm:text-[10rem] font-black leading-none mb-4 bg-gradient-to-br from-purple-300 via-pink-300 to-purple-400 bg-clip-text text-transparent drop-shadow-sm">{t.notFound.title}</h1>

					<h2 class="text-xl sm:text-2xl font-bold text-white/80 mb-4">{t.notFound.heading}</h2>
					<p class="text-white/45 mb-12 max-w-md mx-auto leading-relaxed">{t.notFound.description}</p>

					<div class="flex flex-col sm:flex-row gap-4 justify-center">
						<a href={`${_base}/${lang}/${style}/`} class="px-10 py-4 rounded-2xl bg-gradient-to-r from-purple-500 to-pink-500 text-white font-semibold shadow-xl shadow-purple-500/30 hover:shadow-purple-500/50 hover:scale-105 transition-all duration-300">{t.notFound.backHome}</a>
						<a href={`${_base}/${lang}/${style}/cats`} class="px-10 py-4 rounded-2xl backdrop-blur-xl bg-white/[0.08] border border-white/20 text-white font-semibold hover:bg-white/[0.15] transition-all duration-300">{t.notFound.meetCats}</a>
					</div>
				</section>
			</div>
		</main>
	</div>
</div>
