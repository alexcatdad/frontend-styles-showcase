---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-indigo-950 via-purple-900 to-pink-900 text-white">
	<!-- Decorative background orbs -->
	<div class="fixed inset-0 overflow-hidden pointer-events-none">
		<div class="absolute top-1/2 left-1/4 w-96 h-96 bg-purple-500/30 rounded-full blur-3xl"></div>
		<div class="absolute bottom-1/3 right-1/4 w-80 h-80 bg-pink-500/25 rounded-full blur-3xl"></div>
		<div class="absolute top-1/4 right-0 w-64 h-64 bg-blue-500/20 rounded-full blur-3xl"></div>
	</div>

	<div class="relative z-10">
		<!-- Navigation -->
		<nav class="backdrop-blur-xl bg-white/10 border-b border-white/10 sticky top-0 z-50">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
				<span class="text-xs px-2 py-0.5 rounded-full bg-white/10 border border-white/20 text-purple-200">404</span>
				<div class="flex items-center gap-1 sm:gap-4">
					{nav.map((item: any) => (
						<a href={item.href} class="text-sm text-white/70 hover:text-white transition-colors px-2 py-1 rounded-lg hover:bg-white/10">{item.label}</a>
					))}
				</div>
			</div>
		</nav>

		<main class="max-w-2xl mx-auto px-4 sm:px-6 py-24 sm:py-40">
			<section class="backdrop-blur-lg bg-white/10 border border-white/20 rounded-2xl p-10 sm:p-16 shadow-lg text-center">
				<h1 class="text-7xl sm:text-9xl font-bold mb-4 bg-gradient-to-r from-purple-300 via-pink-300 to-purple-300 bg-clip-text text-transparent">{t.notFound.title}</h1>
				<h2 class="text-xl sm:text-2xl font-semibold text-white/80 mb-4">{t.notFound.heading}</h2>
				<p class="text-white/50 mb-10 max-w-md mx-auto">{t.notFound.description}</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href={`/${lang}/${style}/`} class="px-8 py-3 rounded-2xl bg-gradient-to-r from-purple-500 to-pink-500 text-white font-semibold shadow-lg shadow-purple-500/25 hover:shadow-purple-500/40 hover:scale-105 transition-all">{t.notFound.backHome}</a>
					<a href={`/${lang}/${style}/cats`} class="px-8 py-3 rounded-2xl backdrop-blur-md bg-white/10 border border-white/20 text-white font-semibold hover:bg-white/20 transition-all">{t.notFound.meetCats}</a>
				</div>
			</section>
		</main>
	</div>
</div>
