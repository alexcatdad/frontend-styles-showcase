---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-indigo-950 via-purple-900 to-pink-900 text-white overflow-x-hidden">
	<!-- Decorative background orbs -->
	<div class="fixed inset-0 overflow-hidden pointer-events-none">
		<div class="absolute -top-24 left-1/3 w-[32rem] h-[32rem] bg-purple-600/20 rounded-full blur-[120px]"></div>
		<div class="absolute top-1/2 -right-24 w-[26rem] h-[26rem] bg-pink-500/20 rounded-full blur-[100px]"></div>
		<div class="absolute bottom-0 left-0 w-80 h-80 bg-blue-500/15 rounded-full blur-[90px]"></div>
		<div class="absolute top-1/3 right-1/4 w-48 h-48 bg-fuchsia-400/10 rounded-full blur-[60px]"></div>
		<div class="absolute bottom-1/4 left-1/4 w-40 h-40 bg-cyan-400/10 rounded-full blur-[50px]"></div>
	</div>

	<div class="relative z-10">
		<!-- Floating frosted navigation -->
		<nav class="sticky top-4 z-50 mx-4 sm:mx-8 lg:mx-auto lg:max-w-5xl mt-4">
			<div class="backdrop-blur-2xl bg-white/[0.08] border border-white/[0.15] rounded-2xl shadow-lg shadow-black/10 px-5 sm:px-6 py-3 flex items-center justify-between">
				<span class="text-sm font-semibold px-3 py-1 rounded-full bg-white/10 border border-white/15 text-purple-200 tracking-wide">{t.donate.title}</span>
				<div class="flex items-center gap-1 sm:gap-2">
					{nav.map((item: any) => (
						<a href={item.href} class="text-sm text-white/60 hover:text-white px-2.5 py-1.5 rounded-xl hover:bg-white/10 transition-all duration-200">{item.label}</a>
					))}
				</div>
			</div>
		</nav>

		<main class="px-4 sm:px-8 lg:px-0 lg:max-w-6xl lg:mx-auto pt-12 sm:pt-20 pb-16">
			<!-- Header with decorative floating shards -->
			<div class="relative mb-16 text-center">
				<div class="absolute -top-6 left-1/4 w-24 h-24 backdrop-blur-md bg-white/[0.03] border border-white/[0.06] rounded-2xl rotate-12 hidden md:block"></div>
				<div class="absolute -top-2 right-1/3 w-16 h-16 backdrop-blur-md bg-white/[0.04] border border-white/[0.07] rounded-xl -rotate-6 hidden md:block"></div>
				<div class="relative z-10">
					<h1 class="text-4xl sm:text-6xl font-black mb-5 bg-gradient-to-br from-white via-purple-100 to-pink-200 bg-clip-text text-transparent tracking-tight">{t.donate.title}</h1>
					<p class="text-white/50 text-lg max-w-xl mx-auto">{t.donate.subtitle}</p>
				</div>
			</div>

			<!-- Monthly Tiers — floating cards with depth variation -->
			<section class="mb-20">
				<h2 class="text-2xl font-bold mb-10 text-center bg-gradient-to-r from-purple-200 to-pink-200 bg-clip-text text-transparent">{t.donate.monthly}</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
					{monthlyTiers.map((tier: any) => (
						<div class={`relative backdrop-blur-xl border rounded-3xl p-7 shadow-lg flex flex-col transition-all duration-300 hover:scale-[1.03] ${tier.highlighted ? 'bg-white/[0.18] border-purple-400/30 shadow-purple-500/20 lg:scale-105 lg:-mt-3 lg:mb-3 hover:lg:scale-[1.08]' : 'bg-white/[0.08] border-white/[0.15] hover:bg-white/[0.13]'}`}>
							{tier.highlighted && (
								<span class="absolute -top-3.5 left-1/2 -translate-x-1/2 text-[11px] font-bold px-5 py-1.5 rounded-full bg-gradient-to-r from-purple-500 to-pink-500 text-white shadow-lg shadow-purple-500/30 tracking-wide uppercase">{t.donate.mostPopular}</span>
							)}
							<h3 class="text-lg font-bold text-white mb-3">{tier.name}</h3>
							<p class="mb-5">
								<span class="text-4xl font-black bg-gradient-to-r from-purple-200 to-pink-200 bg-clip-text text-transparent">${tier.amount}</span>
								<span class="text-white/35 text-sm ml-1">{t.donate.perMonth}</span>
							</p>
							<p class="text-white/50 text-sm mb-5">{tier.description}</p>
							<ul class="space-y-2.5 mb-7 flex-1">
								{tier.perks.map((perk: string) => (
									<li class="flex items-start gap-2.5 text-sm text-white/65">
										<span class="text-purple-300 mt-0.5 shrink-0">&#10003;</span>
										<span>{perk}</span>
									</li>
								))}
							</ul>
							<button type="button" class={`w-full py-3.5 rounded-2xl font-semibold transition-all duration-300 ${tier.highlighted ? 'bg-gradient-to-r from-purple-500 to-pink-500 text-white shadow-lg shadow-purple-500/25 hover:shadow-purple-500/50 hover:scale-[1.02]' : 'backdrop-blur-md bg-white/[0.08] border border-white/[0.15] text-white hover:bg-white/[0.15]'}`}>{t.donate.choose} {tier.name}</button>
						</div>
					))}
				</div>
			</section>

			<!-- One-Time Tiers — different glass tone, complementary layout -->
			<section>
				<h2 class="text-2xl font-bold mb-10 text-center bg-gradient-to-r from-pink-200 to-purple-200 bg-clip-text text-transparent">{t.donate.oneTime}</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
					{oneTimeTiers.map((tier: any) => (
						<div class={`relative backdrop-blur-xl border rounded-3xl p-7 shadow-lg flex flex-col transition-all duration-300 hover:scale-[1.03] ${tier.highlighted ? 'bg-white/[0.18] border-pink-400/30 shadow-pink-500/20 lg:scale-105 lg:-mt-3 lg:mb-3 hover:lg:scale-[1.08]' : 'bg-white/[0.08] border-white/[0.15] hover:bg-white/[0.13]'}`}>
							{tier.highlighted && (
								<span class="absolute -top-3.5 left-1/2 -translate-x-1/2 text-[11px] font-bold px-5 py-1.5 rounded-full bg-gradient-to-r from-pink-500 to-purple-500 text-white shadow-lg shadow-pink-500/30 tracking-wide uppercase">{t.donate.greatestImpact}</span>
							)}
							<h3 class="text-lg font-bold text-white mb-3">{tier.name}</h3>
							<p class="mb-5">
								<span class="text-4xl font-black bg-gradient-to-r from-pink-200 to-purple-200 bg-clip-text text-transparent">${tier.amount}</span>
							</p>
							<p class="text-white/50 text-sm mb-5">{tier.description}</p>
							<ul class="space-y-2.5 mb-7 flex-1">
								{tier.perks.map((perk: string) => (
									<li class="flex items-start gap-2.5 text-sm text-white/65">
										<span class="text-pink-300 mt-0.5 shrink-0">&#10003;</span>
										<span>{perk}</span>
									</li>
								))}
							</ul>
							<button type="button" class={`w-full py-3.5 rounded-2xl font-semibold transition-all duration-300 ${tier.highlighted ? 'bg-gradient-to-r from-pink-500 to-purple-500 text-white shadow-lg shadow-pink-500/25 hover:shadow-pink-500/50 hover:scale-[1.02]' : 'backdrop-blur-md bg-white/[0.08] border border-white/[0.15] text-white hover:bg-white/[0.15]'}`}>{t.donate.give} ${tier.amount}</button>
						</div>
					))}
				</div>
			</section>
		</main>
	</div>
</div>
