---
const { lang, style, nav, monthlyTiers, oneTimeTiers, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-indigo-950 via-purple-900 to-pink-900 text-white">
	<!-- Decorative background orbs -->
	<div class="fixed inset-0 overflow-hidden pointer-events-none">
		<div class="absolute top-1/4 -left-20 w-96 h-96 bg-purple-500/30 rounded-full blur-3xl"></div>
		<div class="absolute bottom-1/3 right-0 w-80 h-80 bg-pink-500/20 rounded-full blur-3xl"></div>
		<div class="absolute top-0 right-1/3 w-72 h-72 bg-blue-500/20 rounded-full blur-3xl"></div>
	</div>

	<div class="relative z-10">
		<!-- Navigation -->
		<nav class="backdrop-blur-xl bg-white/10 border-b border-white/10 sticky top-0 z-50">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
				<span class="text-xs px-2 py-0.5 rounded-full bg-white/10 border border-white/20 text-purple-200">{t.donate.title}</span>
				<div class="flex items-center gap-1 sm:gap-4">
					{nav.map((item: any) => (
						<a href={item.href} class="text-sm text-white/70 hover:text-white transition-colors px-2 py-1 rounded-lg hover:bg-white/10">{item.label}</a>
					))}
				</div>
			</div>
		</nav>

		<main class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-16">
			<!-- Header -->
			<div class="text-center mb-14">
				<h1 class="text-3xl sm:text-5xl font-bold mb-4 bg-gradient-to-r from-white via-purple-200 to-pink-200 bg-clip-text text-transparent">{t.donate.title}</h1>
				<p class="text-white/60 text-lg max-w-xl mx-auto">{t.donate.subtitle}</p>
			</div>

			<!-- Monthly Tiers -->
			<section class="mb-16">
				<h2 class="text-2xl font-bold mb-8 text-center bg-gradient-to-r from-purple-300 to-pink-300 bg-clip-text text-transparent">{t.donate.monthly}</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
					{monthlyTiers.map((tier: any) => (
						<div class={`relative backdrop-blur-lg border rounded-2xl p-6 shadow-lg flex flex-col transition-all hover:scale-[1.02] ${tier.highlighted ? 'bg-white/20 border-purple-400/40 shadow-purple-500/20' : 'bg-white/10 border-white/20'}`}>
							{tier.highlighted && (
								<span class="absolute -top-3 left-1/2 -translate-x-1/2 text-xs font-semibold px-4 py-1 rounded-full bg-gradient-to-r from-purple-500 to-pink-500 text-white shadow-lg">{t.donate.mostPopular}</span>
							)}
							<h3 class="text-lg font-bold text-white mb-2">{tier.name}</h3>
							<p class="mb-4">
								<span class="text-3xl font-bold bg-gradient-to-r from-purple-300 to-pink-300 bg-clip-text text-transparent">${tier.amount}</span>
								<span class="text-white/40 text-sm">{t.donate.perMonth}</span>
							</p>
							<p class="text-white/60 text-sm mb-4">{tier.description}</p>
							<ul class="space-y-2 mb-6 flex-1">
								{tier.perks.map((perk: string) => (
									<li class="flex items-start gap-2 text-sm text-white/70">
										<span class="text-purple-300 mt-0.5">&#10003;</span>
										<span>{perk}</span>
									</li>
								))}
							</ul>
							<button type="button" class={`w-full py-3 rounded-xl font-semibold transition-all ${tier.highlighted ? 'bg-gradient-to-r from-purple-500 to-pink-500 text-white shadow-lg shadow-purple-500/25 hover:shadow-purple-500/40' : 'bg-white/10 border border-white/20 text-white hover:bg-white/20'}`}>{t.donate.choose} {tier.name}</button>
						</div>
					))}
				</div>
			</section>

			<!-- One-Time Tiers -->
			<section>
				<h2 class="text-2xl font-bold mb-8 text-center bg-gradient-to-r from-purple-300 to-pink-300 bg-clip-text text-transparent">{t.donate.oneTime}</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
					{oneTimeTiers.map((tier: any) => (
						<div class={`relative backdrop-blur-lg border rounded-2xl p-6 shadow-lg flex flex-col transition-all hover:scale-[1.02] ${tier.highlighted ? 'bg-white/20 border-pink-400/40 shadow-pink-500/20' : 'bg-white/10 border-white/20'}`}>
							{tier.highlighted && (
								<span class="absolute -top-3 left-1/2 -translate-x-1/2 text-xs font-semibold px-4 py-1 rounded-full bg-gradient-to-r from-pink-500 to-purple-500 text-white shadow-lg">{t.donate.greatestImpact}</span>
							)}
							<h3 class="text-lg font-bold text-white mb-2">{tier.name}</h3>
							<p class="mb-4">
								<span class="text-3xl font-bold bg-gradient-to-r from-purple-300 to-pink-300 bg-clip-text text-transparent">${tier.amount}</span>
							</p>
							<p class="text-white/60 text-sm mb-4">{tier.description}</p>
							<ul class="space-y-2 mb-6 flex-1">
								{tier.perks.map((perk: string) => (
									<li class="flex items-start gap-2 text-sm text-white/70">
										<span class="text-pink-300 mt-0.5">&#10003;</span>
										<span>{perk}</span>
									</li>
								))}
							</ul>
							<button type="button" class={`w-full py-3 rounded-xl font-semibold transition-all ${tier.highlighted ? 'bg-gradient-to-r from-pink-500 to-purple-500 text-white shadow-lg shadow-pink-500/25 hover:shadow-pink-500/40' : 'bg-white/10 border border-white/20 text-white hover:bg-white/20'}`}>{t.donate.give} ${tier.amount}</button>
						</div>
					))}
				</div>
			</section>
		</main>
	</div>
</div>
