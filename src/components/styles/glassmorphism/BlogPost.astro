---
const { lang, style, nav, post, otherPosts, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-indigo-950 via-purple-900 to-pink-900 text-white">
	<!-- Decorative background orbs -->
	<div class="fixed inset-0 overflow-hidden pointer-events-none">
		<div class="absolute top-1/3 -left-10 w-80 h-80 bg-purple-500/30 rounded-full blur-3xl"></div>
		<div class="absolute bottom-0 right-0 w-72 h-72 bg-pink-500/20 rounded-full blur-3xl"></div>
		<div class="absolute top-0 right-1/4 w-56 h-56 bg-blue-500/25 rounded-full blur-3xl"></div>
	</div>

	<div class="relative z-10">
		<!-- Navigation -->
		<nav class="backdrop-blur-xl bg-white/10 border-b border-white/10 sticky top-0 z-50">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
				<span class="text-xs px-2 py-0.5 rounded-full bg-white/10 border border-white/20 text-purple-200">{t.blog.title}</span>
				<div class="flex items-center gap-1 sm:gap-4">
					{nav.map((item: any) => (
						<a href={item.href} class="text-sm text-white/70 hover:text-white transition-colors px-2 py-1 rounded-lg hover:bg-white/10">{item.label}</a>
					))}
				</div>
			</div>
		</nav>

		<main class="max-w-3xl mx-auto px-4 sm:px-6 py-8 sm:py-16">
			<!-- Back link -->
			<a href={`/${lang}/${style}/blog`} class="inline-flex items-center gap-1 text-sm text-white/50 hover:text-white/80 transition-colors mb-8">&larr; {t.blog.backToBlog}</a>

			<!-- Article -->
			<article class="backdrop-blur-lg bg-white/10 border border-white/20 rounded-2xl p-6 sm:p-10 shadow-lg mb-12">
				<header class="mb-8 pb-8 border-b border-white/10">
					<div class="flex flex-wrap items-center gap-3 mb-4">
						<time datetime={post.date} class="text-sm text-white/40">{post.date}</time>
						<span class="text-white/20">|</span>
						<span class="text-sm text-white/40">{t.blog.by} {post.author}</span>
					</div>
					<h1 class="text-2xl sm:text-4xl font-bold mb-6 bg-gradient-to-r from-white via-purple-200 to-pink-200 bg-clip-text text-transparent">{post.title}</h1>
					<div class="flex flex-wrap gap-2">
						{post.tags.map((tag: string) => (
							<span class="text-xs px-2.5 py-0.5 rounded-full bg-white/10 border border-white/10 text-purple-200">{tag}</span>
						))}
					</div>
				</header>

				<div class="space-y-5">
					{post.content.map((paragraph: string) => (
						<p class="text-white/75 leading-relaxed">{paragraph}</p>
					))}
				</div>
			</article>

			<!-- More Stories -->
			<section>
				<h2 class="text-2xl font-bold mb-6 bg-gradient-to-r from-purple-300 to-pink-300 bg-clip-text text-transparent">{t.blog.moreStories}</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
					{otherPosts.map((p: any) => (
						<a href={`/${lang}/${style}/blog/${p.slug}`} class="group block backdrop-blur-lg bg-white/10 border border-white/20 rounded-2xl p-6 shadow-lg hover:bg-white/15 hover:scale-[1.02] transition-all">
							<h3 class="text-lg font-semibold text-white group-hover:text-purple-200 transition-colors mb-2">{p.title}</h3>
							<p class="text-sm text-white/50 leading-relaxed">{p.excerpt}</p>
						</a>
					))}
				</div>
			</section>
		</main>
	</div>
</div>
