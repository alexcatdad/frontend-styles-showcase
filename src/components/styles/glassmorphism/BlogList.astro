---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-indigo-950 via-purple-900 to-pink-900 text-white">
	<!-- Decorative background orbs -->
	<div class="fixed inset-0 overflow-hidden pointer-events-none">
		<div class="absolute top-1/4 left-0 w-96 h-96 bg-purple-500/30 rounded-full blur-3xl"></div>
		<div class="absolute bottom-1/4 right-0 w-72 h-72 bg-pink-500/20 rounded-full blur-3xl"></div>
		<div class="absolute top-0 right-1/3 w-64 h-64 bg-blue-500/20 rounded-full blur-3xl"></div>
	</div>

	<div class="relative z-10">
		<!-- Navigation -->
		<nav class="backdrop-blur-xl bg-white/10 border-b border-white/10 sticky top-0 z-50">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
				<span class="text-xs px-2 py-0.5 rounded-full bg-white/10 border border-white/20 text-purple-200">{t.blog.title}</span>
				<div class="flex items-center gap-1 sm:gap-4">
					{nav.map((item: any) => (
						<a href={item.href} class="text-sm text-white/70 hover:text-white transition-colors px-2 py-1 rounded-lg hover:bg-white/10">{item.label}</a>
					))}
				</div>
			</div>
		</nav>

		<main class="max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-16">
			<!-- Header -->
			<div class="text-center mb-12">
				<h1 class="text-3xl sm:text-5xl font-bold mb-4 bg-gradient-to-r from-white via-purple-200 to-pink-200 bg-clip-text text-transparent">{t.blog.title}</h1>
				<p class="text-white/60 text-lg max-w-xl mx-auto">{t.blog.subtitle}</p>
			</div>

			<!-- Blog Posts -->
			<div class="space-y-6">
				{posts.map((post: any) => (
					<a href={`/${lang}/${style}/blog/${post.slug}`} class="group block">
						<article class="backdrop-blur-lg bg-white/10 border border-white/20 rounded-2xl p-6 sm:p-8 shadow-lg hover:bg-white/15 hover:shadow-xl hover:scale-[1.01] transition-all">
							<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-3">
								<time datetime={post.date} class="text-sm text-white/40">{post.date}</time>
								<span class="text-sm text-white/40">{t.blog.by} {post.author}</span>
							</div>
							<h2 class="text-xl sm:text-2xl font-bold text-white group-hover:text-purple-200 transition-colors mb-3">{post.title}</h2>
							<p class="text-white/60 leading-relaxed mb-4">{post.excerpt}</p>
							<div class="flex flex-wrap gap-2">
								{post.tags.map((tag: string) => (
									<span class="text-xs px-2.5 py-0.5 rounded-full bg-white/10 border border-white/10 text-purple-200">{tag}</span>
								))}
							</div>
						</article>
					</a>
				))}
			</div>
		</main>
	</div>
</div>
