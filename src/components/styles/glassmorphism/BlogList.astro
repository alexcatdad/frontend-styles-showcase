---
const { lang, style, nav, posts, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-indigo-950 via-purple-900 to-pink-900 text-white overflow-x-hidden">
	<!-- Decorative background orbs -->
	<div class="fixed inset-0 overflow-hidden pointer-events-none">
		<div class="absolute -top-16 right-1/4 w-[28rem] h-[28rem] bg-purple-600/20 rounded-full blur-[120px]"></div>
		<div class="absolute bottom-1/4 -left-16 w-96 h-96 bg-pink-500/15 rounded-full blur-[100px]"></div>
		<div class="absolute top-1/2 right-0 w-72 h-72 bg-blue-500/15 rounded-full blur-[80px]"></div>
		<div class="absolute bottom-0 left-1/2 w-48 h-48 bg-fuchsia-400/10 rounded-full blur-[60px]"></div>
	</div>

	<div class="relative z-10">
		<!-- Floating frosted navigation -->
		<nav class="sticky top-4 z-50 mx-4 sm:mx-8 lg:mx-auto lg:max-w-5xl mt-4">
			<div class="backdrop-blur-2xl bg-white/[0.08] border border-white/[0.15] rounded-2xl shadow-lg shadow-black/10 px-5 sm:px-6 py-3 flex items-center justify-between">
				<span class="text-sm font-semibold px-3 py-1 rounded-full bg-white/10 border border-white/15 text-purple-200 tracking-wide">{t.blog.title}</span>
				<div class="flex items-center gap-1 sm:gap-2">
					{nav.map((item: any) => (
						<a href={item.href} class="text-sm text-white/60 hover:text-white px-2.5 py-1.5 rounded-xl hover:bg-white/10 transition-all duration-200">{item.label}</a>
					))}
				</div>
			</div>
		</nav>

		<main class="px-4 sm:px-8 lg:px-0 lg:max-w-5xl lg:mx-auto pt-12 sm:pt-20 pb-16">
			<!-- Header -->
			<div class="relative mb-16">
				<div class="absolute -top-4 right-8 w-28 h-28 backdrop-blur-md bg-white/[0.03] border border-white/[0.06] rounded-2xl rotate-6 hidden md:block"></div>
				<div class="relative z-10 max-w-2xl">
					<h1 class="text-4xl sm:text-6xl font-black mb-4 bg-gradient-to-br from-white via-purple-100 to-pink-200 bg-clip-text text-transparent tracking-tight">{t.blog.title}</h1>
					<p class="text-white/50 text-lg">{t.blog.subtitle}</p>
				</div>
			</div>

			<!-- Blog posts — alternating layout with varied glass depth -->
			<div class="space-y-6">
				{posts.map((post: any, i: number) => (
					<a href={`/${lang}/${style}/blog/${post.slug}`} class="group block">
						<article class={`relative backdrop-blur-xl border rounded-3xl p-7 sm:p-9 shadow-lg transition-all duration-300 hover:shadow-xl hover:scale-[1.01] ${i === 0 ? 'bg-white/[0.14] border-white/20 shadow-purple-500/10' : i % 2 === 0 ? 'bg-white/[0.1] border-white/[0.16]' : 'bg-white/[0.07] border-white/[0.12]'}`}>
							<!-- Floating date bubble -->
							<div class="absolute -top-3 right-6 backdrop-blur-md bg-white/[0.1] border border-white/15 rounded-full px-4 py-1 shadow-sm">
								<time datetime={post.date} class="text-xs text-white/50">{post.date}</time>
							</div>

							<img src={post.image} alt={post.title} class="w-full h-40 md:h-48 object-cover rounded-2xl mb-5 border border-white/10" />

							<div class={`flex flex-col ${i === 0 ? 'sm:flex-row sm:gap-8 sm:items-start' : ''}`}>
								<div class="flex-1">
									<span class="text-sm text-white/35 mb-2 block">{t.blog.by} {post.author}</span>
									<h2 class={`font-bold text-white group-hover:text-purple-200 transition-colors mb-3 ${i === 0 ? 'text-2xl sm:text-3xl' : 'text-xl sm:text-2xl'}`}>{post.title}</h2>
									<p class="text-white/55 leading-relaxed mb-5">{post.excerpt}</p>
									<div class="flex flex-wrap gap-2">
										{post.tags.map((tag: string) => (
											<span class="text-[11px] px-2.5 py-0.5 rounded-full backdrop-blur-sm bg-white/[0.08] border border-white/[0.1] text-purple-200/80">{tag}</span>
										))}
									</div>
								</div>
							</div>
						</article>
					</a>
				))}
			</div>
		</main>
	</div>
</div>
