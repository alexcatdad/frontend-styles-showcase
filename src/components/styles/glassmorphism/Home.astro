---
const { lang, style, nav, meta, sanctuary, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-indigo-950 via-purple-900 to-pink-900 text-white">
	<!-- Decorative background orbs -->
	<div class="fixed inset-0 overflow-hidden pointer-events-none">
		<div class="absolute top-1/4 -left-20 w-96 h-96 bg-purple-500/30 rounded-full blur-3xl"></div>
		<div class="absolute top-3/4 right-0 w-80 h-80 bg-pink-500/20 rounded-full blur-3xl"></div>
		<div class="absolute top-0 right-1/3 w-72 h-72 bg-blue-500/20 rounded-full blur-3xl"></div>
	</div>

	<div class="relative z-10">
		<!-- Navigation -->
		<nav class="backdrop-blur-xl bg-white/10 border-b border-white/10 sticky top-0 z-50">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
				<div class="flex items-center gap-2">
					<span class="text-lg font-bold bg-gradient-to-r from-purple-300 to-pink-300 bg-clip-text text-transparent">{sanctuary.name}</span>
					<span class="hidden sm:inline-block text-xs px-2 py-0.5 rounded-full bg-white/10 border border-white/20 text-purple-200">{meta.name}</span>
				</div>
				<div class="flex items-center gap-1 sm:gap-4">
					{nav.map((item: any) => (
						<a href={item.href} class="text-sm text-white/70 hover:text-white transition-colors px-2 py-1 rounded-lg hover:bg-white/10">{item.label}</a>
					))}
				</div>
			</div>
		</nav>

		<main class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-16">
			<!-- Hero Section -->
			<section class="text-center py-12 sm:py-24">
				<h1 class="text-4xl sm:text-6xl lg:text-7xl font-bold mb-6 bg-gradient-to-r from-white via-purple-200 to-pink-200 bg-clip-text text-transparent">{sanctuary.name}</h1>
				<p class="text-lg sm:text-2xl text-white/70 max-w-2xl mx-auto mb-10">{sanctuary.tagline}</p>
				<div class="flex flex-col sm:flex-row gap-4 justify-center">
					<a href={`/${lang}/${style}/cats`} class="px-8 py-3 rounded-2xl bg-gradient-to-r from-purple-500 to-pink-500 text-white font-semibold shadow-lg shadow-purple-500/25 hover:shadow-purple-500/40 hover:scale-105 transition-all">{t.home.meetCats}</a>
					<a href={`/${lang}/${style}/donate`} class="px-8 py-3 rounded-2xl backdrop-blur-md bg-white/10 border border-white/20 text-white font-semibold hover:bg-white/20 transition-all">{t.home.donate}</a>
				</div>
			</section>

			<!-- Mission Section -->
			<section class="mb-16">
				<div class="backdrop-blur-lg bg-white/10 border border-white/20 rounded-2xl p-8 sm:p-12 shadow-lg">
					<h2 class="text-2xl sm:text-3xl font-bold mb-4 bg-gradient-to-r from-purple-300 to-pink-300 bg-clip-text text-transparent">{t.home.mission}</h2>
					<p class="text-white/80 text-lg leading-relaxed">{sanctuary.mission}</p>
				</div>
			</section>

			<!-- Stats Section -->
			<section class="mb-16">
				<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
					{sanctuary.stats.map((stat: any) => (
						<div class="backdrop-blur-lg bg-white/10 border border-white/20 rounded-2xl p-6 text-center shadow-lg hover:bg-white/15 transition-all">
							<span class="block text-3xl sm:text-4xl font-bold bg-gradient-to-r from-purple-300 to-pink-300 bg-clip-text text-transparent">{stat.value}</span>
							<span class="block text-sm text-white/60 mt-2">{stat.label}</span>
						</div>
					))}
				</div>
			</section>

			<!-- About Section -->
			<section class="mb-16">
				<div class="backdrop-blur-lg bg-white/5 border border-white/10 rounded-2xl p-8 sm:p-12 shadow-lg">
					<h2 class="text-2xl sm:text-3xl font-bold mb-6 bg-gradient-to-r from-purple-300 to-pink-300 bg-clip-text text-transparent">{t.home.aboutUs}</h2>
					<div class="space-y-4">
						{sanctuary.about.map((paragraph: string) => (
							<p class="text-white/70 leading-relaxed">{paragraph}</p>
						))}
					</div>
				</div>
			</section>
		</main>

		<footer class="border-t border-white/10 backdrop-blur-md bg-white/5">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 py-6 text-center text-sm text-white/40">
				<p>&copy; 2026 {sanctuary.name}. {t.footer.style}: {meta.name}.</p>
			</div>
		</footer>
	</div>
</div>
