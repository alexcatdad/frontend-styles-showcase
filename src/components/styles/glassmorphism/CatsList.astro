---
const { lang, style, nav, cats, t } = Astro.props;
const _base = import.meta.env.BASE_URL.replace( /\/$/, "");
---

<div class="min-h-screen bg-gradient-to-br from-indigo-950 via-purple-900 to-pink-900 text-white overflow-x-hidden">
	<!-- Decorative background orbs -->
	<div class="fixed inset-0 overflow-hidden pointer-events-none">
		<div class="absolute -top-20 left-1/4 w-[30rem] h-[30rem] bg-purple-600/20 rounded-full blur-[120px]"></div>
		<div class="absolute top-1/2 -right-20 w-[26rem] h-[26rem] bg-pink-500/15 rounded-full blur-[100px]"></div>
		<div class="absolute bottom-0 left-0 w-80 h-80 bg-blue-500/15 rounded-full blur-[90px]"></div>
		<div class="absolute top-1/3 left-1/2 w-40 h-40 bg-fuchsia-400/10 rounded-full blur-[60px]"></div>
	</div>

	<div class="relative z-10">
		<!-- Floating frosted navigation -->
		<nav class="sticky top-4 z-50 mx-4 sm:mx-8 lg:mx-auto lg:max-w-5xl mt-4">
			<div class="backdrop-blur-2xl bg-white/[0.08] border border-white/[0.15] rounded-2xl shadow-lg shadow-black/10 px-5 sm:px-6 py-3 flex items-center justify-between">
				<span class="text-sm font-semibold px-3 py-1 rounded-full bg-white/10 border border-white/15 text-purple-200 tracking-wide">{t.cats.title}</span>
				<div class="flex items-center gap-1 sm:gap-2">
					{nav.map((item: any) => (
						<a href={item.href} class="text-sm text-white/60 hover:text-white px-2.5 py-1.5 rounded-xl hover:bg-white/10 transition-all duration-200">{item.label}</a>
					))}
				</div>
			</div>
		</nav>

		<main class="px-4 sm:px-8 lg:px-0 lg:max-w-6xl lg:mx-auto pt-12 sm:pt-20 pb-16">
			<!-- Header with floating glass accent -->
			<div class="relative mb-16">
				<div class="absolute -top-6 -left-4 w-20 h-20 backdrop-blur-md bg-white/[0.04] border border-white/[0.06] rounded-2xl rotate-12 hidden sm:block"></div>
				<div class="relative z-10 max-w-2xl">
					<h1 class="text-4xl sm:text-6xl font-black mb-4 bg-gradient-to-br from-white via-purple-100 to-pink-200 bg-clip-text text-transparent tracking-tight">{t.cats.title}</h1>
					<p class="text-white/50 text-lg">{t.cats.subtitle}</p>
				</div>
			</div>

			<!-- Cats Grid — staggered with varied glass opacities for depth -->
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
				{cats.map((cat: any, i: number) => (
					<a href={`${_base}/${lang}/${style}/cats/${cat.id}`} class={`group block ${i === 0 ? 'sm:col-span-2 lg:col-span-1' : ''}`}>
						<div class={`relative backdrop-blur-xl border rounded-3xl p-6 sm:p-7 shadow-lg h-full flex flex-col transition-all duration-300 hover:scale-[1.03] hover:shadow-xl ${i % 3 === 0 ? 'bg-white/[0.12] border-white/20 hover:bg-white/[0.18]' : i % 3 === 1 ? 'bg-white/[0.08] border-white/[0.15] hover:bg-white/[0.14]' : 'bg-white/[0.06] border-white/[0.12] hover:bg-white/[0.12]'}`}>
							<!-- Status pill floating at top right -->
							<span class={`absolute -top-2.5 right-5 text-[11px] font-semibold px-3 py-1 rounded-full border shadow-sm ${cat.status === 'available' ? 'bg-emerald-500/25 border-emerald-400/30 text-emerald-300 shadow-emerald-500/10' : cat.status === 'adopted' ? 'bg-blue-500/25 border-blue-400/30 text-blue-300 shadow-blue-500/10' : 'bg-amber-500/25 border-amber-400/30 text-amber-300 shadow-amber-500/10'}`}>{cat.status}</span>

							<img src={cat.thumbnail} alt={cat.name} class="w-full h-36 object-cover rounded-2xl mb-4 border border-white/10" />

							<h2 class="text-xl font-bold text-white group-hover:text-purple-200 transition-colors mt-2 mb-2">{cat.name}</h2>
							<p class="text-sm text-white/40 mb-4">{cat.breed} · {cat.age} · {cat.gender}</p>
							<p class="text-white/60 text-sm leading-relaxed mb-5 flex-1">{cat.description.slice(0, 100)}...</p>

							<!-- Personality traits as tiny glass pills -->
							<div class="flex flex-wrap gap-1.5">
								{cat.personality.map((trait: string) => (
									<span class="text-[11px] px-2.5 py-0.5 rounded-full backdrop-blur-sm bg-white/[0.08] border border-white/[0.1] text-purple-200/80">{trait}</span>
								))}
							</div>
						</div>
					</a>
				))}
			</div>
		</main>
	</div>
</div>
