---
const { lang, style, nav, cats, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-indigo-950 via-purple-900 to-pink-900 text-white">
	<!-- Decorative background orbs -->
	<div class="fixed inset-0 overflow-hidden pointer-events-none">
		<div class="absolute top-1/4 -left-20 w-96 h-96 bg-purple-500/30 rounded-full blur-3xl"></div>
		<div class="absolute bottom-0 right-0 w-80 h-80 bg-pink-500/20 rounded-full blur-3xl"></div>
		<div class="absolute top-0 right-1/4 w-64 h-64 bg-blue-500/20 rounded-full blur-3xl"></div>
	</div>

	<div class="relative z-10">
		<!-- Navigation -->
		<nav class="backdrop-blur-xl bg-white/10 border-b border-white/10 sticky top-0 z-50">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
				<span class="text-xs px-2 py-0.5 rounded-full bg-white/10 border border-white/20 text-purple-200">{t.cats.title}</span>
				<div class="flex items-center gap-1 sm:gap-4">
					{nav.map((item: any) => (
						<a href={item.href} class="text-sm text-white/70 hover:text-white transition-colors px-2 py-1 rounded-lg hover:bg-white/10">{item.label}</a>
					))}
				</div>
			</div>
		</nav>

		<main class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-16">
			<!-- Header -->
			<div class="text-center mb-12">
				<h1 class="text-3xl sm:text-5xl font-bold mb-4 bg-gradient-to-r from-white via-purple-200 to-pink-200 bg-clip-text text-transparent">{t.cats.title}</h1>
				<p class="text-white/60 text-lg max-w-xl mx-auto">{t.cats.subtitle}</p>
			</div>

			<!-- Cats Grid -->
			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
				{cats.map((cat: any) => (
					<a href={`/${lang}/${style}/cats/${cat.id}`} class="group block">
						<div class="backdrop-blur-lg bg-white/10 border border-white/20 rounded-2xl p-6 shadow-lg hover:bg-white/15 hover:shadow-xl hover:scale-[1.02] transition-all h-full flex flex-col">
							<div class="flex items-center justify-between mb-3">
								<h2 class="text-xl font-bold text-white group-hover:text-purple-200 transition-colors">{cat.name}</h2>
								<span class={`text-xs px-2.5 py-1 rounded-full border ${cat.status === 'available' ? 'bg-emerald-500/20 border-emerald-400/30 text-emerald-300' : cat.status === 'adopted' ? 'bg-blue-500/20 border-blue-400/30 text-blue-300' : 'bg-amber-500/20 border-amber-400/30 text-amber-300'}`}>{cat.status}</span>
							</div>
							<p class="text-sm text-white/50 mb-3">{cat.breed} · {cat.age} · {cat.gender}</p>
							<p class="text-white/70 text-sm leading-relaxed mb-4 flex-1">{cat.description.slice(0, 100)}...</p>
							<div class="flex flex-wrap gap-1.5">
								{cat.personality.map((trait: string) => (
									<span class="text-xs px-2 py-0.5 rounded-full bg-white/10 border border-white/10 text-purple-200">{trait}</span>
								))}
							</div>
						</div>
					</a>
				))}
			</div>
		</main>
	</div>
</div>
