---
const { lang, style, nav, cat, otherCats, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-indigo-950 via-purple-900 to-pink-900 text-white">
	<!-- Decorative background orbs -->
	<div class="fixed inset-0 overflow-hidden pointer-events-none">
		<div class="absolute top-1/3 -left-20 w-96 h-96 bg-purple-500/30 rounded-full blur-3xl"></div>
		<div class="absolute bottom-1/4 right-0 w-80 h-80 bg-pink-500/20 rounded-full blur-3xl"></div>
		<div class="absolute top-0 left-1/2 w-64 h-64 bg-blue-500/25 rounded-full blur-3xl"></div>
	</div>

	<div class="relative z-10">
		<!-- Navigation -->
		<nav class="backdrop-blur-xl bg-white/10 border-b border-white/10 sticky top-0 z-50">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
				<span class="text-xs px-2 py-0.5 rounded-full bg-white/10 border border-white/20 text-purple-200">{cat.name}</span>
				<div class="flex items-center gap-1 sm:gap-4">
					{nav.map((item: any) => (
						<a href={item.href} class="text-sm text-white/70 hover:text-white transition-colors px-2 py-1 rounded-lg hover:bg-white/10">{item.label}</a>
					))}
				</div>
			</div>
		</nav>

		<main class="max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-16">
			<!-- Back link -->
			<a href={`/${lang}/${style}/cats`} class="inline-flex items-center gap-1 text-sm text-white/50 hover:text-white/80 transition-colors mb-8">&larr; {t.cats.backToAll}</a>

			<!-- Cat Profile Card -->
			<article class="backdrop-blur-lg bg-white/10 border border-white/20 rounded-2xl p-6 sm:p-10 shadow-lg mb-10">
				<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 gap-4">
					<h1 class="text-3xl sm:text-4xl font-bold bg-gradient-to-r from-white via-purple-200 to-pink-200 bg-clip-text text-transparent">{cat.name}</h1>
					<span class={`self-start text-sm px-3 py-1 rounded-full border ${cat.status === 'available' ? 'bg-emerald-500/20 border-emerald-400/30 text-emerald-300' : cat.status === 'adopted' ? 'bg-blue-500/20 border-blue-400/30 text-blue-300' : 'bg-amber-500/20 border-amber-400/30 text-amber-300'}`}>{cat.status}</span>
				</div>

				<!-- Details grid -->
				<dl class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-8">
					<div class="backdrop-blur-md bg-white/5 border border-white/10 rounded-xl p-4">
						<dt class="text-xs text-white/40 uppercase tracking-wider mb-1">{t.cats.breed}</dt>
						<dd class="text-white/90 font-medium">{cat.breed}</dd>
					</div>
					<div class="backdrop-blur-md bg-white/5 border border-white/10 rounded-xl p-4">
						<dt class="text-xs text-white/40 uppercase tracking-wider mb-1">{t.cats.age}</dt>
						<dd class="text-white/90 font-medium">{cat.age}</dd>
					</div>
					<div class="backdrop-blur-md bg-white/5 border border-white/10 rounded-xl p-4">
						<dt class="text-xs text-white/40 uppercase tracking-wider mb-1">{t.cats.gender}</dt>
						<dd class="text-white/90 font-medium">{cat.gender}</dd>
					</div>
					<div class="backdrop-blur-md bg-white/5 border border-white/10 rounded-xl p-4">
						<dt class="text-xs text-white/40 uppercase tracking-wider mb-1">{t.cats.color}</dt>
						<dd class="text-white/90 font-medium">{cat.color}</dd>
					</div>
					<div class="backdrop-blur-md bg-white/5 border border-white/10 rounded-xl p-4">
						<dt class="text-xs text-white/40 uppercase tracking-wider mb-1">{t.cats.arrived}</dt>
						<dd class="text-white/90 font-medium">{cat.arrivalDate}</dd>
					</div>
					<div class="backdrop-blur-md bg-white/5 border border-white/10 rounded-xl p-4">
						<dt class="text-xs text-white/40 uppercase tracking-wider mb-1">{t.cats.status}</dt>
						<dd class="text-white/90 font-medium">{cat.status}</dd>
					</div>
				</dl>

				<!-- Personality traits -->
				<div class="flex flex-wrap gap-2 mb-8">
					{cat.personality.map((trait: string) => (
						<span class="text-sm px-3 py-1 rounded-full bg-gradient-to-r from-purple-500/20 to-pink-500/20 border border-white/15 text-purple-200">{trait}</span>
					))}
				</div>

				<!-- Description -->
				<p class="text-white/70 leading-relaxed mb-8">{cat.description}</p>

				<!-- Adopt CTA -->
				<a href={`/${lang}/${style}/auth`} class="inline-block px-8 py-3 rounded-2xl bg-gradient-to-r from-purple-500 to-pink-500 text-white font-semibold shadow-lg shadow-purple-500/25 hover:shadow-purple-500/40 hover:scale-105 transition-all">{t.cats.adopt} {cat.name}</a>
			</article>

			<!-- Other Cats -->
			<section>
				<h2 class="text-2xl font-bold mb-6 bg-gradient-to-r from-purple-300 to-pink-300 bg-clip-text text-transparent">{t.cats.otherCats}</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
					{otherCats.map((c: any) => (
						<a href={`/${lang}/${style}/cats/${c.id}`} class="group block backdrop-blur-lg bg-white/10 border border-white/20 rounded-2xl p-5 shadow-lg hover:bg-white/15 hover:scale-[1.02] transition-all">
							<h3 class="text-lg font-semibold text-white group-hover:text-purple-200 transition-colors">{c.name}</h3>
							<p class="text-sm text-white/50 mt-1">{c.breed} · {c.age}</p>
						</a>
					))}
				</div>
			</section>
		</main>
	</div>
</div>
