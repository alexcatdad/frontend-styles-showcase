---
const { lang, style, nav, t } = Astro.props;
---

<div class="min-h-screen bg-gradient-to-br from-indigo-950 via-purple-900 to-pink-900 text-white">
	<!-- Decorative background orbs -->
	<div class="fixed inset-0 overflow-hidden pointer-events-none">
		<div class="absolute top-1/3 -left-10 w-80 h-80 bg-purple-500/30 rounded-full blur-3xl"></div>
		<div class="absolute bottom-1/4 right-0 w-72 h-72 bg-pink-500/25 rounded-full blur-3xl"></div>
		<div class="absolute top-0 left-1/2 w-64 h-64 bg-blue-500/20 rounded-full blur-3xl"></div>
	</div>

	<div class="relative z-10">
		<!-- Navigation -->
		<nav class="backdrop-blur-xl bg-white/10 border-b border-white/10 sticky top-0 z-50">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
				<span class="text-xs px-2 py-0.5 rounded-full bg-white/10 border border-white/20 text-purple-200">{t.auth.title}</span>
				<div class="flex items-center gap-1 sm:gap-4">
					{nav.map((item: any) => (
						<a href={item.href} class="text-sm text-white/70 hover:text-white transition-colors px-2 py-1 rounded-lg hover:bg-white/10">{item.label}</a>
					))}
				</div>
			</div>
		</nav>

		<main class="max-w-md mx-auto px-4 sm:px-6 py-16 sm:py-24">
			<section class="backdrop-blur-lg bg-white/10 border border-white/20 rounded-2xl p-8 shadow-lg">
				<div class="text-center mb-8">
					<h1 class="text-2xl sm:text-3xl font-bold mb-2 bg-gradient-to-r from-white via-purple-200 to-pink-200 bg-clip-text text-transparent">{t.auth.title}</h1>
					<p class="text-white/50 text-sm">{t.auth.subtitle}</p>
				</div>

				<form class="space-y-5">
					<div>
						<label for="email" class="block text-sm text-white/60 mb-1.5">{t.auth.email}</label>
						<input type="email" id="email" name="email" placeholder="you@example.com" class="w-full px-4 py-3 rounded-xl backdrop-blur-md bg-white/5 border border-white/15 text-white placeholder-white/30 focus:outline-none focus:border-purple-400/50 focus:bg-white/10 transition-all" />
					</div>
					<div>
						<label for="password" class="block text-sm text-white/60 mb-1.5">{t.auth.password}</label>
						<input type="password" id="password" name="password" placeholder="••••••••" class="w-full px-4 py-3 rounded-xl backdrop-blur-md bg-white/5 border border-white/15 text-white placeholder-white/30 focus:outline-none focus:border-purple-400/50 focus:bg-white/10 transition-all" />
					</div>
					<div class="flex items-center justify-between">
						<label class="flex items-center gap-2 text-sm text-white/60 cursor-pointer">
							<input type="checkbox" name="remember" class="w-4 h-4 rounded border-white/20 bg-white/5 accent-purple-500" />
							{t.auth.rememberMe}
						</label>
						<a href="#" class="text-sm text-purple-300 hover:text-purple-200 transition-colors">{t.auth.forgotPassword}</a>
					</div>
					<button type="submit" class="w-full py-3 rounded-xl bg-gradient-to-r from-purple-500 to-pink-500 text-white font-semibold shadow-lg shadow-purple-500/25 hover:shadow-purple-500/40 hover:scale-[1.02] transition-all">{t.auth.signIn}</button>
				</form>

				<!-- Social Login -->
				<div class="mt-8">
					<div class="flex items-center gap-3 mb-6">
						<div class="flex-1 h-px bg-white/10"></div>
						<p class="text-xs text-white/40 uppercase tracking-wider">{t.auth.continueWith}</p>
						<div class="flex-1 h-px bg-white/10"></div>
					</div>
					<div class="grid grid-cols-2 gap-3">
						<button type="button" class="py-3 rounded-xl backdrop-blur-md bg-white/5 border border-white/15 text-white/70 font-medium hover:bg-white/10 transition-all">Google</button>
						<button type="button" class="py-3 rounded-xl backdrop-blur-md bg-white/5 border border-white/15 text-white/70 font-medium hover:bg-white/10 transition-all">Apple</button>
					</div>
				</div>

				<p class="text-center text-sm text-white/40 mt-8">
					{t.auth.noAccount} <a href="#" class="text-purple-300 hover:text-purple-200 transition-colors">{t.auth.signUp}</a>
				</p>
			</section>
		</main>
	</div>
</div>
