---
import { catIds, cats, getCat } from "../../../../data/cats";
import type { Locale } from "../../../../data/i18n";
import { locales, ui } from "../../../../data/i18n";
import { getNavigation } from "../../../../data/navigation";
import { getStyle, styleSlugs } from "../../../../data/styles";
import Layout from "../../../../layouts/Layout.astro";

export function getStaticPaths() {
	return locales.flatMap((lang) =>
		styleSlugs.flatMap((style) =>
			catIds.map((id) => ({ params: { lang, style, id } })),
		),
	);
}

const { lang, style, id } = Astro.params;
const t = ui[lang as Locale];
const nav = getNavigation(lang as Locale, style);
const meta = getStyle(style)!;
const cat = getCat(lang as Locale, id)!;
const otherCats = cats[lang as Locale].filter((c) => c.id !== id).slice(0, 3);

const modules = import.meta.glob("/src/components/styles/*/CatProfile.astro", {
	eager: true,
});
const Page = (
	modules[`/src/components/styles/${style}/CatProfile.astro`] as any
).default;
---

<Layout title={cat.name} style={style} lang={lang}>
	<Page lang={lang} style={style} nav={nav} meta={meta} cat={cat} otherCats={otherCats} t={t} />
</Layout>
