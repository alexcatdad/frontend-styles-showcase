---
import { oneTimeTiers, tiers } from "../../../data/donate";
import type { Locale } from "../../../data/i18n";
import { locales, ui } from "../../../data/i18n";
import { getNavigation } from "../../../data/navigation";
import { getStyle, styleSlugs } from "../../../data/styles";
import Layout from "../../../layouts/Layout.astro";

export function getStaticPaths() {
	return locales.flatMap((lang) =>
		styleSlugs.map((style) => ({ params: { lang, style } })),
	);
}

const { lang, style } = Astro.params;
const t = ui[lang as Locale];
const nav = getNavigation(lang as Locale, style);
const meta = getStyle(style)!;
const monthlyTiers = tiers[lang as Locale];
const oneTime = oneTimeTiers[lang as Locale];

const modules = import.meta.glob("/src/components/styles/*/Donate.astro", {
	eager: true,
});
const Page = (modules[`/src/components/styles/${style}/Donate.astro`] as any)
	.default;
---

<Layout title={t.nav.donate} style={style} lang={lang}>
	<Page lang={lang} style={style} nav={nav} meta={meta} monthlyTiers={monthlyTiers} oneTimeTiers={oneTime} t={t} />
</Layout>
