---
import { styles } from "../data/styles";
import Layout from "../layouts/Layout.astro";

const grouped = Object.groupBy(styles, (s) => s.category);

const categoryAccents: Record<string, { border: string; dot: string }> = {
	"Core Modern": { border: "group-hover:border-sky-500/40", dot: "bg-sky-400" },
	"Typography-first": {
		border: "group-hover:border-amber-500/40",
		dot: "bg-amber-400",
	},
	"Nostalgia-driven": {
		border: "group-hover:border-rose-500/40",
		dot: "bg-rose-400",
	},
	Emerging: {
		border: "group-hover:border-emerald-500/40",
		dot: "bg-emerald-400",
	},
	Expressive: {
		border: "group-hover:border-orange-500/40",
		dot: "bg-orange-400",
	},
};
---

<Layout title="Style Showcase">
	<div class="min-h-screen bg-[#09090b] text-white font-['DM_Sans',sans-serif]">

		<header class="relative overflow-hidden border-b border-white/5">
			<div class="absolute inset-0 bg-gradient-to-b from-white/[0.02] to-transparent"></div>
			<div class="relative max-w-6xl mx-auto px-6 md:px-8 pt-24 pb-20 md:pt-32 md:pb-24">
				<p class="text-xs uppercase tracking-[0.3em] text-white/30 mb-6 font-medium">Whisker Haven</p>
				<h1 class="font-['Instrument_Serif',serif] text-5xl md:text-7xl lg:text-8xl font-normal leading-[0.9] tracking-tight mb-8">
					<span class="text-white">Frontend Styles</span>
					<br />
					<span class="italic text-white/40">Showcase</span>
				</h1>
				<div class="flex flex-col sm:flex-row sm:items-end gap-6 sm:gap-12">
					<p class="text-white/40 text-base md:text-lg max-w-md leading-relaxed font-light">
						One cat sanctuary. {styles.length} visual styles. Each page rendered identically — only the design changes.
					</p>
					<div class="flex items-baseline gap-1">
						<span class="font-['Instrument_Serif',serif] text-6xl md:text-7xl tabular-nums text-white/10">{styles.length}</span>
						<span class="text-xs uppercase tracking-[0.2em] text-white/20 mb-2">styles</span>
					</div>
				</div>
			</div>
		</header>

		<main class="max-w-6xl mx-auto px-6 md:px-8 py-16 md:py-24">
			{
				Object.entries(grouped).map(([category, items], catIdx) => {
					const accent = categoryAccents[category] || categoryAccents["Core Modern"];
					return (
						<section class={catIdx > 0 ? "mt-20 md:mt-28" : ""}>
							<div class="flex items-center gap-4 mb-8 md:mb-10">
								<span class={`w-1.5 h-1.5 rounded-full ${accent.dot}`} />
								<h2 class="text-[11px] uppercase tracking-[0.25em] text-white/30 font-medium">
									{category}
								</h2>
								<div class="flex-1 h-px bg-white/5" />
								<span class="text-[11px] text-white/15 tabular-nums">{items?.length}</span>
							</div>
							<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4">
								{items?.map((s) => (
									<a
										href={`/en/${s.slug}/`}
										class={`group relative block rounded-xl border border-white/[0.06] bg-white/[0.02] hover:bg-white/[0.04] ${accent.border} transition-all duration-300 ease-out overflow-hidden`}
									>
										<div class="relative overflow-hidden">
											<img
												src={`/previews/${s.slug}.png`}
												alt={`${s.name} style preview`}
												class="w-full h-auto block group-hover:scale-[1.03] transition-transform duration-500 ease-out"
												loading="lazy"
											/>
											<div class="absolute inset-0 bg-gradient-to-t from-[#09090b] via-[#09090b]/20 to-transparent opacity-60 group-hover:opacity-40 transition-opacity duration-300" />
										</div>
										<div class="p-4 md:p-5">
											<div class="flex items-start justify-between gap-3 mb-2">
												<h3 class="font-['Instrument_Serif',serif] text-lg md:text-xl text-white/90 group-hover:text-white transition-colors duration-300">
													{s.name}
												</h3>
												<span class="mt-0.5 text-[10px] uppercase tracking-wider text-white/10 group-hover:text-white/25 transition-colors whitespace-nowrap font-mono">
													{s.slug}
												</span>
											</div>
											<p class="text-[13px] text-white/30 leading-relaxed group-hover:text-white/40 transition-colors duration-300 font-light">
												{s.description}
											</p>
										</div>
									</a>
								))}
							</div>
						</section>
					);
				})
			}
		</main>

		<footer class="border-t border-white/5 py-10 md:py-12">
			<div class="max-w-6xl mx-auto px-6 md:px-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
				<p class="text-[11px] text-white/15 tracking-wide">
					Built with Astro, Tailwind CSS, and 19 independent design visions.
				</p>
				<p class="text-[11px] text-white/10 tracking-wide">&copy; 2026 Whisker Haven</p>
			</div>
		</footer>

	</div>
</Layout>
